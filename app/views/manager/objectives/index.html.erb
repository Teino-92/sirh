<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6"
     data-controller="tour"
     data-tour-name-value="manager-objectives"
     data-tour-autostart-value="true">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Objectifs équipe</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Suivez et gérez les objectifs de votre équipe</p>
    </div>
    <%= link_to new_manager_objective_path,
          class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition-colors",
          data: { "tour-step": "1", "tour-title": "Créer un objectif", "tour-description": "Définissez un objectif pour un membre avec une deadline et des critères." } do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Nouvel objectif
    <% end %>
  </div>

  <!-- Status Filter Tabs -->
  <div class="mb-6"
       data-tour-step="2"
       data-tour-title="Filtrer les objectifs"
       data-tour-description="Affichez tous les objectifs ou filtrez par statut : en cours, complétés.">
    <div class="border-b border-gray-200 dark:border-gray-700">
      <nav class="-mb-px flex space-x-8 overflow-x-auto" aria-label="Filtres">
        <%= link_to manager_objectives_path,
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status].blank? ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          Tous
        <% end %>
        <%= link_to manager_objectives_path(status: :in_progress),
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status] == 'in_progress' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          En cours
        <% end %>
        <%= link_to manager_objectives_path(status: :completed),
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status] == 'completed' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          Complétés
        <% end %>
      </nav>
    </div>
  </div>

  <!-- Objectives List -->
  <div class="space-y-4">
    <% if @objectives.any? %>
      <% @objectives.each do |objective| %>
        <%
          status_classes = case objective.status
          when 'in_progress' then 'bg-blue-100 dark:bg-blue-800 text-blue-800 dark:text-blue-200'
          when 'completed' then 'bg-green-100 dark:bg-green-800 text-green-800 dark:text-green-200'
          when 'cancelled' then 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300'
          else 'bg-yellow-100 dark:bg-yellow-800 text-yellow-800 dark:text-yellow-200'
          end
          status_label = case objective.status
          when 'in_progress' then 'En cours'
          when 'completed' then 'Complété'
          when 'cancelled' then 'Annulé'
          else objective.status.humanize
          end
          # Deadline urgency for progress bar
          deadline_pct = if objective.deadline && objective.created_at
            total = (objective.deadline - objective.created_at.to_date).to_f
            elapsed = (Date.current - objective.created_at.to_date).to_f
            total > 0 ? [[elapsed / total * 100, 0].max, 100].min.round : 0
          end
          deadline_bar_color = if objective.overdue? then 'bg-red-500'
          elsif deadline_pct && deadline_pct > 80 then 'bg-orange-400'
          elsif deadline_pct && deadline_pct > 50 then 'bg-yellow-400'
          else 'bg-blue-500'
          end
        %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="p-4 sm:p-6">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1">
                  <%= link_to objective.title, manager_objective_path(objective), class: "hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" %>
                </h3>
                <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                  <span class="flex items-center">
                    <svg class="w-4 h-4 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <%= objective.owner.full_name %>
                  </span>
                  <% if objective.deadline %>
                    <span class="flex items-center <%= objective.overdue? ? 'text-red-600 dark:text-red-400 font-medium' : '' %>">
                      <svg class="w-4 h-4 mr-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      <%= l(objective.deadline, format: :short) %>
                      <% if objective.overdue? %>
                        <span class="ml-1 text-xs">(en retard de <%= distance_of_time_in_words(objective.deadline, Date.current) %>)</span>
                      <% elsif !objective.completed? %>
                        <span class="ml-1 text-xs text-gray-400">(<%= distance_of_time_in_words(Date.current, objective.deadline) %> restant<%= 's' %>)</span>
                      <% end %>
                    </span>
                  <% end %>
                  <% if objective.completed_at.present? %>
                    <span class="flex items-center text-green-600 dark:text-green-400 text-xs">
                      Complété le <%= l(objective.completed_at.to_date, format: :short) %>
                    </span>
                  <% end %>
                </div>
                <!-- Progress bar for in_progress with deadline -->
                <% if objective.status == 'in_progress' && deadline_pct %>
                  <div class="mt-3">
                    <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400 mb-1">
                      <span>Progression temporelle</span>
                      <span><%= deadline_pct %>%</span>
                    </div>
                    <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-1.5">
                      <div class="<%= deadline_bar_color %> h-1.5 rounded-full transition-all" style="width: <%= deadline_pct %>%"></div>
                    </div>
                  </div>
                <% end %>
              </div>
              <div class="ml-4 flex-shrink-0 flex items-center gap-2">
                <span class="px-2 py-1 text-xs font-semibold rounded-full <%= status_classes %>">
                  <%= status_label %>
                </span>
                <%= link_to manager_objective_path(objective), class: "text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 font-medium" do %>
                  Voir
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow text-center py-12 px-4">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">Aucun objectif</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Commencez par créer un objectif pour votre équipe.
        </p>
        <div class="mt-6">
          <%= link_to new_manager_objective_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Nouvel objectif
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
