<%# locals: (objective:) %>
<% pct = objective.progress_percentage %>
<% if pct %>
  <div id="objective_progress_<%= objective.id %>" class="mt-4">
    <div class="flex items-center justify-between mb-1">
      <span class="text-xs text-muted-soft dark:text-white/40">Progression des tâches</span>
      <span class="text-xs font-semibold text-text-deep dark:text-white"><%= pct %>%</span>
    </div>
    <div class="w-full bg-border-soft dark:bg-white/10 rounded-full h-1.5">
      <div class="bg-primary h-1.5 rounded-full transition-all duration-500"
           style="width: <%= pct %>%"></div>
    </div>
  </div>
<% end %>
