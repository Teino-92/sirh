<%= form_with model: [:manager, objective], class: 'space-y-4' do |f| %>
  <% if objective.errors.any? %>
    <div class="alert alert-error">
      <ul class="list-disc list-inside text-sm">
        <% objective.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control">
    <%= f.label :title, 'Titre', class: 'label' %>
    <%= f.text_field :title, class: 'input input-bordered w-full', required: true %>
  </div>

  <div class="form-control">
    <%= f.label :description, 'Description', class: 'label' %>
    <%= f.text_area :description, rows: 4, class: 'textarea textarea-bordered w-full' %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="form-control">
      <%= f.label :owner_id, 'Collaborateur', class: 'label' %>
      <%= f.select :owner_id,
            current_employee.direct_reports.order(:last_name, :first_name).map { |e| [e.full_name, e.id] },
            { prompt: 'Sélectionner un collaborateur' },
            class: 'select select-bordered w-full', required: true %>
      <%= f.hidden_field :owner_type, value: 'Employee' %>
    </div>

    <div class="form-control">
      <%= f.label :priority, 'Priorité', class: 'label' %>
      <%= f.select :priority,
            Objective.priorities.keys.map { |p| [p.humanize, p] },
            { selected: objective.priority || 'medium' },
            class: 'select select-bordered w-full', required: true %>
    </div>
  </div>

  <div class="form-control">
    <%= f.label :deadline, 'Échéance', class: 'label' %>
    <%= f.date_field :deadline, class: 'input input-bordered w-full', required: true %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit class: 'btn btn-primary' %>
    <%= link_to 'Annuler', manager_objectives_path, class: 'btn btn-ghost' %>
  </div>
<% end %>
