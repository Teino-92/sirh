<%= form_with model: [:manager, objective], class: 'space-y-4' do |f| %>
  <% if objective.errors.any? %>
    <div class="rounded-md bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 p-4">
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400">
        <% objective.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, 'Titre', class: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' %>
    <%= f.text_field :title, class: 'block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm', required: true %>
  </div>

  <div>
    <%= f.label :description, 'Description', class: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' %>
    <%= f.text_area :description, rows: 4, class: 'block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm' %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :owner_id, 'Collaborateur', class: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' %>
      <%= f.select :owner_id,
            current_employee.direct_reports.order(:last_name, :first_name).map { |e| [e.full_name, e.id] },
            { prompt: 'Sélectionner un collaborateur' },
            class: 'block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm', required: true %>
      <%= f.hidden_field :owner_type, value: 'Employee' %>
    </div>

    <div>
      <%= f.label :priority, 'Priorité', class: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' %>
      <%= f.select :priority,
            [['Faible', 'low'], ['Moyenne', 'medium'], ['Haute', 'high']],
            { selected: objective.priority || 'medium' },
            class: 'block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm', required: true %>
    </div>
  </div>

  <div>
    <%= f.label :deadline, 'Échéance', class: 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1' %>
    <%= f.date_field :deadline, class: 'block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm', required: true %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit objective.persisted? ? 'Enregistrer' : 'Créer l\'objectif',
          class: 'inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all cursor-pointer' %>
    <%= link_to 'Annuler', manager_objectives_path,
          class: 'inline-flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all' %>
  </div>
<% end %>
