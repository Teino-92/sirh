<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-3">
    <div>
      <div class="flex items-center gap-2 text-sm text-muted-soft dark:text-white/50 mb-1">
        <%= link_to "Mon équipe", manager_team_schedules_path, class: "hover:text-primary dark:hover:text-primary" %>
        <span>›</span>
        <span>Planning</span>
      </div>
      <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white">Planning de l'équipe</h1>
    </div>

    <!-- Month navigation -->
    <div class="flex items-center gap-2">
      <%= link_to manager_team_schedules_planning_path(month: @prev_month.iso8601),
          class: "flex items-center justify-center min-h-[44px] min-w-[44px] rounded-lg border border-border-soft dark:border-white/10 bg-surface dark:bg-[#1C1B2E] text-muted-soft dark:text-white/50 hover:bg-bg-soft dark:hover:bg-gray-700 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      <% end %>
      <span class="px-4 py-2 text-sm font-semibold text-text-deep dark:text-white bg-surface dark:bg-[#1C1B2E] border border-border-soft dark:border-white/10 rounded-lg min-w-[140px] text-center">
        <%= l(@current_month, format: "%B %Y").capitalize %>
      </span>
      <%= link_to manager_team_schedules_planning_path(month: @next_month.iso8601),
          class: "flex items-center justify-center min-h-[44px] min-w-[44px] rounded-lg border border-border-soft dark:border-white/10 bg-surface dark:bg-[#1C1B2E] text-muted-soft dark:text-white/50 hover:bg-bg-soft dark:hover:bg-gray-700 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>
  </div>

  <% if @team_members.empty? %>
    <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow text-center py-12 px-4">
      <p class="text-muted-soft dark:text-white/50">Aucun membre dans votre équipe.</p>
      <%= link_to "Ajouter un membre", new_manager_team_member_path, class: "mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary hover:bg-primary" %>
    </div>
  <% else %>

    <%# ── DESKTOP : Grille mensuelle ─────────────────────────────────────── %>
    <div class="hidden sm:block bg-surface dark:bg-[#1C1B2E] rounded-xl shadow border border-border-soft dark:border-white/10 overflow-x-auto">
      <table class="w-full min-w-[640px] border-collapse">
        <thead>
          <tr class="border-b border-border-soft dark:border-white/10">
            <th class="w-44 px-4 py-3 text-left text-xs font-semibold text-muted-soft dark:text-white/50 uppercase tracking-wider bg-bg-soft dark:bg-[#13121F]/50 sticky left-0 z-10">
              Employé
            </th>
            <% @weeks.each do |week| %>
              <% is_current = week == Date.current.beginning_of_week(:monday) %>
              <th class="px-3 py-3 text-center text-xs font-semibold <%= is_current ? 'text-primary dark:text-primary/80' : 'text-muted-soft dark:text-white/50' %> uppercase tracking-wider">
                <div class="<%= is_current ? 'font-bold' : '' %>">Sem.</div>
                <div class="text-[10px] font-normal normal-case text-muted-soft dark:text-white/40">
                  <%= l(week, format: "%-d/%-m") %> – <%= l(week + 4.days, format: "%-d/%-m") %>
                </div>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          <% @team_members.each do |member| %>
            <tr class="hover:bg-bg-soft dark:hover:bg-gray-700/30 transition-colors">
              <!-- Member name -->
              <td class="px-4 py-3 bg-surface dark:bg-[#1C1B2E] sticky left-0 z-10 border-r border-border-soft dark:border-white/10">
                <div class="flex items-center gap-2 min-w-0">
                  <div class="h-8 w-8 rounded-full bg-primary dark:bg-primary flex items-center justify-center flex-shrink-0">
                    <span class="text-primary dark:text-primary font-bold text-xs">
                      <%= member.first_name[0] %><%= member.last_name[0] %>
                    </span>
                  </div>
                  <span class="text-sm font-medium text-text-deep dark:text-white truncate"><%= member.full_name %></span>
                </div>
              </td>

              <!-- Week cells -->
              <% @weeks.each do |week| %>
                <% plan = @plans_by_key[[member.id, week]] %>
                <% template_key = plan ? detect_template_key(plan.schedule_pattern, @schedule_templates) : nil %>
                <% template = template_key ? @schedule_templates[template_key] : nil %>
                <td class="px-2 py-2 text-center">
                  <% if plan && template %>
                    <%= link_to edit_manager_team_member_weekly_schedule_plan_path(member, plan),
                        class: "inline-flex items-center justify-center w-full px-2 py-1.5 rounded-md text-xs font-medium transition-colors hover:opacity-80 #{schedule_badge_classes(template[:color])}" do %>
                      <%= template[:name].split(' ').first(2).join(' ') %>
                    <% end %>
                  <% elsif plan %>
                    <%# Plan exists but doesn't match a template - custom schedule %>
                    <%= link_to edit_manager_team_member_weekly_schedule_plan_path(member, plan),
                        class: "inline-flex items-center justify-center w-full px-2 py-1.5 rounded-md text-xs font-medium transition-colors hover:opacity-80 #{schedule_badge_classes('amber')}" do %>
                      Personnalisé
                    <% end %>
                  <% else %>
                    <%# No plan - link to create %>
                    <%= link_to new_manager_team_member_weekly_schedule_plan_path(member, week_start: week.iso8601),
                        class: "inline-flex items-center justify-center w-full px-2 py-1.5 rounded-md border-2 border-dashed border-border-soft dark:border-white/15 text-muted-soft dark:text-white/40 hover:border-primary dark:hover:border-primary hover:text-primary dark:hover:text-primary transition-colors" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                      </svg>
                    <% end %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# ── LÉGENDE ───────────────────────────────────────────────────────── %>
    <div class="hidden sm:flex items-center gap-3 mt-3 flex-wrap">
      <span class="text-xs text-muted-soft dark:text-white/40">Légende :</span>
      <% @schedule_templates.each do |key, tpl| %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium <%= schedule_badge_classes(tpl[:color]) %>">
          <%= tpl[:name] %>
        </span>
      <% end %>
      <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium <%= schedule_badge_classes('amber') %>">
        Personnalisé
      </span>
    </div>

    <%# ── MOBILE : Liste 2 semaines glissantes par employé ───────────────── %>
    <div class="sm:hidden space-y-3">
      <%
        today = Date.current
        mobile_days = (0..13).map { |i| today + i.days }
        mobile_weeks = mobile_days.map { |d| d.beginning_of_week(:monday) }.uniq
      %>

      <% @team_members.each do |member| %>
        <div class="bg-surface dark:bg-[#1C1B2E] rounded-xl shadow border border-border-soft dark:border-white/10 overflow-hidden"
             data-controller="schedule-expand">
          <!-- Member header (tap to expand) -->
          <button type="button"
                  data-action="click->schedule-expand#toggle"
                  class="w-full flex items-center justify-between px-4 py-3 text-left min-h-[56px]">
            <div class="flex items-center gap-3 min-w-0">
              <div class="h-9 w-9 rounded-full bg-primary dark:bg-primary flex items-center justify-center flex-shrink-0">
                <span class="text-primary dark:text-primary font-bold text-sm">
                  <%= member.first_name[0] %><%= member.last_name[0] %>
                </span>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-text-deep dark:text-white truncate"><%= member.full_name %></p>
                <%
                  current_week_plan = @plans_by_key[[member.id, today.beginning_of_week(:monday)]]
                  current_tpl_key = current_week_plan ? detect_template_key(current_week_plan.schedule_pattern, @schedule_templates) : nil
                  current_tpl = current_tpl_key ? @schedule_templates[current_tpl_key] : nil
                %>
                <p class="text-xs text-muted-soft dark:text-white/50">
                  <% if current_week_plan && current_tpl %>
                    Cette semaine : <%= current_tpl[:name] %>
                  <% elsif current_week_plan %>
                    Cette semaine : Personnalisé
                  <% else %>
                    Cette semaine : Non planifié
                  <% end %>
                </p>
              </div>
            </div>
            <svg class="w-5 h-5 text-muted-soft transition-transform flex-shrink-0" data-schedule-expand-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <!-- Expandable day pills -->
          <div class="hidden border-t border-border-soft dark:border-white/10 px-4 py-3 space-y-2" data-schedule-expand-target="content">
            <% mobile_weeks.each do |week| %>
              <% plan = @plans_by_key[[member.id, week]] %>
              <% tpl_key = plan ? detect_template_key(plan.schedule_pattern, @schedule_templates) : nil %>
              <% tpl = tpl_key ? @schedule_templates[tpl_key] : nil %>
              <div class="flex items-center justify-between gap-2">
                <span class="text-xs text-muted-soft dark:text-white/50 w-28 flex-shrink-0">
                  <%= l(week, format: "%-d/%-m") %> – <%= l(week + 4.days, format: "%-d/%-m") %>
                </span>
                <% if plan && tpl %>
                  <%= link_to edit_manager_team_member_weekly_schedule_plan_path(member, plan),
                      class: "flex-1 text-center text-xs font-medium py-2 rounded-full #{schedule_badge_classes(tpl[:color])}" do %>
                    <%= tpl[:name] %>
                  <% end %>
                <% elsif plan %>
                  <%= link_to edit_manager_team_member_weekly_schedule_plan_path(member, plan),
                      class: "flex-1 text-center text-xs font-medium py-2 rounded-full #{schedule_badge_classes('amber')}" do %>
                    Personnalisé
                  <% end %>
                <% else %>
                  <%= link_to new_manager_team_member_weekly_schedule_plan_path(member, week_start: week.iso8601),
                      class: "flex-1 text-center text-xs font-medium py-2 rounded-full border-2 border-dashed border-border-soft dark:border-white/15 text-muted-soft dark:text-white/40" do %>
                    + Planifier
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  <% end %>
</div>
