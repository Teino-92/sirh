<%# locals: (objective:, task:) %>
<%= form_with model: [objective, task],
      url: manager_objective_objective_tasks_path(objective),
      id: "objective_task_form_#{objective.id}",
      data: { turbo_stream: true },
      class: "space-y-3 p-4 bg-bg-soft dark:bg-white/5 rounded-lg border border-border-soft dark:border-white/10" do |f| %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div class="sm:col-span-2">
      <%= f.text_field :title,
            placeholder: "Titre de la tâche *",
            required: true,
            class: "w-full px-3 py-2 text-sm bg-surface dark:bg-[#1C1B2E] border border-border-soft dark:border-white/15 rounded-lg text-text-deep dark:text-white placeholder:text-muted-soft dark:placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-primary/40" %>
    </div>
    <div class="sm:col-span-2">
      <%= f.text_area :description,
            placeholder: "Description (optionnel)",
            rows: 2,
            class: "w-full px-3 py-2 text-sm bg-surface dark:bg-[#1C1B2E] border border-border-soft dark:border-white/15 rounded-lg text-text-deep dark:text-white placeholder:text-muted-soft dark:placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-primary/40 resize-none" %>
    </div>
    <div>
      <%= f.collection_select :assigned_to_id,
            [objective.owner],
            :id, :full_name,
            { prompt: "Assigner à..." },
            class: "w-full px-3 py-2 text-sm bg-surface dark:bg-[#1C1B2E] border border-border-soft dark:border-white/15 rounded-lg text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/40" %>
    </div>
    <div>
      <%= f.date_field :deadline,
            class: "w-full px-3 py-2 text-sm bg-surface dark:bg-[#1C1B2E] border border-border-soft dark:border-white/15 rounded-lg text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/40" %>
    </div>
  </div>
  <div class="flex justify-end gap-2">
    <button type="button"
            onclick="document.getElementById('new_task_form_<%= objective.id %>').classList.add('hidden')"
            class="px-3 py-1.5 text-xs font-medium text-muted-soft dark:text-white/40 hover:text-text-deep dark:hover:text-white transition-colors">
      Annuler
    </button>
    <%= f.submit "Ajouter la tâche",
          class: "px-3 py-1.5 text-xs font-semibold text-white bg-primary hover:bg-primary/90 rounded-lg transition-colors cursor-pointer" %>
  </div>
<% end %>
