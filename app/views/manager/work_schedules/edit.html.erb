<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white mb-2">Modifier l'horaire de travail</h1>
    <div class="flex items-center text-muted-soft dark:text-white/50">
      <div class="h-10 w-10 rounded-full bg-primary dark:bg-primary flex items-center justify-center mr-3">
        <span class="text-primary dark:text-primary font-semibold">
          <%= @team_member.first_name[0] %><%= @team_member.last_name[0] %>
        </span>
      </div>
      <div>
        <p class="font-semibold text-text-deep dark:text-white"><%= @team_member.full_name %></p>
        <p class="text-sm text-muted-soft dark:text-white/50"><%= @team_member.department || 'Équipe' %> • <%= @team_member.contract_type %></p>
      </div>
    </div>
  </div>

  <!-- Error Messages -->
  <% if @work_schedule.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900 border-l-4 border-red-400 p-4 mb-6">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <%= pluralize(@work_schedule.errors.count, "erreur") %> à corriger :
          </h3>
          <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
            <% @work_schedule.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%= form_with model: @work_schedule, url: manager_team_member_work_schedule_path(@team_member), method: :patch, local: true, class: "space-y-6" do |f| %>

    <!-- Schedule Templates -->
    <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-4">Modèles d'horaires</h2>
      <p class="text-sm text-muted-soft dark:text-white/50 mb-4">Choisissez un modèle pour remplacer l'horaire actuel</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" id="schedule-templates">
        <% @schedule_templates.each do |key, template| %>
          <button type="button"
                  class="template-btn text-left p-4 border-2 border-border-soft dark:border-white/10 rounded-lg hover:border-primary hover:bg-primary dark:bg-primary/20 transition-colors"
                  data-template="<%= key %>"
                  data-weekly-hours="<%= template[:weekly_hours] %>"
                  data-pattern="<%= template[:pattern].to_json %>">
            <div class="font-semibold text-text-deep dark:text-white"><%= template[:name] %></div>
            <div class="text-sm text-muted-soft dark:text-white/50 mt-1"><%= template[:weekly_hours] %>h par semaine</div>
          </button>
        <% end %>
      </div>
    </div>

    <!-- Schedule Name and Weekly Hours -->
    <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-4">Informations de l'horaire</h2>

      <div class="space-y-4">
        <div>
          <%= f.label :name, "Nom de l'horaire", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
          <%= f.text_field :name,
            class: "block w-full rounded-md border-border-soft dark:border-white/15 shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
            placeholder: "Ex: 35h - Temps plein",
            required: true %>
        </div>

        <div>
          <%= f.label :weekly_hours, "Nombre d'heures par semaine", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
          <%= f.number_field :weekly_hours,
            min: 1,
            max: 48,
            step: 0.5,
            class: "block w-full rounded-md border-border-soft dark:border-white/15 shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
            placeholder: "35",
            required: true %>
          <p class="mt-1 text-xs text-muted-soft dark:text-white/50">Entre 1 et 48 heures par semaine</p>
        </div>
      </div>
    </div>

    <!-- Daily Schedule Pattern -->
    <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-6">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-4">Horaire quotidien</h2>
      <p class="text-sm text-muted-soft dark:text-white/50 mb-4">Définissez les horaires pour chaque jour de la semaine</p>

      <div class="space-y-3" id="schedule-pattern">
        <% %w[monday tuesday wednesday thursday friday saturday sunday].each do |day| %>
          <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
            <label class="text-sm font-medium text-text-deep dark:text-white/70 w-32">
              <%= l(Date.current.beginning_of_week + %w[monday tuesday wednesday thursday friday saturday sunday].index(day).days, format: '%A') %>
            </label>

            <div class="flex items-center gap-2 flex-1">
              <input type="text"
                     name="work_schedule[schedule_pattern][<%= day %>]"
                     id="schedule_pattern_<%= day %>"
                     value="<%= @work_schedule.schedule_pattern&.dig(day) %>"
                     class="flex-1 rounded-md border-border-soft dark:border-white/15 shadow-sm focus:border-primary focus:ring-primary sm:text-sm day-schedule"
                     placeholder="09:00-17:00 ou 'off'"
                     pattern="^(\d{2}:\d{2}-\d{2}:\d{2}|off)$"
                     title="Format: HH:MM-HH:MM ou 'off'">

              <button type="button"
                      class="set-off-btn px-3 py-2 text-sm border border-border-soft dark:border-white/15 rounded-md hover:bg-bg-soft dark:bg-[#13121F]"
                      data-day="<%= day %>">
                Repos
              </button>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-4 bg-primary/10 dark:bg-primary/10 border border-blue-200 dark:border-blue-700 rounded-lg p-4">
        <div class="flex">
          <svg class="h-5 w-5 text-primary mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
          <div class="text-sm text-primary dark:text-primary">
            <p class="font-medium">Format des horaires :</p>
            <ul class="mt-1 list-disc list-inside">
              <li>Heures de travail : <code class="bg-primary/10 dark:bg-primary/10 px-1 rounded">09:00-17:00</code></li>
              <li>Jour de repos : <code class="bg-primary/10 dark:bg-primary/10 px-1 rounded">off</code></li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3 pt-4">
      <%= f.submit "Enregistrer les modifications",
        class: "inline-flex justify-center items-center px-6 py-3 border border-transparent shadow-sm text-base font-medium rounded-md text-white bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>

      <%= link_to "Annuler", manager_team_schedules_path,
        class: "inline-flex justify-center items-center px-6 py-3 border border-border-soft dark:border-white/15 shadow-sm text-base font-medium rounded-md text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" %>
    </div>
  <% end %>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  // Template selection
  document.querySelectorAll('.template-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const templateName = this.querySelector('.font-semibold').textContent;
      const weeklyHours = this.dataset.weeklyHours;
      const pattern = JSON.parse(this.dataset.pattern);

      // Highlight selected template
      document.querySelectorAll('.template-btn').forEach(b => {
        b.classList.remove('border-primary', 'bg-primary dark:bg-primary/20');
        b.classList.add('border-border-soft dark:border-white/10');
      });
      this.classList.add('border-primary', 'bg-primary dark:bg-primary/20');
      this.classList.remove('border-border-soft dark:border-white/10');

      // Set schedule name
      document.getElementById('work_schedule_name').value = templateName;

      // Set weekly hours
      document.getElementById('work_schedule_weekly_hours').value = weeklyHours;

      // Set daily schedule pattern
      Object.keys(pattern).forEach(day => {
        const input = document.getElementById(`schedule_pattern_${day}`);
        if (input) {
          input.value = pattern[day] || 'off';
        }
      });

      // Set remaining days to 'off' if not in pattern
      ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'].forEach(day => {
        if (!pattern[day]) {
          const input = document.getElementById(`schedule_pattern_${day}`);
          if (input && !input.value) {
            input.value = 'off';
          }
        }
      });
    });
  });

  // "Repos" button functionality
  document.querySelectorAll('.set-off-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      const day = this.dataset.day;
      const input = document.getElementById(`schedule_pattern_${day}`);
      if (input) {
        input.value = 'off';
      }
    });
  });
});
</script>
