<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Évaluations équipe</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Gérez les évaluations de performance de votre équipe</p>
    </div>
    <%= link_to new_manager_evaluation_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition-colors" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Nouvelle évaluation
    <% end %>
  </div>

  <!-- Status Filter Tabs -->
  <div class="mb-6">
    <div class="border-b border-gray-200 dark:border-gray-700">
      <nav class="-mb-px flex space-x-6 overflow-x-auto" aria-label="Filtres">
        <%= link_to manager_evaluations_path,
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status].blank? ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          Toutes
        <% end %>
        <%= link_to manager_evaluations_path(status: :employee_review_pending),
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status] == 'employee_review_pending' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          Auto-éval. en cours
        <% end %>
        <%= link_to manager_evaluations_path(status: :manager_review_pending),
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status] == 'manager_review_pending' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          À compléter
        <% end %>
        <%= link_to manager_evaluations_path(status: :completed),
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{params[:status] == 'completed' ? 'border-indigo-500 text-indigo-600' : 'border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:border-gray-300'}" do %>
          Complétées
        <% end %>
      </nav>
    </div>
  </div>

  <!-- Evaluations List -->
  <div class="space-y-4">
    <% if @evaluations.any? %>
      <% @evaluations.each do |evaluation| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="p-4 sm:p-6">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-1">
                  <%= link_to evaluation.employee.full_name, manager_evaluation_path(evaluation), class: "hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" %>
                </h3>
                <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                  <span class="flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <%= l(evaluation.period_start, format: :short) %> – <%= l(evaluation.period_end, format: :short) %>
                  </span>
                </div>
                <% if evaluation.manager_review_pending? %>
                  <p class="mt-2 text-sm text-orange-600 dark:text-orange-400 font-medium flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>
                    En attente de votre évaluation
                  </p>
                <% end %>
              </div>
              <div class="ml-4 flex-shrink-0 flex items-center gap-2">
                <%
                  status_classes = case evaluation.status
                  when 'employee_review_pending' then 'bg-yellow-100 dark:bg-yellow-800 text-yellow-800 dark:text-yellow-200'
                  when 'manager_review_pending' then 'bg-orange-100 dark:bg-orange-800 text-orange-800 dark:text-orange-200'
                  when 'completed' then 'bg-green-100 dark:bg-green-800 text-green-800 dark:text-green-200'
                  else 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300'
                  end
                  status_label = case evaluation.status
                  when 'employee_review_pending' then 'Auto-éval.'
                  when 'manager_review_pending' then 'À compléter'
                  when 'completed' then 'Complétée'
                  else evaluation.status.humanize
                  end
                %>
                <span class="px-2 py-1 text-xs font-semibold rounded-full <%= status_classes %>">
                  <%= status_label %>
                </span>
                <%= link_to manager_evaluation_path(evaluation), class: "text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 font-medium" do %>
                  Voir
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow text-center py-12 px-4">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">Aucune évaluation</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Commencez par créer une évaluation pour votre équipe.
        </p>
        <div class="mt-6">
          <%= link_to new_manager_evaluation_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Nouvelle évaluation
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
