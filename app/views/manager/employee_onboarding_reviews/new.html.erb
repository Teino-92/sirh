<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-4">
    <%= link_to '← Onboarding', manager_employee_onboarding_path(@employee_onboarding),
          class: 'text-sm text-muted-soft hover:text-text-deep dark:text-white/50 dark:hover:text-muted-soft' %>
  </div>

  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6">
    <h1 class="text-xl font-serif text-text-deep dark:text-white mb-2">
      Bilan d'intégration — <%= @employee_onboarding.employee.full_name %>
    </h1>
    <p class="text-sm text-muted-soft dark:text-white/50 mb-6">
      Jour J+<%= @review.review_day %> · Ce feedback alimente le score d'intégration
    </p>

    <%= form_with(model: @review, url: manager_employee_onboarding_employee_onboarding_reviews_path(@employee_onboarding), class: "space-y-6") do |f| %>
      <% if @review.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-md p-4">
          <ul class="list-disc list-inside text-sm text-red-600 dark:text-red-400">
            <% @review.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :integration_level, "Niveau d'intégration (1 = difficile, 5 = excellent)",
              class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
        <div class="flex gap-3">
          <% (1..5).each do |n| %>
            <label class="flex flex-col items-center gap-1 cursor-pointer">
              <%= f.radio_button :integration_level, n,
                    class: "sr-only peer" %>
              <span class="w-10 h-10 flex items-center justify-center rounded-full border-2 border-border-soft dark:border-white/15 text-sm font-semibold text-text-deep dark:text-white/70 peer-checked:border-primary peer-checked:bg-primary peer-checked:text-white hover:border-primary transition-all">
                <%= n %>
              </span>
            </label>
          <% end %>
        </div>
        <p class="mt-1 text-xs text-muted-soft dark:text-white/50">1 = Difficultés majeures · 5 = Intégration excellente</p>
      </div>

      <div>
        <%= f.label :strengths, "Points forts observés",
              class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
        <%= f.text_area :strengths, rows: 3,
              class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm",
              placeholder: "Compétences, attitude, prise en main des outils..." %>
      </div>

      <div>
        <%= f.label :risk_signals, "Signaux de risque",
              class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
        <%= f.text_area :risk_signals, rows: 3,
              class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm",
              placeholder: "Difficultés relationnelles, blocages techniques, absentéisme..." %>
        <p class="mt-1 text-xs text-muted-soft dark:text-white/50">
          Laissez vide s'il n'y a pas de signaux particuliers.
        </p>
      </div>

      <div class="flex justify-end gap-3">
        <%= link_to "Annuler", manager_employee_onboarding_path(@employee_onboarding),
              class: "inline-flex items-center py-2 px-4 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all" %>
        <%= f.submit "Enregistrer le bilan",
              class: "inline-flex items-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-primary hover:bg-primary cursor-pointer transition-all" %>
      </div>
    <% end %>
  </div>
</div>
