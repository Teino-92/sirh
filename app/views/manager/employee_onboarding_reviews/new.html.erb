<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-4">
    <%= link_to '← Onboarding', manager_employee_onboarding_path(@employee_onboarding),
          class: 'text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200' %>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2">
      Bilan d'intégration — <%= @employee_onboarding.employee.full_name %>
    </h1>
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">
      Jour J+<%= @review.review_day %> · Ce feedback alimente le score d'intégration
    </p>

    <%= form_with(model: [:manager, @employee_onboarding, @review], class: "space-y-6") do |f| %>
      <% if @review.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-md p-4">
          <ul class="list-disc list-inside text-sm text-red-600 dark:text-red-400">
            <% @review.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :integration_level, "Niveau d'intégration (1 = difficile, 5 = excellent)",
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <div class="flex gap-3">
          <% (1..5).each do |n| %>
            <label class="flex flex-col items-center gap-1 cursor-pointer">
              <%= f.radio_button :integration_level, n,
                    class: "sr-only peer" %>
              <span class="w-10 h-10 flex items-center justify-center rounded-full border-2 border-gray-300 dark:border-gray-600 text-sm font-semibold text-gray-700 dark:text-gray-300 peer-checked:border-indigo-600 peer-checked:bg-indigo-600 peer-checked:text-white hover:border-indigo-400 transition-all">
                <%= n %>
              </span>
            </label>
          <% end %>
        </div>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">1 = Difficultés majeures · 5 = Intégration excellente</p>
      </div>

      <div>
        <%= f.label :strengths, "Points forts observés",
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :strengths, rows: 3,
              class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm",
              placeholder: "Compétences, attitude, prise en main des outils..." %>
      </div>

      <div>
        <%= f.label :risk_signals, "Signaux de risque",
              class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= f.text_area :risk_signals, rows: 3,
              class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm",
              placeholder: "Difficultés relationnelles, blocages techniques, absentéisme..." %>
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
          Laissez vide s'il n'y a pas de signaux particuliers.
        </p>
      </div>

      <div class="flex justify-end gap-3">
        <%= link_to "Annuler", manager_employee_onboarding_path(@employee_onboarding),
              class: "inline-flex items-center py-2 px-4 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all" %>
        <%= f.submit "Enregistrer le bilan",
              class: "inline-flex items-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer transition-all" %>
      </div>
    <% end %>
  </div>
</div>
