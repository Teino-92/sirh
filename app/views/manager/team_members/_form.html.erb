<%= form_with model: team_member, url: team_member.new_record? ? manager_team_members_path : manager_team_member_path(team_member), method: team_member.new_record? ? :post : :patch, class: "space-y-6" do |f| %>
  <% if team_member.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/30 border border-red-300 dark:border-red-700 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 dark:text-red-200 mb-2">
        <%= pluralize(team_member.errors.count, "erreur") %> :
      </h3>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-300 space-y-1">
        <% team_member.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, "Prénom", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.text_field :first_name, required: true,
            class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :last_name, "Nom", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.text_field :last_name, required: true,
            class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>

  <div>
    <%= f.label :email, "Email", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
    <%= f.email_field :email, required: true,
          class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :job_title, "Poste", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.text_field :job_title,
            class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary",
            placeholder: "Ex: Développeur, Chef de projet..." %>
    </div>
    <div>
      <%= f.label :department, "Département", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.text_field :department,
            class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary",
            placeholder: "Ex: Tech, Marketing, Ops..." %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :contract_type, "Type de contrat", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.select :contract_type,
            options_for_select([['CDI', 'CDI'], ['CDD', 'CDD'], ['Stage', 'Stage'], ['Alternance', 'Alternance'], ['Intérim', 'Interim']], team_member.contract_type),
            {},
            class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
    <div>
      <%= f.label :start_date, "Date d'entrée", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.date_field :start_date, required: true,
            class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    </div>
  </div>

  <div>
    <%= f.label :end_date, "Fin de contrat (CDD uniquement)", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
    <%= f.date_field :end_date,
          class: "w-full rounded-md border border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 px-3 py-2 text-sm text-text-deep dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" %>
    <p class="mt-1 text-xs text-muted-soft dark:text-white/50">Obligatoire pour un CDD, laisser vide sinon.</p>
  </div>

  <div class="flex items-center justify-end gap-3 pt-2">
    <%= link_to "Annuler", manager_team_schedules_path,
          class: "px-4 py-2 text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 border border-border-soft dark:border-white/15 rounded-md hover:bg-bg-soft dark:hover:bg-gray-600 transition-colors" %>
    <%= f.submit nil,
          class: "px-4 py-2 text-sm font-medium text-white bg-primary hover:bg-primary rounded-md shadow-sm transition-colors cursor-pointer" %>
  </div>
<% end %>
