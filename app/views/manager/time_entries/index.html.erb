<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center text-gray-600 mb-4">
      <%= link_to manager_team_schedules_path, class: "text-indigo-600 hover:text-indigo-900" do %>
        ← Retour à l'équipe
      <% end %>
    </div>

    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Pointages de <%= @team_member.full_name %></h1>
        <p class="text-sm text-gray-600 mt-1">Validation des heures de travail</p>
      </div>
    </div>
  </div>

  <!-- Pending Validation Alert -->
  <% if @pending_entries.any? %>
    <div class="bg-orange-50 border-2 border-orange-500 rounded-lg p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-semibold text-orange-900 mb-1">
            <%= @pending_entries.count %> pointage<%= 's' if @pending_entries.count > 1 %> en attente de validation
          </h3>
          <p class="text-sm text-orange-800">
            Validez les heures pour qu'elles soient comptabilisées dans la paie
          </p>
        </div>
        <%= button_to "Valider la semaine en cours",
                      validate_week_manager_team_member_time_entries_path(@team_member),
                      method: :post,
                      class: "bg-orange-600 hover:bg-orange-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors",
                      data: { confirm: "Confirmer la validation de tous les pointages de cette semaine ?" } %>
      </div>
    </div>
  <% end %>

  <!-- Time Entries Table -->
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900">Historique des pointages</h2>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Entrée</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sortie</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Durée</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @time_entries.group_by { |te| te.worked_date.beginning_of_week }.each do |week_start, week_entries| %>
            <!-- Week Separator -->
            <tr class="bg-gray-50">
              <td colspan="6" class="px-6 py-2 text-sm font-semibold text-gray-700">
                Semaine du <%= l(week_start, format: :short) %>
              </td>
            </tr>

            <% week_entries.each do |entry| %>
              <tr class="<%= 'bg-yellow-50' unless entry.validated? %>">
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= l(entry.worked_date, format: :long) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <%= l(entry.clock_in, format: :short) %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                  <% if entry.clock_out %>
                    <%= l(entry.clock_out, format: :short) %>
                  <% else %>
                    <span class="text-green-600 font-medium">En cours...</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                  <%= entry.hours_worked.round(2) %>h
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if entry.validated? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      ✓ Validé
                    </span>
                    <div class="text-xs text-gray-500 mt-1">
                      par <%= entry.validated_by.full_name %><br>
                      le <%= l(entry.validated_at, format: :short) %>
                    </div>
                  <% elsif entry.rejected? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      ✗ Refusé
                    </span>
                    <div class="text-xs text-gray-500 mt-1">
                      par <%= entry.rejected_by.full_name %><br>
                      le <%= l(entry.rejected_at, format: :short) %><br>
                      <span class="text-red-600 font-medium">Raison: <%= entry.rejection_reason %></span>
                    </div>
                  <% elsif entry.completed? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      En attente
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      En cours
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <% if entry.completed? && !entry.validated? && !entry.rejected? %>
                    <div class="flex gap-2 justify-end">
                      <%= button_to "Valider",
                                    validate_entry_manager_team_member_time_entry_path(@team_member, entry),
                                    method: :post,
                                    class: "inline-flex items-center px-3 py-1 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700" %>
                      <button type="button"
                              onclick="openRejectModal(<%= entry.id %>, '<%= l(entry.worked_date, format: :long) %>')"
                              class="inline-flex items-center px-3 py-1 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700">
                        Refuser
                      </button>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @time_entries.empty? %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="mt-4 text-gray-500">Aucun pointage trouvé</p>
      </div>
    <% end %>
  </div>
</div>

<!-- Reject Modal -->
<div id="rejectModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); background-color: rgba(0, 0, 0, 0.3); align-items: center; justify-content: center; padding: 1rem;">
  <div class="bg-white rounded-lg shadow-2xl" style="max-width: 32rem; width: 100%; max-height: 90vh; overflow-y: auto;">
      <form action="#" method="post" id="rejectForm">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <!-- Modal Header -->
        <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-red-50 to-orange-50">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-red-100 flex items-center justify-center">
                <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-gray-900">Refuser le pointage</h3>
                <p class="text-sm text-gray-600" id="modalDate">Pointage du ...</p>
              </div>
            </div>
            <button type="button" onclick="closeRejectModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Modal Body -->
        <div class="px-6 py-6">
          <div class="mb-1">
            <label for="rejection_reason" class="block text-sm font-semibold text-gray-700 mb-2">Raison du refus *</label>
            <textarea name="rejection_reason" id="rejection_reason" required rows="5"
                      placeholder="Ex: Heures incohérentes avec le planning prévu, pause non déduite, temps de travail trop élevé..."
                      class="shadow-sm focus:ring-red-500 focus:border-red-500 block w-full text-sm border-gray-300 rounded-lg resize-none"></textarea>
          </div>
          <p class="text-xs text-gray-500 mt-2">
            💡 L'employé recevra une notification avec cette raison
          </p>
        </div>

        <!-- Modal Footer -->
        <div class="px-6 py-4 bg-gray-50 border-t border-gray-200 rounded-b-2xl flex gap-3 justify-end">
          <button type="button" onclick="closeRejectModal()"
                  class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
            Annuler
          </button>
          <button type="submit"
                  class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors shadow-sm">
            Refuser le pointage
          </button>
        </div>
      </form>
    </div>
</div>

<script>
function openRejectModal(entryId, date) {
  const modal = document.getElementById('rejectModal');
  const form = document.getElementById('rejectForm');
  const dateEl = document.getElementById('modalDate');

  form.action = '<%= reject_entry_manager_team_member_time_entry_path(@team_member, '__ID__') %>'.replace('__ID__', entryId);
  dateEl.textContent = 'Pointage du ' + date;
  modal.style.display = 'flex';
}

function closeRejectModal() {
  const modal = document.getElementById('rejectModal');
  const form = document.getElementById('rejectForm');
  modal.style.display = 'none';
  form.reset();
}

// Close modal when clicking on background
document.addEventListener('DOMContentLoaded', function() {
  const modal = document.getElementById('rejectModal');
  if (modal) {
    modal.addEventListener('click', function(e) {
      if (e.target === this) {
        closeRejectModal();
      }
    });
  }
});
</script>
