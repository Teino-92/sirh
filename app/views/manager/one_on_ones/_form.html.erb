<%= form_with model: [:manager, one_on_one], class: 'space-y-4' do |f| %>
  <% if one_on_one.errors.any? %>
    <div class="rounded-md bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 p-4">
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400">
        <% one_on_one.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :employee_id, 'Collaborateur', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.select :employee_id,
          current_employee.direct_reports.order(:last_name, :first_name).map { |e| [e.full_name, e.id] },
          { prompt: 'Sélectionner un collaborateur' },
          class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary/30 focus:ring-purple-500 text-sm', required: true %>
  </div>

  <div>
    <%= f.label :scheduled_at, 'Date et heure', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.datetime_local_field :scheduled_at, class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary/30 focus:ring-purple-500 text-sm', required: true %>
  </div>

  <div>
    <%= f.label :agenda, 'Agenda', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.text_area :agenda, rows: 4,
          class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary/30 focus:ring-purple-500 text-sm',
          placeholder: 'Points à aborder…' %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit one_on_one.persisted? ? 'Enregistrer' : 'Planifier le 1:1',
          class: 'inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-primary/10 hover:bg-primary/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-all cursor-pointer' %>
    <%= link_to 'Annuler', manager_one_on_ones_path,
          class: 'inline-flex justify-center py-2 px-4 border border-border-soft dark:border-white/15 rounded-md shadow-sm text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all' %>
  </div>
<% end %>
