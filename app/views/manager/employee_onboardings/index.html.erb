<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white">Onboarding équipe</h1>
      <p class="text-sm text-muted-soft dark:text-white/50 mt-1">Suivez l'intégration des nouveaux collaborateurs</p>
    </div>
    <div class="mt-4 sm:mt-0 flex items-center gap-3">
      <% if policy(OnboardingTemplate.new(organization: current_employee.organization)).create? %>
        <button onclick="document.getElementById('new-template-modal').showModal()"
                class="inline-flex items-center px-4 py-2 border border-border-soft dark:border-white/15 shadow-sm text-sm font-medium rounded-md text-text-deep dark:text-muted-soft bg-surface dark:bg-[#1C1B2E] hover:bg-bg-soft dark:hover:bg-gray-700 transition-colors">
          <svg class="w-5 h-5 mr-2 text-muted-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Créer un template
        </button>
      <% end %>
      <% if policy(EmployeeOnboarding.new(organization: current_employee.organization)).create? %>
        <%= link_to new_manager_employee_onboarding_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-primary transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Démarrer un onboarding
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Onboarding List -->
  <div class="space-y-4">
    <% if @employee_onboardings.any? %>
      <% @employee_onboardings.each do |onboarding| %>
        <%
          score         = onboarding.integration_score
          progress      = onboarding.progress_percentage
          overdue_count = onboarding.overdue_tasks.count
          risk          = score < 40
        %>
        <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 overflow-hidden">
          <div class="p-4 sm:p-6">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="text-base font-semibold text-text-deep dark:text-white">
                    <%= link_to onboarding.employee.full_name, manager_employee_onboarding_path(onboarding),
                          class: "hover:text-primary dark:hover:text-primary transition-colors" %>
                  </h3>
                  <!-- Status badge -->
                  <%
                    status_classes = case onboarding.status
                    when 'active'    then 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
                    when 'completed' then 'bg-primary/10 dark:bg-primary/10/40 text-primary dark:text-primary'
                    when 'cancelled' then 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/50'
                    end
                    status_labels = { 'active' => 'Actif', 'completed' => 'Terminé', 'cancelled' => 'Annulé' }
                  %>
                  <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= status_classes %>">
                    <%= status_labels[onboarding.status] %>
                  </span>
                  <% if risk %>
                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400">
                      ⚠ Risque d'intégration
                    </span>
                  <% end %>
                  <% if overdue_count > 0 %>
                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-400">
                      <%= overdue_count %> tâche<%= 's' if overdue_count > 1 %> en retard
                    </span>
                  <% end %>
                </div>

                <div class="flex flex-wrap items-center gap-3 mt-2 text-sm text-muted-soft dark:text-white/50">
                  <span class="flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <%= onboarding.onboarding_template.name %>
                  </span>
                  <span class="flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Début : <%= l(onboarding.start_date, format: :short) %>
                  </span>
                  <% if onboarding.active? %>
                    <span>Jour <%= onboarding.day_number %></span>
                  <% end %>
                </div>

                <!-- Progress bar -->
                <div class="mt-3">
                  <div class="flex justify-between text-xs text-muted-soft dark:text-white/50 mb-1">
                    <span>Progression</span>
                    <span><%= progress %>%</span>
                  </div>
                  <div class="w-full bg-bg-soft dark:bg-surface/10 rounded-full h-2">
                    <div class="<%= risk ? 'bg-red-500' : 'bg-primary' %> h-2 rounded-full transition-all duration-300"
                         style="width: <%= progress %>%"></div>
                  </div>
                </div>
              </div>

              <!-- Integration score + link -->
              <div class="ml-6 flex-shrink-0 text-right">
                <div class="text-2xl font-bold <%= score >= 70 ? 'text-green-600 dark:text-green-400' : score >= 40 ? 'text-warning dark:text-warning' : 'text-red-600 dark:text-red-400' %>">
                  <%= score %>
                </div>
                <div class="text-xs text-muted-soft dark:text-white/50">Score</div>
                <div class="mt-2">
                  <%= link_to "Voir →", manager_employee_onboarding_path(onboarding),
                        class: "text-sm text-primary dark:text-primary/80 hover:text-primary font-medium" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow text-center py-12 px-4">
        <svg class="mx-auto h-12 w-12 text-muted-soft dark:text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-text-deep dark:text-white">Aucun onboarding en cours</h3>
        <p class="mt-1 text-sm text-muted-soft dark:text-white/50">
          Commencez par créer un template, puis démarrez l'onboarding d'un collaborateur.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-3">
          <% if policy(OnboardingTemplate.new(organization: current_employee.organization)).create? %>
            <button onclick="document.getElementById('new-template-modal').showModal()"
                    class="inline-flex items-center px-4 py-2 border border-border-soft dark:border-white/15 shadow-sm text-sm font-medium rounded-md text-text-deep dark:text-muted-soft bg-surface dark:bg-[#1C1B2E] hover:bg-bg-soft dark:hover:bg-gray-700">
              <svg class="w-5 h-5 mr-2 text-muted-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Créer un template
            </button>
          <% end %>
          <% if policy(EmployeeOnboarding.new(organization: current_employee.organization)).create? %>
            <%= link_to new_manager_employee_onboarding_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-primary" do %>
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
              </svg>
              Démarrer un onboarding
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if flash[:template_errors].present? %>
  <script>document.addEventListener('DOMContentLoaded', function(){ document.getElementById('new-template-modal').showModal(); });</script>
<% end %>

<!-- Modal : Nouveau template d'onboarding -->
<dialog id="new-template-modal"
        class="rounded-xl shadow-2xl p-0 w-full max-w-lg mx-auto my-auto backdrop:bg-black/50"
        style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);margin:0"
        onclick="if(event.target===this)this.close()">
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-xl">
    <div class="flex items-center justify-between px-6 py-4 border-b border-border-soft dark:border-white/10">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white">Nouveau template d'onboarding</h2>
      <button onclick="document.getElementById('new-template-modal').close()"
              class="text-muted-soft hover:text-muted-soft dark:hover:text-muted-soft">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%= form_with url: manager_onboarding_templates_path, method: :post, class: "px-6 py-5 space-y-4" do |f| %>
      <% if flash[:template_errors].present? %>
        <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-md p-3">
          <ul class="list-disc list-inside text-sm text-red-600 dark:text-red-400 space-y-1">
            <% flash[:template_errors].each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div>
        <%= f.label :name, "Nom du template", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
        <%= f.text_field :name,
              name: "onboarding_template[name]",
              placeholder: "Ex : Intégration développeur",
              value: flash[:template_params]&.dig("name"),
              required: true,
              class: "block w-full rounded-md border-border-soft dark:border-white/15 dark:bg-surface/10 dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
      </div>

      <div>
        <%= f.label :description, "Description", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
        <%= f.text_area :description,
              name: "onboarding_template[description]",
              rows: 3,
              placeholder: "Décrivez le contexte et les objectifs de ce parcours...",
              content: flash[:template_params]&.dig("description"),
              class: "block w-full rounded-md border-border-soft dark:border-white/15 dark:bg-surface/10 dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
      </div>

      <div>
        <%= f.label :duration_days, "Durée (jours)", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
        <%= f.number_field :duration_days,
              name: "onboarding_template[duration_days]",
              value: flash[:template_params]&.dig("duration_days") || 90,
              min: 1,
              class: "block w-32 rounded-md border-border-soft dark:border-white/15 dark:bg-surface/10 dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm" %>
        <p class="mt-1 text-xs text-muted-soft dark:text-white/50">La durée détermine la date de fin calculée automatiquement.</p>
      </div>

      <div class="flex items-center gap-2">
        <%= f.check_box :active,
              name: "onboarding_template[active]",
              checked: true,
              class: "h-4 w-4 rounded border-border-soft text-primary focus:ring-primary" %>
        <%= f.label :active, "Template actif (disponible pour les onboardings)", class: "text-sm text-text-deep dark:text-white/70" %>
      </div>

      <div class="flex justify-end gap-3 pt-2 border-t border-border-soft dark:border-white/10">
        <button type="button"
                onclick="document.getElementById('new-template-modal').close()"
                class="px-4 py-2 text-sm font-medium text-text-deep dark:text-muted-soft bg-surface dark:bg-surface/10 border border-border-soft dark:border-white/15 rounded-md hover:bg-bg-soft dark:hover:bg-gray-600">
          Annuler
        </button>
        <%= f.submit "Créer le template",
              class: "px-4 py-2 text-sm font-medium text-white bg-primary hover:bg-primary rounded-md cursor-pointer" %>
      </div>
    <% end %>
  </div>
</dialog>
