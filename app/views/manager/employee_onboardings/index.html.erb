<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Onboarding équipe</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Suivez l'intégration des nouveaux collaborateurs</p>
    </div>
    <%= link_to new_manager_employee_onboarding_path, class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition-colors" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Démarrer un onboarding
    <% end %>
  </div>

  <!-- Onboarding List -->
  <div class="space-y-4">
    <% if @employee_onboardings.any? %>
      <% @employee_onboardings.each do |onboarding| %>
        <%
          score         = onboarding.integration_score
          progress      = onboarding.progress_percentage
          overdue_count = onboarding.overdue_tasks.count
          risk          = score < 40
        %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
          <div class="p-4 sm:p-6">
            <div class="flex items-start justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100">
                    <%= link_to onboarding.employee.full_name, manager_employee_onboarding_path(onboarding),
                          class: "hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" %>
                  </h3>
                  <!-- Status badge -->
                  <%
                    status_classes = case onboarding.status
                    when 'active'    then 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
                    when 'completed' then 'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300'
                    when 'cancelled' then 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
                    end
                    status_labels = { 'active' => 'Actif', 'completed' => 'Terminé', 'cancelled' => 'Annulé' }
                  %>
                  <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= status_classes %>">
                    <%= status_labels[onboarding.status] %>
                  </span>
                  <% if risk %>
                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400">
                      ⚠ Risque d'intégration
                    </span>
                  <% end %>
                  <% if overdue_count > 0 %>
                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-400">
                      <%= overdue_count %> tâche<%= 's' if overdue_count > 1 %> en retard
                    </span>
                  <% end %>
                </div>

                <div class="flex flex-wrap items-center gap-3 mt-2 text-sm text-gray-600 dark:text-gray-400">
                  <span class="flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <%= onboarding.onboarding_template.name %>
                  </span>
                  <span class="flex items-center">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Début : <%= l(onboarding.start_date, format: :short) %>
                  </span>
                  <% if onboarding.active? %>
                    <span>Jour <%= onboarding.day_number %></span>
                  <% end %>
                </div>

                <!-- Progress bar -->
                <div class="mt-3">
                  <div class="flex justify-between text-xs text-gray-500 dark:text-gray-400 mb-1">
                    <span>Progression</span>
                    <span><%= progress %>%</span>
                  </div>
                  <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                    <div class="<%= risk ? 'bg-red-500' : 'bg-indigo-600' %> h-2 rounded-full transition-all duration-300"
                         style="width: <%= progress %>%"></div>
                  </div>
                </div>
              </div>

              <!-- Integration score + link -->
              <div class="ml-6 flex-shrink-0 text-right">
                <div class="text-2xl font-bold <%= score >= 70 ? 'text-green-600 dark:text-green-400' : score >= 40 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %>">
                  <%= score %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Score</div>
                <div class="mt-2">
                  <%= link_to "Voir →", manager_employee_onboarding_path(onboarding),
                        class: "text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 font-medium" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow text-center py-12 px-4">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">Aucun onboarding en cours</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Démarrez l'onboarding d'un nouveau collaborateur.
        </p>
        <div class="mt-6">
          <%= link_to new_manager_employee_onboarding_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Démarrer un onboarding
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
