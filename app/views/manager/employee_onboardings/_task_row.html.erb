<div id="onboarding_task_<%= task.id %>"
     class="bg-surface dark:bg-[#1C1B2E] rounded-lg border border-border-soft dark:border-white/10 p-4 flex items-start gap-4">
  <!-- Status icon / action button -->
  <div class="flex-shrink-0 mt-0.5">
    <% if task.completed? %>
      <span class="w-6 h-6 flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900/40">
        <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </span>
    <% elsif task.overdue? && task.pending? %>
      <span class="w-6 h-6 flex items-center justify-center rounded-full bg-red-100 dark:bg-red-900/40">
        <svg class="w-4 h-4 text-red-500 dark:text-red-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
        </svg>
      </span>
    <% elsif task.assigned_to_role == 'employee' && task.pending? %>
      <!-- Employee task pending: waiting for employee action -->
      <span class="w-6 h-6 flex items-center justify-center rounded-full border-2 border-border-soft dark:border-white/15 opacity-50">
        <svg class="w-3 h-3 text-muted-soft dark:text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </span>
    <% elsif task.assigned_to_role == 'employee' && task.done? %>
      <!-- Employee task done: waiting for manager validation -->
      <span class="w-6 h-6 flex items-center justify-center rounded-full bg-orange-100 dark:bg-orange-900/40">
        <svg class="w-4 h-4 text-orange-500 dark:text-orange-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 8.586V5z" clip-rule="evenodd" />
        </svg>
      </span>
    <% else %>
      <%= button_to manager_employee_onboarding_task_path(task), method: :patch, class: "cursor-pointer" do %>
        <span class="w-6 h-6 flex items-center justify-center rounded-full border-2 border-border-soft dark:border-white/15 hover:border-primary dark:hover:border-primary transition-colors">
          <svg class="w-3 h-3 text-transparent hover:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </span>
      <% end %>
    <% end %>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex items-start justify-between gap-2">
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium <%= task.completed? ? 'line-through text-muted-soft dark:text-white/40' : 'text-text-deep dark:text-white' %>">
          <%= type_icons[task.task_type] %> <%= task.title %>
        </p>
        <% if task.description.present? %>
          <p class="text-xs text-muted-soft dark:text-white/50 mt-0.5"><%= task.description %></p>
        <% end %>

        <% linked = task.linked_record rescue nil %>
        <% if linked %>
          <p class="text-xs text-primary dark:text-primary/80 mt-1">
            Lié à : <%= linked.try(:title) || linked.try(:name) || "Enregistrement ##{linked.id}" %>
          </p>
        <% end %>

        <!-- Status badges and actions -->
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <% if task.assigned_to_role == 'employee' && task.pending? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300">
              En attente de l'employé
            </span>
          <% elsif task.assigned_to_role == 'employee' && task.done? %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-300">
              À valider
            </span>
            <%= button_to validate_manager_employee_onboarding_task_path(task),
                  method: :patch,
                  data: { turbo_stream: true },
                  class: "inline-flex items-center px-3 py-1 rounded-md text-xs font-semibold text-white bg-primary hover:bg-primary/90 transition-colors" do %>
              Valider
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="flex-shrink-0 text-right">
        <p class="text-xs <%= task.overdue? && task.pending? ? 'text-red-600 dark:text-red-400 font-medium' : 'text-muted-soft dark:text-white/50' %>">
          <%= l(task.due_date, format: :short) %>
        </p>
        <% if task.completed_at.present? %>
          <p class="text-xs text-muted-soft dark:text-white/40 mt-0.5">
            Fait le <%= l(task.completed_at.to_date, format: :short) %>
          </p>
        <% end %>
        <% if task.validated_at.present? %>
          <p class="text-xs text-green-600 dark:text-green-400 mt-0.5">
            Validé le <%= l(task.validated_at.to_date, format: :short) %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
