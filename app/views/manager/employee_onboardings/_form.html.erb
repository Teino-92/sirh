<%= form_with(model: onboarding, url: onboarding.new_record? ? manager_employee_onboardings_path : manager_employee_onboarding_path(onboarding), method: onboarding.new_record? ? :post : :patch, class: "space-y-6") do |f| %>
  <% if onboarding.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-md p-4">
      <p class="text-sm font-medium text-red-700 dark:text-red-400">
        <%= pluralize(onboarding.errors.count, 'erreur') %> :
      </p>
      <ul class="mt-1 list-disc list-inside text-sm text-red-600 dark:text-red-400">
        <% onboarding.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :employee_id, "Collaborateur", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
    <%= f.collection_select :employee_id,
          @team_members,
          :id, :full_name,
          { include_blank: "Choisir un collaborateur" },
          class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm" %>
  </div>

  <div>
    <%= f.label :onboarding_template_id, "Modèle d'onboarding", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
    <%= f.collection_select :onboarding_template_id,
          @templates,
          :id, :name,
          { include_blank: "Choisir un modèle" },
          class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm" %>
    <p class="mt-1 text-xs text-muted-soft dark:text-white/50">
      Les modèles sont configurés par l'administration.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, "Date de début", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.date_field :start_date,
            class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm",
            value: (onboarding.start_date || Date.current).strftime('%Y-%m-%d') %>
    </div>
    <div>
      <%= f.label :end_date, "Date de fin prévue", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
      <%= f.date_field :end_date,
            class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm",
            value: onboarding.end_date&.strftime('%Y-%m-%d') %>
    </div>
  </div>

  <div>
    <%= f.label :notes, "Notes (optionnel)", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-1" %>
    <%= f.text_area :notes, rows: 3,
          class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm",
          placeholder: "Contexte, points d'attention particuliers..." %>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Annuler", manager_employee_onboardings_path,
          class: "inline-flex items-center py-2 px-4 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all" %>
    <%= f.submit (onboarding.new_record? ? "Démarrer l'onboarding" : "Mettre à jour"),
          class: "inline-flex items-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-primary hover:bg-primary cursor-pointer transition-all" %>
  </div>
<% end %>
