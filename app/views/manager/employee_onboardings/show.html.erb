<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Back link -->
  <div class="mb-4">
    <%= link_to '← Onboarding équipe', manager_employee_onboardings_path,
          class: 'text-sm text-muted-soft hover:text-text-deep dark:text-white/50 dark:hover:text-muted-soft' %>
  </div>

  <!-- Header card -->
  <%
    score    = @employee_onboarding.integration_score
    progress = @employee_onboarding.progress_percentage
    overdue  = @employee_onboarding.overdue_tasks.count
    risk     = score < 40
    status_classes = case @employee_onboarding.status
    when 'active'    then 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
    when 'completed' then 'bg-primary/10 dark:bg-primary/10/40 text-primary dark:text-primary'
    when 'cancelled' then 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/50'
    end
    status_labels = { 'active' => 'Actif', 'completed' => 'Terminé', 'cancelled' => 'Annulé' }
  %>

  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-2xl font-serif text-text-deep dark:text-white">
            Onboarding — <%= @employee_onboarding.employee.full_name %>
          </h1>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= status_classes %>">
            <%= status_labels[@employee_onboarding.status] %>
          </span>
          <% if risk %>
            <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400">
              ⚠ Risque d'intégration
            </span>
          <% end %>
        </div>

        <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-4 text-sm">
          <div>
            <dt class="font-medium text-muted-soft dark:text-white/50">Modèle</dt>
            <dd class="mt-1 text-text-deep dark:text-white"><%= @employee_onboarding.onboarding_template.name %></dd>
          </div>
          <div>
            <dt class="font-medium text-muted-soft dark:text-white/50">Début</dt>
            <dd class="mt-1 text-text-deep dark:text-white"><%= l(@employee_onboarding.start_date, format: :long) %></dd>
          </div>
          <div>
            <dt class="font-medium text-muted-soft dark:text-white/50">Fin prévue</dt>
            <dd class="mt-1 text-text-deep dark:text-white"><%= l(@employee_onboarding.end_date, format: :long) %></dd>
          </div>
          <% if @employee_onboarding.active? %>
            <div>
              <dt class="font-medium text-muted-soft dark:text-white/50">Jour</dt>
              <dd class="mt-1 text-text-deep dark:text-white">J+<%= @employee_onboarding.day_number %></dd>
            </div>
          <% end %>
        </dl>

        <% if @employee_onboarding.notes.present? %>
          <p class="mt-4 text-sm text-text-deep dark:text-white/70"><%= @employee_onboarding.notes %></p>
        <% end %>
      </div>

      <!-- Score + actions -->
      <div class="flex flex-row sm:flex-col items-center sm:items-end gap-4">
        <div class="text-center">
          <div class="text-4xl font-bold <%= score >= 70 ? 'text-green-600 dark:text-green-400' : score >= 40 ? 'text-warning dark:text-warning' : 'text-red-600 dark:text-red-400' %>">
            <%= score %>
          </div>
          <div class="text-xs text-muted-soft dark:text-white/50 mt-0.5">Score d'intégration</div>
        </div>

        <div class="flex gap-2 flex-wrap">
          <% if @employee_onboarding.active? %>
            <%= link_to 'Modifier', edit_manager_employee_onboarding_path(@employee_onboarding),
                  class: 'inline-flex items-center py-1.5 px-3 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all' %>
            <%= link_to 'Feedback manager', new_manager_employee_onboarding_employee_onboarding_review_path(@employee_onboarding),
                  class: 'inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-semibold text-white bg-primary hover:bg-primary transition-all' %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="mt-6">
      <div id="onboarding_progress_<%= @employee_onboarding.id %>">
        <div class="flex justify-between text-sm text-muted-soft dark:text-white/50 mb-1">
          <span>Progression globale</span>
          <span class="font-medium"><%= progress %>%</span>
        </div>
        <div class="w-full bg-bg-soft dark:bg-surface/10 rounded-full h-3">
          <div class="<%= risk ? 'bg-red-500' : 'bg-primary' %> h-3 rounded-full transition-all duration-300"
               style="width: <%= progress %>%"></div>
        </div>
      </div>
      <% if overdue > 0 %>
        <p class="mt-2 text-sm text-orange-600 dark:text-orange-400 font-medium">
          <%= overdue %> tâche<%= 's' if overdue > 1 %> en retard
        </p>
      <% end %>
    </div>
  </div>

  <!-- Tasks by role -->
  <%
    role_labels = { 'hr' => 'RH', 'manager' => 'Manager', 'employee' => 'Collaborateur' }
    role_colors = {
      'hr'       => 'bg-primary/10 dark:bg-primary/10/40 text-primary dark:text-primary',
      'manager'  => 'bg-primary/10 dark:bg-primary/10/40 text-primary dark:text-primary',
      'employee' => 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
    }
    type_icons = {
      'manual'        => '✓',
      'objective_30'  => '🎯',
      'objective_60'  => '🎯',
      'objective_90'  => '🎯',
      'training'      => '📚',
      'one_on_one'    => '💬'
    }
  %>

  <% %w[hr manager employee].each do |role| %>
    <% tasks = @tasks_by_role[role] %>
    <% next if tasks.blank? %>

    <div class="mb-6">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-3 flex items-center gap-2">
        <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= role_colors[role] %>">
          <%= role_labels[role] %>
        </span>
        <span>Tâches <%= role_labels[role] %></span>
      </h2>

      <div class="space-y-2">
        <% tasks.each do |task| %>
          <%= render 'manager/employee_onboardings/task_row', task: task, type_icons: type_icons %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Reviews -->
  <% if @employee_onboarding.onboarding_reviews.any? %>
    <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-4">Bilans d'intégration</h2>
      <div class="space-y-4">
        <% @employee_onboarding.onboarding_reviews.order(:review_day).each do |review| %>
          <div class="border-l-4 border-primary pl-4">
            <p class="text-sm font-medium text-text-deep dark:text-white">
              Bilan J+<%= review.review_day %>
              <span class="text-xs text-muted-soft dark:text-white/50 ml-2">(<%= review.reviewer_type == 'manager' ? 'Manager' : 'Collaborateur' %>)</span>
            </p>
            <% if review.manager_integration_level %>
              <p class="text-sm text-text-deep dark:text-white/70 mt-1">
                Niveau d'intégration : <strong><%= review.manager_integration_level %>/5</strong>
              </p>
            <% end %>
            <% fb = review.manager_feedback_json %>
            <% if fb['strengths'].present? %>
              <p class="text-sm text-muted-soft dark:text-white/50 mt-1">Points forts : <%= fb['strengths'] %></p>
            <% end %>
            <% if fb['risk_signals'].present? %>
              <p class="text-sm text-orange-600 dark:text-orange-400 mt-1">Signaux de risque : <%= fb['risk_signals'] %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
