<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6"
     data-controller="tour"
     data-tour-name-value="manager-trainings"
     data-tour-autostart-value="true">

  <!-- Page header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
    <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white">Formations</h1>
    <%= link_to 'Nouvelle formation', new_manager_training_path,
          class: 'mt-4 sm:mt-0 inline-flex items-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all',
          data: { "tour-step": "2", "tour-title": "Créer une formation", "tour-description": "Ajoutez une formation au catalogue et assignez-la à votre équipe." } %>
  </div>

  <!-- Team Assignments Section -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white">Formations de l'équipe</h2>
    </div>

    <!-- Assignment tabs -->
    <div class="flex gap-2 mb-4"
         data-tour-step="1"
         data-tour-title="Formations de l'équipe"
         data-tour-description="Suivez les formations assignées et terminées par vos collaborateurs.">
      <%= link_to manager_trainings_path(assignments_tab: 'active', archived: params[:archived], training_type: params[:training_type]),
            class: "inline-flex items-center py-1.5 px-4 rounded-md text-sm font-medium transition-all #{@team_assignments_tab == 'active' ? 'bg-primary text-white shadow-sm' : 'bg-surface dark:bg-[#1C1B2E] text-muted-soft dark:text-white/70 border border-border-soft dark:border-white/15 hover:bg-bg-soft dark:hover:bg-gray-700'}" do %>
        Assignées / En cours
        <% if @team_assignments_tab == 'active' && @team_assignments.any? %>
          <span class="ml-1.5 bg-surface/20 text-white rounded-full px-1.5 py-0.5 text-xs"><%= @team_assignments.count %></span>
        <% end %>
      <% end %>
      <%= link_to "Terminées", manager_trainings_path(assignments_tab: 'completed', archived: params[:archived], training_type: params[:training_type]),
            class: "inline-flex items-center py-1.5 px-4 rounded-md text-sm font-medium transition-all #{@team_assignments_tab == 'completed' ? 'bg-primary text-white shadow-sm' : 'bg-surface dark:bg-[#1C1B2E] text-muted-soft dark:text-white/70 border border-border-soft dark:border-white/15 hover:bg-bg-soft dark:hover:bg-gray-700'}" %>
    </div>

    <% if @team_assignments.any? %>
      <div class="space-y-3">
        <% @team_assignments.each do |assignment| %>
          <%
            status_classes = {
              'assigned'   => 'bg-warning/10 dark:bg-warning/10/40 text-warning dark:text-warning border-yellow-200 dark:border-yellow-700',
              'in_progress'=> 'bg-primary/10 dark:bg-primary/10/40 text-primary dark:text-primary border-blue-200 dark:border-blue-700',
              'completed'  => 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 border-green-200 dark:border-green-700',
              'cancelled'  => 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/50 border-border-soft dark:border-white/15'
            }
            status_labels = {
              'assigned'   => 'Assignée',
              'in_progress'=> 'En cours',
              'completed'  => 'Terminé',
              'cancelled'  => 'Annulé'
            }
          %>
          <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg border border-border-soft dark:border-white/10 px-4 py-3 flex items-center justify-between">
            <div class="flex items-center min-w-0 gap-3">
              <div class="h-8 w-8 rounded-full bg-primary dark:bg-primary flex items-center justify-center flex-shrink-0">
                <span class="text-primary dark:text-primary text-xs font-bold">
                  <%= assignment.employee.first_name[0] %><%= assignment.employee.last_name[0] %>
                </span>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-medium text-text-deep dark:text-white truncate"><%= assignment.employee.full_name %></p>
                <p class="text-xs text-muted-soft dark:text-white/50 truncate">
                  <%= link_to assignment.training.title, manager_training_path(assignment.training), class: "hover:text-primary dark:hover:text-primary" %>
                  <% if assignment.deadline.present? %>
                    · Échéance <%= l(assignment.deadline, format: :short) %>
                  <% end %>
                </p>
              </div>
            </div>
            <span class="ml-3 flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border <%= status_classes[assignment.status] || 'bg-bg-soft text-muted-soft' %>">
              <%= status_labels[assignment.status] || assignment.status.humanize %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg border border-border-soft dark:border-white/10 p-8 text-center">
        <p class="text-sm text-muted-soft dark:text-white/50">
          <% if @team_assignments_tab == 'completed' %>
            Aucune formation terminée par l'équipe.
          <% else %>
            Aucune formation assignée en cours.
          <% end %>
        </p>
      </div>
    <% end %>
  </div>

  <!-- Catalogue header -->
  <div class="mb-4">
    <h2 class="text-lg font-semibold text-text-deep dark:text-white">Catalogue</h2>
  </div>

  <!-- Status tabs -->
  <div class="flex gap-2 mb-4 overflow-x-auto">
    <%= link_to 'Actives', manager_trainings_path,
          class: "inline-flex items-center py-1.5 px-4 rounded-md text-sm font-medium transition-all #{params[:archived] != 'true' ? 'bg-primary text-white shadow-sm' : 'bg-surface dark:bg-[#1C1B2E] text-muted-soft dark:text-white/70 border border-border-soft dark:border-white/15 hover:bg-bg-soft dark:hover:bg-gray-700'}" %>
    <%= link_to 'Archivées', manager_trainings_path(archived: true),
          class: "inline-flex items-center py-1.5 px-4 rounded-md text-sm font-medium transition-all #{params[:archived] == 'true' ? 'bg-primary text-white shadow-sm' : 'bg-surface dark:bg-[#1C1B2E] text-muted-soft dark:text-white/70 border border-border-soft dark:border-white/15 hover:bg-bg-soft dark:hover:bg-gray-700'}" %>
  </div>

  <!-- Type filter tabs -->
  <%
    type_labels = {
      'internal' => 'Interne',
      'external' => 'Externe',
      'certification' => 'Certification',
      'e_learning' => 'E-learning',
      'mentoring' => 'Mentorat'
    }
  %>
  <div class="flex gap-2 mb-6 overflow-x-auto pb-1">
    <%= link_to 'Tous les types',
          manager_trainings_path(archived: params[:archived]),
          class: "inline-flex items-center py-1 px-3 rounded-full text-xs font-medium transition-all whitespace-nowrap #{params[:training_type].blank? ? 'bg-gray-900 dark:bg-[#1C1B2E] text-white dark:text-text-deep' : 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/70 hover:bg-bg-soft dark:hover:bg-gray-600'}" %>
    <% Training.training_types.keys.each do |type| %>
      <%= link_to type_labels[type] || type.humanize,
            manager_trainings_path(training_type: type, archived: params[:archived]),
            class: "inline-flex items-center py-1 px-3 rounded-full text-xs font-medium transition-all whitespace-nowrap #{params[:training_type] == type ? 'bg-gray-900 dark:bg-[#1C1B2E] text-white dark:text-text-deep' : 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/70 hover:bg-bg-soft dark:hover:bg-gray-600'}" %>
    <% end %>
  </div>

  <!-- Trainings list -->
  <div class="space-y-4">
    <% @trainings.each do |training| %>
      <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-4">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="font-semibold text-lg text-text-deep dark:text-white">
              <%= link_to training.title, manager_training_path(training),
                    class: 'hover:text-primary dark:hover:text-primary' %>
            </h3>
            <div class="flex gap-2 mt-1 flex-wrap items-center">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-primary dark:bg-primary/20/40 text-primary dark:text-primary border border-primary dark:border-primary">
                <%= type_labels[training.training_type] || training.training_type.humanize %>
              </span>
              <% if training.provider.present? %>
                <span class="text-sm text-muted-soft dark:text-white/50"><%= training.provider %></span>
              <% end %>
              <% if training.duration_estimate.present? %>
                <span class="text-sm text-muted-soft dark:text-white/50"><%= training.duration_estimate %>h</span>
              <% end %>
            </div>
            <% if training.description.present? %>
              <p class="text-sm text-muted-soft dark:text-white/50 mt-2 line-clamp-2"><%= training.description %></p>
            <% end %>
          </div>
          <div class="flex gap-2 items-center ml-4">
            <% if training.archived? %>
              <%= button_to 'Restaurer', unarchive_manager_training_path(training),
                    method: :patch,
                    class: 'inline-flex items-center py-1.5 px-3 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all cursor-pointer' %>
            <% else %>
              <%= link_to 'Modifier', edit_manager_training_path(training),
                    class: 'inline-flex items-center py-1.5 px-3 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all' %>
              <%= button_to 'Archiver', archive_manager_training_path(training),
                    method: :patch,
                    class: 'inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-medium text-muted-soft dark:text-white/50 hover:text-red-600 dark:hover:text-red-400 bg-transparent transition-all cursor-pointer',
                    data: { confirm: 'Archiver cette formation ?' } %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @trainings.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-muted-soft dark:text-muted-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
        </svg>
        <p class="mt-2 text-sm text-muted-soft dark:text-white/50">Aucune formation trouvée.</p>
        <%= link_to 'Créer une formation', new_manager_training_path,
              class: 'mt-3 inline-flex items-center text-sm text-primary dark:text-primary/80 hover:underline' %>
      </div>
    <% end %>
  </div>
</div>
