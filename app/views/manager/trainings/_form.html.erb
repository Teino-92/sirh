<%= form_with model: [:manager, training], class: 'space-y-4' do |f| %>
  <% if training.errors.any? %>
    <div class="rounded-md bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 p-4">
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400">
        <% training.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, 'Titre', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.text_field :title, class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm', required: true %>
  </div>

  <div>
    <%= f.label :training_type, 'Type de formation', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.select :training_type,
          [
            ['Interne', 'internal'],
            ['Externe', 'external'],
            ['Certification', 'certification'],
            ['E-learning', 'e_learning'],
            ['Mentorat', 'mentoring']
          ],
          { prompt: 'Sélectionner un type' },
          class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm', required: true %>
  </div>

  <div>
    <%= f.label :description, 'Description', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.text_area :description, rows: 4, class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm' %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :provider, 'Organisme', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
      <%= f.text_field :provider, class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm' %>
    </div>

    <div>
      <%= f.label :duration_estimate, 'Durée (heures)', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
      <%= f.number_field :duration_estimate, min: 1, class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm' %>
    </div>
  </div>

  <div>
    <%= f.label :external_url, 'URL externe', class: 'block text-sm font-medium text-text-deep dark:text-white/70 mb-1' %>
    <%= f.url_field :external_url, class: 'block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary text-sm', placeholder: 'https://' %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit training.persisted? ? 'Enregistrer' : 'Créer la formation',
          class: 'inline-flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all cursor-pointer' %>
    <%= link_to 'Annuler', manager_trainings_path,
          class: 'inline-flex justify-center py-2 px-4 border border-border-soft dark:border-white/15 rounded-md shadow-sm text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all' %>
  </div>
<% end %>
