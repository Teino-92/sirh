<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-4">
    <%= link_to '← Formations équipe', manager_trainings_path,
          class: 'text-sm text-muted-soft hover:text-text-deep dark:text-white/50 dark:hover:text-muted-soft' %>
  </div>

  <!-- Header card -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6 mb-6">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <h1 class="text-2xl font-serif text-text-deep dark:text-white"><%= @training.title %></h1>
        <div class="flex flex-wrap gap-3 mt-2 text-sm text-muted-soft dark:text-white/50">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary dark:bg-primary/20/40 text-primary dark:text-primary border border-primary dark:border-primary">
            <%= {
              'internal' => 'Interne',
              'external' => 'Externe',
              'certification' => 'Certification',
              'e_learning' => 'E-learning',
              'mentoring' => 'Mentorat'
            }[@training.training_type] || @training.training_type.humanize %>
          </span>
          <% if @training.provider.present? %>
            <span><strong class="text-text-deep dark:text-white/70">Organisme :</strong> <%= @training.provider %></span>
          <% end %>
          <% if @training.duration_estimate.present? %>
            <span><strong class="text-text-deep dark:text-white/70">Durée :</strong> <%= @training.duration_estimate %>h</span>
          <% end %>
          <% if @training.external_url.present? %>
            <%= link_to 'Lien externe', @training.external_url,
                  target: '_blank', rel: 'noopener',
                  class: 'text-primary dark:text-primary/80 hover:underline' %>
          <% end %>
        </div>
        <% if @training.description.present? %>
          <p class="mt-4 text-text-deep dark:text-white/70"><%= @training.description %></p>
        <% end %>
      </div>
      <div class="flex gap-2 ml-4">
        <% if @training.archived? %>
          <%= button_to 'Restaurer', unarchive_manager_training_path(@training),
                method: :patch,
                class: 'inline-flex items-center py-1.5 px-3 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all cursor-pointer' %>
        <% else %>
          <%= link_to 'Modifier', edit_manager_training_path(@training),
                class: 'inline-flex items-center py-1.5 px-3 border border-border-soft dark:border-white/15 rounded-md text-sm font-medium text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600 transition-all' %>
          <%= button_to 'Archiver', archive_manager_training_path(@training),
                method: :patch,
                class: 'inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-medium text-muted-soft dark:text-white/50 hover:text-red-600 dark:hover:text-red-400 bg-transparent transition-all cursor-pointer',
                data: { confirm: 'Archiver cette formation ?' } %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Assignments -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6">
    <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-4">
      Assignations (<%= @assignments.count %>)
    </h2>

    <% if @assignments.any? %>
      <div class="space-y-3">
        <% @assignments.each do |assignment| %>
          <div class="flex justify-between items-center py-2 border-b border-border-soft dark:border-white/10 last:border-0">
            <div>
              <span class="font-medium text-text-deep dark:text-white"><%= assignment.employee.full_name %></span>
              <span class="text-sm text-muted-soft dark:text-white/50 ml-2">
                Assigné le <%= l(assignment.assigned_at.to_date, format: :short) %>
              </span>
              <% if assignment.deadline.present? %>
                <span class="text-sm text-muted-soft dark:text-white/50"> &bull; Échéance <%= l(assignment.deadline, format: :short) %></span>
              <% end %>
            </div>
            <%
              status_classes = {
                'pending'    => 'bg-warning/10 dark:bg-warning/10/40 text-warning dark:text-warning border-yellow-200 dark:border-yellow-700',
                'in_progress'=> 'bg-primary/10 dark:bg-primary/10/40 text-primary dark:text-primary border-blue-200 dark:border-blue-700',
                'completed'  => 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 border-green-200 dark:border-green-700',
                'cancelled'  => 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/50 border-border-soft dark:border-white/15'
              }
              status_labels = {
                'pending'    => 'En attente',
                'in_progress'=> 'En cours',
                'completed'  => 'Terminé',
                'cancelled'  => 'Annulé'
              }
            %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border <%= status_classes[assignment.status] || 'bg-bg-soft text-muted-soft' %>">
              <%= status_labels[assignment.status] || assignment.status.humanize %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted-soft dark:text-white/50 text-sm">Aucune assignation pour cette formation.</p>
    <% end %>
  </div>
</div>
