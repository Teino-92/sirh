<div class="container mx-auto px-4 py-6 max-w-4xl">
  <div class="mb-4">
    <%= link_to '← Back to Trainings', manager_trainings_path, class: 'text-sm text-gray-500 hover:text-gray-700' %>
  </div>

  <div class="card bg-white shadow-sm p-6 mb-6">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <h1 class="text-2xl font-bold"><%= @training.title %></h1>
        <div class="flex gap-3 mt-2 flex-wrap text-sm text-gray-600">
          <span class="badge badge-outline"><%= @training.training_type.humanize %></span>
          <% if @training.provider.present? %>
            <span><strong>Provider:</strong> <%= @training.provider %></span>
          <% end %>
          <% if @training.duration_estimate.present? %>
            <span><strong>Duration:</strong> <%= @training.duration_estimate %>h</span>
          <% end %>
          <% if @training.external_url.present? %>
            <%= link_to 'External Link', @training.external_url,
                  target: '_blank', rel: 'noopener', class: 'text-blue-600 hover:underline' %>
          <% end %>
        </div>
        <% if @training.description.present? %>
          <p class="mt-4 text-gray-700"><%= @training.description %></p>
        <% end %>
      </div>
      <div class="flex gap-2 ml-4">
        <% if @training.archived? %>
          <%= button_to 'Restore', unarchive_manager_training_path(@training),
                method: :patch, class: 'btn btn-sm btn-outline' %>
        <% else %>
          <%= link_to 'Edit', edit_manager_training_path(@training), class: 'btn btn-sm btn-outline' %>
          <%= button_to 'Archive', archive_manager_training_path(@training),
                method: :patch, class: 'btn btn-sm btn-ghost text-gray-400',
                data: { confirm: 'Archive this training?' } %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="card bg-white shadow-sm p-6">
    <h2 class="text-lg font-semibold mb-4">Assignments (<%= @assignments.count %>)</h2>

    <% if @assignments.any? %>
      <div class="space-y-3">
        <% @assignments.each do |assignment| %>
          <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
            <div>
              <span class="font-medium"><%= assignment.employee.full_name %></span>
              <span class="text-sm text-gray-500 ml-2">
                Assigned <%= assignment.assigned_at.strftime('%b %d, %Y') %>
              </span>
              <% if assignment.deadline.present? %>
                <span class="text-sm text-gray-500"> &bull; Due <%= assignment.deadline.strftime('%b %d, %Y') %></span>
              <% end %>
            </div>
            <span class="badge badge-<%= assignment.status %>"><%= assignment.status.humanize %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm">No assignments yet.</p>
    <% end %>
  </div>
</div>
