<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Exports & Recherche</h1>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
      Exportez les données légales de votre équipe ou recherchez avec l'IA
    </p>
  </div>

  <!-- Tabs -->
  <div data-controller="tabs" data-tabs-active-tab-class="border-indigo-500 text-indigo-600 dark:text-indigo-400"
       data-tabs-inactive-tab-class="border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600">

    <div class="border-b border-gray-200 dark:border-gray-700 mb-6">
      <nav class="-mb-px flex space-x-8" aria-label="Tabs">
        <button data-tabs-target="tab" data-action="click->tabs#select"
                data-tabs-index="0"
                class="whitespace-nowrap py-3 px-1 border-b-2 font-medium text-sm border-indigo-500 text-indigo-600 dark:text-indigo-400">
          Exports CSV
        </button>
        <button data-tabs-target="tab" data-action="click->tabs#select"
                data-tabs-index="1"
                class="whitespace-nowrap py-3 px-1 border-b-2 font-medium text-sm border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600">
          Recherche IA
        </button>
      </nav>
    </div>

    <!-- Tab 0: Exports CSV -->
    <div data-tabs-target="panel" data-tabs-index="0">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 pb-8">

        <!-- Export Pointages -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900 dark:to-blue-700 border-b-2 border-blue-300 dark:border-blue-500 px-6 py-4">
            <div class="flex items-center">
              <div class="flex-shrink-0 bg-blue-100 dark:bg-blue-800 rounded-lg p-2.5">
                <svg class="h-5 w-5 text-blue-700 dark:text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h2 class="text-lg font-semibold text-blue-900 dark:text-white">Pointages & Temps de travail</h2>
                <p class="text-xs text-blue-800 dark:text-white opacity-90 mt-0.5">Export des horaires et retards</p>
              </div>
            </div>
          </div>

          <div class="p-5">
            <%= form_with url: time_entries_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période</label>
                <%= f.select :period,
                    options_for_select([
                      ['Cette semaine', 'this_week'],
                      ['Ce mois', 'this_month'],
                      ['Mois dernier', 'last_month'],
                      ['Ce trimestre', 'this_quarter'],
                      ['Cette année', 'this_year'],
                      ['Personnalisée', 'custom']
                    ], 'this_month'),
                    {},
                    class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm"
                %>
              </div>

              <div id="custom-dates-time-entries" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
                  <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm" %>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
                  <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm" %>
                </div>
              </div>

              <div>
                <p class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Filtres</p>
                <div class="space-y-2.5 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
                  <label class="flex items-center group cursor-pointer">
                    <%= f.check_box :only_late, class: "rounded border-gray-300 dark:border-gray-600 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50" %>
                    <span class="ml-2.5 text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100">Retards uniquement</span>
                  </label>

                  <label class="flex items-center group cursor-pointer">
                    <%= f.check_box :only_unvalidated, class: "rounded border-gray-300 dark:border-gray-600 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50" %>
                    <span class="ml-2.5 text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100">Non validés uniquement</span>
                  </label>
                </div>
              </div>

              <div>
                <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all" %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Export Absences -->
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
          <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900 dark:to-green-700 border-b-2 border-green-300 dark:border-green-500 px-6 py-4">
            <div class="flex items-center">
              <div class="flex-shrink-0 bg-green-100 dark:bg-green-800 rounded-lg p-2.5">
                <svg class="h-5 w-5 text-green-700 dark:text-green-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h2 class="text-lg font-semibold text-green-900 dark:text-white">Absences & Congés</h2>
                <p class="text-xs text-green-800 dark:text-white opacity-90 mt-0.5">CP, RTT, Maladie...</p>
              </div>
            </div>
          </div>

          <div class="p-5">
            <%= form_with url: absences_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période</label>
                <%= f.select :period,
                    options_for_select([
                      ['Ce mois', 'this_month'],
                      ['Mois dernier', 'last_month'],
                      ['Ce trimestre', 'this_quarter'],
                      ['Cette année', 'this_year'],
                      ['Personnalisée', 'custom']
                    ], 'this_month'),
                    {},
                    class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-green-500 focus:ring-green-500 text-sm"
                %>
              </div>

              <div id="custom-dates-absences" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
                  <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-green-500 focus:border-green-500 text-sm" %>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
                  <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-green-500 focus:border-green-500 text-sm" %>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Statut</label>
                <%= f.select :status,
                    options_for_select([
                      ['Tous', ''],
                      ['En attente', 'pending'],
                      ['Approuvé', 'approved'],
                      ['Refusé', 'rejected']
                    ]),
                    {},
                    class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-green-500 focus:ring-green-500 text-sm"
                %>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Types d'absence</label>
                <div class="p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 space-y-2.5 max-h-44 overflow-y-auto">
                  <% ['CP', 'RTT', 'Maladie', 'Maternite', 'Paternite', 'Sans_Solde'].each do |leave_type| %>
                    <label class="flex items-center group cursor-pointer">
                      <%= check_box_tag 'leave_types[]', leave_type, false, class: "rounded border-gray-300 dark:border-gray-600 text-green-600 shadow-sm focus:border-green-300 focus:ring focus:ring-green-200 focus:ring-opacity-50" %>
                      <span class="ml-2.5 text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100">
                        <%= leave_type == 'CP' ? 'Congés Payés' : leave_type.gsub('_', ' ') %>
                      </span>
                    </label>
                  <% end %>
                </div>
              </div>

              <div class="pt-2">
                <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all" %>
              </div>
            <% end %>
          </div>
        </div>

      </div>

      <!-- Info Notice -->
      <div class="mt-2 bg-gradient-to-br from-indigo-50 to-indigo-100 dark:from-indigo-900 dark:to-indigo-700 border-2 border-indigo-300 dark:border-indigo-500 rounded-lg p-5 shadow-md">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-indigo-800 dark:text-white" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <h3 class="text-sm font-semibold text-indigo-900 dark:text-white mb-1">Format des fichiers CSV</h3>
            <p class="text-sm text-indigo-800 dark:text-white opacity-90 leading-relaxed">
              Les exports sont optimisés pour Excel (séparateur point-virgule, encodage UTF-8 avec BOM).
              Les virgules sont utilisées comme séparateur décimal pour respecter les standards français.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab 1: Recherche IA -->
    <div data-tabs-target="panel" data-tabs-index="1" class="hidden">

      <!-- Scope warning -->
      <% unless current_employee.hr_or_admin? %>
      <div class="mb-6 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 border border-indigo-200 dark:border-indigo-700 px-5 py-4 flex items-start gap-3">
        <svg class="h-5 w-5 text-indigo-600 dark:text-indigo-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm text-indigo-800 dark:text-indigo-300">
          <span class="font-semibold">Recherche limitée à votre équipe</span> · Salaires non accessibles
        </p>
      </div>
      <% end %>

      <!-- Query form -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6"
           data-controller="hr-query">

        <%= form_with url: search_manager_exports_path, method: :post,
                      data: { action: "submit->hr-query#onSubmit", "hr-query-target": "form" } do |f| %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

          <label for="manager_search_query" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
            Votre requête sur l'équipe
          </label>
          <textarea id="manager_search_query" name="query"
                    rows="3"
                    placeholder="Ex : Employés avec plus de 5 jours RTT · Membres en CDI · Nouvelles recrues ce trimestre"
                    class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none"
                    data-hr-query-target="textarea"
          ><%= @query %></textarea>

          <div class="mt-4 flex items-center gap-4">
            <button type="submit"
                    data-hr-query-target="submitBtn"
                    class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
              <svg data-hr-query-target="spinner"
                   class="hidden animate-spin h-4 w-4 text-white"
                   xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor"
                      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z">
                </path>
              </svg>
              <span data-hr-query-target="btnText">Rechercher</span>
            </button>

            <p data-hr-query-target="loadingMsg"
               class="hidden text-sm text-gray-500 dark:text-gray-400 italic">
              Analyse en cours (~2–4 s)…
            </p>
          </div>
        <% end %>

        <% if @search_error.present? %>
          <div class="mt-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4">
            <div class="flex items-start gap-2">
              <svg class="h-5 w-5 text-red-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
              <p class="text-sm text-red-700 dark:text-red-300"><%= @search_error %></p>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Results -->
      <% if @rows %>
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
          <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between flex-wrap gap-3">
            <div>
              <h2 class="text-sm font-semibold text-gray-900 dark:text-white">
                Résultats
                <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300">
                  <%= @rows.size %> employé<%= @rows.size > 1 ? 's' : '' %>
                </span>
              </h2>
              <% if @query.present? %>
                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 italic">"<%= @query %>"</p>
              <% end %>
            </div>

            <% if @rows.any? %>
              <%= link_to search_export_manager_exports_path(filters: @filters_param),
                          class: "inline-flex items-center gap-1.5 px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded-lg transition-colors" do %>
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Exporter CSV
              <% end %>
            <% end %>
          </div>

          <% if @rows.empty? %>
            <div class="px-6 py-12 text-center">
              <svg class="mx-auto h-10 w-10 text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <p class="text-sm text-gray-500 dark:text-gray-400">Aucun employé ne correspond à ces critères.</p>
            </div>
          <% else %>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700/50">
                  <tr>
                    <% @columns.each do |_key, label| %>
                      <th scope="col"
                          class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">
                        <%= label %>
                      </th>
                    <% end %>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-100 dark:divide-gray-700">
                  <% @rows.each do |row| %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/40 transition-colors">
                      <% @columns.each_key do |key| %>
                        <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                          <%= row[key].presence || "—" %>
                        </td>
                      <% end %>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Custom dates toggle for CSV export forms
    const mappings = [
      { panelId: 'custom-dates-time-entries' },
      { panelId: 'custom-dates-absences' }
    ];

    mappings.forEach(function(m) {
      const panel = document.getElementById(m.panelId);
      if (!panel) return;
      const form = panel.closest('form') || panel.parentElement.closest('form');
      if (!form) return;
      const select = form.querySelector('select[name="period"]');
      if (!select) return;
      select.addEventListener('change', function() {
        panel.classList.toggle('hidden', this.value !== 'custom');
      });
    });

    // Simple tabs controller (fallback if Stimulus tabs isn't registered)
    if (!window._tabsRegistered) {
      const tabs = document.querySelectorAll('[data-tabs-target="tab"]');
      const panels = document.querySelectorAll('[data-tabs-target="panel"]');

      function activateTab(idx) {
        tabs.forEach(function(t, i) {
          const active = i === idx;
          t.classList.toggle('border-indigo-500', active);
          t.classList.toggle('text-indigo-600', active);
          t.classList.toggle('dark:text-indigo-400', active);
          t.classList.toggle('border-transparent', !active);
          t.classList.toggle('text-gray-500', !active);
        });
        panels.forEach(function(p, i) {
          p.classList.toggle('hidden', i !== idx);
        });
      }

      tabs.forEach(function(tab, i) {
        tab.addEventListener('click', function() { activateTab(i); });
      });

      // Auto-open AI tab if results or error are present
      <% if @rows || @search_error.present? %>
        activateTab(1);
      <% end %>
    }
  });
</script>
