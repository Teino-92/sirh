<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Exports CSV</h1>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
      Exportez les données de votre équipe au format CSV compatible Excel
    </p>
  </div>

  <!-- Export Cards Grid -->
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 pb-8">

    <!-- Export Pointages -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <!-- Card Header with Gradient -->
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900 dark:to-blue-700 border-b-2 border-blue-300 dark:border-blue-500 px-6 py-4">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-blue-100 dark:bg-blue-800 rounded-lg p-2.5">
            <svg class="h-5 w-5 text-blue-700 dark:text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h2 class="text-lg font-semibold text-blue-900 dark:text-white">Pointages & Temps de travail</h2>
            <p class="text-xs text-blue-800 dark:text-white opacity-90 mt-0.5">Export des horaires et retards</p>
          </div>
        </div>
      </div>

      <!-- Form Content -->
      <div class="p-5">
        <%= form_with url: time_entries_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
          <!-- Period Selection -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période</label>
            <%= f.select :period,
                options_for_select([
                  ['Cette semaine', 'this_week'],
                  ['Ce mois', 'this_month'],
                  ['Mois dernier', 'last_month'],
                  ['Ce trimestre', 'this_quarter'],
                  ['Cette année', 'this_year'],
                  ['Personnalisée', 'custom']
                ], 'this_month'),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm"
            %>
          </div>

          <!-- Custom Date Range (hidden by default) -->
          <div id="custom-dates-time-entries" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
              <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
              <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm" %>
            </div>
          </div>

          <!-- Filters -->
          <div>
            <p class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Filtres</p>
            <div class="space-y-2.5 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
              <label class="flex items-center group cursor-pointer">
                <%= f.check_box :only_late, class: "rounded border-gray-300 dark:border-gray-600 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50" %>
                <span class="ml-2.5 text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100">Retards uniquement</span>
              </label>

              <label class="flex items-center group cursor-pointer">
                <%= f.check_box :only_unvalidated, class: "rounded border-gray-300 dark:border-gray-600 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50" %>
                <span class="ml-2.5 text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100">Non validés uniquement</span>
              </label>
            </div>
          </div>

          <!-- Submit Button -->
          <div style="padding-top: 166px;">
            <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Export Absences -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <!-- Card Header with Gradient -->
      <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900 dark:to-green-700 border-b-2 border-green-300 dark:border-green-500 px-6 py-4">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-green-100 dark:bg-green-800 rounded-lg p-2.5">
            <svg class="h-5 w-5 text-green-700 dark:text-green-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h2 class="text-lg font-semibold text-green-900 dark:text-white">Absences & Congés</h2>
            <p class="text-xs text-green-800 dark:text-white opacity-90 mt-0.5">CP, RTT, Maladie...</p>
          </div>
        </div>
      </div>

      <!-- Form Content -->
      <div class="p-5">
        <%= form_with url: absences_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
          <!-- Period Selection -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période</label>
            <%= f.select :period,
                options_for_select([
                  ['Ce mois', 'this_month'],
                  ['Mois dernier', 'last_month'],
                  ['Ce trimestre', 'this_quarter'],
                  ['Cette année', 'this_year'],
                  ['Personnalisée', 'custom']
                ], 'this_month'),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-green-500 focus:ring-green-500 text-sm"
            %>
          </div>

          <!-- Custom Date Range -->
          <div id="custom-dates-absences" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
              <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-green-500 focus:border-green-500 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
              <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-green-500 focus:border-green-500 text-sm" %>
            </div>
          </div>

          <!-- Status Filter -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Statut</label>
            <%= f.select :status,
                options_for_select([
                  ['Tous', ''],
                  ['En attente', 'pending'],
                  ['Approuvé', 'approved'],
                  ['Refusé', 'rejected']
                ]),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-green-500 focus:ring-green-500 text-sm"
            %>
          </div>

          <!-- Leave Type Filter -->
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Types d'absence</label>
            <div class="p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700 space-y-2.5 max-h-44 overflow-y-auto">
              <% ['CP', 'RTT', 'Maladie', 'Maternite', 'Paternite', 'Sans_Solde'].each do |leave_type| %>
                <label class="flex items-center group cursor-pointer">
                  <%= check_box_tag 'leave_types[]', leave_type, false, class: "rounded border-gray-300 dark:border-gray-600 text-green-600 shadow-sm focus:border-green-300 focus:ring focus:ring-green-200 focus:ring-opacity-50" %>
                  <span class="ml-2.5 text-sm text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-gray-100">
                    <%= leave_type == 'CP' ? 'Congés Payés' : leave_type.gsub('_', ' ') %>
                  </span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="pt-2">
            <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Export 1:1 -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900 dark:to-purple-700 border-b-2 border-purple-300 dark:border-purple-500 px-6 py-4">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-purple-100 dark:bg-purple-800 rounded-lg p-2.5">
            <svg class="h-5 w-5 text-purple-700 dark:text-purple-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h2 class="text-lg font-semibold text-purple-900 dark:text-white">Entretiens 1:1</h2>
            <p class="text-xs text-purple-800 dark:text-white opacity-90 mt-0.5">Historique des échanges manager/collaborateur</p>
          </div>
        </div>
      </div>

      <div class="p-5">
        <%= form_with url: one_on_ones_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période</label>
            <%= f.select :period,
                options_for_select([
                  ['Ce mois', 'this_month'],
                  ['Mois dernier', 'last_month'],
                  ['Ce trimestre', 'this_quarter'],
                  ['Cette année', 'this_year'],
                  ['Personnalisée', 'custom']
                ], 'this_quarter'),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm"
            %>
          </div>

          <div id="custom-dates-one-on-ones" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
              <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-purple-500 focus:border-purple-500 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
              <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-purple-500 focus:border-purple-500 text-sm" %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Statut</label>
            <%= f.select :status,
                options_for_select([
                  ['Tous', ''],
                  ['Planifié', 'scheduled'],
                  ['Complété', 'completed'],
                  ['Annulé', 'cancelled']
                ]),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm"
            %>
          </div>

          <div class="pt-2">
            <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-purple-600 hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500 transition-all" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Export Évaluations -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-br from-orange-50 to-orange-100 dark:from-orange-900 dark:to-orange-700 border-b-2 border-orange-300 dark:border-orange-500 px-6 py-4">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-orange-100 dark:bg-orange-800 rounded-lg p-2.5">
            <svg class="h-5 w-5 text-orange-700 dark:text-orange-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h2 class="text-lg font-semibold text-orange-900 dark:text-white">Évaluations de performance</h2>
            <p class="text-xs text-orange-800 dark:text-white opacity-90 mt-0.5">Scores, auto-évaluations, avis manager</p>
          </div>
        </div>
      </div>

      <div class="p-5">
        <%= form_with url: evaluations_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période (fin de période)</label>
            <%= f.select :period,
                options_for_select([
                  ['Ce trimestre', 'this_quarter'],
                  ['Cette année', 'this_year'],
                  ['Personnalisée', 'custom']
                ], 'this_year'),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-orange-500 focus:ring-orange-500 text-sm"
            %>
          </div>

          <div id="custom-dates-evaluations" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
              <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
              <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-orange-500 focus:border-orange-500 text-sm" %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Statut</label>
            <%= f.select :status,
                options_for_select([
                  ['Tous', ''],
                  ['Complétée', 'completed'],
                  ['En cours', 'manager_review_pending'],
                  ['Auto-éval. attendue', 'employee_review_pending']
                ]),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-orange-500 focus:ring-orange-500 text-sm"
            %>
          </div>

          <div class="pt-2">
            <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition-all" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Export Formations -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden border border-gray-200 dark:border-gray-700">
      <div class="bg-gradient-to-br from-teal-50 to-teal-100 dark:from-teal-900 dark:to-teal-700 border-b-2 border-teal-300 dark:border-teal-500 px-6 py-4">
        <div class="flex items-center">
          <div class="flex-shrink-0 bg-teal-100 dark:bg-teal-800 rounded-lg p-2.5">
            <svg class="h-5 w-5 text-teal-700 dark:text-teal-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h2 class="text-lg font-semibold text-teal-900 dark:text-white">Formations</h2>
            <p class="text-xs text-teal-800 dark:text-white opacity-90 mt-0.5">Suivi des formations assignées et complétées</p>
          </div>
        </div>
      </div>

      <div class="p-5">
        <%= form_with url: trainings_manager_exports_path, method: :get, local: true, class: "space-y-5" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Période (date d'assignation)</label>
            <%= f.select :period,
                options_for_select([
                  ['Ce mois', 'this_month'],
                  ['Mois dernier', 'last_month'],
                  ['Ce trimestre', 'this_quarter'],
                  ['Cette année', 'this_year'],
                  ['Personnalisée', 'custom']
                ], 'this_year'),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm"
            %>
          </div>

          <div id="custom-dates-trainings" class="hidden space-y-3 p-4 bg-gray-50 dark:bg-gray-900 rounded-lg border border-gray-200 dark:border-gray-700">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date début</label>
              <%= f.date_field :start_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-teal-500 focus:border-teal-500 text-sm" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
              <%= f.date_field :end_date, class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:ring-teal-500 focus:border-teal-500 text-sm" %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Statut</label>
            <%= f.select :status,
                options_for_select([
                  ['Tous', ''],
                  ['Assignée', 'assigned'],
                  ['En cours', 'in_progress'],
                  ['Terminée', 'completed'],
                  ['Annulée', 'cancelled']
                ]),
                {},
                class: "block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-teal-500 focus:ring-teal-500 text-sm"
            %>
          </div>

          <div class="pt-2">
            <%= f.submit "Télécharger CSV", class: "w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-teal-600 hover:bg-teal-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 transition-all" %>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <!-- Info Notice -->
  <div class="mt-2 bg-gradient-to-br from-indigo-50 to-indigo-100 dark:from-indigo-900 dark:to-indigo-700 border-2 border-indigo-300 dark:border-indigo-500 rounded-lg p-5 shadow-md">
    <div class="flex items-start">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-indigo-800 dark:text-white" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3 flex-1">
        <h3 class="text-sm font-semibold text-indigo-900 dark:text-white mb-1">Format des fichiers CSV</h3>
        <p class="text-sm text-indigo-800 dark:text-white opacity-90 leading-relaxed">
          Les exports sont optimisés pour Excel (séparateur point-virgule, encodage UTF-8 avec BOM).
          Les virgules sont utilisées comme séparateur décimal pour respecter les standards français.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Map each form's period select to its custom-dates panel via data attributes
    const mappings = [
      { formAction: 'time_entries', panelId: 'custom-dates-time-entries' },
      { formAction: 'absences',     panelId: 'custom-dates-absences' },
      { formAction: 'one_on_ones',  panelId: 'custom-dates-one-on-ones' },
      { formAction: 'evaluations',  panelId: 'custom-dates-evaluations' },
      { formAction: 'trainings',    panelId: 'custom-dates-trainings' }
    ];

    mappings.forEach(function(m) {
      const panel = document.getElementById(m.panelId);
      if (!panel) return;

      // Find the form that submits to this action
      const form = panel.closest('form') || panel.parentElement.closest('form');
      if (!form) return;

      const select = form.querySelector('select[name="period"]');
      if (!select) return;

      select.addEventListener('change', function() {
        panel.classList.toggle('hidden', this.value !== 'custom');
      });
    });
  });
</script>
