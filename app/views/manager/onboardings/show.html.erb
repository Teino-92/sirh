<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Back link -->
  <div class="mb-4">
    <%= link_to '← Onboarding équipe', manager_onboardings_path,
          class: 'text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200' %>
  </div>

  <!-- Header card -->
  <%
    score    = @onboarding.integration_score
    progress = @onboarding.progress_percentage
    overdue  = @onboarding.overdue_tasks.count
    risk     = score < 40
    status_classes = case @onboarding.status
    when 'active'    then 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
    when 'completed' then 'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300'
    when 'cancelled' then 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
    end
    status_labels = { 'active' => 'Actif', 'completed' => 'Terminé', 'cancelled' => 'Annulé' }
  %>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-3 flex-wrap">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
            Onboarding — <%= @onboarding.employee.full_name %>
          </h1>
          <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= status_classes %>">
            <%= status_labels[@onboarding.status] %>
          </span>
          <% if risk %>
            <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400">
              ⚠ Risque d'intégration
            </span>
          <% end %>
        </div>

        <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-4 text-sm">
          <div>
            <dt class="font-medium text-gray-600 dark:text-gray-400">Modèle</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100"><%= @onboarding.onboarding_template.name %></dd>
          </div>
          <div>
            <dt class="font-medium text-gray-600 dark:text-gray-400">Début</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100"><%= l(@onboarding.start_date, format: :long) %></dd>
          </div>
          <div>
            <dt class="font-medium text-gray-600 dark:text-gray-400">Fin prévue</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100"><%= l(@onboarding.end_date, format: :long) %></dd>
          </div>
          <% if @onboarding.active? %>
            <div>
              <dt class="font-medium text-gray-600 dark:text-gray-400">Jour</dt>
              <dd class="mt-1 text-gray-900 dark:text-gray-100">J+<%= @onboarding.day_number %></dd>
            </div>
          <% end %>
        </dl>

        <% if @onboarding.notes.present? %>
          <p class="mt-4 text-sm text-gray-700 dark:text-gray-300"><%= @onboarding.notes %></p>
        <% end %>
      </div>

      <!-- Score + actions -->
      <div class="flex flex-row sm:flex-col items-center sm:items-end gap-4">
        <div class="text-center">
          <div class="text-4xl font-bold <%= score >= 70 ? 'text-green-600 dark:text-green-400' : score >= 40 ? 'text-yellow-600 dark:text-yellow-400' : 'text-red-600 dark:text-red-400' %>">
            <%= score %>
          </div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Score d'intégration</div>
        </div>

        <div class="flex gap-2 flex-wrap">
          <% if @onboarding.active? %>
            <%= link_to 'Modifier', edit_manager_onboarding_path(@onboarding),
                  class: 'inline-flex items-center py-1.5 px-3 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all' %>
            <%= link_to 'Feedback manager', new_manager_onboarding_onboarding_review_path(@onboarding),
                  class: 'inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 transition-all' %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="mt-6">
      <div class="flex justify-between text-sm text-gray-600 dark:text-gray-400 mb-1">
        <span>Progression globale</span>
        <span class="font-medium"><%= progress %>%</span>
      </div>
      <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
        <div class="<%= risk ? 'bg-red-500' : 'bg-indigo-600' %> h-3 rounded-full transition-all duration-300"
             style="width: <%= progress %>%"></div>
      </div>
      <% if overdue > 0 %>
        <p class="mt-2 text-sm text-orange-600 dark:text-orange-400 font-medium">
          <%= overdue %> tâche<%= 's' if overdue > 1 %> en retard
        </p>
      <% end %>
    </div>
  </div>

  <!-- Tasks by role -->
  <%
    role_labels = { 'hr' => 'RH', 'manager' => 'Manager', 'employee' => 'Collaborateur' }
    role_colors = {
      'hr'       => 'bg-purple-100 dark:bg-purple-900/40 text-purple-800 dark:text-purple-300',
      'manager'  => 'bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300',
      'employee' => 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300'
    }
    type_icons = {
      'manual'        => '✓',
      'objective_30'  => '🎯',
      'objective_60'  => '🎯',
      'objective_90'  => '🎯',
      'training'      => '📚',
      'one_on_one'    => '💬'
    }
  %>

  <% %w[hr manager employee].each do |role| %>
    <% tasks = @tasks_by_role[role] %>
    <% next if tasks.blank? %>

    <div class="mb-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-3 flex items-center gap-2">
        <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= role_colors[role] %>">
          <%= role_labels[role] %>
        </span>
        <span>Tâches <%= role_labels[role] %></span>
      </h2>

      <div class="space-y-2">
        <% tasks.each do |task| %>
          <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 flex items-start gap-4">
            <!-- Complete button (Turbo Stream) -->
            <div class="flex-shrink-0 mt-0.5">
              <% if task.completed? %>
                <span class="w-6 h-6 flex items-center justify-center rounded-full bg-green-100 dark:bg-green-900/40">
                  <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </span>
              <% elsif task.overdue? %>
                <span class="w-6 h-6 flex items-center justify-center rounded-full bg-red-100 dark:bg-red-900/40">
                  <svg class="w-4 h-4 text-red-500 dark:text-red-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                  </svg>
                </span>
              <% else %>
                <%= button_to manager_onboarding_task_path(task), method: :patch, class: "cursor-pointer" do %>
                  <span class="w-6 h-6 flex items-center justify-center rounded-full border-2 border-gray-300 dark:border-gray-600 hover:border-indigo-500 dark:hover:border-indigo-400 transition-colors">
                    <svg class="w-3 h-3 text-transparent hover:text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </span>
                <% end %>
              <% end %>
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class="text-sm font-medium <%= task.completed? ? 'line-through text-gray-400 dark:text-gray-500' : 'text-gray-900 dark:text-gray-100' %>">
                    <%= type_icons[task.task_type] %> <%= task.title %>
                  </p>
                  <% if task.description.present? %>
                    <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= task.description %></p>
                  <% end %>

                  <% linked = task.linked_record rescue nil %>
                  <% if linked %>
                    <p class="text-xs text-indigo-600 dark:text-indigo-400 mt-1">
                      Lié à : <%= linked.try(:title) || linked.try(:name) || "Enregistrement ##{linked.id}" %>
                    </p>
                  <% end %>
                </div>

                <div class="flex-shrink-0 text-right">
                  <p class="text-xs <%= task.overdue? && task.pending? ? 'text-red-600 dark:text-red-400 font-medium' : 'text-gray-500 dark:text-gray-400' %>">
                    <%= l(task.due_date, format: :short) %>
                  </p>
                  <% if task.completed_at.present? %>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">
                      Fait le <%= l(task.completed_at.to_date, format: :short) %>
                    </p>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Reviews -->
  <% if @onboarding.onboarding_reviews.any? %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Bilans d'intégration</h2>
      <div class="space-y-4">
        <% @onboarding.onboarding_reviews.order(:review_day).each do |review| %>
          <div class="border-l-4 border-indigo-400 pl-4">
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100">
              Bilan J+<%= review.review_day %>
              <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">(<%= review.reviewer_type == 'manager' ? 'Manager' : 'Collaborateur' %>)</span>
            </p>
            <% if review.manager_integration_level %>
              <p class="text-sm text-gray-700 dark:text-gray-300 mt-1">
                Niveau d'intégration : <strong><%= review.manager_integration_level %>/5</strong>
              </p>
            <% end %>
            <% fb = review.manager_feedback_json %>
            <% if fb['strengths'].present? %>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Points forts : <%= fb['strengths'] %></p>
            <% end %>
            <% if fb['risk_signals'].present? %>
              <p class="text-sm text-orange-600 dark:text-orange-400 mt-1">Signaux de risque : <%= fb['risk_signals'] %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
