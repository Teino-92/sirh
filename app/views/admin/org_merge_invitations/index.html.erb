<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <%# En-tête %>
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Fusion d'organisations</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        Invitez une organisation Manager OS à rejoindre votre espace SIRH
      </p>
    </div>
    <div class="mt-4 sm:mt-0">
      <%= link_to new_admin_org_merge_invitation_path,
          class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Inviter une organisation
      <% end %>
    </div>
  </div>

  <%# Avertissement fusion irréversible %>
  <div class="mb-6 rounded-md bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 p-4">
    <div class="flex">
      <svg class="h-5 w-5 text-amber-400 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
      </svg>
      <p class="text-sm text-amber-800 dark:text-amber-200">
        La fusion est <strong>irréversible</strong>. L'organisation source sera dissoute et toutes ses données migrées ici.
      </p>
    </div>
  </div>

  <%# Liste des invitations %>
  <% if @invitations.empty? %>
    <div class="text-center py-16 bg-white dark:bg-gray-800 rounded-lg shadow border border-dashed border-gray-300 dark:border-gray-600">
      <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">Aucune invitation envoyée</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Invitez une organisation Manager OS à rejoindre votre espace.</p>
      <%= link_to "Envoyer une invitation", new_admin_org_merge_invitation_path,
          class: "mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
    </div>
  <% else %>
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Organisation source</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email invité</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Statut</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Envoyée le</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Expire le</th>
            <th class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
          <% @invitations.each do |invitation| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                  <%= invitation.source_organization.name %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400">plan <%= invitation.source_organization.plan %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-700 dark:text-gray-300">
                <%= invitation.invited_email %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <% badge_class = case invitation.status
                   when 'pending'   then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300'
                   when 'accepted'  then 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300'
                   when 'merging'   then 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300'
                   when 'completed' then 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300'
                   when 'failed'    then 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300'
                   when 'declined', 'expired' then 'bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400'
                   else 'bg-gray-100 text-gray-500'
                   end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= badge_class %>">
                  <%= invitation.status.humanize %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                <%= invitation.created_at.strftime('%d/%m/%Y') %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                <%= invitation.expires_at.strftime('%d/%m/%Y') %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <% if invitation.status == 'pending' %>
                  <%= button_to admin_org_merge_invitation_path(invitation),
                      method: :delete,
                      class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 text-sm font-medium",
                      data: { turbo_confirm: "Annuler cette invitation ? L'organisation source ne pourra plus l'accepter." } do %>
                    Annuler
                  <% end %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

</div>
