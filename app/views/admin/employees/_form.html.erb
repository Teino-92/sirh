<%= form_with(model: [:admin, employee], class: "space-y-6") do |form| %>
  <% if employee.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900 border-l-4 border-red-400 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
            <%= pluralize(employee.errors.count, "erreur") %> :
          </h3>
          <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
            <% employee.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <!-- Informations personnelles -->
    <div>
      <%= form.label :first_name, "Prénom", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :first_name,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          required: true %>
    </div>

    <div>
      <%= form.label :last_name, "Nom", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :last_name,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          required: true %>
    </div>

    <div class="sm:col-span-2">
      <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.email_field :email,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          required: true %>
    </div>

    <!-- Mot de passe (seulement pour nouvel employé) -->
    <% if employee.new_record? %>
      <div>
        <%= form.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.password_field :password,
            class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
            required: true %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmation", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <%= form.password_field :password_confirmation,
            class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
            required: true %>
      </div>
    <% end %>

    <!-- Informations professionnelles -->
    <div>
      <%= form.label :role, "Rôle", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.select :role,
          [['Employé', 'employee'], ['Manager', 'manager'], ['RH', 'hr'], ['Admin', 'admin']],
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :contract_type, "Type de contrat", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.select :contract_type,
          [['CDI', 'CDI'], ['CDD', 'CDD'], ['Stage', 'Stage'], ['Alternance', 'Alternance'], ['Intérim', 'Interim']],
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :start_date, "Date d'entrée", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.date_field :start_date,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
          required: true %>
    </div>

    <div>
      <%= form.label :end_date, "Date de sortie (optionnel)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.date_field :end_date,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :department, "Département", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :department,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <% if employee.hr? %>
    <div class="sm:col-span-2">
      <%= form.label :hr_perimeter_list, "Périmètre RH", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :hr_perimeter_list,
          placeholder: "ex: Sales, Engineering, Marketing",
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Départements couverts par cet HR officer, séparés par des virgules.</p>
    </div>
    <% end %>

    <div>
      <%= form.label :job_title, "Poste", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.text_field :job_title,
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :manager_id, "Manager", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.collection_select :manager_id,
          Employee.where.not(id: employee.id).managers.order(:first_name),
          :id,
          :full_name,
          { include_blank: "Aucun manager" },
          class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= form.label :avatar, "Photo de profil", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= form.file_field :avatar,
          accept: "image/*",
          class: "mt-1 block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 dark:file:bg-indigo-900 file:text-indigo-700 dark:file:text-indigo-300 hover:file:bg-indigo-100 dark:hover:file:bg-indigo-800" %>
    </div>

    <!-- Rémunération (HR/admin only — droit du travail français) -->
    <% if policy(employee).see_salary? %>
    <div class="sm:col-span-2">
      <fieldset class="border border-gray-200 dark:border-gray-600 rounded-md p-4">
        <legend class="text-sm font-medium text-gray-700 dark:text-gray-300 px-1">Rémunération</legend>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <%= form.label :gross_salary_eur, "Salaire brut mensuel (€)", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.number_field :gross_salary_eur,
                step: 0.01, min: 0,
                placeholder: "ex: 3500",
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Saisir en euros (ex : 3500)</p>
          </div>
          <div>
            <%= form.label :variable_pay_eur, "Part variable mensuelle (€)", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.number_field :variable_pay_eur,
                step: 0.01, min: 0,
                placeholder: "ex: 500",
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Primes, commissions...</p>
          </div>
          <div>
            <%= form.label :employer_charges_rate, "Taux de charges employeur", class: "block text-xs font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.number_field :employer_charges_rate,
                step: 0.01, min: 1.0, max: 2.0,
                placeholder: "ex: 1.45",
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">1.45 = +45% de charges</p>
          </div>
        </div>
      </fieldset>
    </div>
    <% end %>

    <div class="sm:col-span-2">
      <fieldset class="border border-gray-200 dark:border-gray-600 rounded-md p-4">
        <legend class="text-sm font-medium text-gray-700 dark:text-gray-300 px-1">Statut contractuel</legend>
        <label class="flex items-start gap-3 cursor-pointer">
          <%= form.fields_for :settings do |sf| %>
            <%= sf.check_box :cadre,
                { checked: employee.cadre?, class: "mt-0.5 h-4 w-4 text-indigo-600 border-gray-300 dark:border-gray-600 rounded focus:ring-indigo-500" },
                true, false %>
          <% end %>
          <div>
            <span class="text-sm font-medium text-gray-900 dark:text-gray-100">Cadre (forfait jours)</span>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
              Les cadres au forfait n'ont pas de planning ni de pointage. Les onglets Horaire et Pointage sont masqués sur leur interface.
            </p>
          </div>
        </label>
      </fieldset>
    </div>
  </div>

  <% if policy(employee).see_salary? %>
  <!-- Section Informations paie (DSN) -->
  <div class="sm:col-span-2 pt-2">
    <details class="group">
      <summary class="flex items-center gap-2 cursor-pointer list-none">
        <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Informations paie (DSN)</span>
        <svg class="h-4 w-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
        <span class="ml-auto text-xs text-amber-600 dark:text-amber-400 font-medium">Données sensibles — accès tracé</span>
      </summary>

      <div class="mt-4 space-y-6 border border-gray-200 dark:border-gray-600 rounded-lg p-5">

        <!-- Identité légale -->
        <fieldset>
          <legend class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Identité légale</legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= form.label :birth_date, "Date de naissance", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.date_field :birth_date, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :birth_city, "Ville de naissance", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :birth_city, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :birth_department, "Département de naissance", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :birth_department, placeholder: "ex: 75, 2A", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :birth_country, "Pays de naissance", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :birth_country, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :nationality, "Nationalité", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :nationality, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :nir, "N° Sécurité Sociale (NIR)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :nir,
                  placeholder: "13 chiffres",
                  autocomplete: "off",
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Chiffré en base · 13 chiffres, commence par 1 (homme) ou 2 (femme)</p>
            </div>
            <div>
              <%= form.label :nir_key, "Clé NIR", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :nir_key,
                  placeholder: "2 chiffres",
                  maxlength: 2,
                  autocomplete: "off",
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
            </div>
          </div>
        </fieldset>

        <!-- Coordonnées bancaires -->
        <fieldset>
          <legend class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Coordonnées bancaires</legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <%= form.label :iban, "IBAN", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :iban,
                  placeholder: "FR76...",
                  autocomplete: "off",
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Chiffré en base</p>
            </div>
            <div>
              <%= form.label :bic, "BIC / SWIFT", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :bic, placeholder: "ex: BNPAFRPP", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
            </div>
          </div>
        </fieldset>

        <!-- Contrat -->
        <fieldset>
          <legend class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Détails du contrat</legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <%= form.label :convention_collective, "Convention collective (IDCC)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :convention_collective,
                  placeholder: "ex: 1486 — Bureaux d'études",
                  list: "idcc_list",
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              <datalist id="idcc_list">
                <option value="1486 — Bureaux d'études techniques (Syntec)">
                <option value="3218 — Métallurgie">
                <option value="1090 — Commerces de détail alimentaires">
                <option value="1979 — Hôtels, cafés, restaurants">
                <option value="2264 — Banque">
                <option value="0573 — Manutention ferroviaire">
                <option value="1596 — Coiffure">
                <option value="2120 — Immobilier">
                <option value="1527 — Bâtiment (ETAM)">
                <option value="0016 — Transports routiers">
              </datalist>
            </div>
            <div>
              <%= form.label :qualification, "Qualification", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :qualification, placeholder: "ex: Cadre niveau 2", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :coefficient, "Coefficient", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :coefficient, placeholder: "ex: 360", class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :part_time_rate, "Taux temps partiel", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.number_field :part_time_rate,
                  step: 0.05, min: 0.1, max: 1.0,
                  placeholder: "1.0 = temps plein",
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">1.0 = temps plein · 0.8 = 80%</p>
            </div>
            <div>
              <%= form.label :trial_period_end, "Fin de période d'essai", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.date_field :trial_period_end, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>
        </fieldset>

        <!-- Fin de contrat -->
        <fieldset>
          <legend class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Fin de contrat</legend>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= form.label :termination_date, "Date de résiliation", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.date_field :termination_date, class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <div>
              <%= form.label :termination_reason, "Motif", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.select :termination_reason,
                  options_for_select([
                    ['', ''],
                    ['Démission', 'resignation'],
                    ['Licenciement économique', 'layoff_economic'],
                    ['Licenciement personnel', 'layoff_personal'],
                    ['Rupture conventionnelle', 'mutual_agreement'],
                    ['Fin de CDD', 'cdd_end'],
                    ['Fin de période d\'essai', 'trial_period_end'],
                    ['Retraite', 'retirement'],
                    ['Décès', 'death']
                  ], employee.termination_reason),
                  {},
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
          </div>
        </fieldset>

      </div>
    </details>
  </div>
  <% end %>

  <div class="flex justify-end gap-3 pt-4">
    <%= link_to "Annuler", admin_employees_path,
        class: "px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    <%= form.submit employee.new_record? ? "Créer l'employé" : "Mettre à jour",
        class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  </div>
<% end %>
