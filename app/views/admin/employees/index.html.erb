<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Gestion des Employés</h1>
      <p class="mt-1 text-sm text-gray-600"><%= @employees.total_count %> employé(s) au total</p>
    </div>
    <div class="mt-4 sm:mt-0 flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full sm:w-auto">
      <!-- Search Bar -->
      <div class="relative flex-1 sm:flex-initial" data-controller="search">
        <%= form_with url: admin_employees_path, method: :get,
                      data: { search_target: "form", turbo_frame: "employees_list" },
                      class: "relative w-full sm:w-80" do |f| %>
          <input type="text"
                 name="q"
                 value="<%= params[:q] %>"
                 placeholder="Rechercher par nom, email..."
                 data-search-target="input"
                 data-action="input->search#perform"
                 data-turbo-permanent
                 id="employee_search_input"
                 autocomplete="off"
                 class="w-full pl-10 pr-10 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">

          <svg data-search-target="searchIcon" class="<%= params[:q].present? ? 'hidden' : '' %> absolute left-3 top-2.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>

          <button type="button"
                  data-search-target="clearBtn"
                  data-action="click->search#clear"
                  class="<%= params[:q].present? ? '' : 'hidden' %> absolute left-3 top-2.5 text-gray-500 hover:text-gray-700 bg-transparent border-0 p-0 cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        <% end %>
      </div>

      <%= link_to new_admin_employee_path,
          class: "inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
          data: { turbo_frame: "employee_modal" } do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Nouvel Employé
      <% end %>
    </div>
  </div>

  <!-- Turbo Frame for modal forms -->
  <%= turbo_frame_tag "employee_modal" %>

  <%= turbo_frame_tag "employees_list" do %>
    <!-- Mobile Card View -->
    <div class="sm:hidden space-y-6">
    <% @employees.each do |employee| %>
        <div class="bg-white shadow-sm rounded-lg overflow-hidden" id="<%= dom_id(employee) %>">
          <div class="p-4">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center flex-1">
                <div class="flex-shrink-0">
                  <% if employee.avatar.attached? %>
                    <%= image_tag employee.avatar, class: "h-12 w-12 rounded-full object-cover" %>
                  <% else %>
                    <div class="h-12 w-12 rounded-full bg-indigo-100 flex items-center justify-center">
                      <span class="text-indigo-600 font-medium text-sm">
                        <%= employee.first_name[0] %><%= employee.last_name[0] %>
                      </span>
                    </div>
                  <% end %>
                </div>
                <div class="ml-3">
                  <div class="text-base font-semibold text-gray-900">
                    <%= employee.full_name %>
                  </div>
                  <div class="text-xs text-gray-600">
                    <%= employee.email %>
                  </div>
                </div>
              </div>
              <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full
                <%= case employee.role
                    when 'admin' then 'bg-purple-100 text-purple-800'
                    when 'hr' then 'bg-pink-100 text-pink-800'
                    when 'manager' then 'bg-blue-100 text-blue-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= employee.role.upcase %>
              </span>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-3 text-sm">
              <div>
                <dt class="text-xs font-medium text-gray-600">Contrat</dt>
                <dd class="text-gray-900"><%= employee.contract_type %></dd>
              </div>
              <div>
                <dt class="text-xs font-medium text-gray-600">Date d'entrée</dt>
                <dd class="text-gray-900"><%= l(employee.start_date, format: :short) %></dd>
              </div>
              <div class="col-span-2">
                <dt class="text-xs font-medium text-gray-600">Manager</dt>
                <dd class="text-gray-900"><%= employee.manager&.full_name || '-' %></dd>
              </div>
            </div>

            <div class="flex justify-end gap-3 pt-3 border-t border-gray-200">
              <%= link_to admin_employee_path(employee),
                  class: "p-2 text-gray-400 hover:text-indigo-600 transition-colors",
                  "aria-label": "Voir #{employee.full_name}",
                  title: "Voir" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
              <% end %>
              <%= link_to edit_admin_employee_path(employee),
                  class: "p-2 text-gray-400 hover:text-indigo-600 transition-colors",
                  data: { turbo_frame: "employee_modal" },
                  "aria-label": "Modifier #{employee.full_name}",
                  title: "Modifier" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
              <% end %>
              <%= button_to admin_employee_path(employee),
                  method: :delete,
                  form: { data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer #{employee.full_name} ?" }, "aria-label": "Supprimer #{employee.full_name}" },
                  class: "p-2 text-gray-400 hover:text-red-600 transition-colors border-0 bg-transparent cursor-pointer",
                  title: "Supprimer" do %>
                <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
              <% end %>
            </div>
          </div>
        </div>
    <% end %>
  </div>

  <!-- Desktop Table View -->
  <div class="hidden sm:block bg-white shadow-sm rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Employé
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Rôle
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Contrat
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Manager
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
              Date d'entrée
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200" id="employees">
          <%= render @employees %>
        </tbody>
      </table>
    </div>

  </div>

  <!-- Pagination (Mobile & Desktop) -->
  <% if @employees.total_pages > 1 %>
    <div class="mt-4 sm:mt-0">
      <div class="bg-white shadow-sm rounded-lg px-4 py-3 border-t border-gray-200 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="hidden sm:block text-sm text-gray-700">
            Affichage de <span class="font-medium"><%= ((@employees.current_page - 1) * 20) + 1 %></span> à <span class="font-medium"><%= [@employees.current_page * 20, @employees.total_count].min %></span> sur <span class="font-medium"><%= @employees.total_count %></span> employé(s)
          </div>
          <div class="flex-1 flex justify-center sm:justify-end">
            <nav class="inline-flex gap-1" aria-label="Pagination">
              <% if @employees.prev_page %>
                <%= link_to admin_employees_path(page: @employees.prev_page),
                    class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50",
                    "aria-label": "Page précédente" do %>
                  ← Préc.
                <% end %>
              <% end %>

              <% page_range = [] %>
              <% if @employees.total_pages <= 7 %>
                <% page_range = (1..@employees.total_pages).to_a %>
              <% else %>
                <% if @employees.current_page <= 4 %>
                  <% page_range = (1..5).to_a + ['...'] + [@employees.total_pages] %>
                <% elsif @employees.current_page >= @employees.total_pages - 3 %>
                  <% page_range = [1] + ['...'] + ((@employees.total_pages - 4)..@employees.total_pages).to_a %>
                <% else %>
                  <% page_range = [1] + ['...'] + ((@employees.current_page - 1)..(@employees.current_page + 1)).to_a + ['...'] + [@employees.total_pages] %>
                <% end %>
              <% end %>

              <% page_range.each do |page| %>
                <% if page == '...' %>
                  <span class="px-3 py-2 text-sm font-medium text-gray-700">...</span>
                <% elsif page == @employees.current_page %>
                  <span class="px-3 py-2 text-sm font-medium text-white bg-indigo-600 border border-indigo-600 rounded-md" aria-current="page"><%= page %></span>
                <% else %>
                  <%= link_to page, admin_employees_path(page: page),
                      class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50",
                      "aria-label": "Page #{page}" %>
                <% end %>
              <% end %>

              <% if @employees.next_page %>
                <%= link_to admin_employees_path(page: @employees.next_page),
                    class: "px-3 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50",
                    "aria-label": "Page suivante" do %>
                  Suiv. →
                <% end %>
              <% end %>
            </nav>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <% end %>
</div>
