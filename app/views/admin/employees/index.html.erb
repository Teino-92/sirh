<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="sm:flex sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Gestion des Employés</h1>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400 dark:text-gray-500"><%= @employees.total_count %> employé(s) au total</p>
    </div>
    <div class="mt-4 sm:mt-0 flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full sm:w-auto">
      <!-- Search Bar -->
      <div class="relative flex-1 sm:flex-initial" data-controller="search">
        <%= form_with url: admin_employees_path, method: :get,
                      data: { search_target: "form", turbo_frame: "employees_list" },
                      class: "relative w-full sm:w-80" do |f| %>
          <input type="text"
                 name="q"
                 value="<%= params[:q] %>"
                 placeholder="Rechercher par nom, email..."
                 data-search-target="input"
                 data-action="input->search#perform"
                 data-turbo-permanent
                 id="employee_search_input"
                 autocomplete="off"
                 class="w-full pl-10 pr-10 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">

          <svg data-search-target="searchIcon" class="<%= params[:q].present? ? 'hidden' : '' %> absolute left-3 top-2.5 w-5 h-5 text-gray-400 dark:text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>

          <button type="button"
                  data-search-target="clearBtn"
                  data-action="click->search#clear"
                  class="<%= params[:q].present? ? '' : 'hidden' %> absolute left-3 top-2.5 text-gray-500 dark:text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:text-gray-300 bg-transparent border-0 p-0 cursor-pointer">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        <% end %>
      </div>

      <%= link_to new_admin_employee_path,
          class: "inline-flex items-center justify-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500",
          data: { turbo_frame: "employee_modal" } do %>
        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Nouvel Employé
      <% end %>
    </div>
  </div>

  <!-- Turbo Frame for modal forms -->
  <%= turbo_frame_tag "employee_modal" %>

  <%= turbo_frame_tag "employees_list" do %>
    <!-- Employees Table -->
    <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-900">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              Employé
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              Rôle
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              Contrat
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              Manager
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              Date d'entrée
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 dark:text-gray-500 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700" id="employees">
          <%= render @employees %>
        </tbody>
      </table>
    </div>

  </div>

  <!-- Pagination (Mobile & Desktop) -->
  <% if @employees.total_pages > 1 %>
    <div class="mt-4 sm:mt-0">
      <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg px-4 py-3 border-t border-gray-200 dark:border-gray-700 sm:px-6">
        <div class="flex items-center justify-between">
          <div class="hidden sm:block text-sm text-gray-700 dark:text-gray-300">
            Affichage de <span class="font-medium"><%= ((@employees.current_page - 1) * 20) + 1 %></span> à <span class="font-medium"><%= [@employees.current_page * 20, @employees.total_count].min %></span> sur <span class="font-medium"><%= @employees.total_count %></span> employé(s)
          </div>
          <div class="flex-1 flex justify-center sm:justify-end">
            <nav class="inline-flex gap-1" aria-label="Pagination">
              <% if @employees.prev_page %>
                <%= link_to admin_employees_path(page: @employees.prev_page),
                    class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:bg-gray-900",
                    "aria-label": "Page précédente" do %>
                  ← Préc.
                <% end %>
              <% end %>

              <% page_range = [] %>
              <% if @employees.total_pages <= 7 %>
                <% page_range = (1..@employees.total_pages).to_a %>
              <% else %>
                <% if @employees.current_page <= 4 %>
                  <% page_range = (1..5).to_a + ['...'] + [@employees.total_pages] %>
                <% elsif @employees.current_page >= @employees.total_pages - 3 %>
                  <% page_range = [1] + ['...'] + ((@employees.total_pages - 4)..@employees.total_pages).to_a %>
                <% else %>
                  <% page_range = [1] + ['...'] + ((@employees.current_page - 1)..(@employees.current_page + 1)).to_a + ['...'] + [@employees.total_pages] %>
                <% end %>
              <% end %>

              <% page_range.each do |page| %>
                <% if page == '...' %>
                  <span class="px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300">...</span>
                <% elsif page == @employees.current_page %>
                  <span class="px-3 py-2 text-sm font-medium text-white bg-indigo-600 border border-indigo-600 rounded-md" aria-current="page"><%= page %></span>
                <% else %>
                  <%= link_to page, admin_employees_path(page: page),
                      class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:bg-gray-900",
                      "aria-label": "Page #{page}" %>
                <% end %>
              <% end %>

              <% if @employees.next_page %>
                <%= link_to admin_employees_path(page: @employees.next_page),
                    class: "px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:bg-gray-900",
                    "aria-label": "Page suivante" do %>
                  Suiv. →
                <% end %>
              <% end %>
            </nav>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <% end %>
</div>
