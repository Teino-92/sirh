  <tr class="hover:bg-gray-50 dark:hover:bg-gray-700" id="<%= dom_id(employee) %>">
    <td class="px-6 py-5 whitespace-nowrap">
      <div class="flex items-center">
        <div class="flex-shrink-0 h-10 w-10">
          <% if employee.avatar.attached? %>
            <%= image_tag employee.avatar, class: "h-10 w-10 rounded-full object-cover" %>
          <% else %>
            <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-800 flex items-center justify-center">
              <span class="text-indigo-600 dark:text-indigo-300 font-medium text-sm">
                <%= employee.first_name[0] %><%= employee.last_name[0] %>
              </span>
            </div>
          <% end %>
        </div>
        <div class="ml-4">
          <div class="text-base font-semibold text-gray-900 dark:text-gray-100">
            <%= employee.full_name %>
          </div>
          <div class="text-xs text-gray-600 dark:text-gray-400">
            <%= employee.email %>
          </div>
        </div>
      </div>
    </td>
    <td class="px-6 py-5 whitespace-nowrap">
      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full
        <%= case employee.role
            when 'admin' then 'bg-purple-100 dark:bg-purple-900 text-purple-800 dark:text-purple-200'
            when 'hr' then 'bg-pink-100 dark:bg-pink-900 text-pink-800 dark:text-pink-200'
            when 'manager' then 'bg-blue-100 dark:bg-blue-800 text-blue-800 dark:text-blue-200'
            else 'bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-200'
            end %>">
        <%= employee.role.upcase %>
      </span>
    </td>
    <td class="px-6 py-5 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
      <%= employee.contract_type %>
    </td>
    <td class="px-6 py-5 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
      <%= employee.manager&.full_name || '-' %>
    </td>
    <td class="px-6 py-5 whitespace-nowrap text-sm text-gray-600 dark:text-gray-400">
      <%= l(employee.start_date, format: :short) %>
    </td>
    <td class="px-6 py-5 whitespace-nowrap text-right text-sm font-medium">
      <div class="flex justify-end gap-3">
        <%= link_to admin_employee_path(employee),
            class: "p-2 text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors",
            "aria-label": "Voir #{employee.full_name}",
            title: "Voir" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
        <% end %>
        <%= link_to edit_admin_employee_path(employee),
            class: "p-2 text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors",
            data: { turbo_frame: "employee_modal" },
            "aria-label": "Modifier #{employee.full_name}",
            title: "Modifier" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        <% end %>
        <%= button_to admin_employee_path(employee),
            method: :delete,
            form: { data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer #{employee.full_name} ?" }, "aria-label": "Supprimer #{employee.full_name}" },
            class: "p-2 text-gray-400 hover:text-red-600 dark:hover:text-red-500 transition-colors border-0 bg-transparent cursor-pointer",
            title: "Supprimer" do %>
          <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        <% end %>
      </div>
    </td>
  </tr>
