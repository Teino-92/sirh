<%= turbo_frame_tag "employee_modal" do %>
  <div class="fixed inset-0 bg-gray-50 dark:bg-gray-900 bg-opacity-75 overflow-y-auto z-50" data-controller="modal" data-action="click->modal#closeBackground">
    <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
      <div class="relative transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-2xl" data-modal-target="container">
        <div class="bg-white dark:bg-gray-800 px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
          <div class="sm:flex sm:items-start">
            <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
              <h3 class="text-lg font-semibold leading-6 text-gray-900 dark:text-gray-100 mb-4">
                Nouvel Employé
              </h3>

              <% if @seat_warning %>
                <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 p-4">
                  <div class="flex items-start gap-3">
                    <svg class="h-5 w-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                    </svg>
                    <div class="flex-1">
                      <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
                        Vous avez atteint votre quota de 6 membres inclus.
                      </p>
                      <p class="mt-1 text-sm text-amber-700 dark:text-amber-300">
                        Ajouter ce membre coûtera <strong>+2 €/mois</strong> (prélevé au prorata immédiatement).
                        Remplissez le formulaire ci-dessous puis confirmez.
                      </p>
                    </div>
                  </div>
                </div>
                <%# Hidden token injected into the main form via data attribute — picked up by the form partial %>
                <input type="hidden" name="seat_confirmation_token" value="<%= @seat_confirm_token %>">
              <% end %>

              <%= render "form", employee: @employee %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
