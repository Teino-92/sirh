<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <%= link_to admin_employees_path, class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 text-sm font-medium" do %>
      ← Retour à la liste
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg overflow-hidden">
    <!-- Header avec photo -->
    <div class="px-6 py-8 bg-gradient-to-r from-indigo-50 to-indigo-100 dark:from-indigo-900 dark:to-indigo-800 border-b border-indigo-200 dark:border-indigo-700">
      <div class="flex items-center">
        <div class="flex-shrink-0">
          <% if @employee.avatar.attached? %>
            <%= image_tag @employee.avatar, class: "h-24 w-24 rounded-full object-cover border-4 border-white shadow-sm" %>
          <% else %>
            <div class="h-24 w-24 rounded-full bg-white dark:bg-gray-800 flex items-center justify-center border-4 border-white shadow-sm">
              <span class="text-indigo-600 font-bold text-3xl">
                <%= @employee.first_name[0] %><%= @employee.last_name[0] %>
              </span>
            </div>
          <% end %>
        </div>
        <div class="ml-6">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @employee.full_name %></h1>
          <p class="text-gray-600 dark:text-gray-400 mt-1"><%= @employee.job_title || @employee.role.capitalize %></p>
          <div class="mt-2 flex gap-2">
            <span class="px-3 py-1 text-xs font-semibold rounded-full bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600">
              <%= @employee.contract_type %>
            </span>
            <span class="px-3 py-1 text-xs font-semibold rounded-full bg-indigo-600 text-white">
              <%= @employee.role.upcase %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Informations -->
    <div class="px-6 py-6 space-y-6">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Informations personnelles</h2>
        <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Email</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @employee.email %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Département</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @employee.department || '-' %></dd>
          </div>
          <% if @employee.hr? && @employee.hr_perimeter.any? %>
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Périmètre RH</dt>
            <dd class="mt-1 flex flex-wrap gap-1">
              <% @employee.hr_perimeter.each do |dept| %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 dark:bg-indigo-900 text-indigo-800 dark:text-indigo-200">
                  <%= dept %>
                </span>
              <% end %>
            </dd>
          </div>
          <% elsif !@employee.hr? && @employee.department.present? %>
            <% referent = @employee.hr_referent %>
            <% if referent %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Référent RH</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100">
                <%= referent.full_name %>
                <span class="text-gray-400 dark:text-gray-500 text-xs ml-1">— <%= referent.email %></span>
              </dd>
            </div>
            <% end %>
          <% end %>
        </dl>
      </div>

      <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Informations contractuelles</h2>
        <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Date d'entrée</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= l(@employee.start_date, format: :long) %></dd>
          </div>
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Ancienneté</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @employee.tenure_in_months %> mois</dd>
          </div>
          <% if @employee.end_date %>
            <div>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Date de sortie</dt>
              <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= l(@employee.end_date, format: :long) %></dd>
            </div>
          <% end %>
          <div>
            <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Manager</dt>
            <dd class="mt-1 text-sm text-gray-900 dark:text-gray-100"><%= @employee.manager&.full_name || 'Aucun' %></dd>
          </div>
        </dl>
      </div>

      <!-- Rémunération -->
      <% if policy(@employee).see_salary? %>
      <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Rémunération</h2>
        <% if @employee.gross_salary_cents > 0 %>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="bg-indigo-50 dark:bg-indigo-900 rounded-lg p-4">
              <p class="text-xs text-indigo-600 dark:text-indigo-400 font-medium uppercase tracking-wide mb-1">Brut mensuel</p>
              <p class="text-xl font-bold text-indigo-900 dark:text-white">
                <%= number_to_currency(@employee.gross_salary, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
              </p>
            </div>
            <% if @employee.variable_pay_cents > 0 %>
              <div class="bg-purple-50 dark:bg-purple-900 rounded-lg p-4">
                <p class="text-xs text-purple-600 dark:text-purple-400 font-medium uppercase tracking-wide mb-1">Part variable</p>
                <p class="text-xl font-bold text-purple-900 dark:text-white">
                  <%= number_to_currency(@employee.variable_pay, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
                </p>
              </div>
            <% end %>
            <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
              <p class="text-xs text-gray-500 dark:text-gray-400 font-medium uppercase tracking-wide mb-1">Coût employeur / mois</p>
              <p class="text-xl font-bold text-gray-900 dark:text-white">
                <%= number_to_currency(@employee.total_employer_cost, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
              </p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                charges incluses (×<%= number_with_precision(@employee.employer_charges_rate, precision: 2) %>)
              </p>
            </div>
          </div>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-3">
            Coût annuel estimé : <%= number_to_currency(@employee.total_employer_cost * 12, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
          </p>
        <% else %>
          <p class="text-sm text-gray-500 dark:text-gray-400 italic">
            Aucun salaire renseigné.
            <%= link_to "Modifier la fiche", edit_admin_employee_path(@employee), class: "text-indigo-600 hover:text-indigo-700 dark:text-indigo-400" %>
          </p>
        <% end %>
      </div>
      <% end %>

      <% if @employee.manager? && @employee.direct_reports.any? %>
        <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Équipe (<%= @employee.direct_reports.count %>)</h2>
          <ul class="divide-y divide-gray-200 dark:divide-gray-700">
            <% @employee.direct_reports.each do |report| %>
              <li class="py-3 flex justify-between items-center">
                <div>
                  <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= report.full_name %></p>
                  <p class="text-sm text-gray-600 dark:text-gray-400"><%= report.job_title %></p>
                </div>
                <%= link_to "Voir", admin_employee_path(report), class: "text-indigo-600 hover:text-indigo-900 text-sm" %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <!-- Actions -->
    <div class="px-6 py-4 bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 flex justify-end gap-3">
      <%= link_to "Modifier", edit_admin_employee_path(@employee),
          class: "px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" %>
      <%= button_to "Supprimer", admin_employee_path(@employee),
          method: :delete,
          form: { data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer #{@employee.full_name} ? Cette action est irréversible." } },
          class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700" %>
    </div>
  </div>
</div>
