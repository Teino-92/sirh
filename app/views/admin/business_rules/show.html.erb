<% content_for :title, @rule.name %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <%= link_to "Admin", admin_root_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %>
    <span>›</span>
    <%= link_to "Automatisations", admin_business_rules_path, class: "hover:text-gray-700 dark:hover:text-gray-200" %>
    <span>›</span>
    <span class="text-gray-900 dark:text-gray-100 font-medium"><%= @rule.name %></span>
  </nav>

  <div class="flex items-start justify-between mb-4">
    <div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100 flex items-center gap-2">
        <%= @rule.name %>
        <% if @rule.active? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300">Actif</span>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Désactivé</span>
        <% end %>
      </h1>
      <% if @rule.description.present? %>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400"><%= @rule.description %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Modifier", edit_admin_business_rule_path(@rule),
          class: "px-3 py-1.5 border border-gray-300 dark:border-gray-600 rounded text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600" %>
      <%= button_to @rule.active? ? "Désactiver" : "Activer", toggle_admin_business_rule_path(@rule), method: :patch,
          class: "px-3 py-1.5 border border-transparent rounded text-sm font-medium text-white #{@rule.active? ? 'bg-yellow-500 hover:bg-yellow-600' : 'bg-green-600 hover:bg-green-700'}" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">

    <%# Configuration %>
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg border border-gray-200 dark:border-gray-700 p-4">
      <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-3 uppercase tracking-wide">Configuration</h2>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between items-start gap-4">
          <dt class="text-gray-500 dark:text-gray-400 flex-shrink-0">Événement déclencheur</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100 text-right"><%= trigger_label(@rule.trigger) %></dd>
        </div>
        <div class="flex justify-between items-center">
          <dt class="text-gray-500 dark:text-gray-400">Priorité</dt>
          <dd class="font-semibold text-gray-900 dark:text-gray-100"><%= @rule.priority %></dd>
        </div>
        <div class="flex justify-between items-center">
          <dt class="text-gray-500 dark:text-gray-400">Créée le</dt>
          <dd class="text-gray-900 dark:text-gray-100"><%= @rule.created_at.strftime("%d/%m/%Y") %></dd>
        </div>
        <div class="flex justify-between items-center">
          <dt class="text-gray-500 dark:text-gray-400">Fois déclenchée</dt>
          <dd class="font-semibold text-indigo-600 dark:text-indigo-400"><%= @executions.size %></dd>
        </div>
      </dl>
    </div>

    <%# Conditions %>
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg border border-gray-200 dark:border-gray-700 p-4">
      <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-3 uppercase tracking-wide">Conditions</h2>
      <% if @rule.conditions.any? %>
        <div class="space-y-2">
          <% @rule.conditions.each do |cond| %>
            <div class="flex items-center gap-2 flex-wrap bg-gray-100 dark:bg-gray-700 px-3 py-2 rounded">
              <span class="font-medium text-gray-900 dark:text-gray-100 text-sm">
                <%= field_label(cond["field"]) %>
              </span>
              <span class="text-gray-500 dark:text-gray-400 text-xs">
                <%= operator_label(cond["operator"]) %>
              </span>
              <span class="font-semibold text-indigo-600 dark:text-indigo-300 text-sm">
                <% val = cond["value"] %>
                <%= val.is_a?(Array) ? val.join(", ") : val %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 dark:text-gray-500 italic">Aucune condition — s'applique à chaque déclenchement</p>
      <% end %>
    </div>

  </div>

  <%# Actions %>
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg border border-gray-200 dark:border-gray-700 p-4 mb-6">
    <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-3 uppercase tracking-wide">Actions (<%= @rule.actions.size %>)</h2>
    <div class="space-y-2">
      <% @rule.actions.each_with_index do |action, idx| %>
        <div class="flex items-start gap-3 bg-gray-100 dark:bg-gray-700 rounded p-3">
          <span class="flex-shrink-0 w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-800 text-indigo-700 dark:text-indigo-200 text-xs font-bold flex items-center justify-center">
            <%= action["order"] || idx + 1 %>
          </span>
          <div class="flex-1 space-y-1.5">
            <%= render partial: "admin/business_rules/action_badge", locals: { action: action } %>
            <% action.except("type", "order").each do |key, val| %>
              <div class="text-xs text-gray-600 dark:text-gray-300">
                <span class="font-medium"><%= action_key_label(key) %> :</span>
                <span class="ml-1"><%= role_label(val.to_s).presence || val %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Dernières exécutions %>
  <div class="bg-white dark:bg-gray-800 shadow rounded-lg border border-gray-200 dark:border-gray-700 p-4">
    <h2 class="text-xs font-semibold text-gray-500 dark:text-gray-400 mb-3 uppercase tracking-wide">Dernières exécutions</h2>
    <% if @executions.empty? %>
      <p class="text-sm text-gray-400 dark:text-gray-500 italic text-center py-4">Aucune exécution enregistrée</p>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider border-b border-gray-200 dark:border-gray-700">
              <th class="pb-2 pr-4">Date</th>
              <th class="pb-2 pr-4">Demande</th>
              <th class="pb-2 pr-4">Résultat</th>
              <th class="pb-2">Action déclenchée</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            <% @executions.each do |exec| %>
              <tr>
                <td class="py-2 pr-4 text-xs text-gray-500 dark:text-gray-400 whitespace-nowrap"><%= exec.created_at.strftime("%d/%m %H:%M") %></td>
                <td class="py-2 pr-4 text-xs text-gray-700 dark:text-gray-300">Demande #<%= exec.resource_id %></td>
                <td class="py-2 pr-4">
                  <% label, color = result_label(exec.result) %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium
                    <%= color == 'green' ? 'bg-green-100 text-green-800 dark:bg-green-800/40 dark:text-green-300' :
                        color == 'red'   ? 'bg-red-100 text-red-800 dark:bg-red-800/40 dark:text-red-300' :
                                           'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300' %>">
                    <%= label %>
                  </span>
                </td>
                <td class="py-2 text-xs text-gray-600 dark:text-gray-300">
                  <%= (exec.actions_executed || []).map { |a| action_type_label(a["type"]) }.join(", ").presence || "—" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

</div>
