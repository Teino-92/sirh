<% type = action["type"] %>
<% color, label = case type
   when "require_approval" then ["purple", "✓ Approbation #{{"manager" => "Manager", "hr" => "RH", "admin" => "Admin"}[action['role']] || action['role']}"]
   when "auto_approve"     then ["green",  "⚡ Approbation automatique"]
   when "block"            then ["red",    "✗ Demande bloquée"]
   when "notify"           then ["blue",   "🔔 Notification → #{{"manager" => "Manager", "hr" => "RH", "admin" => "Admin"}[action['role']] || action['role']}"]
   when "escalate_after"   then ["orange", "⬆ Escalade après #{action['hours']}h → #{{"manager" => "Manager", "hr" => "RH", "admin" => "Admin"}[action['escalate_to_role']] || action['escalate_to_role']}"]
   else                         ["gray",   type]
   end %>
<span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-<%= color %>-50 text-<%= color %>-700 dark:bg-<%= color %>-900/20 dark:text-<%= color %>-300">
  <%= label %>
</span>
