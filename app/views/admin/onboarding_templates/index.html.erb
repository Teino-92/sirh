<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Modèles d'onboarding</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
        Configurez les parcours d'intégration disponibles pour vos managers
      </p>
    </div>
    <%= link_to new_admin_onboarding_template_path,
          class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 transition-colors" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Nouveau modèle
    <% end %>
  </div>

  <div class="space-y-4">
    <% if @templates.any? %>
      <% @templates.each do |template| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-5">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100">
                  <%= link_to template.name, admin_onboarding_template_path(template),
                        class: "hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors" %>
                </h3>
                <% if template.active? %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400">
                    Actif
                  </span>
                <% else %>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
                    Inactif
                  </span>
                <% end %>
              </div>
              <% if template.description.present? %>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1"><%= template.description %></p>
              <% end %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
                <%= template.duration_days %> jours ·
                <%= template.onboarding_template_tasks.count %> étape<%= 's' if template.onboarding_template_tasks.count != 1 %>
              </p>
            </div>
            <div class="flex gap-2 ml-4">
              <%= link_to "Voir", admin_onboarding_template_path(template),
                    class: "inline-flex items-center py-1.5 px-3 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all" %>
              <%= link_to "Modifier", edit_admin_onboarding_template_path(template),
                    class: "inline-flex items-center py-1.5 px-3 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all" %>
              <%= button_to "Supprimer", admin_onboarding_template_path(template),
                    method: :delete,
                    class: "inline-flex items-center py-1.5 px-3 rounded-md text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all cursor-pointer",
                    data: { confirm: "Supprimer le modèle « #{template.name} » ? Cette action est irréversible." } %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow text-center py-12 px-4">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-gray-100">Aucun modèle créé</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          Créez votre premier modèle d'onboarding pour commencer.
        </p>
        <div class="mt-6">
          <%= link_to new_admin_onboarding_template_path,
                class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Nouveau modèle
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
