<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-4">
    <%= link_to '← Modèles d\'onboarding', admin_onboarding_templates_path,
          class: 'text-sm text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200' %>
  </div>

  <!-- Template header -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
    <div class="flex items-start justify-between">
      <div>
        <div class="flex items-center gap-3">
          <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100"><%= @template.name %></h1>
          <% if @template.active? %>
            <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400">Actif</span>
          <% else %>
            <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">Inactif</span>
          <% end %>
        </div>
        <% if @template.description.present? %>
          <p class="text-sm text-gray-600 dark:text-gray-400 mt-2"><%= @template.description %></p>
        <% end %>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
          Durée : <strong class="text-gray-900 dark:text-gray-100"><%= @template.duration_days %> jours</strong>
        </p>
      </div>
      <div class="flex gap-2">
        <%= link_to "Modifier", edit_admin_onboarding_template_path(@template),
              class: "inline-flex items-center py-1.5 px-3 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 transition-all" %>
        <%= button_to "Supprimer", admin_onboarding_template_path(@template),
              method: :delete,
              class: "inline-flex items-center py-1.5 px-3 rounded-md text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all cursor-pointer",
              data: { confirm: "Supprimer ce modèle ?" } %>
      </div>
    </div>
  </div>

  <!-- Tasks -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">
        Étapes du parcours (<%= @tasks.count %>)
      </h2>
      <%= link_to new_admin_onboarding_template_onboarding_template_task_path(@template),
            class: "inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-all" do %>
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        Ajouter une étape
      <% end %>
    </div>

    <% if @tasks.any? %>
      <%
        type_labels = {
          'manual'        => 'Manuel',
          'objective_30'  => 'Objectif J30',
          'objective_60'  => 'Objectif J60',
          'objective_90'  => 'Objectif J90',
          'training'      => 'Formation',
          'one_on_one'    => '1:1'
        }
        type_colors = {
          'manual'        => 'bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300',
          'objective_30'  => 'bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300',
          'objective_60'  => 'bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300',
          'objective_90'  => 'bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300',
          'training'      => 'bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300',
          'one_on_one'    => 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300'
        }
        role_labels = { 'hr' => 'RH', 'manager' => 'Manager', 'employee' => 'Collaborateur' }
        role_colors = {
          'hr'       => 'bg-pink-100 dark:bg-pink-900/40 text-pink-700 dark:text-pink-300',
          'manager'  => 'bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-300',
          'employee' => 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300'
        }
      %>
      <div class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @tasks.each do |task| %>
          <div class="px-6 py-4 flex items-start justify-between">
            <div class="flex items-start gap-3 flex-1 min-w-0">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 flex items-center justify-center text-xs font-semibold">
                <%= task.position || '—' %>
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= task.title %></p>
                <% if task.description.present? %>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= task.description %></p>
                <% end %>
                <div class="flex flex-wrap gap-2 mt-2">
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full <%= type_colors[task.task_type] %>">
                    <%= type_labels[task.task_type] || task.task_type %>
                  </span>
                  <span class="px-2 py-0.5 text-xs font-medium rounded-full <%= role_colors[task.assigned_to_role] %>">
                    <%= role_labels[task.assigned_to_role] || task.assigned_to_role %>
                  </span>
                  <span class="px-2 py-0.5 text-xs rounded-full bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">
                    J+<%= task.due_day_offset %>
                  </span>
                </div>
              </div>
            </div>
            <div class="flex gap-2 ml-4 flex-shrink-0">
              <%= link_to "Modifier",
                    edit_admin_onboarding_template_task_path(task),
                    class: "text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300" %>
              <%= button_to "✕",
                    admin_onboarding_template_task_path(task),
                    method: :delete,
                    class: "text-sm text-red-500 dark:text-red-400 hover:text-red-700 cursor-pointer bg-transparent",
                    data: { confirm: "Supprimer cette étape ?" } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-10 text-gray-500 dark:text-gray-400">
        <p class="text-sm">Aucune étape configurée pour ce modèle.</p>
        <%= link_to "Ajouter la première étape", new_admin_onboarding_template_onboarding_template_task_path(@template),
              class: "mt-2 inline-flex items-center text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
      </div>
    <% end %>
  </div>
</div>
