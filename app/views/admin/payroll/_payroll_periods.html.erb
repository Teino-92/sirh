<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mt-8">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Clôture de paie</h2>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
        Une période clôturée interdit toute modification des pointages et absences.
      </p>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg border border-gray-200 dark:border-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
      <thead class="bg-gray-50 dark:bg-gray-700/50">
        <tr>
          <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider text-xs">Période</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider text-xs">Statut</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider text-xs">Clôturée par</th>
          <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider text-xs">Date de clôture</th>
          <% if current_organization.payroll_webhook_url.present? %>
            <th class="px-4 py-3 text-left font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider text-xs">Silae</th>
          <% end %>
          <th class="px-4 py-3 text-right font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider text-xs">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-800">
        <% locked_index = @payroll_periods_locked.index_by(&:period) %>
        <% @lockable_months.reverse.each do |month| %>
          <% locked = locked_index[month] %>
          <% period_key = month.strftime('%Y-%m') %>
          <% last_push = @last_push_by_period[period_key] %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/40 transition-colors">
            <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">
              <%= l(month, format: '%B %Y') %>
            </td>
            <td class="px-4 py-3">
              <% if locked %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                  </svg>
                  Clôturée
                </span>
              <% else %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 2a5 5 0 00-5 5v2a2 2 0 00-2 2v5a2 2 0 002 2h10a2 2 0 002-2v-5a2 2 0 00-2-2H7V7a3 3 0 015.905-.75 1 1 0 001.937-.5A5.002 5.002 0 0010 2z" />
                  </svg>
                  Ouverte
                </span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
              <%= locked ? locked.locked_by.full_name : '—' %>
            </td>
            <td class="px-4 py-3 text-gray-600 dark:text-gray-400">
              <%= locked ? l(locked.locked_at, format: :short) : '—' %>
            </td>
            <% if current_organization.payroll_webhook_url.present? %>
              <td class="px-4 py-3">
                <% if last_push %>
                  <% if last_push[:status] == 'success' %>
                    <span class="inline-flex items-center gap-1 text-xs text-green-700 dark:text-green-400" title="Envoyé le <%= l(last_push[:at], format: :short) %>">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-5.121-5.121a1 1 0 011.414-1.414L8.414 12.172l6.879-6.879a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                      <%= l(last_push[:at], format: :short) %>
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 text-xs text-red-700 dark:text-red-400" title="Échec le <%= l(last_push[:at], format: :short) %>">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                      Échec
                    </span>
                  <% end %>
                <% else %>
                  <span class="text-xs text-gray-400 dark:text-gray-500">—</span>
                <% end %>
              </td>
            <% end %>
            <td class="px-4 py-3 text-right">
              <div class="inline-flex items-center gap-2">
                <% if locked %>
                  <% if current_organization.payroll_webhook_url.present? %>
                    <%= button_to push_silae_admin_payroll_path,
                                  params: { period: period_key },
                                  method: :post,
                                  form: { data: { turbo_confirm: "Envoyer #{l(month, format: '%B %Y')} à Silae ? Les données NIR, IBAN et heures seront transmises." } },
                                  data: { turbo_disable_with: "Envoi…" },
                                  class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-md hover:bg-emerald-100 dark:hover:bg-emerald-900/30 transition" do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                      </svg>
                      Silae
                    <% end %>
                  <% end %>
                  <%= button_to admin_payroll_payroll_period_path(locked),
                                method: :delete,
                                form: { data: { turbo_confirm: "Rouvrir #{l(month, format: '%B %Y')} ? Les modifications des pointages et absences seront à nouveau possibles." } },
                                class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-md hover:bg-red-100 dark:hover:bg-red-900/30 transition" do %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" />
                    </svg>
                    Rouvrir
                  <% end %>
                <% else %>
                  <%= button_to admin_payroll_payroll_periods_path,
                                params: { period: month.strftime('%Y-%m') },
                                method: :post,
                                form: { data: { turbo_confirm: "Clôturer #{l(month, format: '%B %Y')} ? Les pointages et absences de ce mois ne pourront plus être modifiés." } },
                                class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-indigo-700 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 rounded-md hover:bg-indigo-100 dark:hover:bg-indigo-900/30 transition" do %>
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 1a4.5 4.5 0 00-4.5 4.5V9H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2v-6a2 2 0 00-2-2h-.5V5.5A4.5 4.5 0 0010 1zm3 8V5.5a3 3 0 10-6 0V9h6z" clip-rule="evenodd" />
                    </svg>
                    Clôturer
                  <% end %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
