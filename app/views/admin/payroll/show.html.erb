<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <!-- Header -->
  <div class="mb-8 flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Masse salariale</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Synthèse RH · <%= l(Date.current, format: :long) %>
      </p>
    </div>

    <div class="flex items-center gap-3 flex-wrap">
      <!-- Export CSV standard -->
      <%= link_to export_admin_payroll_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg shadow-sm transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        Export masse salariale
      <% end %>

      <!-- Export Silae avec sélecteur de période -->
      <form action="<%= export_silae_admin_payroll_path %>" method="get" class="flex items-center gap-2">
        <div class="relative">
          <input type="month"
                 name="period"
                 value="<%= Date.current.strftime('%Y-%m') %>"
                 max="<%= Date.current.strftime('%Y-%m') %>"
                 class="block pl-3 pr-8 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 cursor-pointer"
                 title="Sélectionner la période de paie">
        </div>
        <button type="submit"
                class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg shadow-sm transition"
                title="Générer le fichier d'import Silae pour la période sélectionnée">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Export Silae
        </button>
      </form>
    </div>
  </div>

  <!-- ── KPI Cards ─────────────────────────────────────────────────────── -->
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">

    <!-- Masse brute mensuelle -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Masse brute / mois</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-1">
        <%= number_to_currency(@total_gross_monthly, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Charges exclues</p>
    </div>

    <!-- Coût employeur mensuel -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Coût employeur / mois</p>
      <p class="text-2xl font-bold text-indigo-700 dark:text-indigo-400 mt-1">
        <%= number_to_currency(@total_employer_monthly, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Charges incluses</p>
    </div>

    <!-- Masse annuelle projetée -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Projection annuelle</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-1">
        <%= number_to_currency(@total_annual_gross, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Brut × 12 mois</p>
    </div>

    <!-- Effectif -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Effectif actif</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-1"><%= @headcount %></p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
        <%= @cadre_count %> cadre<%= 's' if @cadre_count != 1 %> · <%= @non_cadre_count %> non-cadre<%= 's' if @non_cadre_count != 1 %>
      </p>
    </div>

    <!-- Salaire moyen -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-5">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">Salaire moyen brut</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-1">
        <%= number_to_currency(@average_gross, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">/ mois · brut</p>
    </div>

  </div>

  <!-- ── Section principale ─────────────────────────────────────────────── -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <!-- Répartition par contrat -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Répartition par type de contrat</h2>
      <% if @by_contract.any? %>
        <div class="space-y-3">
          <% @by_contract.sort_by { |_, v| -v }.each do |contract_type, mass| %>
            <%
              count    = @headcount_by_contract[contract_type].to_i
              pct      = @total_gross_monthly > 0 ? (mass / @total_gross_monthly * 100).round(1) : 0
            %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= contract_type %></span>
                  <span class="text-xs text-gray-500 dark:text-gray-400"><%= count %> pers.</span>
                </div>
                <div class="text-right">
                  <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">
                    <%= number_to_currency(mass, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
                  </span>
                  <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">(<%= pct %>%)</span>
                </div>
              </div>
              <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-500 rounded-full" style="width: <%= pct %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">Aucune donnée de salaire enregistrée.</p>
      <% end %>
    </div>

    <!-- Répartition par département -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Répartition par département</h2>
      <% if @by_department.any? %>
        <div class="space-y-3">
          <% @by_department.sort_by { |_, v| -v }.each do |dept, mass| %>
            <%
              count = @headcount_by_department[dept].to_i
              pct   = @total_gross_monthly > 0 ? (mass / @total_gross_monthly * 100).round(1) : 0
            %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= dept %></span>
                  <span class="text-xs text-gray-500 dark:text-gray-400"><%= count %> pers.</span>
                </div>
                <div class="text-right">
                  <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">
                    <%= number_to_currency(mass, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
                  </span>
                  <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">(<%= pct %>%)</span>
                </div>
              </div>
              <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full bg-emerald-500 rounded-full" style="width: <%= pct %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-gray-400">Aucun département renseigné.</p>
      <% end %>
    </div>

    <!-- Distribution salariale -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Distribution salariale (brut mensuel)</h2>
      <% max_band_count = @salary_bands.map { |b| b[:count] }.max.to_i %>
      <div class="space-y-3">
        <% @salary_bands.each do |band| %>
          <%
            bar_pct = max_band_count > 0 ? (band[:count].to_f / max_band_count * 100).round : 0
          %>
          <div class="flex items-center gap-3">
            <span class="text-xs text-gray-600 dark:text-gray-400 w-32 flex-shrink-0"><%= band[:label] %></span>
            <div class="flex-1 h-5 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full bg-violet-400 dark:bg-violet-600 rounded-full flex items-center justify-end pr-2" style="width: <%= [bar_pct, 4].max %>%">
                <% if band[:count] > 0 %>
                  <span class="text-xs text-white font-medium"><%= band[:count] %></span>
                <% end %>
              </div>
            </div>
            <span class="text-xs text-gray-500 dark:text-gray-400 w-6 text-right"><%= band[:count] %></span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Salaire × Ancienneté -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Salaire moyen par ancienneté</h2>
      <div class="space-y-3">
        <% @by_tenure.each do |bracket| %>
          <%
            pct = @average_gross > 0 ? [(bracket[:avg_gross] / (@average_gross * 1.5) * 100).round, 100].min : 0
            color = case
                    when bracket[:avg_gross] > @average_gross * 1.1 then 'bg-green-400'
                    when bracket[:avg_gross] < @average_gross * 0.9 then 'bg-yellow-400'
                    else 'bg-blue-400'
                    end
          %>
          <div>
            <div class="flex justify-between mb-1">
              <span class="text-sm text-gray-700 dark:text-gray-300"><%= bracket[:label] %></span>
              <div class="text-right">
                <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
                  <%= bracket[:count] > 0 ? number_to_currency(bracket[:avg_gross], unit: '€', format: '%n %u', delimiter: ' ', precision: 0) : '—' %>
                </span>
                <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">(<%= bracket[:count] %> pers.)</span>
              </div>
            </div>
            <div class="h-2 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
              <div class="h-full <%= color %> rounded-full" style="width: <%= pct %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-3">
        Moyenne globale : <%= number_to_currency(@average_gross, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>/mois
      </p>
    </div>

  </div>

  <!-- ── Coût des absences ce mois ──────────────────────────────────────── -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-2">
        Coût estimé des absences — <%= l(Date.current, format: '%B %Y') %>
      </h2>
      <p class="text-3xl font-bold text-orange-600 dark:text-orange-400">
        <%= number_to_currency(@leave_cost_estimate, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
      </p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
        Basé sur les congés approuvés ce mois et le coût journalier moyen
        (<%= number_to_currency(@average_gross / 22.0, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>/j).
        Indicateur de pilotage — ne remplace pas la paie.
      </p>
    </div>

    <!-- Cadres vs non-cadres -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Cadres vs non-cadres</h2>
      <div class="space-y-2">
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-600 dark:text-gray-400">Cadres (<%= @cadre_count %>)</span>
          <span class="text-sm font-semibold text-gray-900 dark:text-gray-100">
            moy. <%= number_to_currency(@cadre_avg_gross, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>/mois
          </span>
        </div>
        <% cadre_share = @headcount > 0 ? (@cadre_count.to_f / @headcount * 100).round : 0 %>
        <div class="h-3 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
          <div class="h-full bg-indigo-500 rounded-full" style="width: <%= cadre_share %>%"></div>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-400">
          <%= cadre_share %>% de l'effectif en statut cadre
        </p>
      </div>
    </div>

    <!-- Taux de charges moyen -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-2">Taux de charges moyen</h2>
      <%
        avg_rate = @employees.any? ? (@employees.sum('employer_charges_rate') / @employees.count).to_f : 1.45
        surcharge_pct = ((avg_rate - 1) * 100).round(1)
      %>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100">+<%= surcharge_pct %>%</p>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">sur le brut</p>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">
        Pour 1 € de salaire brut, l'employeur paie en moyenne <%= number_with_precision(avg_rate, precision: 2) %> €
      </p>
    </div>

  </div>

  <!-- ── Top rémunérations ──────────────────────────────────────────────── -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Top 10 — Rémunérations (brut mensuel)</h2>
      <%= link_to "Gérer les fiches", admin_employees_path, class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 dark:hover:text-indigo-300" %>
    </div>
    <% if @top_earners.any? && @top_earners.first.gross_salary_cents > 0 %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide border-b border-gray-200 dark:border-gray-700">
              <th class="pb-2 pr-4">Employé</th>
              <th class="pb-2 pr-4">Poste</th>
              <th class="pb-2 pr-4">Contrat</th>
              <th class="pb-2 pr-4 text-right">Brut / mois</th>
              <th class="pb-2 pr-4 text-right">Variable</th>
              <th class="pb-2 text-right">Coût employeur</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            <% @top_earners.each_with_index do |emp, i| %>
              <% next if emp.gross_salary_cents == 0 %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="py-3 pr-4">
                  <div class="flex items-center gap-2">
                    <span class="text-xs text-gray-400 w-5">#<%= i + 1 %></span>
                    <div>
                      <p class="font-medium text-gray-900 dark:text-gray-100"><%= emp.full_name %></p>
                      <% if emp.cadre? %>
                        <span class="inline-block text-xs bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 rounded px-1">Cadre</span>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="py-3 pr-4 text-gray-600 dark:text-gray-400"><%= emp.job_title.presence || '—' %></td>
                <td class="py-3 pr-4">
                  <span class="inline-block text-xs rounded px-2 py-0.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300"><%= emp.contract_type %></span>
                </td>
                <td class="py-3 pr-4 text-right font-medium text-gray-900 dark:text-gray-100">
                  <%= number_to_currency(emp.gross_salary, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
                </td>
                <td class="py-3 pr-4 text-right text-gray-600 dark:text-gray-400">
                  <%= emp.variable_pay > 0 ? number_to_currency(emp.variable_pay, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) : '—' %>
                </td>
                <td class="py-3 text-right font-medium text-indigo-700 dark:text-indigo-400">
                  <%= number_to_currency(emp.total_employer_cost, unit: '€', format: '%n %u', delimiter: ' ', precision: 0) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-10">
        <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="mt-3 text-sm font-medium text-gray-500 dark:text-gray-400">Aucun salaire renseigné</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Renseignez les salaires dans les fiches employés pour afficher les analyses.</p>
        <%= link_to "Gérer les employés", admin_employees_path, class: "mt-4 inline-block text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400" %>
      </div>
    <% end %>
  </div>

  <%= render 'payroll_periods' %>

</div>
