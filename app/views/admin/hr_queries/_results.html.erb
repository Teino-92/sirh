<%# locals: (rows:, columns:, filters_param:, query:) %>
<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">

  <!-- Results header -->
  <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between flex-wrap gap-3">
    <div>
      <h2 class="text-sm font-semibold text-gray-900 dark:text-white">
        Résultats
        <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                     <%= rows.size >= 500 ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300' : 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300' %>">
          <%= rows.size %> employé<%= rows.size > 1 ? 's' : '' %>
          <%= " (limité à 500)" if rows.size >= 500 %>
        </span>
      </h2>
      <% if query.present? %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 italic">"<%= query %>"</p>
      <% end %>
    </div>

    <% if rows.any? %>
      <%= link_to export_admin_hr_query_path(filters: filters_param),
                  class: "inline-flex items-center gap-1.5 px-4 py-2 bg-green-600 hover:bg-green-700
                          text-white text-xs font-medium rounded-lg transition-colors" do %>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Exporter CSV
      <% end %>
    <% end %>
  </div>

  <!-- Table -->
  <% if rows.empty? %>
    <div class="px-6 py-12 text-center">
      <svg class="mx-auto h-10 w-10 text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm text-gray-500 dark:text-gray-400">Aucun employé ne correspond à ces critères.</p>
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <% columns.each do |_key, label| %>
              <th scope="col"
                  class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider whitespace-nowrap">
                <%= label %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-100 dark:divide-gray-700">
          <% rows.each do |row| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/40 transition-colors">
              <% columns.each_key do |key| %>
                <td class="px-4 py-3 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  <%= row[key].presence || "—" %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
