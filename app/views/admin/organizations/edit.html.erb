<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <%= link_to admin_organization_path, class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-900 dark:hover:text-indigo-300 text-sm font-medium" do %>
      ← Retour
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">Modifier les paramètres de l'organisation</h1>
    </div>

    <div class="px-6 py-6">
      <%= form_with(model: [:admin, @organization], class: "space-y-8") do |form| %>
        <% if @organization.errors.any? %>
          <div class="bg-red-50 dark:bg-red-900 border-l-4 border-red-400 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
                  <%= pluralize(@organization.errors.count, "erreur") %> :
                </h3>
                <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
                  <% @organization.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Informations générales -->
        <div>
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Informations générales</h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <%= form.label :name, "Nom de l'organisation", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :name,
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                  required: true %>
            </div>

            <div>
              <%= form.label :siret, "SIRET", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :siret,
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>

            <div class="sm:col-span-2">
              <%= form.label :address, "Adresse", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_area :address,
                  rows: 3,
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>

            <%= form.fields_for :settings do |sf| %>
              <div>
                <%= sf.label :legal_department, "Département siège social", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= sf.text_field :legal_department,
                    value: @organization.settings['legal_department'],
                    placeholder: "ex: 67",
                    maxlength: 3,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Départements 57, 67, 68 → régime Alsace-Moselle (Vendredi Saint + 26 déc. fériés).
                </p>
                <% if @organization.legal_region == :alsace_moselle %>
                  <p class="mt-1 text-xs font-medium text-indigo-600 dark:text-indigo-400">
                    Régime Alsace-Moselle actif — 13 jours fériés.
                  </p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Convention collective par défaut -->
        <%= form.fields_for :settings do |sf| %>
          <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Convention collective</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
              Définissez la convention collective de votre organisation. Elle sera pré-remplie automatiquement dans chaque fiche collaborateur (modifiable individuellement).
            </p>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <%= sf.label :convention_collective, "Convention collective (IDCC)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= sf.text_field :convention_collective,
                    value: @organization.settings['convention_collective'],
                    placeholder: "ex: 1486 — Bureaux d'études techniques (Syntec)",
                    list: "idcc_list_org",
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <datalist id="idcc_list_org">
                  <option value="1486 — Bureaux d'études techniques (Syntec)">
                  <option value="3218 — Métallurgie">
                  <option value="1090 — Commerces de détail alimentaires">
                  <option value="1979 — Hôtels, cafés, restaurants">
                  <option value="2264 — Banque">
                  <option value="0573 — Manutention ferroviaire">
                  <option value="1596 — Coiffure">
                  <option value="2120 — Immobilier">
                  <option value="1527 — Bâtiment (ETAM)">
                  <option value="0016 — Transports routiers">
                </datalist>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Pré-remplie dans les fiches employés — modifiable par employé si besoin.</p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Paramètres de temps de travail -->
        <%= form.fields_for :settings do |settings_form| %>
          <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Temps de travail</h2>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div>
                <%= settings_form.label :work_week_hours, "Heures hebdomadaires", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.number_field :work_week_hours,
                    value: @organization.work_week_hours,
                    step: 0.5,
                    min: 1,
                    max: 48,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Généralement 35h en France</p>
              </div>

              <div>
                <%= settings_form.label :overtime_threshold, "Seuil heures sup.", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.number_field :overtime_threshold,
                    value: @organization.settings.dig('overtime_threshold') || 35,
                    step: 0.5,
                    min: 1,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Heures/semaine</p>
              </div>

              <div>
                <%= settings_form.label :max_daily_hours, "Durée max. quotidienne", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.number_field :max_daily_hours,
                    value: @organization.settings.dig('max_daily_hours') || 10,
                    step: 0.5,
                    min: 1,
                    max: 12,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Limite légale: 10h en France</p>
              </div>

              <div>
                <%= settings_form.label :rtt_enabled, "RTT activé", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <div class="mt-2">
                  <%= settings_form.check_box :rtt_enabled,
                      { checked: @organization.rtt_enabled?, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 dark:border-gray-600 rounded" },
                      true, false %>
                  <span class="ml-2 text-sm text-gray-600 dark:text-gray-400">Activer le système de RTT</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Paramètres de congés payés -->
          <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Congés payés</h2>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div>
                <%= settings_form.label :cp_acquisition_rate, "Taux d'acquisition", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.number_field :cp_acquisition_rate,
                    value: @organization.settings.dig('cp_acquisition_rate') || 2.5,
                    step: 0.1,
                    min: 0,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Jours/mois (légal: 2.5)</p>
              </div>

              <div>
                <%= settings_form.label :min_consecutive_leave_days, "Min. jours consécutifs", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.number_field :min_consecutive_leave_days,
                    value: @organization.settings.dig('min_consecutive_leave_days') || 10,
                    step: 1,
                    min: 1,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Durée minimale d'un congé principal</p>
              </div>

              <div>
                <%= settings_form.label :cp_expiry_month, "Mois d'expiration", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.select :cp_expiry_month,
                    (1..12).map { |m| [I18n.l(Date.new(2000, m, 1), format: '%B'), m] },
                    { selected: @organization.settings.dig('cp_expiry_month') || 5 },
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              </div>

              <div>
                <%= settings_form.label :cp_expiry_day, "Jour d'expiration", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= settings_form.number_field :cp_expiry_day,
                    value: @organization.settings.dig('cp_expiry_day') || 31,
                    step: 1,
                    min: 1,
                    max: 31,
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Intégration Calendrier -->
        <%= form.fields_for :settings do |sf| %>
          <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Intégration Calendrier</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
              Configurez un webhook pour connecter vos outils de calendrier (N8n, Calendly, Google Calendar, Outlook…).
              Lors de la création d'un 1:1 ou d'une formation, Izi-RH enverra automatiquement les informations à ce webhook.
            </p>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <%= sf.label :calendar_webhook_url, "URL du Webhook", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= sf.url_field :calendar_webhook_url,
                    value: @organization.settings['calendar_webhook_url'],
                    placeholder: "https://n8n.votre-domaine.com/webhook/xxxxx",
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Izi-RH fera un POST JSON à cette URL. Le payload inclut l'événement, l'organisation, et les détails de l'occurrence.
                </p>
              </div>

              <div>
                <%= sf.label :calendar_provider, "Service de calendrier cible", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= sf.select :calendar_provider,
                    options_for_select([
                      ['— Non configuré —', ''],
                      ['N8n (workflow personnalisé)', 'n8n'],
                      ['Google Calendar', 'google'],
                      ['Microsoft Outlook / Teams', 'outlook'],
                      ['Calendly', 'calendly'],
                      ['Autre', 'other']
                    ], @organization.settings['calendar_provider'] || ''),
                    {},
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Inclus dans le payload pour que votre workflow N8n sache vers quel service router.
                </p>
              </div>
            </div>

            <% if @organization.settings['calendar_webhook_url'].present? %>
              <div class="mt-4 p-3 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded-md">
                <p class="text-xs text-green-800 dark:text-green-300 font-medium">
                  Webhook actif — les nouveaux 1:1 et formations seront automatiquement transmis.
                </p>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Intégration Silae / Paie -->
        <%= form.fields_for :settings do |sf| %>
          <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1">Intégration Paie (Silae / ADP)</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
              Configurez un webhook pour pousser automatiquement les données de paie vers Silae ou ADP lors d'une clôture.
              Le payload JSON contient les données de tous les employés actifs (NIR, IBAN, heures, absences).
            </p>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="sm:col-span-2">
                <%= sf.label :payroll_webhook_url, "URL du Webhook Silae", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= sf.url_field :payroll_webhook_url,
                    value: @organization.settings['payroll_webhook_url'],
                    placeholder: "https://silae.votre-domaine.com/api/webhooks/paie",
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Izi-RH fera un POST JSON à cette URL lors de chaque envoi de clôture.
                </p>
              </div>

              <div class="sm:col-span-2">
                <%= sf.label :payroll_webhook_secret, "Secret / Token Bearer", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
                <%= sf.password_field :payroll_webhook_secret,
                    value: '',
                    placeholder: @organization.settings['payroll_webhook_secret'].present? ? '••••••••••••••••' : 'Optionnel — envoyé comme Authorization: Bearer …',
                    autocomplete: 'new-password',
                    class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono" %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Laissez vide pour ne pas modifier le secret existant.
                </p>
              </div>
            </div>

            <% if @organization.payroll_webhook_url.present? %>
              <div class="mt-4 p-3 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded-md">
                <p class="text-xs text-green-800 dark:text-green-300 font-medium">
                  Webhook Silae actif — le bouton "Envoyer à Silae" sera visible sur les périodes clôturées.
                </p>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="flex justify-end gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
          <%= link_to "Annuler", admin_organization_path,
              class: "px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" %>
          <%= form.submit "Enregistrer les modifications",
              class: "px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
