<div class="bg-surface dark:bg-[#1C1B2E] rounded-xl shadow-xl border border-border-soft dark:border-white/10 overflow-hidden w-full sm:w-[480px]" style="max-width: 90vw; max-height: 600px;">
  <!-- Header -->
  <div class="p-4 border-b border-border-soft dark:border-white/10">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="text-lg font-semibold text-text-deep dark:text-white">Notifications</h3>
        <p class="text-xs text-muted-soft dark:text-white/40 mt-0.5">
          <%= unread_count %> non lue<%= 's' if unread_count > 1 %>
        </p>
      </div>
      <% if unread_count > 0 %>
        <%= button_to mark_all_as_read_notifications_path, method: :post,
          class: "text-xs text-primary hover:text-primary/80 font-medium" do %>
          Tout marquer comme lu
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Notifications List -->
  <div class="overflow-y-auto" style="max-height: 520px;">
    <% if notifications.any? %>
      <ul class="divide-y divide-border-soft dark:divide-white/8">
        <% notifications.limit(10).each do |notification| %>
          <li class="<%= notification.unread? ? 'bg-primary/5 dark:bg-primary/10' : '' %>">
            <%= form_with url: mark_as_read_notification_path(notification), method: :post, local: true, class: "w-full" do |f| %>
              <%= f.button type: :submit, class: "w-full text-left block hover:bg-black/4 dark:hover:bg-surface/5 transition-colors border-0 bg-transparent p-0 cursor-pointer" do %>
              <div class="px-4 py-3">
                <div class="flex items-start gap-3">
                  <!-- Icon -->
                  <div class="flex-shrink-0">
                    <% case notification.notification_type %>
                    <% when 'schedule_created', 'schedule_updated' %>
                      <div class="h-8 w-8 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center">
                        <svg class="h-4 w-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                    <% when 'leave_approved' %>
                      <div class="h-8 w-8 rounded-full bg-success/10 dark:bg-success/20 flex items-center justify-center">
                        <svg class="h-4 w-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% when 'leave_rejected' %>
                      <div class="h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                        <svg class="h-4 w-4 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% when 'hours_validated' %>
                      <div class="h-8 w-8 rounded-full bg-warning/10 dark:bg-warning/20 flex items-center justify-center">
                        <svg class="h-4 w-4 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% when 'hours_rejected' %>
                      <div class="h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                        <svg class="h-4 w-4 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% else %>
                      <div class="h-8 w-8 rounded-full bg-bg-soft dark:bg-surface/8 flex items-center justify-center">
                        <svg class="h-4 w-4 text-muted-soft dark:text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                        </svg>
                      </div>
                    <% end %>
                  </div>

                  <!-- Content -->
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2">
                      <p class="text-sm font-medium text-text-deep dark:text-white flex-1">
                        <%= notification.title %>
                      </p>
                      <% if notification.unread? %>
                        <span class="flex h-2 w-2">
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                        </span>
                      <% end %>
                    </div>
                    <p class="mt-0.5 text-xs text-muted-soft dark:text-white/40 line-clamp-2"><%= notification.message %></p>
                    <p class="mt-1 text-xs text-muted-soft dark:text-white/30">
                      <%= time_ago_in_words(notification.created_at) %>
                    </p>
                  </div>
                </div>
              </div>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>

      <% if notifications.count > 10 %>
        <div class="p-3 border-t border-border-soft dark:border-white/10 text-center">
          <%= link_to notifications_path, class: "text-sm text-primary hover:text-primary/80 font-medium" do %>
            Voir toutes les notifications
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center">
        <svg class="mx-auto h-8 w-8 text-muted-soft dark:text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
        </svg>
        <p class="mt-2 text-sm text-muted-soft dark:text-white/40">Aucune notification</p>
      </div>
    <% end %>
  </div>
</div>
