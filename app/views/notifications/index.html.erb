<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white mb-2">Notifications</h1>
      <p class="text-sm text-muted-soft dark:text-white/50">
        <%= @unread_count %> notification<%= 's' if @unread_count > 1 %> non lue<%= 's' if @unread_count > 1 %>
      </p>
    </div>

    <% if @unread_count > 0 %>
      <%= button_to mark_all_as_read_notifications_path, method: :post,
        class: "text-sm text-primary hover:text-primary font-medium" do %>
        Tout marquer comme lu
      <% end %>
    <% end %>
  </div>

  <!-- Notifications List -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
    <% if @notifications.any? %>
      <ul class="divide-y divide-gray-200 dark:divide-gray-700">
        <% @notifications.each do |notification| %>
          <li class="<%= notification.unread? ? 'bg-primary/10 dark:bg-primary/10' : 'bg-surface dark:bg-[#1C1B2E]' %>">
            <%= form_with url: mark_as_read_notification_path(notification), method: :post, local: true, class: "w-full" do |f| %>
              <%= f.button type: :submit, class: "w-full text-left block hover:bg-bg-soft dark:bg-[#13121F] transition-colors border-0 bg-transparent p-0 cursor-pointer" do %>
              <div class="px-4 sm:px-6 py-4">
                <div class="flex items-start">
                  <!-- Icon -->
                  <div class="flex-shrink-0">
                    <% case notification.notification_type %>
                    <% when 'schedule_created', 'schedule_updated' %>
                      <div class="h-10 w-10 rounded-full bg-primary dark:bg-primary flex items-center justify-center">
                        <svg class="h-6 w-6 text-primary dark:text-primary/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                      </div>
                    <% when 'leave_approved' %>
                      <div class="h-10 w-10 rounded-full bg-green-100 dark:bg-green-900 flex items-center justify-center">
                        <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% when 'leave_rejected' %>
                      <div class="h-10 w-10 rounded-full bg-red-100 dark:bg-red-900 flex items-center justify-center">
                        <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% when 'hours_validated' %>
                      <div class="h-10 w-10 rounded-full bg-primary/10 dark:bg-primary/10 flex items-center justify-center">
                        <svg class="h-6 w-6 text-primary dark:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% when 'hours_rejected' %>
                      <div class="h-10 w-10 rounded-full bg-red-100 dark:bg-red-900 flex items-center justify-center">
                        <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                    <% else %>
                      <div class="h-10 w-10 rounded-full bg-bg-soft dark:bg-[#1C1B2E] flex items-center justify-center">
                        <svg class="h-6 w-6 text-muted-soft dark:text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                        </svg>
                      </div>
                    <% end %>
                  </div>

                  <!-- Content -->
                  <div class="ml-3 flex-1 min-w-0">
                    <p class="text-sm font-medium text-text-deep dark:text-white">
                      <%= notification.title %>
                      <% if notification.unread? %>
                        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-primary/10 dark:bg-primary/10 text-primary dark:text-primary">
                          Nouveau
                        </span>
                      <% end %>
                    </p>
                    <p class="mt-1 text-sm text-muted-soft dark:text-white/50"><%= notification.message %></p>
                    <p class="mt-1 text-xs text-muted-soft dark:text-white/50">
                      <%= l(notification.created_at, format: :long) %>
                    </p>
                  </div>

                  <!-- Arrow -->
                  <div class="ml-3 flex-shrink-0">
                    <svg class="h-5 w-5 text-muted-soft dark:text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </div>
                </div>
              </div>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-muted-soft dark:text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
        </svg>
        <p class="mt-4 text-muted-soft dark:text-white/50">Aucune notification</p>
      </div>
    <% end %>
  </div>
</div>
