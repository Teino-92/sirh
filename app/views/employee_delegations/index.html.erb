<% content_for :title, "Mes délégations" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100">Mes délégations</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Déléguer votre rôle d'approbation à un collègue pendant votre absence.</p>
    </div>
    <% if policy(EmployeeDelegation).create? %>
      <%= link_to new_employee_delegation_path,
          class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Nouvelle délégation
      <% end %>
    <% end %>
  </div>

  <%# Délégations reçues actives %>
  <% if @as_delegatee.any? %>
    <div class="bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-700 rounded-lg p-4 mb-6">
      <h2 class="text-sm font-semibold text-indigo-800 dark:text-indigo-300 mb-3 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Vous remplacez actuellement
      </h2>
      <div class="space-y-2">
        <% @as_delegatee.each do |d| %>
          <div class="flex items-center justify-between bg-white dark:bg-gray-800 rounded px-3 py-2 text-sm">
            <div class="flex items-center gap-2">
              <span class="font-medium text-gray-900 dark:text-gray-100"><%= d.delegator.full_name %></span>
              <span class="text-gray-400">·</span>
              <span class="text-indigo-600 dark:text-indigo-400 font-medium"><%= d.role.humanize %></span>
            </div>
            <span class="text-xs text-gray-500 dark:text-gray-400">jusqu'au <%= l(d.ends_at.to_date, format: :long) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Délégations émises %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
    <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700">
      <h2 class="text-sm font-semibold text-gray-700 dark:text-gray-300">Délégations émises</h2>
    </div>

    <% if @as_delegator.empty? %>
      <div class="px-4 py-10 text-center">
        <svg class="mx-auto w-10 h-10 text-gray-300 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
        </svg>
        <p class="text-sm text-gray-400 dark:text-gray-500 italic">Aucune délégation créée</p>
      </div>
    <% else %>
      <ul class="divide-y divide-gray-100 dark:divide-gray-700">
        <% @as_delegator.each do |d| %>
          <% active = d.active? && d.starts_at <= Time.current && d.ends_at >= Time.current %>
          <li class="flex items-center justify-between px-4 py-3 gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-medium text-sm text-gray-900 dark:text-gray-100"><%= d.delegatee.full_name %></span>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300">
                  <%= d.role.humanize %>
                </span>
                <% if active %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300">En cours</span>
                <% elsif d.ends_at < Time.current %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 dark:bg-gray-700 dark:text-gray-400">Expirée</span>
                <% elsif !d.active? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400">Révoquée</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300">À venir</span>
                <% end %>
              </div>
              <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">
                Du <%= l(d.starts_at.to_date, format: :long) %> au <%= l(d.ends_at.to_date, format: :long) %>
                <% if d.reason.present? %> · <%= d.reason %><% end %>
              </p>
            </div>
            <% if d.active? && d.ends_at >= Time.current && policy(d).destroy? %>
              <%= button_to employee_delegation_path(d), method: :delete,
                  data: { turbo_confirm: "Révoquer cette délégation ?" },
                  class: "flex-shrink-0 text-xs text-red-500 hover:text-red-700 dark:hover:text-red-400 font-medium" do %>
                Révoquer
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

</div>
