<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center mb-2">
      <%= link_to dashboard_path, class: "text-gray-500 hover:text-gray-700 mr-3" do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Demandes en attente</h1>
    </div>
    <p class="text-sm text-gray-600">Approuvez ou refusez les demandes de congés de votre équipe</p>
  </div>

  <!-- Stats Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-orange-50 border-2 border-orange-500 rounded-lg p-4">
      <p class="text-sm font-medium text-orange-800">En attente</p>
      <p class="text-3xl font-bold text-orange-900 mt-1">
        <%= @pending_requests.count %>
      </p>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
      <p class="text-sm font-medium text-green-800">Approuvées ce mois</p>
      <p class="text-3xl font-bold text-green-900 mt-1">
        <%= @approved_this_month %>
      </p>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
      <p class="text-sm font-medium text-blue-800">Jours totaux demandés</p>
      <p class="text-3xl font-bold text-blue-900 mt-1">
        <%= @pending_requests.sum(&:days_count).to_f.round(1) %>
      </p>
    </div>
  </div>

  <!-- Pending Requests -->
  <div class="space-y-4">
    <% if @pending_requests.any? %>
      <% @pending_requests.each do |request| %>
        <div class="bg-white rounded-lg shadow overflow-hidden border-l-4 border-orange-500">
          <div class="p-4 sm:p-6">
            <!-- Employee Info -->
            <div class="flex items-center mb-4">
              <div class="h-12 w-12 rounded-full bg-indigo-100 flex items-center justify-center">
                <span class="text-indigo-700 font-semibold text-lg">
                  <%= request.employee.first_name[0] %><%= request.employee.last_name[0] %>
                </span>
              </div>
              <div class="ml-4">
                <h3 class="text-lg font-semibold text-gray-900">
                  <%= request.employee.full_name %>
                </h3>
                <p class="text-sm text-gray-600">
                  <%= request.employee.department || 'Employé' %>
                </p>
              </div>
            </div>

            <!-- Request Details -->
            <div class="bg-gray-50 rounded-lg p-4 mb-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <p class="text-xs text-gray-600 font-medium mb-1">Type de congé</p>
                  <p class="text-sm font-semibold text-gray-900">
                    <%= LeaveBalance.leave_type_name(request.leave_type) %>
                  </p>
                </div>

                <div>
                  <p class="text-xs text-gray-600 font-medium mb-1">Période</p>
                  <p class="text-sm font-semibold text-gray-900">
                    <%= l(request.start_date, format: :short) %>
                    <% if request.start_date != request.end_date %>
                      → <%= l(request.end_date, format: :short) %>
                    <% end %>
                  </p>
                </div>

                <div>
                  <p class="text-xs text-gray-600 font-medium mb-1">Durée</p>
                  <p class="text-sm font-semibold text-gray-900">
                    <%= request.days_count.to_f.round(1) %> jour<%= 's' if request.days_count > 1 %>
                  </p>
                </div>

                <div>
                  <p class="text-xs text-gray-600 font-medium mb-1">Demandé</p>
                  <p class="text-sm font-semibold text-gray-900">
                    <%= time_ago_in_words(request.created_at) %>
                  </p>
                </div>

                <div class="sm:col-span-2">
                  <p class="text-xs text-gray-600 font-medium mb-1">Solde actuel (<%= LeaveBalance.leave_type_name(request.leave_type) %>)</p>
                  <% balance = request.employee.leave_balances.find_by(leave_type: request.leave_type) %>
                  <p class="text-sm font-semibold <%= balance && balance.balance >= request.days_count ? 'text-green-700' : 'text-red-700' %>">
                    <%= balance&.balance&.to_f&.round(1) || 0 %> jours disponibles
                    <% if balance && balance.balance < request.days_count %>
                      <span class="text-xs font-normal text-red-600 ml-2">
                        (Solde insuffisant: <%= (request.days_count - balance.balance).round(1) %> jours en négatif)
                      </span>
                    <% end %>
                  </p>
                </div>
              </div>

              <% if request.reason.present? %>
                <div class="mt-4 pt-4 border-t border-gray-200">
                  <p class="text-xs text-gray-600 font-medium mb-1">Motif</p>
                  <p class="text-sm text-gray-700 italic">"<%= request.reason %>"</p>
                </div>
              <% end %>
            </div>

            <!-- Team Impact (if available) -->
            <% team_absences = @team_absences_by_date[request.start_date..request.end_date] %>
            <% if team_absences && team_absences.any? %>
              <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4">
                <div class="flex items-start">
                  <svg class="w-5 h-5 text-yellow-600 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <p class="text-sm font-medium text-yellow-800">Autres absences sur cette période</p>
                    <p class="text-xs text-yellow-700 mt-1">
                      <%= team_absences.count %> autre<%= 's' if team_absences.count > 1 %> membre<%= 's' if team_absences.count > 1 %> de l'équipe absent<%= 's' if team_absences.count > 1 %>
                    </p>
                  </div>
                </div>
              </div>
            <% end %>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-3">
              <%= button_to approve_leave_request_path(request), method: :post,
                class: "flex-1 inline-flex justify-center items-center px-4 py-3 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 transition-colors",
                data: { confirm: "Approuver cette demande de #{request.days_count.to_f.round(1)} jour(s) pour #{request.employee.full_name} ?" } do %>
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Approuver
              <% end %>

              <%= link_to reject_form_leave_request_path(request),
                class: "flex-1 inline-flex justify-center items-center px-4 py-3 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 transition-colors" do %>
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Refuser
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="bg-white rounded-lg shadow text-center py-12 px-4">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900">Aucune demande en attente</h3>
        <p class="mt-1 text-sm text-gray-500">
          Toutes les demandes de congés ont été traitées.
        </p>
        <div class="mt-6">
          <%= link_to team_calendar_leave_requests_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            Voir le calendrier d'équipe
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Quick Links -->
  <div class="mt-6 flex gap-3">
    <%= link_to leave_requests_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
      Mes congés
    <% end %>
    <%= link_to team_calendar_leave_requests_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      Calendrier d'équipe
    <% end %>
  </div>
</div>
