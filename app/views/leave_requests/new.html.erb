<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <div class="flex items-center mb-2">
      <%= link_to leave_requests_path, class: "text-muted-soft dark:text-white/50 hover:text-text-deep dark:text-white/70 mr-3" do %>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white">Nouvelle demande de congé</h1>
    </div>
    <p class="text-sm text-muted-soft dark:text-white/50">Remplissez le formulaire pour soumettre votre demande</p>
  </div>

  <!-- Available Balances Card -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-md p-6 mb-6 border border-border-soft dark:border-white/10">
    <h2 class="text-sm font-semibold text-text-deep dark:text-white mb-3 uppercase tracking-wide">Soldes disponibles</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% @leave_balances.each do |balance| %>
        <%
          # Map leave types to Tailwind gradient classes
          gradient_class = case balance.leave_type
          when 'cp' then 'bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900 dark:to-blue-700 border-2 border-blue-300 dark:border-blue-500'
          when 'rtt' then 'bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900 dark:to-green-700 border-2 border-green-300 dark:border-green-500'
          when 'maladie' then 'bg-gradient-to-br from-red-50 to-red-100 dark:from-red-900 dark:to-red-700 border-2 border-red-300 dark:border-red-500'
          else 'bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900 dark:to-purple-700 border-2 border-primary/30 dark:border-primary/30'
          end
          value_color = case balance.leave_type
          when 'cp' then 'text-primary dark:text-white'
          when 'rtt' then 'text-green-900 dark:text-white'
          when 'maladie' then 'text-red-900 dark:text-white'
          else 'text-primary dark:text-white'
          end
          text_color = case balance.leave_type
          when 'cp' then 'text-primary dark:text-white'
          when 'rtt' then 'text-green-800 dark:text-white'
          when 'maladie' then 'text-red-800 dark:text-white'
          else 'text-primary dark:text-white'
          end
        %>
        <div class="<%= gradient_class %> text-center rounded-lg p-3 shadow-md">
          <p class="text-2xl font-bold <%= value_color %>">
            <%= balance.balance.to_f.round(1) %>
          </p>
          <p class="text-xs <%= text_color %> font-medium opacity-90">
            <%= LeaveBalance.leave_type_name(balance.leave_type) %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Form -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-6">
    <%= form_with model: @leave_request, local: true, class: "space-y-6" do |f| %>
      <!-- Error Messages -->
      <% if @leave_request.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900 border border-red-200 dark:border-red-700 rounded-md p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
                <%= pluralize(@leave_request.errors.count, "erreur") %> empêche<%= 'nt' if @leave_request.errors.count > 1 %> l'enregistrement:
              </h3>
              <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                <ul class="list-disc pl-5 space-y-1">
                  <% @leave_request.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Leave Type -->
      <div>
        <%= f.label :leave_type, "Type de congé", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
        <%= f.select :leave_type,
          options_for_select(
            LeaveBalance::LEAVE_TYPES.map { |k, v| [v, k] },
            @leave_request.leave_type
          ),
          { include_blank: "Sélectionnez un type..." },
          class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
          required: true
        %>
      </div>

      <!-- Date Range -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :start_date, "Date de début", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
          <%= f.date_field :start_date,
            class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
            min: Date.current,
            required: true
          %>
        </div>

        <div>
          <%= f.label :end_date, "Date de fin", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
          <%= f.date_field :end_date,
            class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm",
            min: Date.current,
            required: true
          %>
        </div>
      </div>

      <!-- Half Days (AM/PM) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :start_half_day, "Demi-journée de début", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
          <%= f.select :start_half_day,
            options_for_select(
              [
                ['Journée complète', nil],
                ['Matin uniquement (AM)', 'am'],
                ['Après-midi uniquement (PM)', 'pm']
              ],
              @leave_request.start_half_day
            ),
            {},
            class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm"
          %>
          <p class="mt-1 text-xs text-muted-soft dark:text-white/50">Pour un congé d'une demi-journée</p>
        </div>

        <div>
          <%= f.label :end_half_day, "Demi-journée de fin", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
          <%= f.select :end_half_day,
            options_for_select(
              [
                ['Journée complète', nil],
                ['Matin uniquement (AM)', 'am'],
                ['Après-midi uniquement (PM)', 'pm']
              ],
              @leave_request.end_half_day
            ),
            {},
            class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white shadow-sm focus:border-primary focus:ring-primary sm:text-sm"
          %>
          <p class="mt-1 text-xs text-muted-soft dark:text-white/50">Si différent du premier jour</p>
        </div>
      </div>

      <!-- Reason -->
      <div>
        <%= f.label :reason, "Motif (optionnel)", class: "block text-sm font-medium text-text-deep dark:text-white/70 mb-2" %>
        <%= f.text_area :reason,
          rows: 3,
          placeholder: "Expliquez brièvement la raison de votre demande...",
          class: "block w-full rounded-md border-border-soft dark:border-white/15 bg-surface dark:bg-surface/10 text-text-deep dark:text-white placeholder-gray-400 dark:placeholder-gray-500 shadow-sm focus:border-primary focus:ring-primary sm:text-sm"
        %>
      </div>

      <!-- Info Box -->
      <div class="bg-primary/10 dark:bg-primary/10 border border-blue-200 dark:border-blue-700 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-primary dark:text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <p class="text-sm text-primary dark:text-primary">
              <strong>À savoir:</strong> Les demandes de 2 jours ou moins avec un solde suffisant (≥15 jours) sont auto-approuvées.
              Les autres nécessitent l'approbation de votre manager.
            </p>
          </div>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-3">
        <%= link_to "Annuler", leave_requests_path,
          class: "inline-flex justify-center items-center px-4 py-2 border border-border-soft dark:border-white/15 shadow-sm text-sm font-medium rounded-md text-text-deep dark:text-white/70 bg-surface dark:bg-surface/10 hover:bg-bg-soft dark:hover:bg-gray-600"
        %>
        <%= f.submit "Soumettre la demande",
          class: "inline-flex justify-center items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-primary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
        %>
      </div>
    <% end %>
  </div>

  <!-- Help Section -->
  <div class="mt-6 bg-bg-soft dark:bg-[#13121F] rounded-lg p-6">
    <h3 class="text-sm font-semibold text-text-deep dark:text-white mb-3">Règles de gestion des congés</h3>
    <ul class="text-sm text-muted-soft dark:text-white/50 space-y-2">
      <li class="flex items-start">
        <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><strong>Congés Payés (CP):</strong> 2,5 jours acquis par mois, maximum 30 jours par an</span>
      </li>
      <li class="flex items-start">
        <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><strong>RTT:</strong> Basé sur les heures supplémentaires au-delà de 35h/semaine</span>
      </li>
      <li class="flex items-start">
        <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><strong>Délai:</strong> Soumettez vos demandes au moins 48h à l'avance (sauf urgence)</span>
      </li>
      <li class="flex items-start">
        <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><strong>Congés obligatoires:</strong> 10 jours consécutifs minimum par an (loi française)</span>
      </li>
    </ul>
  </div>
</div>
