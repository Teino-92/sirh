<div id="onboarding_task_emp_<%= task.id %>"
     class="flex items-start gap-3 p-3 rounded-lg <%= task.completed? ? 'bg-green-50 dark:bg-green-900/10' : task.overdue? ? 'bg-red-50 dark:bg-red-900/10' : 'bg-bg-soft dark:bg-surface/10/40' %>">
  <div class="flex-shrink-0 mt-0.5">
    <% if task.completed? %>
      <span class="w-5 h-5 flex items-center justify-center rounded-full bg-green-500">
        <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
        </svg>
      </span>
    <% elsif task.overdue? %>
      <span class="w-5 h-5 flex items-center justify-center rounded-full bg-red-400">
        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
        </svg>
      </span>
    <% elsif task.done? %>
      <span class="w-5 h-5 flex items-center justify-center rounded-full bg-orange-300 dark:bg-orange-500">
        <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 8.586V5z" clip-rule="evenodd" />
        </svg>
      </span>
    <% else %>
      <span class="w-5 h-5 flex items-center justify-center rounded-full border-2 border-border-soft dark:border-white/10"></span>
    <% end %>
  </div>

  <div class="flex-1 min-w-0">
    <p class="text-sm font-medium <%= task.completed? ? 'line-through text-muted-soft dark:text-white/40' : 'text-text-deep dark:text-white' %>">
      <%= type_icons[task.task_type] %> <%= task.title %>
    </p>
    <% if task.description.present? %>
      <p class="text-xs text-muted-soft dark:text-white/50 mt-0.5"><%= task.description %></p>
    <% end %>
    <% linked = task.linked_record rescue nil %>
    <% if linked %>
      <p class="text-xs text-primary dark:text-primary/80 mt-1">
        Associé : <%= linked.try(:title) || linked.try(:name) %>
      </p>
    <% end %>

    <!-- Action / status badge for employee tasks -->
    <% if task.pending? %>
      <div class="mt-2">
        <%= button_to mark_done_employee_onboarding_employee_onboarding_task_path(onboarding, task),
              method: :patch,
              data: { turbo_stream: true },
              class: "inline-flex items-center px-3 py-1 rounded-md text-xs font-semibold text-white bg-primary hover:bg-primary/90 transition-colors" do %>
          Marquer fait
        <% end %>
      </div>
    <% elsif task.done? %>
      <div class="mt-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-300">
          En attente de validation
        </span>
      </div>
    <% end %>
  </div>

  <div class="flex-shrink-0 text-right">
    <p class="text-xs <%= task.overdue? && task.pending? ? 'text-red-600 dark:text-red-400 font-medium' : 'text-muted-soft dark:text-white/50' %>">
      <%= l(task.due_date, format: :short) %>
    </p>
  </div>
</div>
