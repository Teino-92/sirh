<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <%
    progress = @employee_onboarding.progress_percentage
    score    = @employee_onboarding.integration_score
    overdue  = @employee_onboarding.overdue_tasks.count
    type_icons = {
      'manual'        => '✓',
      'objective_30'  => '🎯',
      'objective_60'  => '🎯',
      'objective_90'  => '🎯',
      'training'      => '📚',
      'one_on_one'    => '💬'
    }
  %>

  <!-- Header card -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6 mb-6">
    <h1 class="text-2xl font-serif text-text-deep dark:text-white">Mon intégration</h1>
    <p class="text-sm text-muted-soft dark:text-white/50 mt-1">
      <%= @employee_onboarding.onboarding_template.name %>
      · Débuté le <%= l(@employee_onboarding.start_date, format: :long) %>
      <% if @employee_onboarding.active? %>
        · Jour J+<%= @employee_onboarding.day_number %>
      <% end %>
    </p>

    <!-- Score and progress -->
    <div class="mt-4 grid grid-cols-2 gap-4">
      <div class="bg-bg-soft dark:bg-surface/10/50 rounded-lg p-4 text-center">
        <div class="text-3xl font-bold <%= score >= 70 ? 'text-green-600 dark:text-green-400' : score >= 40 ? 'text-warning dark:text-warning' : 'text-red-600 dark:text-red-400' %>">
          <%= score %>
        </div>
        <div class="text-xs text-muted-soft dark:text-white/50 mt-1">Score d'intégration</div>
      </div>
      <div class="bg-bg-soft dark:bg-surface/10/50 rounded-lg p-4 text-center">
        <div class="text-3xl font-bold text-primary dark:text-primary/80"><%= progress %>%</div>
        <div class="text-xs text-muted-soft dark:text-white/50 mt-1">Progression</div>
      </div>
    </div>

    <div class="mt-4">
      <div class="w-full bg-bg-soft dark:bg-surface/10 rounded-full h-2.5">
        <div class="bg-primary h-2.5 rounded-full" style="width: <%= progress %>%"></div>
      </div>
    </div>

    <% if overdue > 0 %>
      <p class="mt-3 text-sm text-orange-600 dark:text-orange-400 font-medium">
        ⚠ <%= overdue %> tâche<%= 's' if overdue > 1 %> en retard — pensez à les compléter rapidement.
      </p>
    <% end %>
  </div>

  <!-- My tasks (employee role only) -->
  <%
    my_tasks = @employee_onboarding.onboarding_tasks.where(assigned_to_role: 'employee').order(:due_date)
  %>

  <% if my_tasks.any? %>
    <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6 mb-6">
      <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-4">Mes tâches</h2>
      <div class="space-y-3">
        <% my_tasks.each do |task| %>
          <%= render 'employee_onboardings/task_row', task: task, onboarding: @employee_onboarding, type_icons: type_icons %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Manager info -->
  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-6">
    <h2 class="text-lg font-semibold text-text-deep dark:text-white mb-2">Votre manager référent</h2>
    <p class="text-text-deep dark:text-white/70"><%= @employee_onboarding.manager.full_name %></p>
    <% if @employee_onboarding.manager.email.present? %>
      <p class="text-sm text-primary dark:text-primary/80 mt-1">
        <%= mail_to @employee_onboarding.manager.email, @employee_onboarding.manager.email %>
      </p>
    <% end %>
  </div>
</div>
