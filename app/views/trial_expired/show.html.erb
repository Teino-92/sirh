<div class="min-h-screen bg-gray-50 dark:bg-gray-900 flex items-center justify-center px-4">
  <div class="max-w-md w-full text-center">

    <!-- Logo -->
    <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-8 w-auto mx-auto mb-8">

    <!-- Icone horloge -->
    <div class="mx-auto w-16 h-16 bg-amber-100 dark:bg-amber-900/30 rounded-full flex items-center justify-center mb-6">
      <svg class="w-8 h-8 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
      Votre essai gratuit est terminé
    </h1>

    <p class="text-gray-600 dark:text-gray-400 mb-2">
      L'essai gratuit de <strong class="text-gray-900 dark:text-white"><%= current_employee.organization.name %></strong>
      a expiré le <%= current_employee.organization.trial_ends_at.strftime('%d/%m/%Y') %>.
    </p>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      Vos données sont conservées. Contactez-nous pour continuer à utiliser Izi-RH.
    </p>

    <!-- CTA -->
    <a href="mailto:bonjour@izi-rh.com?subject=Abonnement%20Izi-RH%20-%20<%= CGI.escape(current_employee.organization.name) %>"
       class="inline-flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors w-full mb-3">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      Contacter l'équipe Izi-RH
    </a>

    <!-- Déconnexion -->
    <%= button_to destroy_employee_session_path, method: :delete,
          class: "w-full text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 bg-transparent border border-gray-200 dark:border-gray-700 rounded-lg py-2 cursor-pointer transition-colors" do %>
      Se déconnecter
    <% end %>

  </div>
</div>
