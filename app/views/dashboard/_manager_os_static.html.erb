<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6"
     data-controller="tour"
     data-tour-name-value="manager-dashboard"
     data-tour-autostart-value="true">

  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">
      Bonjour, <%= @employee.first_name %> 👋
    </h1>
    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
      <%= l(Date.current, format: :long) %> · <%= @employee.organization.name %>
    </p>
  </div>

  <!-- 4 summary cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">

    <!-- Onboardings actifs -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5"
         data-tour-step="1"
         data-tour-title="Onboardings actifs"
         data-tour-description="Suivez l'intégration de vos nouveaux collaborateurs en temps réel.">
      <div class="flex items-center justify-between mb-3">
        <div class="p-2 bg-teal-100 dark:bg-teal-500 rounded-lg">
          <svg class="w-5 h-5 text-teal-600 dark:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <%= link_to manager_employee_onboardings_path, class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium" do %>
          Voir tout
        <% end %>
      </div>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @active_onboardings&.count || 0 %></p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Onboarding<%= 's' if (@active_onboardings&.count || 0) != 1 %> actif<%= 's' if (@active_onboardings&.count || 0) != 1 %></p>
    </div>

    <!-- Prochains 1:1 -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5"
         data-tour-step="2"
         data-tour-title="Entretiens 1:1"
         data-tour-description="Planifiez et suivez vos entretiens individuels avec chaque membre.">
      <div class="flex items-center justify-between mb-3">
        <div class="p-2 bg-purple-100 dark:bg-purple-900 rounded-lg">
          <svg class="w-5 h-5 text-purple-600 dark:text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
          </svg>
        </div>
        <%= link_to manager_one_on_ones_path, class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium" do %>
          Voir tout
        <% end %>
      </div>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @upcoming_one_on_ones&.count || 0 %></p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">1:1 cette semaine</p>
    </div>

    <!-- Objectifs en cours -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5"
         data-tour-step="3"
         data-tour-title="Objectifs équipe"
         data-tour-description="Visualisez les objectifs en cours et leur progression.">
      <div class="flex items-center justify-between mb-3">
        <div class="p-2 bg-blue-100 dark:bg-blue-900 rounded-lg">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <%= link_to manager_objectives_path(status: :in_progress), class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium" do %>
          Voir tout
        <% end %>
      </div>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @team_active_objectives_count %></p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Objectif<%= 's' if @team_active_objectives_count != 1 %> en cours</p>
    </div>

    <!-- Formations en cours -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-5"
         data-tour-step="4"
         data-tour-title="Formations"
         data-tour-description="Suivez les formations assignées à votre équipe.">
      <div class="flex items-center justify-between mb-3">
        <div class="p-2 bg-yellow-100 dark:bg-yellow-900 rounded-lg">
          <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
        </div>
        <%= link_to manager_trainings_path, class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium" do %>
          Voir tout
        <% end %>
      </div>
      <p class="text-3xl font-bold text-gray-900 dark:text-gray-100"><%= @team_pending_training_count %></p>
      <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Formation<%= 's' if @team_pending_training_count != 1 %> en cours</p>
    </div>

  </div>

  <!-- Two column layout: Onboardings + Prochains 1:1 -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

    <!-- Onboardings actifs -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
      <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Onboardings en cours</h2>
        <%= link_to manager_employee_onboardings_path, class: "text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800" do %>
          Tous
        <% end %>
      </div>
      <div class="p-5">
        <% if @active_onboardings&.any? %>
          <div class="space-y-3">
            <% @active_onboardings.limit(4).each do |onboarding| %>
              <div class="flex items-center justify-between">
                <div class="flex items-center min-w-0">
                  <div class="h-8 w-8 rounded-full bg-teal-100 dark:bg-teal-600 flex items-center justify-center flex-shrink-0">
                    <span class="text-teal-800 dark:text-white text-xs font-bold">
                      <%= onboarding.employee.first_name[0] %><%= onboarding.employee.last_name[0] %>
                    </span>
                  </div>
                  <div class="ml-3 min-w-0">
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate"><%= onboarding.employee.full_name %></p>
                    <% tasks = onboarding.onboarding_tasks.to_a %>
                    <p class="text-xs text-gray-500 dark:text-gray-400">
                      <%= tasks.count { |t| t.completed_at.present? } %> / <%= tasks.size %> tâches
                    </p>
                  </div>
                </div>
                <%= link_to manager_employee_onboarding_path(onboarding), class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline ml-2 flex-shrink-0" do %>
                  Voir
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-6">Aucun onboarding actif</p>
        <% end %>
      </div>
    </div>

    <!-- Prochains 1:1 -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700">
      <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Prochains 1:1</h2>
        <%= link_to manager_one_on_ones_path, class: "text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800" do %>
          Tous
        <% end %>
      </div>
      <div class="p-5">
        <% if @upcoming_one_on_ones&.any? %>
          <div class="space-y-3">
            <% @upcoming_one_on_ones.each do |meeting| %>
              <div class="flex items-center justify-between p-3 bg-purple-50 dark:bg-gray-700 rounded-lg">
                <div class="flex items-center min-w-0">
                  <div class="h-8 w-8 rounded-full bg-purple-200 dark:bg-purple-600 flex items-center justify-center flex-shrink-0">
                    <span class="text-purple-800 dark:text-white text-xs font-bold">
                      <%= meeting.employee.first_name[0] %><%= meeting.employee.last_name[0] %>
                    </span>
                  </div>
                  <div class="ml-2 min-w-0">
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate"><%= meeting.employee.full_name %></p>
                    <p class="text-xs text-gray-500 dark:text-gray-400"><%= l(meeting.scheduled_at, format: :short) %></p>
                  </div>
                </div>
                <div class="flex items-center gap-2 ml-2 flex-shrink-0">
                  <%= link_to manager_one_on_one_path(meeting), class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium" do %>
                    Voir
                  <% end %>
                  <%= link_to new_manager_one_on_one_path, class: "text-xs text-gray-500 dark:text-gray-400 hover:underline" do %>
                    + 1:1
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6">
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Aucun 1:1 cette semaine</p>
            <%= link_to new_manager_one_on_one_path, class: "inline-flex items-center text-sm text-indigo-600 dark:text-indigo-400 hover:underline" do %>
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              Planifier un 1:1
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <!-- Quick access row -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4"
       data-tour-step="5"
       data-tour-title="Accès rapides"
       data-tour-description="Accédez rapidement à Mon équipe, Objectifs et Formations.">
    <%= link_to manager_team_schedules_path, class: "bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 flex items-center gap-3 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors group" do %>
      <div class="p-2 bg-indigo-50 dark:bg-indigo-900/40 rounded-lg group-hover:bg-indigo-100 dark:group-hover:bg-indigo-900/60 transition-colors">
        <svg class="w-5 h-5 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">Mon équipe</p>
        <p class="text-xs text-gray-500 dark:text-gray-400"><%= @employee.team_members.count %> membre<%= 's' if @employee.team_members.count != 1 %></p>
      </div>
    <% end %>

    <%= link_to manager_objectives_path, class: "bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 flex items-center gap-3 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors group" do %>
      <div class="p-2 bg-blue-50 dark:bg-blue-900/40 rounded-lg group-hover:bg-blue-100 dark:group-hover:bg-blue-900/60 transition-colors">
        <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">Objectifs équipe</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">Suivi et progression</p>
      </div>
    <% end %>

    <%= link_to manager_trainings_path, class: "bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 flex items-center gap-3 hover:border-indigo-300 dark:hover:border-indigo-600 transition-colors group" do %>
      <div class="p-2 bg-yellow-50 dark:bg-yellow-900/40 rounded-lg group-hover:bg-yellow-100 dark:group-hover:bg-yellow-900/60 transition-colors">
        <svg class="w-5 h-5 text-yellow-600 dark:text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">Formations</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">Catalogue et assignations</p>
      </div>
    <% end %>
  </div>

</div>
