<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Welcome Header -->
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">
      Bonjour, <%= @employee.first_name %> 👋
    </h1>
    <p class="text-sm text-gray-600 mt-1">
      <%= l(Date.current, format: :long) %>
    </p>
  </div>

  <!-- Quick Action: Clock In/Out -->
  <% if @current_shift %>
    <!-- Currently Clocked In -->
    <div class="bg-green-50 border-2 border-green-500 rounded-lg p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium text-green-800">Vous êtes pointé(e) depuis</p>
          <p class="text-3xl font-bold text-green-900">
            <%= l(@current_shift.clock_in, format: :short) %>
          </p>
          <p class="text-sm text-green-700 mt-1">
            <%= distance_of_time_in_words(Time.current, @current_shift.clock_in) %>
          </p>
        </div>
        <%= button_to clock_out_time_entries_path, method: :post, class: "bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors shadow-lg" do %>
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Pointer la sortie
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <!-- Clock In Button -->
    <div class="bg-gradient-to-r from-indigo-500 to-purple-600 rounded-lg p-6 mb-6 text-white shadow-xl">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-sm font-medium opacity-90">Prêt(e) à commencer ?</p>
          <p class="text-2xl font-bold mt-1">Pointez votre arrivée</p>
        </div>
        <%= button_to clock_in_time_entries_path, method: :post, class: "bg-white hover:bg-gray-100 text-indigo-600 font-semibold py-3 px-6 rounded-lg transition-colors shadow-lg" do %>
          <div class="flex items-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Pointer l'entrée
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Dashboard Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column: Main Info -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Leave Balances -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Soldes de congés</h2>
          <%= link_to "Demander", new_leave_request_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <% @leave_balances.each do |balance| %>
            <div class="bg-gray-50 rounded-lg p-4">
              <p class="text-xs text-gray-600 font-medium"><%= LeaveBalance.leave_type_name(balance.leave_type) %></p>
              <p class="text-2xl font-bold text-gray-900 mt-1">
                <%= balance.balance.to_f.round(1) %>
                <span class="text-sm font-normal text-gray-600">jours</span>
              </p>
              <% if balance.expiring_soon? %>
                <p class="text-xs text-orange-600 mt-1 flex items-center">
                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                  Expire bientôt
                </p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- This Week's Hours -->
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-gray-900">Cette semaine</h2>
          <%= link_to "Voir tout", time_entries_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium" %>
        </div>

        <div class="flex items-end justify-between">
          <div>
            <p class="text-4xl font-bold text-gray-900">
              <%= @weekly_hours.round(1) %>h
            </p>
            <p class="text-sm text-gray-600 mt-1">
              sur <%= @expected_hours %>h attendues
            </p>
          </div>

          <!-- Progress Bar -->
          <div class="flex-1 ml-6">
            <div class="h-8 bg-gray-200 rounded-full overflow-hidden">
              <% percentage = [(@weekly_hours / @expected_hours * 100).to_i, 100].min %>
              <div class="h-full bg-indigo-600 rounded-full transition-all" style="width: <%= percentage %>%"></div>
            </div>
            <p class="text-xs text-gray-600 text-right mt-1"><%= percentage %>%</p>
          </div>
        </div>
      </div>

      <!-- Upcoming Leaves (if any) -->
      <% if @upcoming_leaves.any? %>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Prochains congés</h2>
          <div class="space-y-3">
            <% @upcoming_leaves.each do |leave| %>
              <div class="flex items-center justify-between p-3 bg-blue-50 rounded-lg">
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-blue-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <div>
                    <p class="font-medium text-gray-900">
                      <%= l(leave.start_date, format: :short) %> - <%= l(leave.end_date, format: :short) %>
                    </p>
                    <p class="text-sm text-gray-600">
                      <%= leave.days_count.to_f.round(1) %> jours • <%= LeaveBalance.leave_type_name(leave.leave_type) %>
                    </p>
                  </div>
                </div>
                <span class="px-2 py-1 text-xs font-medium text-green-800 bg-green-100 rounded">
                  <%= leave.status == 'auto_approved' ? 'Auto-approuvé' : 'Approuvé' %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Right Column: Side Info -->
    <div class="space-y-6">
      <!-- Manager Pending Approvals (if manager) -->
      <% if @employee.manager? && @pending_approvals_count > 0 %>
        <div class="bg-orange-50 border-2 border-orange-500 rounded-lg p-6">
          <div class="flex items-center mb-3">
            <svg class="w-6 h-6 text-orange-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <h3 class="font-semibold text-orange-900">Action requise</h3>
          </div>
          <p class="text-orange-800 mb-4">
            <%= @pending_approvals_count %> demande<%= 's' if @pending_approvals_count > 1 %> de congé en attente
          </p>
          <%= link_to pending_approvals_leave_requests_path, class: "block w-full bg-orange-600 hover:bg-orange-700 text-white text-center font-medium py-2 px-4 rounded-lg transition-colors" do %>
            Voir les demandes
          <% end %>
        </div>
      <% end %>

      <!-- My Pending Requests -->
      <% if @my_pending_requests.any? %>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Mes demandes en cours</h2>
          <div class="space-y-3">
            <% @my_pending_requests.each do |request| %>
              <div class="p-3 bg-yellow-50 rounded-lg border border-yellow-200">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-medium text-yellow-800 bg-yellow-200 px-2 py-1 rounded">
                    En attente
                  </span>
                  <span class="text-xs text-gray-600">
                    <%= time_ago_in_words(request.created_at) %>
                  </span>
                </div>
                <p class="text-sm font-medium text-gray-900">
                  <%= l(request.start_date, format: :short) %> - <%= l(request.end_date, format: :short) %>
                </p>
                <p class="text-xs text-gray-600">
                  <%= request.days_count.to_f.round(1) %> jours • <%= LeaveBalance.leave_type_name(request.leave_type) %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Today's Schedule -->
      <% if @today_schedule %>
        <div class="bg-white rounded-lg shadow p-6">
          <h2 class="text-lg font-semibold text-gray-900 mb-4">Horaire du jour</h2>
          <div class="flex items-center">
            <svg class="w-8 h-8 text-indigo-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
              <p class="text-2xl font-bold text-gray-900"><%= @today_schedule %></p>
              <p class="text-sm text-gray-600">Horaire prévu</p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Quick Links -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Accès rapides</h2>
        <div class="space-y-2">
          <%= link_to time_entries_path, class: "flex items-center p-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" do %>
            <svg class="w-5 h-5 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="font-medium">Mes pointages</span>
          <% end %>

          <%= link_to leave_requests_path, class: "flex items-center p-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" do %>
            <svg class="w-5 h-5 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span class="font-medium">Mes congés</span>
          <% end %>

          <% if @employee.manager? %>
            <%= link_to pending_approvals_leave_requests_path, class: "flex items-center p-3 text-gray-700 hover:bg-gray-50 rounded-lg transition-colors" do %>
              <svg class="w-5 h-5 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              <span class="font-medium">Mon équipe</span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
