<%
  layout  = @employee.dashboard_layout
  order   = layout['order']
  hidden  = layout['hidden']
  sizes   = layout['sizes']
%>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6"
     data-controller="dashboard-customizer"
     data-dashboard-customizer-save-url-value="<%= dashboard_layout_profile_path %>">

  <!-- Header row -->
  <div class="flex items-baseline justify-between gap-4 mb-6">
    <div>
      <div class="flex items-baseline gap-2 mb-1">
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">
          Bonjour, <%= @employee.first_name %> 👋
        </h1>
        <span class="text-sm text-gray-500 dark:text-gray-400">· <%= @employee.organization.name %></span>
      </div>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        <%= l(Date.current, format: :long) %>
      </p>
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      <button type="button"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
              data-dashboard-customizer-target="customizeBtn"
              data-action="click->dashboard-customizer#enterEditMode">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Personnaliser
      </button>

      <button type="button"
              style="display:none"
              class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-sm font-medium text-white transition-colors shadow"
              data-dashboard-customizer-target="saveBtn"
              data-action="click->dashboard-customizer#save">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Sauvegarder
      </button>
    </div>
  </div>

  <!-- Feedback toast -->
  <div class="hidden fixed bottom-4 right-4 z-50 px-4 py-2 rounded-lg shadow-lg text-sm font-medium text-white"
       data-dashboard-customizer-target="feedback"></div>

  <!-- Dashboard grid — flex-wrap, same layout in both view and edit mode -->
  <div class="flex flex-wrap" data-dashboard-customizer-target="grid">

    <% order.each do |card_id| %>
      <% next unless @employee.dashboard_card_permitted?(card_id) %>
      <%
        size      = sizes.fetch(card_id, 'normal')
        is_hidden = hidden.include?(card_id)
        wide      = size == 'wide'
      %>
      <div class="dashboard-card <%= is_hidden ? 'dashboard-card--hidden' : '' %>"
           style="width:<%= wide ? '66.666%' : '33.333%' %>; padding:0 12px 24px;"
           data-dashboard-customizer-target="card"
           data-card-id="<%= card_id %>"
           data-card-size="<%= size %>"
           data-card-hidden="<%= is_hidden %>">

        <!-- Wrapper gives position:relative context for the edit chrome -->
        <div class="relative pt-5">

          <!-- Edit chrome: hidden until edit mode -->
          <div class="dashboard-edit-chrome" style="display:none; position:absolute; top:0; left:0; right:0; z-index:10; align-items:center; justify-content:space-between;">
            <!-- Drag handle -->
            <div class="cursor-grab active:cursor-grabbing select-none touch-none p-1 bg-white dark:bg-gray-700 rounded shadow border border-gray-200 dark:border-gray-600 text-gray-400 hover:text-indigo-600"
                 data-drag-handle>
              <svg class="w-4 h-4 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
              </svg>
            </div>

            <!-- Normal / Large + eye -->
            <div class="flex items-center gap-1">
              <div class="flex rounded overflow-hidden border border-gray-200 dark:border-gray-600 text-xs select-none">
                <button type="button"
                        class="px-2 py-1 font-medium transition-colors <%= !wide ? 'bg-indigo-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %>"
                        data-size-btn="normal"
                        data-action="click->dashboard-customizer#setSize"
                        data-dashboard-customizer-size-param="normal">Normal</button>
                <button type="button"
                        class="px-2 py-1 font-medium border-l border-gray-200 dark:border-gray-600 transition-colors <%= wide ? 'bg-indigo-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600' %>"
                        data-size-btn="wide"
                        data-action="click->dashboard-customizer#setSize"
                        data-dashboard-customizer-size-param="wide">Large</button>
              </div>

              <button type="button"
                      class="p-1 bg-white dark:bg-gray-700 rounded shadow border border-gray-200 dark:border-gray-600 text-gray-400 hover:text-indigo-600"
                      data-action="click->dashboard-customizer#toggleHide"
                      title="Afficher / masquer">
                <svg class="w-4 h-4 <%= is_hidden ? 'hidden' : '' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-eye-open>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                </svg>
                <svg class="w-4 h-4 <%= is_hidden ? '' : 'hidden' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-eye-closed>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Card content -->
          <div class="card-content">
            <%= render "dashboard/cards/#{card_id}", size: size, employee: @employee %>
          </div>

        </div>
      </div>
    <% end %>

  </div>
</div>
