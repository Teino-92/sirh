<%# locals: (size:, employee:) %>
<% if size == 'compact' %>
  <div class="card-inner bg-surface dark:bg-[#1C1B2E] rounded-lg shadow px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-muted-soft dark:text-white/40 truncate">Équipe présente</span>
    <span class="text-xl font-bold text-text-deep dark:text-white flex-shrink-0"><%= @team_this_week&.count || 0 %></span>
  </div>
<% else %>
  <div class="card-inner bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-5">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-semibold text-text-deep dark:text-white">Planning équipe — semaine</h2>
      <%= link_to 'Gérer', manager_team_schedules_path, class: "text-sm text-primary hover:text-primary dark:text-primary/70" %>
    </div>
    <% if @team_this_week&.any? %>
      <% week_start = @today.beginning_of_week(:monday) %>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr>
              <th class="text-left py-1 pr-3 font-medium text-muted-soft dark:text-white/40 w-20">Employé</th>
              <% %w[L Ma Me J V S D].each_with_index do |label, i| %>
                <% day_date = week_start + i.days; is_today = day_date == @today %>
                <th class="text-center py-1 px-1 font-medium <%= is_today ? 'text-primary dark:text-primary/70' : 'text-muted-soft dark:text-white/40' %>">
                  <div><%= label %></div>
                  <div class="font-normal"><%= day_date.day %>/<%= day_date.month %></div>
                </th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-soft dark:divide-white/8">
            <% @team_this_week.each do |row| %>
              <tr>
                <td class="py-2 pr-3 font-medium text-text-deep dark:text-white truncate max-w-[5rem]">
                  <%= row[:employee].first_name %>
                </td>
                <% row[:days].each_with_index do |status, i| %>
                  <% is_today = (week_start + i.days) == @today %>
                  <td class="py-2 px-1 text-center">
                    <% case status %>
                    <% when :work %>
                      <span class="inline-flex w-6 h-6 rounded-full <%= is_today ? 'bg-primary' : 'bg-green-200 dark:bg-green-700' %> items-center justify-center">
                        <svg class="w-3 h-3 <%= is_today ? 'text-white' : 'text-green-700 dark:text-green-200' %>" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                      </span>
                    <% when :leave %>
                      <span class="inline-flex w-6 h-6 rounded-full bg-orange-100 dark:bg-orange-800 items-center justify-center">
                        <svg class="w-3 h-3 text-orange-600 dark:text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
                        </svg>
                      </span>
                    <% else %>
                      <span class="inline-block w-6 h-6 rounded-full bg-bg-soft dark:bg-surface/8"></span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if size == 'wide' %>
        <div class="flex gap-4 mt-3 pt-3 border-t border-border-soft dark:border-white/10">
          <div class="flex items-center gap-1 text-xs text-muted-soft dark:text-white/40">
            <span class="inline-block w-3 h-3 rounded-full bg-green-200 dark:bg-green-700"></span> Présent
          </div>
          <div class="flex items-center gap-1 text-xs text-muted-soft dark:text-white/40">
            <span class="inline-block w-3 h-3 rounded-full bg-orange-100 dark:bg-orange-800"></span> Congé
          </div>
          <div class="flex items-center gap-1 text-xs text-muted-soft dark:text-white/40">
            <span class="inline-block w-3 h-3 rounded-full bg-bg-soft dark:bg-surface/8"></span> Repos/NC
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-muted-soft dark:text-white/30 text-center py-4">Aucune donnée d'équipe disponible</p>
    <% end %>
  </div>
<% end %>
