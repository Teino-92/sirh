<%# locals: (size:, employee:) %>
<% count = @pending_approvals_count.to_i %>
<% if size == 'compact' %>
  <div class="card-inner bg-orange-50 dark:bg-orange-900 border border-orange-400 rounded-lg px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-orange-800 dark:text-orange-200 truncate">Approbations</span>
    <span class="text-xl font-bold text-orange-700 dark:text-orange-300 flex-shrink-0"><%= count %></span>
  </div>
<% else %>
  <div class="card-inner bg-orange-50 dark:bg-orange-900 border-2 border-orange-500 dark:border-orange-600 rounded-lg p-5">
    <div class="flex items-center mb-3">
      <svg class="w-5 h-5 text-orange-600 dark:text-orange-400 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <h3 class="font-semibold text-orange-900 dark:text-orange-100">Action requise</h3>
    </div>
    <p class="text-orange-800 dark:text-orange-200 mb-3 text-sm">
      <%= count %> demande<%= 's' if count > 1 %> de congé en attente
    </p>
    <%= link_to pending_approvals_leave_requests_path, class: "block w-full bg-orange-600 hover:bg-orange-700 text-white text-center font-medium py-2 px-4 rounded-lg transition-colors text-sm" do %>
      Voir les demandes
    <% end %>
  </div>
<% end %>
