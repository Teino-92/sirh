<%# locals: (size:, employee:) %>
<% count = @pending_approvals_count.to_i %>
<div class="card-inner h-full flex flex-col rounded-lg shadow overflow-hidden <%= count > 0 ? 'bg-orange-50 dark:bg-orange-900/40 border border-orange-300 dark:border-orange-700' : 'bg-surface dark:bg-[#1C1B2E]' %>">
  <div class="flex items-center justify-between px-3 py-2 border-b <%= count > 0 ? 'border-orange-200 dark:border-orange-800' : 'border-border-soft dark:border-white/8' %> flex-shrink-0">
    <span class="text-xs font-semibold <%= count > 0 ? 'text-orange-700 dark:text-orange-300' : 'text-muted-soft dark:text-white/60' %> flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Approbations
    </span>
    <span class="text-sm font-bold <%= count > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-muted-soft dark:text-white/30' %>"><%= count %></span>
  </div>
  <div class="flex-1 flex flex-col justify-between px-3 py-2">
    <% if count > 0 %>
      <p class="text-xs text-orange-800 dark:text-orange-200 mb-2">
        <%= count %> demande<%= 's' if count > 1 %> en attente de validation
      </p>
      <%= link_to pending_approvals_leave_requests_path,
            class: "mt-auto block w-full bg-orange-600 hover:bg-orange-700 text-white text-center font-medium py-1.5 px-3 rounded-lg transition-colors text-xs" do %>
        Voir les demandes →
      <% end %>
    <% else %>
      <p class="text-xs text-muted-soft dark:text-white/30 text-center py-2">Aucune approbation en attente ✓</p>
    <% end %>
  </div>
</div>
