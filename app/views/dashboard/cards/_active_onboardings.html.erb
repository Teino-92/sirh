<%# locals: (size:, employee:) %>
<% count = @active_onboardings.count %>
<% if size == 'compact' %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">Onboardings actifs</span>
    <span class="text-xl font-bold text-indigo-700 dark:text-indigo-300 flex-shrink-0"><%= count %></span>
  </div>
<% else %>
  <div class="card-inner h-full bg-white dark:bg-gray-800 rounded-lg shadow p-3 overflow-hidden flex flex-col">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Onboardings actifs
      </h2>
      <span class="text-xs font-bold text-indigo-600 dark:text-indigo-400"><%= count %></span>
    </div>
    <% if @active_onboardings.any? %>
      <% limit = size == 'wide' ? @active_onboardings.count : 3 %>
      <div class="space-y-3 overflow-auto flex-1">
        <% @active_onboardings.first(limit).each do |ob| %>
          <%
            tasks     = ob.onboarding_tasks.to_a
            pct       = ob.progress_percentage
            total     = tasks.size
            done      = tasks.count { |t| t.status == 'completed' }
            overdue   = tasks.count { |t| t.status == 'pending' && t.due_date&.< Date.current }
            day_num   = ob.day_number
            bar_color = pct >= 75 ? 'bg-green-500' : pct >= 40 ? 'bg-indigo-500' : 'bg-yellow-500'
          %>
          <div class="border border-gray-100 dark:border-gray-700 rounded-lg p-3">
            <div class="flex items-start justify-between gap-2 mb-2">
              <div class="min-w-0">
                <p class="text-xs font-semibold text-gray-900 dark:text-gray-100 truncate"><%= ob.employee.full_name %></p>
                <% if size == 'wide' %>
                  <p class="text-xs text-gray-500 dark:text-gray-400">J<%= day_num %> · mgr : <%= ob.manager.first_name %></p>
                <% end %>
              </div>
              <% if overdue > 0 %>
                <span class="text-xs bg-red-100 dark:bg-red-900 text-red-600 dark:text-red-300 px-1.5 py-0.5 rounded flex-shrink-0">
                  <%= overdue %> en retard
                </span>
              <% end %>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex-1 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                <div class="h-full <%= bar_color %> rounded-full" style="width: <%= pct %>%"></div>
              </div>
              <span class="text-xs font-medium text-gray-600 dark:text-gray-400 flex-shrink-0"><%= pct %>%</span>
            </div>
            <% if size == 'wide' %>
              <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= done %>/<%= total %> tâches</p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-400 dark:text-gray-500 text-center py-3">Aucun onboarding en cours</p>
    <% end %>
  </div>
<% end %>
