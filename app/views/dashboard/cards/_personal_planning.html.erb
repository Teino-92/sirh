<%# locals: (size:, employee:) %>
<% if size == 'compact' %>
  <%
    today_key   = @today.strftime('%A').downcase
    today_hours = @weekly_plan&.schedule_pattern&.dig(today_key)
    label       = today_hours.present? && today_hours != 'off' ? today_hours : 'Repos'
  %>
  <div class="card-inner bg-surface dark:bg-[#1C1B2E] rounded-lg shadow px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-muted-soft dark:text-white/40 truncate">Aujourd'hui</span>
    <span class="text-base font-bold text-text-deep dark:text-white flex-shrink-0"><%= label %></span>
  </div>
<% else %>
  <div class="card-inner bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-text-deep dark:text-white">Planning de la semaine</h2>
      <%= link_to 'Voir tout', work_schedule_path(employee.id), class: "text-sm text-primary hover:text-primary dark:text-primary/70" %>
    </div>
    <% if @weekly_plan %>
      <% week_start = @today.beginning_of_week(:monday) %>

      <%# Mobile : liste verticale des jours %>
      <div class="sm:hidden space-y-1 mb-3">
        <% %w[monday tuesday wednesday thursday friday saturday sunday].each_with_index do |day_name, index| %>
          <%
            day_date    = week_start + index.days
            is_today    = day_date == @today
            hours       = @weekly_plan.schedule_pattern[day_name]
            has_worked  = @week_time_entries.key?(day_date)
            is_work_day = hours.present? && hours != 'off'
          %>
          <div class="flex items-center justify-between px-3 py-2 rounded-lg
                      <%= is_today ? 'ring-2 ring-primary bg-primary/10 dark:bg-primary/20' : (has_worked ? 'bg-green-50 dark:bg-green-900/30' : (is_work_day ? 'bg-bg-soft dark:bg-[#1C1B2E]' : 'bg-bg-soft dark:bg-[#1C1B2E] opacity-60')) %>">
            <div class="flex items-center gap-2">
              <span class="text-xs font-semibold w-8 <%= is_today ? 'text-primary dark:text-primary/70' : 'text-muted-soft dark:text-white/50' %>">
                <%= l(day_date, format: '%a') %>
              </span>
              <span class="text-xs text-muted-soft dark:text-white/30"><%= day_date.strftime('%-d/%-m') %></span>
            </div>
            <div class="flex items-center gap-1.5">
              <% if is_work_day %>
                <span class="text-xs font-medium text-text-deep dark:text-white"><%= hours %></span>
                <% if has_worked %>
                  <span class="text-xs text-green-600 dark:text-green-400">✓</span>
                <% end %>
              <% else %>
                <span class="text-xs text-muted-soft dark:text-white/30">—</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Desktop : grille 7 colonnes inchangée %>
      <div class="hidden sm:grid grid-cols-7 gap-1 mb-4">
        <% %w[monday tuesday wednesday thursday friday saturday sunday].each_with_index do |day_name, index| %>
          <%
            day_date   = week_start + index.days
            is_today   = day_date == @today
            hours      = @weekly_plan.schedule_pattern[day_name]
            has_worked = @week_time_entries.key?(day_date)
            is_work_day = hours.present? && hours != 'off'
          %>
          <div class="<%= is_today ? 'ring-2 ring-primary' : 'border border-border-soft dark:border-white/10' %>
                      <%= has_worked ? 'bg-green-50 dark:bg-green-900' : (is_work_day ? 'bg-primary/10 dark:bg-primary/20' : 'bg-bg-soft dark:bg-[#13121F]') %>
                      rounded-lg p-2 text-center">
            <p class="text-xs font-medium <%= is_today ? 'text-primary' : 'text-muted-soft dark:text-white/50' %>">
              <%= l(day_date, format: '%a') %>
            </p>
            <p class="text-xs text-muted-soft dark:text-white/40"><%= day_date.day %>/<%= day_date.month %></p>
            <% if is_work_day %>
              <p class="text-xs font-semibold <%= has_worked ? 'text-green-700 dark:text-green-300' : 'text-text-deep dark:text-white' %>">
                <%= hours %>
              </p>
              <% if has_worked %><p class="text-xs text-green-600">✓</p><% end %>
            <% else %>
              <p class="text-xs text-muted-soft">—</p>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if size == 'wide' %>
        <div class="flex items-end justify-between pt-3 border-t border-border-soft dark:border-white/10">
          <div>
            <p class="text-3xl font-bold text-text-deep dark:text-white"><%= @weekly_hours.round(1) %>h</p>
            <p class="text-sm text-muted-soft dark:text-white/50">sur <%= @expected_hours.round(1) %>h prévues</p>
          </div>
          <div class="flex-1 ml-6">
            <div class="h-6 bg-border-soft dark:bg-surface/10 rounded-full overflow-hidden">
              <% pct = [(@expected_hours > 0 ? (@weekly_hours / @expected_hours * 100).to_i : 0), 100].min %>
              <div class="h-full bg-primary rounded-full" style="width: <%= pct %>%"></div>
            </div>
            <p class="text-xs text-muted-soft dark:text-white/50 text-right mt-1"><%= pct %>%</p>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-warning/10 dark:bg-warning/10 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4 text-center">
        <p class="text-warning dark:text-warning font-medium text-sm">Aucun planning pour cette semaine</p>
        <p class="text-xs text-warning dark:text-warning mt-1">Contactez votre manager</p>
      </div>
    <% end %>
  </div>
<% end %>
