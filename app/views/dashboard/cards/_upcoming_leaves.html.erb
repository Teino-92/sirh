<%# locals: (size:, employee:) %>
<div class="card-inner h-full flex flex-col bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-gray-100 dark:border-gray-700 flex-shrink-0">
    <span class="text-xs font-semibold text-gray-600 dark:text-gray-300 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Prochains congés
    </span>
    <span class="text-xs font-bold text-blue-500"><%= @upcoming_leaves.count %></span>
  </div>
  <div class="flex-1 overflow-auto px-3 py-2">
    <% if @upcoming_leaves.any? %>
      <div class="space-y-1.5">
        <% @upcoming_leaves.first(5).each do |leave| %>
          <div class="flex items-center justify-between py-1 border-b border-gray-50 dark:border-gray-700 last:border-0">
            <div class="min-w-0">
              <p class="text-xs font-medium text-gray-900 dark:text-gray-100">
                <%= l(leave.start_date, format: :short) %> → <%= l(leave.end_date, format: :short) %>
              </p>
              <p class="text-[10px] text-gray-500 dark:text-gray-400">
                <%= leave.days_count.to_f.round(1) %>j · <%= LeaveBalance.leave_type_name(leave.leave_type) %>
              </p>
            </div>
            <span class="text-[10px] px-1.5 py-0.5 rounded flex-shrink-0 ml-2 bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300">
              <%= leave.status == 'auto_approved' ? 'Auto' : 'Approuvé' %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-400 dark:text-gray-500 text-center py-2">Aucun congé à venir</p>
    <% end %>
  </div>
</div>
