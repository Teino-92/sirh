<%# locals: (size:, employee:) %>
<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-border-soft dark:border-white/8 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Ma performance
    </span>
  </div>
  <div class="flex-1 overflow-auto px-3 py-2">
    <% if @my_active_objectives_count.to_i > 0 || @my_pending_training_count.to_i > 0 || @my_next_one_on_one %>
      <div class="space-y-1.5">
        <% if @my_active_objectives_count.to_i > 0 %>
          <%= link_to objectives_path, class: "flex items-center justify-between py-1 border-b border-border-soft dark:border-white/8 hover:text-primary dark:hover:text-primary/80 transition-colors" do %>
            <span class="text-xs text-text-deep dark:text-white/80">Objectifs actifs</span>
            <span class="text-xs font-bold text-primary dark:text-primary"><%= @my_active_objectives_count %></span>
          <% end %>
        <% end %>
        <% if @my_next_one_on_one %>
          <div class="flex items-center justify-between py-1 border-b border-border-soft dark:border-white/8">
            <span class="text-xs text-text-deep dark:text-white/80">Prochain 1:1</span>
            <span class="text-[10px] text-primary dark:text-primary"><%= l(@my_next_one_on_one.scheduled_at, format: :short) %></span>
          </div>
        <% end %>
        <% if @my_pending_training_count.to_i > 0 %>
          <%= link_to training_assignments_path, class: "flex items-center justify-between py-1 hover:text-primary transition-colors" do %>
            <span class="text-xs text-text-deep dark:text-white/80">Formations à compléter</span>
            <span class="text-xs font-bold text-warning dark:text-warning"><%= @my_pending_training_count %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-muted-soft dark:text-white/30 text-center py-2">Aucun élément en cours</p>
    <% end %>
  </div>
</div>
