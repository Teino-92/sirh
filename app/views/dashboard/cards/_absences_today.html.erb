<%# locals: (size:, employee:) %>
<% count = @absences_today.count %>
<div class="card-inner h-full flex flex-col bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-gray-100 dark:border-gray-700 flex-shrink-0">
    <span class="text-xs font-semibold text-gray-600 dark:text-gray-300 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Absences du jour
    </span>
    <span class="text-sm font-bold <%= count > 0 ? 'text-orange-500' : 'text-gray-400 dark:text-gray-500' %>"><%= count %></span>
  </div>
  <div class="flex-1 overflow-auto px-3 py-2">
    <% if @absences_today.any? %>
      <% limit = size == 'wide' ? 10 : 5 %>
      <div class="space-y-1.5">
        <% @absences_today.first(limit).each do |leave| %>
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-1.5 min-w-0">
              <div class="w-5 h-5 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center flex-shrink-0">
                <span class="text-[10px] font-semibold text-indigo-700 dark:text-indigo-300">
                  <%= leave.employee.first_name[0] %><%= leave.employee.last_name[0] %>
                </span>
              </div>
              <span class="text-xs text-gray-800 dark:text-gray-200 truncate">
                <%= leave.employee.first_name %> <%= leave.employee.last_name[0] %>.
              </span>
            </div>
            <span class="text-[10px] px-1.5 py-0.5 rounded flex-shrink-0 <%= leave.leave_type == 'Maladie' ? 'bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-300' : 'bg-blue-100 dark:bg-blue-900/40 text-blue-600 dark:text-blue-300' %>">
              <%= leave.leave_type %>
            </span>
          </div>
        <% end %>
        <% if count > limit %>
          <p class="text-[10px] text-gray-400 text-center pt-0.5">+ <%= count - limit %> autres</p>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-400 dark:text-gray-500 text-center py-2">Tout le monde est présent ✓</p>
    <% end %>
  </div>
</div>
