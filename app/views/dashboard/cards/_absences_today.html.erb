<%# locals: (size:, employee:) %>
<% count = @absences_today.count %>
<% if size == 'compact' %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">Absences du jour</span>
    <span class="text-xl font-bold <%= count > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-400' %> flex-shrink-0"><%= count %></span>
  </div>
<% else %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow p-5">
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100 flex items-center gap-2">
        <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Absences du jour
      </h2>
      <span class="text-xs font-bold <%= count > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-400' %>"><%= count %></span>
    </div>
    <% if @absences_today.any? %>
      <% limit = size == 'wide' ? 8 : 4 %>
      <div class="space-y-2">
        <% @absences_today.first(limit).each do |leave| %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2 min-w-0">
              <div class="w-7 h-7 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center flex-shrink-0">
                <span class="text-xs font-semibold text-indigo-700 dark:text-indigo-300">
                  <%= leave.employee.first_name[0] %><%= leave.employee.last_name[0] %>
                </span>
              </div>
              <span class="text-xs font-medium text-gray-900 dark:text-gray-100 truncate">
                <%= leave.employee.first_name %> <%= leave.employee.last_name[0] %>.
              </span>
            </div>
            <% if size == 'wide' %>
              <span class="text-xs px-1.5 py-0.5 rounded flex-shrink-0 ml-2 <%= leave.leave_type == 'Maladie' ? 'bg-red-100 dark:bg-red-900 text-red-700 dark:text-red-300' : 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300' %>">
                <%= leave.leave_type %>
              </span>
            <% end %>
          </div>
        <% end %>
        <% if count > limit %>
          <p class="text-xs text-gray-400 dark:text-gray-500 text-center pt-1">+ <%= count - limit %> autres</p>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-gray-400 dark:text-gray-500 text-center py-3">Tout le monde est présent aujourd'hui ✓</p>
    <% end %>
  </div>
<% end %>
