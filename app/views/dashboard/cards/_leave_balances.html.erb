<%# locals: (size:, employee:) %>
<% if size == 'compact' %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">Congés</span>
    <span class="text-xl font-bold text-gray-900 dark:text-gray-100 flex-shrink-0">
      <%= @leave_balances.sum { |b| b.available_balance.to_f }.round(1) %>j
    </span>
  </div>
<% else %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100">Soldes de congés</h2>
      <%= link_to 'Demander', new_leave_request_path, class: "text-sm text-indigo-600 hover:text-indigo-700 dark:text-indigo-400 font-medium" %>
    </div>
    <% if @leave_balances.any? %>
      <% if size == 'wide' %>
        <div class="grid grid-cols-3 gap-3">
          <% @leave_balances.each do |balance| %>
            <%= render 'shared/leave_balance_card', balance: balance %>
          <% end %>
        </div>
      <% else %>
        <div class="grid grid-cols-2 gap-3">
          <% @leave_balances.each do |balance| %>
            <%= render 'shared/leave_balance_card', balance: balance %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Aucun solde configuré</p>
    <% end %>
  </div>
<% end %>
