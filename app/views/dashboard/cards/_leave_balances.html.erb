<%# locals: (size:, employee:) %>
<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-border-soft dark:border-white/8 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Soldes de congés
    </span>
    <%= link_to 'Demander', new_leave_request_path, class: "text-[10px] text-primary hover:text-primary dark:text-primary/70 font-medium" %>
  </div>
  <div class="flex-1 min-h-0 overflow-auto">
    <% if @leave_balances.any? %>
      <%# Mobile: liste verticale compacte %>
      <div class="sm:hidden divide-y divide-border-soft dark:divide-white/8">
        <% @leave_balances.each do |balance| %>
          <%= render 'shared/leave_balance_row', balance: balance %>
        <% end %>
      </div>
      <%# Desktop: pills horizontales %>
      <div class="hidden sm:flex items-stretch gap-2 p-2 h-full">
        <% @leave_balances.each do |balance| %>
          <div class="flex-1 min-w-0">
            <%= render 'shared/leave_balance_card', balance: balance %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-muted-soft dark:text-white/30 text-center py-4">Aucun solde configuré</p>
    <% end %>
  </div>
</div>
