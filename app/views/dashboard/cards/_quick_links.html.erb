<%# locals: (size:, employee:) %>
<% links = [
  { path: time_entries_path,                   label: 'Mes pointages', desc: 'Historique', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
  { path: leave_requests_path,                 label: 'Mes congés',    desc: 'Demandes et soldes', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { path: objectives_path,                     label: 'Mes objectifs', desc: 'En cours', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
  { path: training_assignments_path,           label: 'Formations',    desc: 'Assignées', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' }
] %>
<% if employee.manager? %>
  <% links << { path: pending_approvals_leave_requests_path, label: 'Mon équipe', desc: 'Approbations', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' } %>
<% end %>

<% if size == 'compact' %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow px-4 py-3 flex items-center gap-3 flex-wrap">
    <% links.each do |link| %>
      <%= link_to link[:path], class: "p-1.5 text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors", title: link[:label] do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= link[:icon] %>"/>
        </svg>
      <% end %>
    <% end %>
  </div>
<% elsif size == 'wide' %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow p-5">
    <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Accès rapides</h2>
    <div class="grid grid-cols-2 gap-1">
      <% links.each do |link| %>
        <%= link_to link[:path], class: "flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
          <svg class="w-5 h-5 mr-3 text-gray-400 dark:text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= link[:icon] %>"/>
          </svg>
          <div>
            <p class="font-medium text-sm"><%= link[:label] %></p>
            <p class="text-xs text-gray-500 dark:text-gray-400"><%= link[:desc] %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow p-5">
    <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Accès rapides</h2>
    <div class="space-y-1">
      <% links.each do |link| %>
        <%= link_to link[:path], class: "flex items-center p-3 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
          <svg class="w-5 h-5 mr-3 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= link[:icon] %>"/>
          </svg>
          <span class="font-medium text-sm"><%= link[:label] %></span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
