<%# locals: (size:, employee:) %>
<% links = [
  { path: time_entries_path,       label: 'Mes pointages', desc: 'Historique',        icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
  { path: leave_requests_path,     label: 'Mes congés',    desc: 'Demandes et soldes',icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
  { path: objectives_path,         label: 'Mes objectifs', desc: 'En cours',          icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
  { path: training_assignments_path,label: 'Formations',   desc: 'Assignées',         icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' }
] %>
<% if employee.manager? %>
  <% links << { path: pending_approvals_leave_requests_path, label: 'Mon équipe', desc: 'Approbations', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' } %>
<% end %>

<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
  <div class="px-3 py-2 border-b border-border-soft dark:border-white/8 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
      Accès rapides
    </span>
  </div>
  <div class="flex-1 overflow-auto px-2 pt-2 pb-3">
    <div class="grid grid-cols-1 gap-0.5">
      <% links.each do |link| %>
        <%= link_to link[:path], class: "flex items-center gap-2 px-2 py-1.5 rounded-lg text-text-deep dark:text-white/80 hover:bg-black/5 dark:hover:bg-surface/8 transition-colors" do %>
          <svg class="w-4 h-4 text-muted-soft dark:text-white/30 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= link[:icon] %>"/>
          </svg>
          <div class="min-w-0">
            <p class="text-xs font-medium truncate"><%= link[:label] %></p>
            <p class="text-[10px] text-muted-soft dark:text-white/30 truncate"><%= link[:desc] %></p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
