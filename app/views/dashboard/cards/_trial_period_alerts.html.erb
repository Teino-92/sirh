<%# locals: (size:, employee:) %>
<% alerts = @trial_period_alerts.to_a %>
<% count  = alerts.size %>
<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow border border-amber-200 dark:border-amber-800 overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-amber-100 dark:border-amber-900 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      Périodes d'essai
    </span>
    <span class="text-sm font-bold <%= count > 0 ? 'text-amber-500' : 'text-muted-soft dark:text-white/30' %>"><%= count %></span>
  </div>
  <div class="flex-1 overflow-auto px-3 py-2">
    <% if alerts.empty? %>
      <p class="text-xs text-muted-soft dark:text-white/30 text-center py-2">Aucune dans les 14 prochains jours</p>
    <% else %>
      <div class="space-y-2">
        <% alerts.each do |emp| %>
          <div class="flex items-center justify-between gap-2 py-1 border-b border-border-soft dark:border-white/8 last:border-0">
            <div class="min-w-0">
              <p class="text-xs font-medium text-text-deep dark:text-white truncate"><%= emp.full_name %></p>
              <% days_left = (emp.trial_period_end - Date.today).to_i %>
              <p class="text-[10px] text-amber-600 dark:text-amber-400">Fin le <%= emp.trial_period_end.strftime('%d/%m') %> · <%= days_left %>j</p>
            </div>
            <% if size != 'compact' %>
              <div class="flex gap-1 flex-shrink-0">
                <%= button_to confirm_trial_period_decision_path(emp), method: :post,
                      class: "px-2 py-1 text-[10px] font-medium rounded bg-green-600 hover:bg-green-700 text-white" do %>✓<% end %>
                <%= button_to renew_trial_period_decision_path(emp), method: :post,
                      class: "px-2 py-1 text-[10px] font-medium rounded bg-primary hover:opacity-90 text-white" do %>↻<% end %>
                <%= button_to terminate_trial_period_decision_path(emp), method: :post,
                      data: { turbo_confirm: "Confirmer la fin de période d'essai de #{emp.full_name} ?" },
                      class: "px-2 py-1 text-[10px] font-medium rounded bg-red-600 hover:bg-red-700 text-white" do %>✕<% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
