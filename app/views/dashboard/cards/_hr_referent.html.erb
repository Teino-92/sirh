<%# locals: (size:, employee:) %>
<% referent = employee.hr_referent %>

<div class="card-inner h-full flex flex-col bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
  <div class="px-3 py-2 border-b border-gray-100 dark:border-gray-700 flex-shrink-0">
    <span class="text-xs font-semibold text-gray-600 dark:text-gray-300 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      Votre référent RH
    </span>
  </div>

  <div class="flex-1 flex items-center px-3 py-3">
    <% if referent %>
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-full bg-indigo-100 dark:bg-indigo-900 flex items-center justify-center flex-shrink-0">
          <span class="text-indigo-600 dark:text-indigo-300 font-semibold text-sm">
            <%= referent.first_name[0] %><%= referent.last_name[0] %>
          </span>
        </div>
        <div>
          <p class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= referent.full_name %></p>
          <p class="text-xs text-gray-500 dark:text-gray-400"><%= referent.job_title.presence || 'HR Officer' %></p>
          <a href="mailto:<%= referent.email %>" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline mt-0.5 block">
            <%= referent.email %>
          </a>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 dark:text-gray-500 italic">
        Aucun référent RH affecté à votre département.
      </p>
    <% end %>
  </div>
</div>
