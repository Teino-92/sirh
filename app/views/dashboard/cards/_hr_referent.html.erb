<%# locals: (size:, employee:) %>
<% referent = employee.hr_referent %>

<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
  <div class="px-3 py-2 border-b border-border-soft dark:border-white/8 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
      </svg>
      Votre référent RH
    </span>
  </div>

  <div class="flex-1 flex items-center px-3 py-3">
    <% if referent %>
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center flex-shrink-0">
          <span class="text-primary dark:text-primary/70 font-semibold text-sm">
            <%= referent.first_name[0] %><%= referent.last_name[0] %>
          </span>
        </div>
        <div>
          <p class="text-sm font-semibold text-text-deep dark:text-white"><%= referent.full_name %></p>
          <p class="text-xs text-muted-soft dark:text-white/40"><%= referent.job_title.presence || 'HR Officer' %></p>
          <a href="mailto:<%= referent.email %>" class="text-xs text-primary dark:text-primary/70 hover:underline mt-0.5 block">
            <%= referent.email %>
          </a>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-muted-soft dark:text-white/30 italic">
        Aucun référent RH affecté à votre département.
      </p>
    <% end %>
  </div>
</div>
