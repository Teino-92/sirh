<%# locals: (size:, employee:) %>
<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-border-soft dark:border-white/8 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
      </svg>
      Performance équipe
    </span>
  </div>
  <div class="flex-1 overflow-auto px-3 py-2">
    <% if @team_overdue_objectives_count.to_i > 0 || @pending_manager_reviews_count.to_i > 0 %>
      <div class="space-y-1.5">
        <% if @team_overdue_objectives_count.to_i > 0 %>
          <%= link_to manager_objectives_path(status: :in_progress), class: "flex items-center justify-between py-1 border-b border-border-soft dark:border-white/8 hover:text-primary transition-colors" do %>
            <span class="text-xs text-text-deep dark:text-white/80">Objectifs en retard</span>
            <span class="text-xs font-bold text-red-600 dark:text-red-400"><%= @team_overdue_objectives_count %></span>
          <% end %>
        <% end %>
        <% if @pending_manager_reviews_count.to_i > 0 %>
          <%= link_to manager_evaluations_path(status: :manager_review_pending), class: "flex items-center justify-between py-1 hover:text-primary transition-colors" do %>
            <span class="text-xs text-text-deep dark:text-white/80">Évaluations à compléter</span>
            <span class="text-xs font-bold text-orange-600 dark:text-orange-400"><%= @pending_manager_reviews_count %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-muted-soft dark:text-white/30 text-center py-2">Aucun retard ✓</p>
    <% end %>
  </div>
</div>
