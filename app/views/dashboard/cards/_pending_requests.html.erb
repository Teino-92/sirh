<%# locals: (size:, employee:) %>
<% requests = @my_pending_requests %>
<div class="card-inner h-full flex flex-col bg-surface dark:bg-[#1C1B2E] rounded-lg shadow overflow-hidden">
  <div class="flex items-center justify-between px-3 py-2 border-b border-border-soft dark:border-white/8 flex-shrink-0">
    <span class="text-xs font-semibold text-muted-soft dark:text-white/60 flex items-center gap-1.5">
      <svg class="w-3.5 h-3.5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      Demandes en cours
    </span>
    <span class="text-sm font-bold <%= requests.any? ? 'text-warning' : 'text-muted-soft dark:text-white/30' %>"><%= requests.count %></span>
  </div>
  <div class="flex-1 overflow-auto px-3 py-2">
    <% if requests.any? %>
      <div class="space-y-1.5">
        <% requests.first(5).each do |req| %>
          <div class="flex items-center justify-between gap-2 py-1 border-b border-border-soft dark:border-white/8 last:border-0">
            <div class="min-w-0">
              <p class="text-xs font-medium text-text-deep dark:text-white truncate">
                <%= LeaveBalance.leave_type_name(req.leave_type) %>
              </p>
              <p class="text-[10px] text-muted-soft dark:text-white/40">
                <%= l(req.start_date, format: :short) %> → <%= l(req.end_date, format: :short) %> · <%= req.days_count.to_f.round(1) %>j
              </p>
            </div>
            <span class="text-[10px] px-1.5 py-0.5 rounded flex-shrink-0 bg-warning/10 dark:bg-warning/10/40 text-warning dark:text-warning">En attente</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-xs text-muted-soft dark:text-white/30 text-center py-2">Aucune demande en cours</p>
    <% end %>
  </div>
</div>
