<%# locals: (size:, employee:) %>
<% if size == 'compact' %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow px-4 py-3 flex items-center justify-between gap-3">
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">Demandes en cours</span>
    <span class="text-xl font-bold text-yellow-700 dark:text-yellow-300 flex-shrink-0"><%= @my_pending_requests.count %></span>
  </div>
<% else %>
  <div class="card-inner bg-white dark:bg-gray-800 rounded-lg shadow p-5">
    <h2 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-4">Mes demandes en cours</h2>
    <% if @my_pending_requests.any? %>
      <% limit = size == 'wide' ? 4 : 2 %>
      <div class="space-y-3">
        <% @my_pending_requests.first(limit).each do |request| %>
          <div class="p-3 bg-yellow-50 dark:bg-yellow-900 rounded-lg border border-yellow-200 dark:border-yellow-700">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs font-medium text-yellow-800 dark:text-yellow-100 bg-yellow-200 dark:bg-yellow-700 px-2 py-0.5 rounded">
                En attente
              </span>
              <span class="text-xs text-gray-600 dark:text-gray-400">
                <%= time_ago_in_words(request.created_at) %>
              </span>
            </div>
            <p class="text-sm font-medium text-gray-900 dark:text-gray-100">
              <%= l(request.start_date, format: :short) %> - <%= l(request.end_date, format: :short) %>
            </p>
            <p class="text-xs text-gray-600 dark:text-gray-400">
              <%= request.days_count.to_f.round(1) %> jours · <%= LeaveBalance.leave_type_name(request.leave_type) %>
            </p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">Aucune demande en cours</p>
    <% end %>
  </div>
<% end %>
