<div class="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <!-- Header -->
    <div class="text-center">
      <h1 class="text-4xl font-bold text-indigo-600 mb-2">Izi-RH</h1>
      <h2 class="text-2xl font-semibold text-gray-900 dark:text-gray-100">Connexion</h2>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
        Bienvenue sur votre espace RH
      </p>
    </div>

    <!-- Sign In Form -->
    <div class="bg-white dark:bg-gray-800 py-8 px-4 shadow-lg rounded-lg sm:px-10">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
        <!-- Email Field -->
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm placeholder-gray-400 dark:placeholder-gray-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>

        <!-- Password Field -->
        <div>
          <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= f.password_field :password,
              autocomplete: "current-password",
              class: "appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm placeholder-gray-400 dark:placeholder-gray-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
        </div>

        <!-- Remember Me -->
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 dark:border-gray-600 rounded" %>
            <%= f.label :remember_me, "Se souvenir de moi", class: "ml-2 block text-sm text-gray-900 dark:text-gray-100" %>
          </div>
        <% end %>

        <!-- Submit Button -->
        <div>
          <%= f.submit "Se connecter",
              class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <!-- Links -->
      <div class="mt-6 text-center text-sm">
        <%= render "devise/shared/links" %>
      </div>
    </div>

    <!-- Demo Credentials (for development only) -->
    <% if Rails.env.development? %>
      <div class="bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-md p-4">
        <p class="text-xs text-yellow-800 dark:text-yellow-200 font-semibold mb-3">🔐 Comptes de test :</p>

        <!-- TechCorp France -->
        <div class="mb-3">
          <p class="text-xs font-semibold text-yellow-900 mb-1">🏢 TechCorp France:</p>
          <div class="space-y-1 text-xs text-yellow-700 dark:text-yellow-300 ml-3">
            <p><strong>RH:</strong> nathalie.legrand@techcorp.fr</p>
            <p><strong>Manager:</strong> thomas.martin@techcorp.fr</p>
            <p><strong>Employé:</strong> baptiste.gros@techcorp.fr</p>
          </div>
        </div>

        <!-- StartupCo Paris -->
        <div class="mb-3">
          <p class="text-xs font-semibold text-yellow-900 mb-1">🏢 StartupCo Paris:</p>
          <div class="space-y-1 text-xs text-yellow-700 dark:text-yellow-300 ml-3">
            <p><strong>Admin:</strong> admin@startupco.fr</p>
            <p><strong>Manager:</strong> claire.rousseau@startupco.fr</p>
            <p><strong>Employé:</strong> antoine.mercier@startupco.fr</p>
          </div>
        </div>

        <p class="text-xs text-yellow-800 dark:text-yellow-200 font-semibold mt-3 pt-2 border-t border-yellow-300 dark:border-yellow-600">
          <strong>Mot de passe:</strong> password123
        </p>
      </div>
    <% end %>
  </div>
</div>
