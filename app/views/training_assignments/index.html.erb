<div class="container mx-auto px-4 py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">My Trainings</h1>
  </div>

  <div class="flex gap-2 mb-4 overflow-x-auto">
    <%= link_to 'All', training_assignments_path, class: "btn btn-sm #{params[:status].blank? ? 'btn-primary' : 'btn-outline'}" %>
    <%= link_to 'In Progress', training_assignments_path(status: :in_progress), class: "btn btn-sm #{params[:status] == 'in_progress' ? 'btn-primary' : 'btn-outline'}" %>
    <%= link_to 'Assigned', training_assignments_path(status: :assigned), class: "btn btn-sm #{params[:status] == 'assigned' ? 'btn-primary' : 'btn-outline'}" %>
    <%= link_to 'Completed', training_assignments_path(status: :completed), class: "btn btn-sm #{params[:status] == 'completed' ? 'btn-primary' : 'btn-outline'}" %>
  </div>

  <div class="space-y-4">
    <% @assignments.each do |assignment| %>
      <div class="card bg-white shadow-sm p-4">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="font-semibold text-lg">
              <%= link_to assignment.training.title, training_assignment_path(assignment), class: 'hover:text-blue-600' %>
            </h3>
            <div class="text-sm text-gray-500 mt-1">
              <span class="badge badge-outline text-xs"><%= assignment.training.training_type.humanize %></span>
              <span class="ml-2">Assigned by <%= assignment.assigned_by.full_name %></span>
              <% if assignment.deadline.present? %>
                <span class="ml-2 <%= assignment.overdue? ? 'text-red-500 font-medium' : '' %>">
                  Due <%= assignment.deadline.strftime('%b %d, %Y') %>
                  <%= ' (overdue)' if assignment.overdue? %>
                </span>
              <% end %>
            </div>
          </div>
          <div class="flex gap-2 items-center ml-4">
            <span class="badge badge-<%= assignment.status %>"><%= assignment.status.humanize %></span>
            <% if assignment.active? %>
              <%= link_to 'View', training_assignment_path(assignment), class: 'btn btn-sm btn-outline' %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @assignments.empty? %>
      <p class="text-gray-500 text-center py-8">No training assignments found.</p>
    <% end %>
  </div>
</div>
