<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
      .header { background: linear-gradient(to right, #6366f1, #4f46e5); color: white; padding: 30px; border-radius: 8px 8px 0 0; text-align: center; }
      .header h1 { margin: 0; font-size: 24px; }
      .content { background: #f9fafb; padding: 30px; border: 1px solid #e5e7eb; border-top: none; }
      .message-box { background: white; border-left: 4px solid #6366f1; padding: 15px; margin: 20px 0; border-radius: 4px; }
      .footer { text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #e5e7eb; color: #6b7280; font-size: 14px; }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>Notification Izi-RH</h1>
    </div>

    <div class="content">
      <p>Bonjour <%= @employee.first_name %>,</p>

      <div class="message-box">
        <p><%= @message %></p>
      </div>

      <p>
        Cordialement,<br>
        <strong>L'équipe Izi-RH</strong>
      </p>
    </div>

    <div class="footer">
      <p>Cet email a été envoyé automatiquement par le système de règles Izi-RH.</p>
      <p>&copy; <%= Date.current.year %> Izi-RH. Tous droits réservés.</p>
    </div>
  </body>
</html>
