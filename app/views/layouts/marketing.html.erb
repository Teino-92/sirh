          </svg>
          <span class="font-serif text-base text-text-deep">Manager OS</span>
        </a>
        <div class="flex items-center gap-3">
          <%= link_to "Se connecter", new_employee_session_path,
                class: "text-sm font-medium text-muted-soft hover:text-text-deep transition" %>
          <%= link_to "Essayer gratuitement", new_trial_registration_path,
                class: "text-sm font-semibold px-4 py-2 rounded-xl bg-primary text-white hover:opacity-90 transition" %>
        </div>
      </div>
    </header>

    <div style="position:relative; z-index:1; overflow-x:hidden">
      <%= yield %>
    </div>
    <%= javascript_importmap_tags %>
  </body>
</html>
