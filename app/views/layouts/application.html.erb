<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Easy-RH - Le compagnon du manager</title>
    <meta name="description" content="SIRH moderne et mobile-first pour les équipes françaises">

    <!-- PWA -->
    <meta name="theme-color" content="#4F46E5">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="/manifest.json">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(registration => console.log('SW registered:', registration))
            .catch(err => console.log('SW registration failed:', err));
        });
      }
    </script>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <% if employee_signed_in? %>
      <!-- Mobile-first navigation -->
      <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <!-- Logo & Primary Nav -->
            <div class="flex">
              <div class="flex-shrink-0 flex items-center">
                <div>
                  <h1 class="text-xl font-bold text-indigo-600">Easy-RH</h1>
                  <p class="text-xs text-gray-600"><%= current_employee.organization.name %></p>
                </div>
              </div>

              <!-- Desktop Navigation -->
              <div class="hidden sm:ml-6 sm:flex sm:space-x-4">
                <%= link_to "Tableau de bord", dashboard_path,
                    class: "inline-flex items-center px-3 py-2 text-sm font-medium #{current_page?(dashboard_path) ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>
                <%= link_to "Pointage", time_entries_path,
                    class: "inline-flex items-center px-3 py-2 text-sm font-medium #{current_page?(time_entries_path) ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>
                <%= link_to "Horaire", work_schedule_path(current_employee.work_schedule || current_employee.id),
                    class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'work_schedules' ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>
                <%= link_to "Congés", leave_requests_path,
                    class: "inline-flex items-center px-3 py-2 text-sm font-medium #{current_page?(leave_requests_path) ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>

                <% if current_employee.manager? %>
                  <%= link_to "Approbations", pending_approvals_leave_requests_path,
                      class: "inline-flex items-center px-3 py-2 text-sm font-medium #{current_page?(pending_approvals_leave_requests_path) ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>
                  <%= link_to "Horaires équipe", manager_team_schedules_path,
                      class: "inline-flex items-center px-3 py-2 text-sm font-medium #{current_page?(manager_team_schedules_path) ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>
                <% end %>

                <% if current_employee.hr_or_admin? %>
                  <%= link_to "Admin", admin_root_path,
                      class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller.class.name.start_with?('Admin::') ? 'text-indigo-600 border-b-2 border-indigo-600' : 'text-gray-700 hover:text-indigo-600'}" %>
                <% end %>
              </div>
            </div>

            <!-- User Menu -->
            <div class="flex items-center gap-4">
              <!-- Notification Bell with Dropdown -->
              <% unread_count = current_employee.notifications.unread.count %>
              <% notifications = current_employee.notifications.recent.limit(50) %>
              <div class="relative" data-controller="notifications-dropdown" data-action="click@window->notifications-dropdown#hide">
                <button type="button"
                        class="relative p-2 text-gray-600 hover:text-gray-900"
                        data-action="click->notifications-dropdown#toggle">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                  </svg>
                  <% if unread_count > 0 %>
                    <span class="absolute top-0 right-0 inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none text-white transform translate-x-1/2 -translate-y-1/2 bg-red-600 rounded-full">
                      <%= unread_count %>
                    </span>
                  <% end %>
                </button>

                <!-- Dropdown -->
                <div class="hidden absolute right-0 mt-2 z-50" data-notifications-dropdown-target="dropdown">
                  <%= render 'notifications/dropdown', notifications: notifications, unread_count: unread_count %>
                </div>
              </div>

              <%= link_to profile_path, class: "text-sm font-medium text-gray-700 hover:text-indigo-600 hidden sm:block transition" do %>
                <%= current_employee.first_name %>
              <% end %>
              <%= button_to "Déconnexion", destroy_employee_session_path, method: :delete,
                  class: "text-sm font-medium text-gray-600 hover:text-gray-900 px-3 py-2" %>
            </div>
          </div>
        </div>

        <!-- Mobile Bottom Navigation -->
        <div class="sm:hidden border-t border-gray-200">
          <div class="flex justify-around">
            <%= link_to dashboard_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(dashboard_path) ? 'text-indigo-600' : 'text-gray-600'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              <span>Accueil</span>
            <% end %>

            <%= link_to time_entries_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(time_entries_path) ? 'text-indigo-600' : 'text-gray-600'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Pointage</span>
            <% end %>

            <%= link_to work_schedule_path(current_employee.work_schedule || current_employee.id), class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'work_schedules' ? 'text-indigo-600' : 'text-gray-600'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span>Horaire</span>
            <% end %>

            <%= link_to leave_requests_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(leave_requests_path) ? 'text-indigo-600' : 'text-gray-600'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span>Congés</span>
            <% end %>

            <% if current_employee.manager? %>
              <%= link_to manager_team_schedules_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(manager_team_schedules_path) || current_page?(pending_approvals_leave_requests_path) ? 'text-indigo-600' : 'text-gray-600'}" do %>
                <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                <span>Équipe</span>
              <% end %>
            <% end %>
          </div>
        </div>
      </nav>

      <!-- Flash Messages -->
      <% if notice || alert %>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
          <% if notice %>
            <div class="bg-green-50 border-l-4 border-green-400 p-4 mb-4">
              <p class="text-sm text-green-700"><%= notice %></p>
            </div>
          <% end %>
          <% if alert %>
            <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-4">
              <p class="text-sm text-red-700"><%= alert %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <!-- Main Content -->
    <main class="<%= employee_signed_in? ? 'pb-16 sm:pb-0' : '' %>">
      <%= yield %>
    </main>
  </body>
</html>
