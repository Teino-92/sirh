<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Izi-RH - Le compagnon du manager</title>
    <meta name="description" content="SIRH moderne et mobile-first pour les équipes françaises">

    <!-- PWA -->
    <meta name="theme-color" content="#4F46E5">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="manifest" href="/manifest.json">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- GridStack: loaded globally so it's available before Stimulus connects -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack.min.css" data-turbo-track="reload">
    <script src="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack-all.js" data-turbo-track="reload"></script>

    <%= render 'shared/dark_mode_init' %>

    <!-- Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js')
            .then(registration => console.log('SW registered:', registration))
            .catch(err => console.log('SW registration failed:', err));
        });
      }
    </script>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900 min-h-screen transition-colors duration-200">
    <% if employee_signed_in? %>
      <!-- Mobile-first navigation -->
      <nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50 transition-colors duration-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <!-- Logo & Primary Nav -->
            <div class="flex">
              <div class="flex-shrink-0 flex items-center">
                <div class="flex items-center gap-2">
                  <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-6 w-auto dark:invert">
                  <span class="text-gray-300 dark:text-gray-600 select-none">·</span>
                  <span class="text-sm font-medium text-gray-600 dark:text-gray-400 truncate max-w-[160px]"><%= current_employee.organization.name %></span>
                </div>
              </div>

              <!-- Desktop Navigation -->
              <div class="hidden sm:ml-8 sm:flex sm:items-center sm:space-x-1">
                <%= link_to "Dashboard", dashboard_path,
                    class: "inline-flex items-center px-4 py-2 text-base font-medium #{current_page?(dashboard_path) ? 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400' : 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400'}" %>
                <% if sirh_plan? && !current_employee.cadre? %>
                <%= link_to "Pointage", time_entries_path,
                    class: "inline-flex items-center px-4 py-2 text-base font-medium #{current_page?(time_entries_path) ? 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400' : 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400'}" %>
                <%= link_to "Horaire", work_schedule_path(current_employee.work_schedule || current_employee.id),
                    class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'work_schedules' ? 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400' : 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400'}" %>
                <% end %>
                <% if sirh_plan? %>
                <%= link_to "Congés", leave_requests_path,
                    class: "inline-flex items-center px-4 py-2 text-base font-medium #{current_page?(leave_requests_path) ? 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400' : 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400'}" %>
                <% end %>

                <% if current_employee.manager? %>
                  <%# Dropdown "Équipe" — Approbations + Planning + Onboarding + Exports %>
                  <% team_active = current_page?(pending_approvals_leave_requests_path) ||
                                   current_page?(manager_team_schedules_path) ||
                                   (controller_name == 'employee_onboardings' && controller.class.name.start_with?('Manager::')) ||
                                   (controller_name == 'team_members' && controller.class.name.start_with?('Manager::')) ||
                                   (controller_name == 'one_on_ones' && controller.class.name.start_with?('Manager::')) ||
                                   (controller_name == 'objectives' && controller.class.name.start_with?('Manager::')) ||
                                   (controller_name == 'trainings' && controller.class.name.start_with?('Manager::')) ||
                                   current_page?(manager_exports_path) %>
                  <div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
                    <button type="button"
                            x-on:click="open = !open"
                            class="inline-flex items-center gap-1 px-4 py-2 text-base font-medium <%= team_active ? 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400' : 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400' %>">
                      Équipe
                      <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </button>
                    <div x-show="open"
                         x-transition:enter="transition ease-out duration-100"
                         x-transition:enter-start="opacity-0 scale-95"
                         x-transition:enter-end="opacity-100 scale-100"
                         x-transition:leave="transition ease-in duration-75"
                         x-transition:leave-start="opacity-100 scale-100"
                         x-transition:leave-end="opacity-0 scale-95"
                         class="absolute top-full left-0 mt-1 w-48 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 z-50"
                         style="display: none;">
                      <div class="py-1">
                        <%= link_to manager_team_schedules_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{current_page?(manager_team_schedules_path) ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                          Mon équipe
                        <% end %>
                        <% if sirh_plan? %>
                          <%= link_to pending_approvals_leave_requests_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{current_page?(pending_approvals_leave_requests_path) ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            Approbations
                          <% end %>
                        <% end %>
                        <%= link_to manager_one_on_ones_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'one_on_ones' && controller.class.name.start_with?('Manager::') ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
                          1:1
                        <% end %>
                        <%= link_to manager_objectives_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'objectives' && controller.class.name.start_with?('Manager::') ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                          Objectifs
                        <% end %>
                        <%= link_to manager_trainings_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'trainings' && controller.class.name.start_with?('Manager::') ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                          Formations
                        <% end %>
                        <%= link_to manager_employee_onboardings_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'employee_onboardings' && controller.class.name.start_with?('Manager::') ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                          Onboarding
                        <% end %>
                        <% if sirh_plan? %>
                          <%= link_to manager_exports_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{current_page?(manager_exports_path) ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}", "x-on:click": "open = false" do %>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                            Exports
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>

                <% if current_employee.hr_or_admin? && sirh_plan? %>
                  <%= link_to(current_employee.admin? ? "Admin" : "RH"), admin_root_path,
                      class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller.class.name.start_with?('Admin::') ? 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400' : 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400'}" %>
                <% end %>
              </div>
            </div>

            <!-- User Menu -->
            <div class="flex items-center gap-4">
              <!-- Notification Bell with Dropdown -->
              <% unread_count = current_employee.notifications.unread.count %>
              <% notifications = current_employee.notifications.recent.limit(50) %>
              <div class="relative" data-controller="notifications-dropdown" data-action="click@window->notifications-dropdown#hide">
                <button type="button"
                        class="relative p-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
                        data-action="click->notifications-dropdown#toggle">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                  </svg>
                  <% if unread_count > 0 %>
                    <span class="absolute top-0 right-0 inline-flex items-center justify-center px-2 py-1 text-xs font-bold leading-none text-white transform translate-x-1/2 -translate-y-1/2 bg-red-600 rounded-full">
                      <%= unread_count %>
                    </span>
                  <% end %>
                </button>

                <!-- Dropdown -->
                <div class="hidden absolute right-0 mt-2 z-50" data-notifications-dropdown-target="dropdown">
                  <%= render 'notifications/dropdown', notifications: notifications, unread_count: unread_count %>
                </div>
              </div>

              <!-- Dark Mode Toggle -->
              <%= render 'shared/dark_mode_toggle' %>

              <%# Dropdown profil %>
              <div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
                <button type="button"
                        x-on:click="open = !open"
                        class="flex items-center gap-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 px-2 py-2 rounded-md transition">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                  </svg>
                  <span class="hidden sm:inline"><%= current_employee.first_name %></span>
                  <svg class="w-3 h-3 hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-75"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute right-0 mt-1 w-44 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 z-50"
                     style="display: none;">
                  <div class="py-1">
                    <div class="px-4 py-2 text-xs text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-700">
                      <%= current_employee.organization.name %>
                    </div>
                    <%= link_to profile_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700", "x-on:click": "open = false" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                      Mon profil
                    <% end %>
                    <%= button_to destroy_employee_session_path, method: :delete,
                        class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                      Déconnexion
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Mobile Bottom Navigation -->
        <div class="sm:hidden border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
          <div class="flex justify-around">
            <%= link_to dashboard_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(dashboard_path) ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
              <span>Accueil</span>
            <% end %>

            <% if sirh_plan? && !current_employee.cadre? %>
            <%= link_to time_entries_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(time_entries_path) ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Pointage</span>
            <% end %>

            <%= link_to work_schedule_path(current_employee.work_schedule || current_employee.id), class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'work_schedules' ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span>Horaire</span>
            <% end %>
            <% end %>

            <% if sirh_plan? %>
            <%= link_to leave_requests_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(leave_requests_path) ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300'}" do %>
              <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <span>Congés</span>
            <% end %>
            <% end %>

            <% if current_employee.manager? %>
              <%= link_to manager_team_schedules_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{current_page?(manager_team_schedules_path) || current_page?(pending_approvals_leave_requests_path) || current_page?(manager_exports_path) ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300'}" do %>
                <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                </svg>
                <span>Équipe</span>
              <% end %>
            <% end %>

            <% if current_employee.hr_or_admin? && sirh_plan? %>
              <%= link_to admin_root_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller.class.name.start_with?('Admin::') ? 'text-indigo-600 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300'}" do %>
                <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span><%= current_employee.admin? ? 'Admin' : 'RH' %></span>
              <% end %>
            <% end %>
          </div>
        </div>
      </nav>

      <!-- Flash Messages -->
      <%= render 'shared/flash_messages' %>
    <% end %>
    <%# Tailwind dynamic class safelist — DO NOT REMOVE %>
    <div class="hidden w-1/3 w-2/3 opacity-30 flex flex-wrap bg-green-600 bg-red-600"></div>

    <!-- Main Content -->
    <main class="<%= employee_signed_in? ? 'pb-16 sm:pb-0' : '' %>">
      <%= yield %>
    </main>
  </body>
</html>
