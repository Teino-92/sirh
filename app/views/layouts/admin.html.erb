<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= content_for?(:title) ? "#{yield(:title)} — Izi-RH Admin" : "Administration — Izi-RH" %></title>
    <meta name="description" content="Panel d'administration Izi-RH">

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% if Rails.env.production? %>
      <meta name="sentry-dsn" content="<%= ENV['SENTRY_DSN'] %>">
    <% end %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <style>
      .logo-z    { fill: #4F46E5; }
      .logo-rest { fill: #1e1b4b; }
      .dark .logo-z    { fill: #B0B91A; }
      .dark .logo-rest { fill: white; }
    </style>
    <%= javascript_importmap_tags %>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <%= render 'shared/dark_mode_init' %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900 min-h-screen">
    <!-- Admin Navigation -->
    <nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <!-- Logo & Primary Nav -->
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <div class="flex items-center gap-2">
                <svg class="h-6 w-auto" viewBox="0 0 606 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Izi-RH">
                  <!-- i gauche -->
                  <path d="M11.4 144C7.93333 144 5.13333 143.067 3 141.2C1 139.333 0 136.733 0 133.4V10.6C0 7.26667 1 4.66667 3 2.8C5.13333 0.933337 7.93333 0 11.4 0C14.7333 0 17.4667 1 19.6 3C21.7333 4.86667 22.8 7.4 22.8 10.6V133.4C22.8 136.6 21.7333 139.2 19.6 141.2C17.4667 143.067 14.7333 144 11.4 144Z" class="logo-rest"/>
                  <!-- Z : indigo en light, vert-jaune en dark -->
                  <path d="M72.9516 142C65.0849 142 58.8182 140.133 54.1516 136.4C49.6182 132.533 47.3516 127.333 47.3516 120.8C47.3516 115.867 48.2849 111.6 50.1516 108C52.1516 104.267 55.8182 100.333 61.1516 96.2L141.152 34.2C143.152 32.6 144.552 31.2 145.352 30C146.285 28.6667 146.752 27.0667 146.752 25.2C146.752 21.6 144.218 19.8 139.152 19.8H63.1516C59.6849 19.8 56.8182 19.0667 54.5516 17.6C52.2849 16 51.1516 13.8 51.1516 11C51.1516 8.06666 52.2849 5.86667 54.5516 4.4C56.8182 2.8 59.6849 2 63.1516 2H143.952C151.952 2 158.218 3.86667 162.752 7.6C167.285 11.2 169.552 16.4 169.552 23.2C169.552 28.5333 168.618 32.9333 166.752 36.4C164.885 39.7333 161.218 43.4667 155.752 47.6L75.7516 109.8C73.7516 111.267 72.2849 112.733 71.3516 114.2C70.5516 115.533 70.1516 117.133 70.1516 119C70.1516 122.467 73.2849 124.2 79.5516 124.2H159.152C162.618 124.2 165.485 125 167.752 126.6C170.018 128.067 171.152 130.2 171.152 133C171.152 135.933 170.018 138.2 167.752 139.8C165.485 141.267 162.618 142 159.152 142H72.9516Z" class="logo-z"/>
                  <!-- i droite -->
                  <path d="M207.111 144C203.644 144 200.844 143.067 198.711 141.2C196.711 139.333 195.711 136.733 195.711 133.4V10.6C195.711 7.26667 196.711 4.66667 198.711 2.8C200.844 0.933337 203.644 0 207.111 0C210.444 0 213.178 1 215.311 3C217.444 4.86667 218.511 7.4 218.511 10.6V133.4C218.511 136.6 217.444 139.2 215.311 141.2C213.178 143.067 210.444 144 207.111 144Z" class="logo-rest"/>
                  <!-- tiret -->
                  <path d="M249.841 81.0749C246.241 81.0749 243.441 80.2749 241.441 78.6749C239.574 77.0749 238.641 74.9416 238.641 72.2749C238.641 66.2749 242.374 63.2749 249.841 63.2749H309.241C316.707 63.2749 320.441 66.2749 320.441 72.2749C320.441 74.9416 319.441 77.0749 317.441 78.6749C315.574 80.2749 312.841 81.0749 309.241 81.0749H249.841Z" class="logo-rest"/>
                  <!-- R -->
                  <path d="M391.477 93.4028L386.675 93.3984L386.578 93.4001H363.978V133.2C363.978 136.533 362.845 139.2 360.578 141.2C358.445 143.067 355.645 144 352.178 144C348.578 144 345.711 143.067 343.578 141.2C341.578 139.2 340.578 136.533 340.578 133.2V30C340.578 21.3335 343.111 14.5334 348.178 9.6001C353.245 4.53345 360.378 2 369.578 2L391.479 2.00342H399.272C418.606 2.00342 433.174 5.99564 442.907 13.729C452.774 21.4623 457.707 32.8623 457.707 47.929C457.707 62.1957 453.374 73.2624 444.707 81.129C437.92 86.8332 430.333 90.2794 420.353 91.9404L454.782 126.475C456.915 128.608 457.982 130.941 457.982 133.475C457.982 136.275 456.648 138.808 453.982 141.075C451.448 142.941 448.982 143.875 446.582 143.875C443.248 143.875 440.048 142.275 436.982 139.075L392.908 93.4028H391.477ZM391.479 20.4034L372.978 20.4001C370.178 20.4001 367.978 21.3335 366.378 23.2002C364.778 24.9333 363.978 27.4001 363.978 30.6001V75L391.514 75.129H399.107C411.907 75.129 420.907 73.129 426.107 69.129C431.441 64.9957 434.107 57.929 434.107 47.929C434.107 38.1957 431.241 31.1957 425.507 26.929C419.774 22.6624 410.939 20.4034 399.072 20.4034H391.479Z" class="logo-rest"/>
                  <!-- H -->
                  <path d="M493.747 144C490.28 144 487.547 143.067 485.547 141.2C483.547 139.333 482.547 136.733 482.547 133.4V10.6C482.547 7.26667 483.547 4.66667 485.547 2.8C487.547 0.933337 490.28 0 493.747 0C497.214 0 499.947 1 501.947 3C504.08 4.86667 505.147 7.4 505.147 10.6V61.2H582.347V10.6C582.347 7.4 583.347 4.86667 585.347 3C587.48 1 590.28 0 593.747 0C597.214 0 599.947 0.933337 601.947 2.8C604.08 4.66667 605.147 7.26667 605.147 10.6V133.4C605.147 136.733 604.08 139.333 601.947 141.2C599.947 143.067 597.214 144 593.747 144C590.28 144 587.48 143.067 585.347 141.2C583.347 139.2 582.347 136.6 582.347 133.4V79H505.147V133.4C505.147 136.6 504.08 139.2 501.947 141.2C499.947 143.067 497.214 144 493.747 144Z" class="logo-rest"/>
                </svg>
                <span class="text-indigo-300 dark:text-gray-600 select-none">·</span>
                <span class="text-sm font-medium text-indigo-600 dark:text-gray-400">Admin</span>
              </div>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-1">
              <%= link_to "Employés", admin_employees_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'employees' ? 'text-indigo-600 border-b-2 border-indigo-600 dark:border-indigo-400 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-white'}" %>
              <%= link_to "Importer", new_admin_employee_import_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'employee_imports' ? 'text-indigo-600 border-b-2 border-indigo-600 dark:border-indigo-400 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-white'}" %>
              <%= link_to "Paie", admin_payroll_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'payroll' ? 'text-indigo-600 border-b-2 border-indigo-600 dark:border-indigo-400 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-white'}" %>
              <%= link_to "IA", admin_hr_query_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'hr_queries' ? 'text-indigo-600 border-b-2 border-indigo-600 dark:border-indigo-400 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-white'}" %>
              <%= link_to "Audit", admin_audit_log_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'audit_logs' ? 'text-indigo-600 border-b-2 border-indigo-600 dark:border-indigo-400 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-white'}" %>

              <%# Dropdown "Paramètres" — Paramètres org + Règles RH + Onboarding %>
              <% settings_active = %w[organizations onboarding_templates onboarding_template_tasks business_rules].include?(controller_name) %>
              <div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
                <button type="button"
                        x-on:click="open = !open"
                        class="inline-flex items-center gap-1 px-4 py-2 text-base font-medium <%= settings_active ? 'text-indigo-600 border-b-2 border-indigo-600 dark:border-indigo-400 dark:text-indigo-400' : 'text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-white' %>">
                  Paramètres
                  <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-75"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute top-full left-0 mt-1 w-48 rounded-md shadow-lg bg-white dark:bg-gray-700 ring-1 ring-black ring-opacity-5 z-50"
                     style="display: none;">
                  <div class="py-1">
                    <%= link_to admin_organization_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'organizations' ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}", x_on: { click: "open = false" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                      Organisation
                    <% end %>
                    <%= link_to admin_business_rules_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'business_rules' ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}", x_on: { click: "open = false" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                      Automatisations
                    <% end %>
                    <%= link_to admin_onboarding_templates_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{%w[onboarding_templates onboarding_template_tasks].include?(controller_name) ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}", x_on: { click: "open = false" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                      Onboarding
                    <% end %>
                  </div>
                </div>
              </div>

              <%= link_to "← App", dashboard_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-white" %>
            </div>
          </div>

          <!-- User Menu -->
          <div class="flex items-center gap-2">
            <%= render 'shared/dark_mode_toggle' %>

            <%# Dropdown profil %>
            <div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
              <button type="button"
                      x-on:click="open = !open"
                      class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-white rounded-md">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <span class="hidden sm:inline"><%= current_employee.first_name %></span>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div x-show="open"
                   x-transition:enter="transition ease-out duration-100"
                   x-transition:enter-start="opacity-0 scale-95"
                   x-transition:enter-end="opacity-100 scale-100"
                   x-transition:leave="transition ease-in duration-75"
                   x-transition:leave-start="opacity-100 scale-100"
                   x-transition:leave-end="opacity-0 scale-95"
                   class="absolute right-0 mt-1 w-44 rounded-md shadow-lg bg-white dark:bg-gray-700 ring-1 ring-black ring-opacity-5 z-50"
                   style="display: none;">
                <div class="py-1">
                  <div class="px-4 py-2 text-xs text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-600">
                    <%= current_employee.role.upcase %>
                  </div>
                  <%= link_to profile_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Mon profil
                  <% end %>
                  <%= button_to destroy_employee_session_path, method: :delete,
                      class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Déconnexion
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile Bottom Navigation (5 items max) -->
      <div class="sm:hidden border-t border-indigo-800 dark:border-gray-700">
        <div class="flex justify-around">
          <%= link_to admin_employees_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{%w[employees employee_imports].include?(controller_name) ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <span>Employés</span>
          <% end %>

          <%= link_to admin_payroll_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'payroll' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Paie</span>
          <% end %>

          <%= link_to admin_hr_query_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'hr_queries' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            <span>IA</span>
          <% end %>

          <%= link_to admin_audit_log_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'audit_logs' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
            </svg>
            <span>Audit</span>
          <% end %>

          <%= link_to dashboard_path, class: "flex-1 flex flex-col items-center py-2 text-xs text-indigo-200 dark:text-gray-300" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            <span>Retour</span>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <%= render 'shared/flash_messages' %>

    <!-- Main Content -->
    <main class="pb-16 sm:pb-0">
      <%= yield %>
    </main>
  </body>
</html>
