<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= content_for?(:title) ? "#{yield(:title)} — Easy-RH Admin" : "Administration — Easy-RH" %></title>
    <meta name="description" content="Panel d'administration Easy-RH">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <%= render 'shared/dark_mode_init' %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900 min-h-screen">
    <!-- Admin Navigation -->
    <nav class="bg-indigo-700 dark:bg-gray-800 border-b border-indigo-800 dark:border-gray-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <!-- Logo & Primary Nav -->
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <div class="flex items-center gap-2">
                <span class="text-xl font-bold text-white dark:text-indigo-400">Easy-RH</span>
                <span class="text-indigo-400 dark:text-gray-600 select-none">·</span>
                <span class="text-sm font-medium text-indigo-100 dark:text-gray-400">Admin</span>
              </div>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden sm:ml-6 sm:flex sm:items-center sm:space-x-1">
              <%= link_to "Employés", admin_employees_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'employees' ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300 hover:text-white dark:hover:text-white'}" %>
              <%= link_to "Importer", new_admin_employee_import_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'employee_imports' ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300 hover:text-white dark:hover:text-white'}" %>
              <%= link_to "Paie", admin_payroll_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'payroll' ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white'}" %>
              <%= link_to "IA", admin_hr_query_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'hr_queries' ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white'}" %>
              <%= link_to "Audit", admin_audit_log_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium #{controller_name == 'audit_logs' ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white'}" %>

              <%# Dropdown "Paramètres" — Paramètres org + Règles RH + Onboarding %>
              <% settings_active = %w[organizations group_policies onboarding_templates onboarding_template_tasks].include?(controller_name) %>
              <div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
                <button type="button"
                        x-on:click="open = !open"
                        class="inline-flex items-center gap-1 px-4 py-2 text-base font-medium <%= settings_active ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white' %>">
                  Paramètres
                  <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-75"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="absolute top-full left-0 mt-1 w-48 rounded-md shadow-lg bg-white dark:bg-gray-700 ring-1 ring-black ring-opacity-5 z-50"
                     style="display: none;">
                  <div class="py-1">
                    <%= link_to admin_organization_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'organizations' ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}", x_on: { click: "open = false" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                      Organisation
                    <% end %>
                    <%= link_to edit_admin_group_policies_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{controller_name == 'group_policies' ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}", x_on: { click: "open = false" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                      Règles RH
                    <% end %>
                    <%= link_to admin_onboarding_templates_path, class: "flex items-center gap-2 px-4 py-2 text-sm #{%w[onboarding_templates onboarding_template_tasks].include?(controller_name) ? 'text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600'}", x_on: { click: "open = false" } do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                      Onboarding
                    <% end %>
                  </div>
                </div>
              </div>

              <%= link_to "← App", dashboard_path,
                  class: "inline-flex items-center px-4 py-2 text-base font-medium text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white" %>
            </div>
          </div>

          <!-- User Menu -->
          <div class="flex items-center gap-2">
            <%= render 'shared/dark_mode_toggle' %>

            <%# Dropdown profil %>
            <div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
              <button type="button"
                      x-on:click="open = !open"
                      class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-indigo-100 dark:text-gray-300 hover:text-white dark:hover:text-white rounded-md">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <span class="hidden sm:inline"><%= current_employee.first_name %></span>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div x-show="open"
                   x-transition:enter="transition ease-out duration-100"
                   x-transition:enter-start="opacity-0 scale-95"
                   x-transition:enter-end="opacity-100 scale-100"
                   x-transition:leave="transition ease-in duration-75"
                   x-transition:leave-start="opacity-100 scale-100"
                   x-transition:leave-end="opacity-0 scale-95"
                   class="absolute right-0 mt-1 w-44 rounded-md shadow-lg bg-white dark:bg-gray-700 ring-1 ring-black ring-opacity-5 z-50"
                   style="display: none;">
                <div class="py-1">
                  <div class="px-4 py-2 text-xs text-gray-400 dark:text-gray-500 border-b border-gray-100 dark:border-gray-600">
                    <%= current_employee.role.upcase %>
                  </div>
                  <%= link_to profile_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-600" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    Mon profil
                  <% end %>
                  <%= button_to destroy_employee_session_path, method: :delete,
                      class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Déconnexion
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile Bottom Navigation (5 items max) -->
      <div class="sm:hidden border-t border-indigo-800 dark:border-gray-700">
        <div class="flex justify-around">
          <%= link_to admin_employees_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{%w[employees employee_imports].include?(controller_name) ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <span>Employés</span>
          <% end %>

          <%= link_to admin_payroll_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'payroll' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Paie</span>
          <% end %>

          <%= link_to admin_hr_query_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'hr_queries' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            <span>IA</span>
          <% end %>

          <%= link_to admin_audit_log_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'audit_logs' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
            </svg>
            <span>Audit</span>
          <% end %>

          <%= link_to dashboard_path, class: "flex-1 flex flex-col items-center py-2 text-xs text-indigo-200 dark:text-gray-300" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            <span>Retour</span>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <%= render 'shared/flash_messages' %>

    <!-- Main Content -->
    <main class="pb-16 sm:pb-0">
      <%= yield %>
    </main>
  </body>
</html>
