<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Administration - Easy-RH</title>
    <meta name="description" content="Panel d'administration Easy-RH">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <%= render 'shared/dark_mode_init' %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-900 min-h-screen">
    <!-- Admin Navigation -->
    <nav class="bg-indigo-700 dark:bg-gray-800 border-b border-indigo-800 dark:border-gray-700">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <!-- Logo & Primary Nav -->
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <div>
                <h1 class="text-xl font-bold text-white dark:text-indigo-400">Easy-RH Admin</h1>
                <p class="text-xs text-indigo-100 dark:text-gray-400 font-medium"><%= current_employee.organization.name %></p>
              </div>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden sm:ml-6 sm:flex sm:space-x-4">
              <%= link_to "Employés", admin_employees_path,
                  class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'employees' ? 'text-white border-b-2 border-white dark:border-indigo-400 dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300 hover:text-white dark:hover:text-white'}" %>
              <%= link_to "Organisation", admin_organization_path,
                  class: "inline-flex items-center px-3 py-2 text-sm font-medium #{controller_name == 'organizations' ? 'text-white border-b-2 border-white' : 'text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white'}" %>
              <%= link_to "Retour à l'app", dashboard_path,
                  class: "inline-flex items-center px-3 py-2 text-sm font-medium text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white" %>
            </div>
          </div>

          <!-- User Menu -->
          <div class="flex items-center gap-4">
            <!-- Dark Mode Toggle -->
            <%= render 'shared/dark_mode_toggle' %>

            <span class="text-sm font-medium text-indigo-100 dark:text-gray-300 hidden sm:block">
              <%= current_employee.first_name %> (<%= current_employee.role.upcase %>)
            </span>
            <%= button_to "Déconnexion", destroy_employee_session_path, method: :delete,
                class: "text-sm font-medium text-indigo-200 dark:text-gray-400 hover:text-white dark:hover:text-white px-3 py-2" %>
          </div>
        </div>
      </div>

      <!-- Mobile Bottom Navigation -->
      <div class="sm:hidden border-t border-indigo-800 dark:border-gray-700">
        <div class="flex justify-around">
          <%= link_to admin_employees_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'employees' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <span>Employés</span>
          <% end %>

          <%= link_to admin_organization_path, class: "flex-1 flex flex-col items-center py-2 text-xs #{controller_name == 'organizations' ? 'text-white dark:text-indigo-400' : 'text-indigo-200 dark:text-gray-300'}" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            <span>Organisation</span>
          <% end %>

          <%= link_to dashboard_path, class: "flex-1 flex flex-col items-center py-2 text-xs text-indigo-200 dark:text-gray-300" do %>
            <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            <span>Retour</span>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <%= render 'shared/flash_messages' %>

    <!-- Main Content -->
    <main class="pb-16 sm:pb-0">
      <%= yield %>
    </main>
  </body>
</html>
