<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">Mon horaire de travail</h1>
    <p class="text-sm text-gray-600 dark:text-gray-400 dark:text-gray-500">Consultez votre planning et vos congés</p>
  </div>

  <!-- Month Navigation -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-6 p-4">
    <div class="flex items-center justify-between gap-2">
      <%= link_to work_schedule_path(current_employee.id, date: @current_date - 1.month),
        class: "flex-shrink-0 inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:bg-gray-900" do %>
        <svg class="w-5 h-5 sm:mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        <span class="hidden sm:inline">Mois précédent</span>
      <% end %>

      <h2 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-gray-100 text-center flex-1">
        <%= l(@current_date, format: '%B %Y').capitalize %>
      </h2>

      <%= link_to work_schedule_path(current_employee.id, date: @current_date + 1.month),
        class: "flex-shrink-0 inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:bg-gray-900" do %>
        <span class="hidden sm:inline">Mois suivant</span>
        <svg class="w-5 h-5 sm:ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      <% end %>
    </div>

    <div class="mt-4">
      <%= link_to work_schedule_path(current_employee.id, date: Date.current),
        class: "text-sm text-indigo-600 hover:text-indigo-800 dark:text-indigo-200 font-medium" do %>
        Aujourd'hui
      <% end %>
    </div>
  </div>

  <!-- Stats (hidden on mobile) -->
  <div class="hidden sm:grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow p-6">
      <p class="text-sm font-medium text-gray-600 dark:text-gray-400 dark:text-gray-500">Contrat</p>
      <p class="text-2xl font-bold text-gray-900 dark:text-gray-100 mt-2"><%= @employee.contract_type %></p>
    </div>

    <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900 dark:to-purple-700 border-2 border-purple-300 dark:border-purple-500 rounded-lg shadow p-6">
      <p class="text-sm font-medium text-purple-800 dark:text-white opacity-90">Congés ce mois</p>
      <p class="text-2xl font-bold text-purple-900 dark:text-white mt-2">
        <%= @leaves.sum(&:days_count).to_f.round(1) %> jours
      </p>
    </div>

    <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900 dark:to-blue-700 border-2 border-blue-300 dark:border-blue-500 rounded-lg shadow p-6">
      <p class="text-sm font-medium text-blue-800 dark:text-white opacity-90">Jours travaillés</p>
      <p class="text-2xl font-bold text-blue-900 dark:text-white mt-2">
        <%= @time_entries.map(&:worked_date).uniq.count %>
      </p>
    </div>
  </div>

  <!-- Planned Weeks Info -->
  <% planned_weeks = @weekly_plans.values %>
  <% if planned_weeks.any? %>
    <div class="bg-green-50 dark:bg-green-900 border border-green-200 dark:border-green-700 rounded-lg p-6 mb-6">
      <div class="flex items-start">
        <svg class="h-6 w-6 text-green-600 dark:text-green-400 mr-3 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div class="flex-1">
          <h3 class="text-base font-semibold text-green-900 dark:text-green-100 mb-2">
            <%= planned_weeks.count %> semaine<%= 's' if planned_weeks.count > 1 %> planifiée<%= 's' if planned_weeks.count > 1 %> ce mois
          </h3>
          <div class="space-y-2">
            <% planned_weeks.each do |plan| %>
              <div class="bg-white dark:bg-gray-800 rounded-lg p-3 border border-green-200 dark:border-green-700">
                <div class="flex items-center justify-between mb-1">
                  <span class="font-semibold text-gray-900 dark:text-gray-100">
                    <%= l(plan.week_start_date, format: :short) %> - <%= l(plan.week_end_date, format: :short) %>
                  </span>
                  <span class="text-sm text-gray-600 dark:text-gray-400 dark:text-gray-500">
                    <%= plan.total_weekly_hours.round(1) %>h
                  </span>
                </div>
                <% if plan.notes.present? %>
                  <p class="text-sm text-gray-600 dark:text-gray-400 dark:text-gray-500 italic">Note: <%= plan.notes %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="bg-yellow-50 dark:bg-yellow-900 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4 mb-6">
      <div class="flex items-start">
        <svg class="h-5 w-5 text-yellow-600 dark:text-yellow-400 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <p class="text-sm text-yellow-800 dark:text-yellow-200">
          Aucune semaine planifiée ce mois. Contactez votre manager pour établir votre planning.
        </p>
      </div>
    </div>
  <% end %>

  <!-- Legend -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow mb-6 p-4">
    <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100 mb-3">Légende</h3>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="flex items-center">
        <div class="w-4 h-4 bg-indigo-500 rounded mr-2"></div>
        <span class="text-sm text-gray-700 dark:text-gray-300">Jour travaillé</span>
      </div>
      <div class="flex items-center">
        <div class="w-4 h-4 bg-blue-500 rounded mr-2"></div>
        <span class="text-sm text-gray-700 dark:text-gray-300">Congés</span>
      </div>
      <div class="flex items-center">
        <div class="w-4 h-4 bg-gray-300 rounded mr-2"></div>
        <span class="text-sm text-gray-700 dark:text-gray-300">Non planifié</span>
      </div>
      <div class="flex items-center">
        <div class="w-4 h-4 border-2 border-indigo-600 rounded mr-2"></div>
        <span class="text-sm text-gray-700 dark:text-gray-300">Aujourd'hui</span>
      </div>
    </div>
  </div>

  <!-- Calendar -->
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
    <!-- Calendar Header -->
    <div class="grid grid-cols-7 bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
      <% %w[Lun Mar Mer Jeu Ven Sam Dim].each do |day_name| %>
        <div class="py-3 text-center">
          <span class="text-xs sm:text-sm font-semibold text-gray-700 dark:text-gray-300"><%= day_name %></span>
        </div>
      <% end %>
    </div>

    <!-- Calendar Body -->
    <div class="bg-white dark:bg-gray-800">
      <% @calendar_weeks.each do |week| %>
        <div class="grid grid-cols-7 border-b border-gray-200 dark:border-gray-700 last:border-b-0">
          <% week.each do |day_info| %>
            <%
              date = day_info[:date]
              in_month = day_info[:in_current_month]
              is_today = day_info[:is_today]

              # Check if there's a leave on this day
              leave_on_day = @leaves.find { |l| date >= l.start_date && date <= l.end_date }

              # Get weekly plan for this week
              week_start = date.beginning_of_week
              weekly_plan = @weekly_plans[week_start]

              # Get work hours from weekly plan
              day_name = date.strftime('%A').downcase
              work_hours = weekly_plan&.schedule_pattern&.dig(day_name)
              is_work_day = work_hours.present? && work_hours != 'off'

              # Time entry for this day
              time_entry = @time_entries.find { |te| te.worked_date == date }
            %>

            <div class="min-h-[80px] sm:min-h-[100px] border-r border-gray-200 dark:border-gray-700 last:border-r-0 p-2
                        <%= 'bg-gray-50 dark:bg-gray-900' unless in_month %>
                        <%= 'bg-indigo-50 dark:bg-indigo-900' if is_work_day && in_month && !leave_on_day %>
                        <%= 'bg-blue-100 dark:bg-blue-800' if leave_on_day %>
                        <%= 'bg-gray-100 dark:bg-gray-800' if in_month && !is_work_day && !leave_on_day && !weekly_plan %>
                        <%= 'border-2 border-indigo-600' if is_today %>">

              <!-- Date Number -->
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-semibold
                            <%= in_month ? 'text-gray-900 dark:text-gray-100' : 'text-gray-400 dark:text-gray-500' %>
                            <%= 'text-indigo-600' if is_today %>">
                  <%= date.day %>
                </span>

                <% if is_today %>
                  <span class="hidden sm:inline-block px-2 py-0.5 text-xs font-semibold bg-indigo-600 text-white rounded-full">
                    Aujourd'hui
                  </span>
                <% end %>
              </div>

              <!-- Day Content -->
              <% if in_month %>
                <!-- Leave Badge -->
                <% if leave_on_day %>
                  <div class="mt-1">
                    <span class="inline-block px-2 py-0.5 text-xs font-semibold bg-blue-600 text-white rounded">
                      <%= LeaveBalance.leave_type_name(leave_on_day.leave_type) %>
                    </span>
                  </div>
                <% elsif is_work_day %>
                  <!-- Work Hours -->
                  <div class="mt-1">
                    <p class="text-xs text-gray-600 dark:text-gray-400 dark:text-gray-500 font-medium">
                      <%= work_hours %>
                    </p>

                    <!-- Actual worked hours if available -->
                    <% if time_entry %>
                      <p class="text-xs text-green-600 font-semibold mt-0.5">
                        ✓ <%= time_entry.hours_worked.round(1) %>h
                      </p>
                    <% end %>
                  </div>
                <% elsif weekly_plan %>
                  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Repos</p>
                <% else %>
                  <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Non planifié</p>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="bg-gradient-to-br from-indigo-50 to-indigo-100 dark:from-indigo-900 dark:to-indigo-700 border-2 border-indigo-300 dark:border-indigo-500 rounded-lg shadow-lg p-6">
      <p class="text-sm font-medium text-indigo-800 dark:text-white opacity-90">Heures travaillées ce mois</p>
      <p class="text-3xl font-bold text-indigo-900 dark:text-white mt-2">
        <%= @time_entries.sum(&:hours_worked).round(1) %>h
      </p>
    </div>

    <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900 dark:to-purple-700 border-2 border-purple-300 dark:border-purple-500 rounded-lg shadow-lg p-6">
      <p class="text-sm font-medium text-purple-800 dark:text-white opacity-90">Jours de congé pris</p>
      <p class="text-3xl font-bold text-purple-900 dark:text-white mt-2">
        <%= @leaves.sum(&:days_count).to_f.round(1) %>
      </p>
    </div>
  </div>
</div>
