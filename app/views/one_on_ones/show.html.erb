<div class="max-w-3xl mx-auto px-4 py-6">
  <%= link_to "&larr; Mes 1:1".html_safe, one_on_ones_path, class: "text-sm text-muted-soft dark:text-white/50 hover:text-primary mb-4 inline-block" %>

  <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow p-6">
    <div class="flex justify-between items-start mb-6">
      <h1 class="text-xl font-serif text-text-deep dark:text-white flex-1">
        1:1 avec <%= @one_on_one.manager.full_name %>
      </h1>
      <span class="ml-3 px-3 py-1 text-sm font-medium rounded-full bg-bg-soft dark:bg-surface/10 text-text-deep dark:text-white/70">
        <%= @one_on_one.status.humanize %>
      </span>
    </div>

    <dl class="space-y-4 text-sm">
      <div>
        <dt class="font-medium text-muted-soft dark:text-white/50">Date</dt>
        <dd class="text-text-deep dark:text-white mt-1"><%= l(@one_on_one.scheduled_at, format: :long) %></dd>
      </div>

      <% if @one_on_one.agenda.present? %>
        <div>
          <dt class="font-medium text-muted-soft dark:text-white/50">Agenda</dt>
          <dd class="text-text-deep dark:text-white mt-1"><%= @one_on_one.agenda %></dd>
        </div>
      <% end %>

      <% if @one_on_one.notes.present? %>
        <div>
          <dt class="font-medium text-muted-soft dark:text-white/50">Notes</dt>
          <dd class="text-text-deep dark:text-white/70 mt-1 whitespace-pre-wrap"><%= @one_on_one.notes %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
