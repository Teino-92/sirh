<% if notice || alert %>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <% if notice %>
      <div class="bg-green-50 dark:bg-green-900 border-l-4 border-green-400 p-4 mb-4 flex items-start rounded-md shadow-sm">
        <svg class="w-5 h-5 text-green-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-sm text-green-700 dark:text-green-300 flex-1"><%= notice %></p>
        <button type="button" onclick="this.parentElement.remove()" class="ml-auto flex-shrink-0 text-green-400 hover:text-green-600 transition-colors" aria-label="Fermer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 dark:bg-red-900 border-l-4 border-red-400 p-4 mb-4 flex items-start rounded-md shadow-sm">
        <svg class="w-5 h-5 text-red-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="text-sm text-red-700 dark:text-red-300 flex-1"><%= alert %></p>
        <button type="button" onclick="this.parentElement.remove()" class="ml-auto flex-shrink-0 text-red-400 hover:text-red-600 transition-colors" aria-label="Fermer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>
