<%
  text = local_assigns[:text]
  path = local_assigns[:path]
  active = local_assigns[:active]
  active_class = local_assigns[:active_class] || 'text-indigo-600 dark:text-indigo-400 border-b-2 border-indigo-600 dark:border-indigo-400'
  inactive_class = local_assigns[:inactive_class] || 'text-gray-700 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400'
  base_class = 'inline-flex items-center px-3 py-2 text-sm font-medium'
%>

<%= link_to text, path, class: "#{base_class} #{active ? active_class : inactive_class}" %>
