<% content_for :title, "Abonnement — Izi-RH" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

  <% if @org.trial_active? %>
    <!-- Trial encore actif -->
    <div class="mb-4 p-4 bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-700 rounded-xl flex items-start gap-3">
      <svg class="w-5 h-5 text-indigo-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <div>
        <p class="text-sm font-semibold text-indigo-700 dark:text-indigo-300">
          Essai gratuit — <strong><%= @org.trial_days_remaining.to_i %> jour<%= "s" if @org.trial_days_remaining.to_i > 1 %> restant<%= "s" if @org.trial_days_remaining.to_i > 1 %></strong>
        </p>
        <p class="text-sm text-indigo-600 dark:text-indigo-400 mt-0.5">
          Souscrivez maintenant pour sécuriser vos données. Votre carte sera enregistrée mais <strong>le paiement ne se déclenchera qu'à la fin de votre essai</strong> (le <%= @org.trial_ends_at.strftime("%d/%m/%Y") %>).
        </p>
      </div>
    </div>
    <% if @org.manager_os? %>
      <!-- Info : trial Manager OS, SIRH nécessite contact -->
      <div class="mb-8 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-xl flex items-start justify-between gap-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <p class="text-sm font-semibold text-blue-700 dark:text-blue-300">Vous testez actuellement Manager OS</p>
            <p class="text-sm text-blue-600 dark:text-blue-400 mt-0.5">
              Le SIRH (congés, pointage, paie) est un plan différent. Il n'est pas possible de tester les deux avec le même compte — contactez-nous pour une démo SIRH ou pour migrer votre essai.
            </p>
          </div>
        </div>
        <button type="button"
                onclick="document.getElementById('upgrade-modal').classList.remove('hidden')"
                class="flex-shrink-0 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold rounded-lg transition-colors">
          Nous contacter
        </button>
      </div>
    <% end %>
  <% end %>

  <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white mb-2">Abonnement</h1>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">Gérez votre plan et votre facturation.</p>

  <% if @subscription&.active? || @subscription&.past_due? %>
    <!-- Abonnement actif -->
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 mb-8">
      <div class="flex items-center justify-between mb-4">
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Plan actuel</p>
          <p class="text-xl font-bold text-gray-900 dark:text-white"><%= plan_label(@subscription.plan) %></p>
        </div>
        <% if @subscription.past_due? %>
          <span class="px-3 py-1 bg-red-100 text-red-700 text-xs font-semibold rounded-full">Paiement en échec</span>
        <% elsif @subscription.cancel_at_period_end %>
          <span class="px-3 py-1 bg-orange-100 text-orange-700 text-xs font-semibold rounded-full">Résiliation prévue</span>
        <% else %>
          <span class="px-3 py-1 bg-green-100 text-green-700 text-xs font-semibold rounded-full">Actif</span>
        <% end %>
      </div>

      <% if @subscription.current_period_end.present? %>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
          Prochaine facturation : <strong><%= @subscription.current_period_end.strftime("%d/%m/%Y") %></strong>
        </p>
      <% end %>

      <% if @subscription.committed? %>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
          Engagement actif jusqu'au <strong><%= @subscription.commitment_end_at.strftime("%d/%m/%Y") %></strong>
          (<%= @subscription.commitment_months_remaining %> mois restant<%= "s" if @subscription.commitment_months_remaining > 1 %>)
        </p>
      <% end %>

      <!-- Upgrade Essentiel → Pro -->
      <% if @billing.can_self_upgrade? %>
        <div class="mt-4 p-4 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl">
          <p class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-1">Passez à SIRH Pro</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">IA RH, géolocalisation, journal d'audit, API mobile. Facturation au prorata immédiate.</p>
          <%= button_to "Passer à SIRH Pro →", upgrade_billing_path,
              method: :post,
              class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors",
              data: { turbo_confirm: "Passer à SIRH Pro ? La différence de prix sera facturée immédiatement au prorata." } %>
        </div>
      <% end %>

      <!-- Demande upgrade OS → SIRH : séparé du plan actuel -->
      <% if @billing.upgrade_requires_contact? %>
        <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-700">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Évoluer vers le SIRH complet</p>
          <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-gray-800 dark:text-gray-200">Passer au SIRH complet</p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Congés, pointage, paie, analytics — notre équipe vous accompagne dans la migration.</p>
            </div>
            <button type="button"
                    onclick="document.getElementById('upgrade-modal').classList.remove('hidden')"
                    class="flex-shrink-0 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl transition-colors">
              Nous contacter →
            </button>
          </div>
        </div>

      <% end %>

      <!-- Résiliation -->
      <% if @subscription.can_cancel? && !@subscription.cancel_at_period_end %>
        <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-700">
          <%= button_to "Résilier l'abonnement", cancel_billing_path,
              method: :delete,
              class: "text-sm text-red-500 hover:text-red-700 underline",
              data: { turbo_confirm: "Résilier votre abonnement à la fin de la période en cours ?" } %>
        </div>
      <% elsif @subscription.committed? %>
        <p class="mt-4 text-xs text-gray-400">
          Résiliation disponible à partir du <%= @subscription.commitment_end_at.strftime("%d/%m/%Y") %>.
        </p>
      <% end %>
    </div>

  <% elsif @org.trial_expired? || @org.trial_ends_at.nil? || @subscription.nil? || @subscription.canceled? || @subscription&.status == "incomplete" %>
    <!-- Tunnel de souscription (trial expiré, ou pas d'abonnement) -->
    <% if @org.trial_expired? %>
      <div class="mb-6 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-xl">
        <p class="text-sm text-amber-800 dark:text-amber-300 font-semibold mb-1">Votre période d'essai est terminée.</p>
        <p class="text-sm text-amber-700 dark:text-amber-400">Choisissez un plan pour continuer à utiliser Izi-RH. Engagement 1 an, puis sans engagement.</p>
      </div>
    <% end %>

    <% manager_readonly = current_employee.manager? && !current_employee.hr_or_admin? && !@org.trial_active? %>

    <% if manager_readonly %>
      <div class="mb-6 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700 rounded-xl flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-sm text-amber-800 dark:text-amber-300">Pour souscrire un abonnement, veuillez contacter votre <strong>Admin RH</strong>.</p>
      </div>
    <% end %>

    <div class="grid sm:grid-cols-3 gap-4">
      <!-- Manager OS -->
      <div class="p-6 bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700" data-controller="billing-interval">
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">Manager OS</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Onboarding, 1:1, OKR, Formation</p>

        <%# Toggle mensuel / annuel %>
        <div class="inline-flex rounded-lg border border-gray-200 dark:border-gray-700 text-xs mb-3 overflow-hidden">
          <button type="button" data-billing-interval-target="monthly" data-action="click->billing-interval#setMonthly"
                  class="px-3 py-1.5 font-medium bg-indigo-600 text-white transition-colors">Mensuel</button>
          <button type="button" data-billing-interval-target="yearly" data-action="click->billing-interval#setYearly"
                  class="px-3 py-1.5 font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">Annuel</button>
        </div>

        <div data-billing-interval-target="priceMonthly">
          <p class="text-3xl font-extrabold text-indigo-600 mb-1">19 €<span class="text-sm font-normal text-gray-500">/mois</span></p>
          <p class="text-xs text-gray-400 mb-4">+2 €/mois par membre supplémentaire</p>
        </div>
        <div data-billing-interval-target="priceYearly" class="hidden">
          <p class="text-3xl font-extrabold text-indigo-600 mb-1">200 €<span class="text-sm font-normal text-gray-500">/an</span></p>
          <p class="text-xs text-gray-400 mb-4">≈ 16,67 €/mois · économise 28 €</p>
        </div>

        <% unless manager_readonly %>
          <%= button_to "Choisir ce plan", create_checkout_billing_path,
              params: { plan: "manager_os", interval: "monthly" },
              method: :post,
              data: { billing_interval_target: "form" },
              class: "w-full text-center py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors" %>
        <% end %>
      </div>

      <!-- SIRH Essentiel -->
      <div class="p-6 bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700">
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">SIRH Essentiel</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Manager OS + Temps & Congés</p>
        <p class="text-3xl font-extrabold text-indigo-600 mb-1">79 €<span class="text-sm font-normal text-gray-500">/mois</span></p>
        <p class="text-xs text-gray-400 mb-5">+4 €/employé au-delà de 10</p>
        <% unless manager_readonly %>
          <% if @org.manager_os? %>
            <button type="button" onclick="document.getElementById('upgrade-modal').classList.remove('hidden')"
                    class="w-full text-center py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors">
              Nous contacter →
            </button>
          <% else %>
            <%= button_to "Choisir ce plan", create_checkout_billing_path, params: { plan: "sirh_essential" },
                method: :post,
                class: "w-full text-center py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors" %>
          <% end %>
        <% end %>
      </div>

      <!-- SIRH Pro -->
      <div class="pt-6 px-6 pb-6 bg-gray-900 dark:bg-gray-900 rounded-2xl border border-gray-700 text-white relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-0.5 bg-violet-600 text-white text-xs font-bold rounded-full">Complet</span>
        <h3 class="text-base font-bold text-white mb-1">SIRH Pro</h3>
        <p class="text-xs text-gray-400 mb-4">Tout SIRH + IA RH & audit<br>&nbsp;</p>
        <p class="text-3xl font-extrabold text-white mb-1">149 €<span class="text-sm font-normal text-gray-400">/mois</span></p>
        <p class="text-xs text-gray-500 mb-5">+6 €/employé au-delà de 20</p>
        <% unless manager_readonly %>
          <% if @org.manager_os? %>
            <button type="button" onclick="document.getElementById('upgrade-modal').classList.remove('hidden')"
                    class="w-full text-center py-2 border border-gray-500 text-gray-200 hover:bg-gray-700 text-sm font-semibold rounded-xl transition-colors">
              Nous contacter →
            </button>
          <% else %>
            <%= button_to "Choisir ce plan", create_checkout_billing_path, params: { plan: "sirh_pro" },
                method: :post,
                class: "w-full text-center py-2 border border-gray-500 text-gray-200 hover:bg-gray-700 text-sm font-semibold rounded-xl transition-colors" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="mt-5 flex flex-col items-center gap-2">
      <p class="text-xs text-gray-400">Engagement 1 an · puis mensuel sans engagement</p>
      <div class="flex items-center gap-1.5 text-xs text-gray-500">
        <span>Paiement sécurisé par</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 25" class="h-4 fill-current text-gray-400" aria-label="Stripe">
          <path d="M59.64 14.28h-8.06c.19 1.93 1.6 2.55 3.2 2.55 1.64 0 2.96-.37 4.05-.95v3.32a10.15 10.15 0 0 1-4.56 1c-4.01 0-6.83-2.5-6.83-7.48 0-4.19 2.39-7.52 6.3-7.52 3.92 0 5.96 3.28 5.96 7.5 0 .4-.04 1.26-.06 1.58zm-5.92-5.62c-1.03 0-2.17.73-2.17 2.58h4.25c0-1.85-1.07-2.58-2.08-2.58zM40.95 20.3c-1.44 0-2.32-.6-2.9-1.04l-.02 4.63-4.12.87V5.57h3.76l.08 1.02a4.7 4.7 0 0 1 3.23-1.29c2.9 0 5.62 2.6 5.62 7.4 0 5.23-2.7 7.6-5.65 7.6zM40 8.95c-.95 0-1.54.34-1.97.81l.02 6.12c.4.44.98.78 1.95.78 1.52 0 2.54-1.65 2.54-3.87 0-2.15-1.04-3.84-2.54-3.84zM28.24 5.57h4.13v14.44h-4.13V5.57zm0-4.7L32.37 0v3.36l-4.13.88V.87zm-4.32 9.35v9.79H19.8V5.57h3.7l.12 1.22c1-1.77 3.07-1.41 3.62-1.22v3.79c-.52-.17-2.29-.43-3.32.86zm-8.55 4.72c0 2.43 2.6 1.68 3.12 1.46v3.36c-.55.3-1.54.54-2.89.54a4.15 4.15 0 0 1-4.27-4.24l.01-13.17 4.02-.86v3.54h3.14V9.1h-3.13v5.85zm-4.91.7c0 2.97-2.31 4.66-5.73 4.66a11.2 11.2 0 0 1-4.46-.93v-3.93c1.38.75 3.1 1.31 4.46 1.31.92 0 1.53-.24 1.53-1C6.26 13.77 0 14.51 0 9.95 0 7.04 2.28 5.3 5.62 5.3c1.36 0 2.72.2 4.09.75v3.88a9.23 9.23 0 0 0-4.1-1.06c-.86 0-1.44.25-1.44.9 0 1.85 6.29.97 6.29 5.87z"/>
        </svg>
      </div>
    </div>
  <% end %>

</div>

<%# Modal upgrade OS → SIRH — rendu pour toutes les orgs Manager OS, quelle que soit la section affichée %>
<% if @org.manager_os? %>
  <div id="upgrade-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-xl w-full max-w-md p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white">Passer au SIRH complet</h2>
        <button type="button" onclick="document.getElementById('upgrade-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-5">Notre équipe vous contactera sous 24h pour configurer votre premier compte admin RH et migrer votre espace.</p>
      <%= form_with url: request_upgrade_billing_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 mb-1">Votre nom</label>
          <%= f.text_field :contact_name, value: current_employee.full_name,
              class: "w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500",
              required: true %>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 mb-1">Votre email</label>
          <%= f.email_field :contact_email, value: current_employee.email,
              class: "w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500",
              required: true %>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-600 dark:text-gray-400 mb-1">Message <span class="font-normal text-gray-400">(optionnel)</span></label>
          <%= f.text_area :contact_message, rows: 3,
              placeholder: "Dites-nous en plus sur vos besoins...",
              class: "w-full px-3 py-2 text-sm border border-gray-200 dark:border-gray-700 rounded-lg bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" %>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="document.getElementById('upgrade-modal').classList.add('hidden')"
                  class="flex-1 py-2 text-sm font-semibold text-gray-600 dark:text-gray-400 border border-gray-200 dark:border-gray-700 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
            Annuler
          </button>
          <%= f.submit "Envoyer la demande →",
              class: "flex-1 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
