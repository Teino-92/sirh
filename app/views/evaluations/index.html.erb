<div class="container mx-auto px-4 py-6">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">My Evaluations</h1>
  </div>

  <div class="space-y-4">
    <% @evaluations.each do |evaluation| %>
      <div class="card bg-white shadow-sm p-4">
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="font-semibold text-lg">
              <%= link_to "#{evaluation.period_start.year} Evaluation", evaluation_path(evaluation), class: 'hover:text-blue-600' %>
            </h3>
            <p class="text-sm text-gray-600 mt-1">
              Manager: <%= evaluation.manager.full_name %> &bull;
              <%= evaluation.period_start.strftime('%b %d') %> &ndash; <%= evaluation.period_end.strftime('%b %d, %Y') %>
            </p>
          </div>
          <span class="badge badge-<%= evaluation.status %>"><%= evaluation.status.humanize %></span>
        </div>
        <% if evaluation.employee_review_pending? %>
          <div class="mt-3">
            <%= link_to 'Submit Self Review', evaluation_path(evaluation), class: 'btn btn-sm btn-primary' %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @evaluations.empty? %>
      <p class="text-gray-500 text-center py-8">No evaluations found.</p>
    <% end %>
  </div>
</div>
