<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Mes évaluations</h1>
    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">Évaluations de performance sur vos périodes de travail</p>
  </div>

  <div class="space-y-4">
    <% @evaluations.each do |evaluation| %>
      <%
        status_classes = {
          'draft'                   => 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-600',
          'employee_review_pending' => 'bg-yellow-100 dark:bg-yellow-900/40 text-yellow-800 dark:text-yellow-300 border-yellow-200 dark:border-yellow-700',
          'manager_review_pending'  => 'bg-orange-100 dark:bg-orange-900/40 text-orange-800 dark:text-orange-300 border-orange-200 dark:border-orange-700',
          'completed'               => 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 border-green-200 dark:border-green-700',
          'cancelled'               => 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 border-gray-200 dark:border-gray-600'
        }
        status_labels = {
          'draft'                   => 'Brouillon',
          'employee_review_pending' => 'Auto-évaluation attendue',
          'manager_review_pending'  => 'En cours d\'évaluation',
          'completed'               => 'Complétée',
          'cancelled'               => 'Annulée'
        }
      %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-5">
        <div class="flex justify-between items-start gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-gray-900 dark:text-gray-100 text-base">
              <%= link_to evaluation_path(evaluation),
                    class: 'hover:text-indigo-600 dark:hover:text-indigo-400' do %>
                Évaluation <%= evaluation.period_start.year %>
                <% if evaluation.period_start.year != evaluation.period_end.year %>
                  – <%= evaluation.period_end.year %>
                <% end %>
              <% end %>
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
              Manager : <%= evaluation.manager.full_name %> &bull;
              <%= l(evaluation.period_start, format: :short) %> – <%= l(evaluation.period_end, format: :short) %>
            </p>
            <% avg = evaluation.average_score %>
            <% if avg %>
              <p class="text-xs text-orange-600 dark:text-orange-400 font-medium mt-1">Score moyen : <%= avg %>/5</p>
            <% end %>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= status_classes[evaluation.status] || 'bg-gray-100 text-gray-600' %>">
              <%= status_labels[evaluation.status] || evaluation.status.humanize %>
            </span>
            <%= link_to evaluation_path(evaluation),
                  class: 'text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 font-medium' do %>
              Voir
            <% end %>
          </div>
        </div>

        <% if evaluation.employee_review_pending? %>
          <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between">
            <p class="text-sm text-yellow-700 dark:text-yellow-400">
              Votre auto-évaluation est attendue pour cette période.
            </p>
            <%= link_to 'Soumettre mon auto-évaluation', evaluation_path(evaluation),
                  class: 'inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-semibold text-white bg-yellow-600 hover:bg-yellow-700 transition-all' %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @evaluations.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Aucune évaluation pour le moment.</p>
      </div>
    <% end %>
  </div>
</div>
