<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-serif text-text-deep dark:text-white">Mes évaluations</h1>
    <p class="mt-1 text-sm text-muted-soft dark:text-white/50">Évaluations de performance sur vos périodes de travail</p>
  </div>

  <div class="space-y-4">
    <% @evaluations.each do |evaluation| %>
      <%
        status_classes = {
          'draft'                   => 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/50 border-border-soft dark:border-white/15',
          'employee_review_pending' => 'bg-warning/10 dark:bg-warning/10/40 text-warning dark:text-warning border-yellow-200 dark:border-yellow-700',
          'manager_review_pending'  => 'bg-orange-100 dark:bg-orange-900/40 text-orange-800 dark:text-orange-300 border-orange-200 dark:border-orange-700',
          'completed'               => 'bg-green-100 dark:bg-green-900/40 text-green-800 dark:text-green-300 border-green-200 dark:border-green-700',
          'cancelled'               => 'bg-bg-soft dark:bg-surface/10 text-muted-soft dark:text-white/50 border-border-soft dark:border-white/15'
        }
        status_labels = {
          'draft'                   => 'Brouillon',
          'employee_review_pending' => 'Auto-évaluation attendue',
          'manager_review_pending'  => 'En cours d\'évaluation',
          'completed'               => 'Complétée',
          'cancelled'               => 'Annulée'
        }
      %>
      <div class="bg-surface dark:bg-[#1C1B2E] rounded-lg shadow-sm border border-border-soft dark:border-white/10 p-5">
        <div class="flex justify-between items-start gap-4">
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-text-deep dark:text-white text-base">
              <%= link_to evaluation_path(evaluation),
                    class: 'hover:text-primary dark:hover:text-primary' do %>
                Évaluation <%= evaluation.period_start.year %>
                <% if evaluation.period_start.year != evaluation.period_end.year %>
                  – <%= evaluation.period_end.year %>
                <% end %>
              <% end %>
            </h3>
            <p class="text-sm text-muted-soft dark:text-white/50 mt-0.5">
              Manager : <%= evaluation.manager.full_name %> &bull;
              <%= l(evaluation.period_start, format: :short) %> – <%= l(evaluation.period_end, format: :short) %>
            </p>
            <% avg = evaluation.average_score %>
            <% if avg %>
              <p class="text-xs text-orange-600 dark:text-orange-400 font-medium mt-1">Score moyen : <%= avg %>/5</p>
            <% end %>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= status_classes[evaluation.status] || 'bg-bg-soft text-muted-soft' %>">
              <%= status_labels[evaluation.status] || evaluation.status.humanize %>
            </span>
            <%= link_to evaluation_path(evaluation),
                  class: 'text-sm text-primary dark:text-primary/80 hover:text-primary dark:hover:text-primary font-medium' do %>
              Voir
            <% end %>
          </div>
        </div>

        <% if evaluation.employee_review_pending? %>
          <div class="mt-4 pt-4 border-t border-border-soft dark:border-white/10 flex items-center justify-between">
            <p class="text-sm text-warning dark:text-warning">
              Votre auto-évaluation est attendue pour cette période.
            </p>
            <%= link_to 'Soumettre mon auto-évaluation', evaluation_path(evaluation),
                  class: 'inline-flex items-center py-1.5 px-3 border border-transparent rounded-md text-sm font-semibold text-white bg-warning/10 hover:bg-warning/10 transition-all' %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @evaluations.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-muted-soft dark:text-muted-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
        </svg>
        <p class="mt-2 text-sm text-muted-soft dark:text-white/50">Aucune évaluation pour le moment.</p>
      </div>
    <% end %>
  </div>
</div>
