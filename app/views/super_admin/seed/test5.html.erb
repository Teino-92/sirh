<!DOCTYPE html>
<html>
<head>
  <title>Seed test5</title>
  <style>
    body { font-family: monospace; background: #0f172a; color: #e2e8f0; padding: 2rem; }
    h1   { color: #818cf8; }
    .ok  { color: #4ade80; }
    .box { background: #1e293b; border: 1px solid #334155; border-radius: 8px; padding: 1.5rem; margin-top: 1rem; }
    table { border-collapse: collapse; width: 100%; }
    td, th { padding: 6px 12px; text-align: left; border-bottom: 1px solid #334155; }
    th { color: #94a3b8; font-size: 0.75rem; text-transform: uppercase; }
    a  { color: #818cf8; }
  </style>
</head>
<body>
  <h1>✅ Seed test5 terminé</h1>

  <div class="box">
    <table>
      <tr><th>Org ID</th><td><%= @stats[:org_id] %></td></tr>
      <tr><th>Employés</th><td class="ok"><%= @stats[:employees_after] %></td></tr>
      <tr><th>Leave requests</th><td class="ok"><%= @stats[:leave_requests] %></td></tr>
      <tr><th>Business rules</th><td class="ok"><%= @stats[:business_rules] %></td></tr>
    </table>
  </div>

  <div class="box" style="margin-top:1.5rem">
    <p style="color:#94a3b8; margin:0 0 0.5rem">Comptes créés :</p>
    <table>
      <tr><th>Rôle</th><th>Email</th><th>Mot de passe</th></tr>
      <tr><td>Admin / CEO</td><td>ceo@test5.fr</td><td>password123</td></tr>
      <tr><td>RH</td><td>dhr@test5.fr</td><td>password123</td></tr>
      <tr><td>Manager Backend</td><td>mgr.backend@test5.fr</td><td>password123</td></tr>
      <tr><td>Manager Frontend</td><td>mgr.frontend@test5.fr</td><td>password123</td></tr>
      <tr><td>Employé</td><td>dev.b1@test5.fr</td><td>password123</td></tr>
    </table>
  </div>

  <p style="margin-top:1.5rem">
    <a href="/super_admin/analytics">← Retour analytics</a>
  </p>
</body>
</html>
