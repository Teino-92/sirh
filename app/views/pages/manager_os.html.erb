<script>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  // Hero text
  gsap.from('[data-hero="text"] > *', {
    opacity: 0, y: 30, duration: 0.6, stagger: 0.12, ease: 'power2.out', delay: 0.1
  });

  // Mock UI
  gsap.to('[data-mock-ui]', {
    opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
    scrollTrigger: { trigger: '[data-mock-ui]', start: 'top 85%', once: true }
  });

  // Module sections
  document.querySelectorAll('[data-module="left"], [data-module="right"]').forEach(function(el, i) {
    var isRight = el.hasAttribute('data-module') && el.getAttribute('data-module') === 'right';
    gsap.from(el, {
      opacity: 0, x: isRight ? 40 : -40, duration: 0.7, ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 82%', once: true }
    });
  });
});
</script>
