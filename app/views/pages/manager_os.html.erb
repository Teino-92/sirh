<%# Page produit Manager OS — layout: marketing %>
<% content_for :body_style do %>background-color:#0f0a2e<% end %>
<style>
  .mock-logo-z    { fill: #B0B91A; }
  .mock-logo-rest { fill: white; }
</style>

<% content_for :bg_decoration do %>
  <div style="position:absolute; left:-15vw; top:5vh; width:60vw; height:60vw; max-width:800px; max-height:800px; border-radius:50%; background:radial-gradient(circle, rgba(99,102,241,0.13) 0%, transparent 65%)"></div>
  <div style="position:absolute; right:-10vw; top:20vh; width:50vw; height:50vw; max-width:700px; max-height:700px; border-radius:50%; background:radial-gradient(circle, rgba(139,92,246,0.10) 0%, transparent 65%)"></div>
  <div style="position:absolute; left:10vw; bottom:15vh; width:45vw; height:45vw; max-width:600px; max-height:600px; border-radius:50%; background:radial-gradient(circle, rgba(99,102,241,0.09) 0%, transparent 65%)"></div>
  <div style="position:absolute; right:-5vw; bottom:5vh; width:40vw; height:40vw; max-width:550px; max-height:550px; border-radius:50%; background:radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 65%)"></div>
<% end %>

<%# ─── NAVBAR ─────────────────────────────────────────────────────────────── %>
<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm"
     x-data="{ mobileOpen: false }">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <%= link_to root_path do %>
        <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-7 w-auto">
      <% end %>

      <div class="hidden md:flex items-center gap-8">
        <%= link_to "Manager OS", manager_os_path, class: "text-sm font-semibold text-indigo-600" %>
        <%= link_to "SIRH", sirh_path, class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
        <%= link_to "Tarifs", root_path + "#tarifs", class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
        <%= link_to "FAQ", root_path + "#faq", class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to new_employee_session_path, class: "hidden sm:block text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>Connexion<% end %>
        <%= link_to root_path + "#essai-manager-os", class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm" do %>
          Essai gratuit
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
      </div>
    </div>
  </div>
</nav>

<main id="main-content">

<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<section class="relative pt-20 pb-24">

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl" data-hero="text">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 text-indigo-300 text-xs font-semibold rounded-full mb-6 border border-white/10">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
        Manager OS — Le produit d'entrée
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Le cycle complet<br>du <span class="text-indigo-400">management d'équipe</span>
      </h1>
      <p class="text-xl text-indigo-200 mb-10 leading-relaxed max-w-2xl">
        Onboarding, 1:1, objectifs, formation — tout ce qu'un manager fait aujourd'hui dans 4 outils différents, réuni en un seul endroit. Simple, rapide, pensé pour les équipes françaises.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <%= link_to root_path + "#essai-manager-os", class: "inline-flex items-center justify-center gap-2 px-5 py-3 sm:px-8 sm:py-4 bg-white hover:bg-indigo-50 text-indigo-600 font-bold rounded-xl transition-colors shadow-lg text-sm sm:text-base" do %>
          Essayer gratuitement — 30 jours
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
        <%= link_to sirh_path, class: "inline-flex items-center justify-center gap-2 px-5 py-3 sm:px-8 sm:py-4 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold rounded-xl transition-colors text-sm sm:text-base" do %>
          Voir le SIRH complet
        <% end %>
      </div>
      <div class="flex flex-wrap gap-5 mt-8">
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-300">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Sans carte bancaire
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-300">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Données en Europe · RGPD
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-300">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Conforme Code du Travail
        </span>
      </div>
    </div>
  </div>
</section>


<%# ─── MOCK UI DASHBOARD ──────────────────────────────────────────────────── %>
<section class="py-14">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <p class="text-sm font-semibold text-indigo-400 uppercase tracking-wide mb-2">L'interface</p>
      <h2 class="text-3xl font-extrabold text-white">Vue manager en temps réel</h2>
    </div>

    <%# Mock dashboard — dark mode %>
    <div data-mock-ui class="rounded-2xl overflow-hidden border border-white/10" style="opacity:0; background-color:#1e2035">
      <%# Navbar %>
      <div class="flex items-center justify-between px-6 py-3 border-b border-white/10" style="background-color:#15172a">
        <div class="flex items-center gap-3">
          <svg class="h-4 w-auto flex-shrink-0" viewBox="0 0 606 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Izi-RH"><path d="M11.4 144C7.93333 144 5.13333 143.067 3 141.2C1 139.333 0 136.733 0 133.4V10.6C0 7.26667 1 4.66667 3 2.8C5.13333 0.933337 7.93333 0 11.4 0C14.7333 0 17.4667 1 19.6 3C21.7333 4.86667 22.8 7.4 22.8 10.6V133.4C22.8 136.6 21.7333 139.2 19.6 141.2C17.4667 143.067 14.7333 144 11.4 144Z" class="mock-logo-rest"/><path d="M72.9516 142C65.0849 142 58.8182 140.133 54.1516 136.4C49.6182 132.533 47.3516 127.333 47.3516 120.8C47.3516 115.867 48.2849 111.6 50.1516 108C52.1516 104.267 55.8182 100.333 61.1516 96.2L141.152 34.2C143.152 32.6 144.552 31.2 145.352 30C146.285 28.6667 146.752 27.0667 146.752 25.2C146.752 21.6 144.218 19.8 139.152 19.8H63.1516C59.6849 19.8 56.8182 19.0667 54.5516 17.6C52.2849 16 51.1516 13.8 51.1516 11C51.1516 8.06666 52.2849 5.86667 54.5516 4.4C56.8182 2.8 59.6849 2 63.1516 2H143.952C151.952 2 158.218 3.86667 162.752 7.6C167.285 11.2 169.552 16.4 169.552 23.2C169.552 28.5333 168.618 32.9333 166.752 36.4C164.885 39.7333 161.218 43.4667 155.752 47.6L75.7516 109.8C73.7516 111.267 72.2849 112.733 71.3516 114.2C70.5516 115.533 70.1516 117.133 70.1516 119C70.1516 122.467 73.2849 124.2 79.5516 124.2H159.152C162.618 124.2 165.485 125 167.752 126.6C170.018 128.067 171.152 130.2 171.152 133C171.152 135.933 170.018 138.2 167.752 139.8C165.485 141.267 162.618 142 159.152 142H72.9516Z" class="mock-logo-z"/><path d="M207.111 144C203.644 144 200.844 143.067 198.711 141.2C196.711 139.333 195.711 136.733 195.711 133.4V10.6C195.711 7.26667 196.711 4.66667 198.711 2.8C200.844 0.933337 203.644 0 207.111 0C210.444 0 213.178 1 215.311 3C217.444 4.86667 218.511 7.4 218.511 10.6V133.4C218.511 136.6 217.444 139.2 215.311 141.2C213.178 143.067 210.444 144 207.111 144Z" class="mock-logo-rest"/><path d="M249.841 81.0749C246.241 81.0749 243.441 80.2749 241.441 78.6749C239.574 77.0749 238.641 74.9416 238.641 72.2749C238.641 66.2749 242.374 6