9.2 501.947 141.2C499.947 143.067 497.214 144 493.747 144Z" class="mock-logo-rest"/></svg>
          <span class="hidden sm:inline text-xs text-gray-400">Studio Créatif Demo</span>
          <span class="text-xs font-semibold text-indigo-400 border-b border-indigo-400 pb-0.5">Dashboard</span>
          <span class="hidden sm:inline text-xs text-gray-500">Équipe</span>
        </div>
        <div class="flex items-center gap-3">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          <div class="w-7 h-7 rounded-full bg-indigo-500/30 flex items-center justify-center text-xs font-bold text-indigo-300">L</div>
        </div>
      </div>
      <%# Body %>
      <div class="p-6">
        <div class="mb-5">
          <h3 class="text-xl font-bold text-white">Bonjour, Lucas 👋</h3>
          <p class="text-sm text-gray-400">25 mars 2026 · Studio Créatif Demo</p>
        </div>
        <%# 4 stat cards %>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
          <% [
            ["1", "Onboarding actif", "#22c55e", "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"],
            ["1", "1:1 cette semaine", "#8b5cf6", "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"],
            ["4", "Objectifs en cours", "#6366f1", "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"],
            ["2", "Formations en cours", "#f59e0b", "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"],
          ].each do |val, label, color, icon| %>
            <div class="rounded-xl p-4 border border-white/5" style="background-color:#15172a">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-3" style="background-color:<%= color %>22">
                <svg class="w-4 h-4" style="color:<%= color %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon %>"/></svg>
              </div>
              <div class="text-xl font-extrabold text-white"><%= val %></div>
              <div class="text-xs text-gray-400 mt-0.5"><%= label %></div>
            </div>
          <% end %>
        </div>
        <%# 2 cards — Onboardings + 1:1 %>
        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-xl border border-white/5 overflow-hidden" style="background-color:#15172a">
            <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">Onboardings en cours</span>
              <span class="text-xs text-indigo-400">Tous</span>
            </div>
            <div class="px-4 py-3 flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center text-xs font-bold flex-shrink-0">MG</div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-semibold text-white">Manon Garcia</div>
                <div class="text-xs text-gray-400">8 / 8 tâches</div>
              </div>
              <span class="text-xs text-indigo-400">Voir</span>
            </div>
          </div>
          <div class="rounded-xl border border-white/5 overflow-hidden" style="background-color:#15172a">
            <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">Prochains 1:1</span>
              <span class="text-xs text-indigo-400">Tous</span>
            </div>
            <div class="px-4 py-3 flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-violet-500/20 text-violet-400 flex items-center justify-center text-xs font-bold flex-shrink-0">AL</div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-semibold text-white">Antoine Leroy</div>
                <div class="text-xs text-gray-400">26 mar. 10:30</div>
              </div>
              <span class="text-xs text-indigo-400">Voir</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── WAVE dark → white ──────────────────────────────────────────────────── %>
<div style="margin-bottom:-1px; line-height:0" aria-hidden="true">
  <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" preserveAspectRatio="none">
    <path d="M0,80 C360,20 1080,80 1440,20 L1440,80 Z" fill="white"/>
  </svg>
</div>

<%# ─── MODULE ONBOARDING ──────────────────────────────────────────────────── %>
<section class="py-16 bg-white" id="onboarding">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div data-module="left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-orange-50 text-orange-700 text-xs font-semibold rounded-full mb-6 border border-orange-100">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Onboarding
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">Chaque nouvel arrivant, un onboarding sans friction</h2>
        <p class="text-lg text-gray-500 mb-8 leading-relaxed">Créez des templates réutilisables par rôle. Assignez les tâches automatiquement dès la création du profil. Suivez la progression en temps réel, sans relancer manuellement.</p>
        <ul class="space-y-4">
          <% [
            ["Templates par rôle", "Dev, commercial, ops, RH — un template adapté pour chaque poste, réutilisable à l'infini."],
            ["Check-lists avec responsables", "Chaque tâche a un owner et une deadline. Plus rien ne tombe dans les oubliettes."],
            ["Rappels automatiques", "Si une tâche est en retard, le manager et le responsable reçoivent une notification automatique."],
            ["Tableau de bord d'avancement", "Vision globale de tous les onboardings en cours : qui est en retard, qui est on track."],
          ].each do |title, desc| %>
            <li class="flex gap-4">
              <div class="w-6 h-6 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-orange-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
              <div>
                <div class="text-sm font-semibold text-gray-800 mb-0.5"><%= title %></div>
                <div class="text-sm text-gray-500"><%= desc %></div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>

      <%# Mock onboarding UI — fidèle à la vraie app %>
      <div data-module="right" class="relative">
        <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <div>
              <h3 class="text-xl font-extrabold text-gray-900">Onboarding équipe</h3>
              <p class="text-sm text-gray-400">Suivez l'intégration des nouveaux collaborateurs</p>
            </div>
            <div class="flex gap-2">
              <span class="px-3 py-1.5 text-xs font-semibold rounded-lg border border-gray-200 text-gray-600">Créer un template</span>
              <span class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-indigo-600 text-white">+ Démarrer un onboarding</span>
            </div>
          </div>
          <div class="p-4 space-y-3">
            <% [
              ["Manon Garcia", "Actif", "bg-emerald-100 text-emerald-700", "Intégration Designer", "17 sept.", "Jour 190", 100],
              ["Thomas Bernard", "Terminé", "bg-indigo-100 text-indigo-700", "Intégration Tech", "17 jan.", nil, 100],
            ].each do |name, status, badge_cls, template, date, jour, pct| %>
              <div class="border border-gray-100 rounded-xl p-4">
                <div class="flex items-start justify-between mb-2">
                  <div class="flex items-center gap-2">
                    <span class="text-base font-bold text-gray-900"><%= name %></span>
                    <span class="px-2 py-0.5 text-xs font-semibold rounded-full <%= badge_cls %>"><%= status %></span>
                  </div>
                  <div class="text-right">
                    <div class="text-xl font-extrabold text-amber-500">40</div>
                    <div class="text-xs text-gray-400">Score</div>
                  </div>
                </div>
                <div class="flex items-center gap-4 text-xs text-gray-400 mb-3">
