<%# Landing page Izi-RH — layout: marketing %>

<%# ─── NAVBAR ─────────────────────────────────────────────────────────────── %>
<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm"
     x-data="{ mobileOpen: false }">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-7 w-auto">

      <div class="hidden md:flex items-center gap-8">
        <%= link_to "Manager OS", manager_os_path, class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
        <%= link_to "SIRH", sirh_path, class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
        <a href="#tarifs"          class="text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors">Tarifs</a>
        <a href="#faq"             class="text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors">FAQ</a>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to new_employee_session_path, class: "hidden sm:block text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>Connexion<% end %>
        <a href="#essai" class="inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Essai gratuit
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <button @click="mobileOpen = !mobileOpen" :aria-expanded="mobileOpen.toString()" aria-controls="mobile-menu" aria-label="Menu de navigation"
                class="md:hidden p-2 rounded-lg text-gray-500 hover:bg-gray-100 transition-colors">
          <svg x-show="!mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg x-show="mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" x-show="mobileOpen" @click.outside="mobileOpen = false"
       x-transition:enter="transition ease-out duration-150" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-100" x-transition:leave-start="opacity-100 translate-y-0" x-transition:leave-end="opacity-0 -translate-y-2"
       class="md:hidden border-t border-gray-100 bg-white" style="display:none">
    <div class="px-4 py-3 space-y-1">
      <%= link_to "Manager OS", manager_os_path, "@click": "mobileOpen = false", class: "block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= link_to "SIRH", sirh_path, "@click": "mobileOpen = false", class: "block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <a href="#tarifs"          @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">Tarifs</a>
      <a href="#faq"             @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">FAQ</a>
      <div class="pt-2 border-t border-gray-100">
        <%= link_to new_employee_session_path, class: "block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50" do %>Connexion<% end %>
      </div>
    </div>
  </div>
</nav>

<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<main id="main-content">
<section class="relative overflow-hidden bg-white pt-20 pb-0">


  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <%# Colonne texte %>
      <div>
        <div data-hero="badge" class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 text-indigo-700 text-xs font-semibold rounded-full mb-6 border border-indigo-100">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          Concu par des managers, pour les managers
        </div>

        <h1 data-hero="title" class="font-extrabold text-gray-900 leading-[1.1] tracking-tight mb-6" style="font-size: clamp(2rem, 5vw, 3.5rem)">
          Gérez vos équipes.<br>
          <span class="text-indigo-600">Sans les tableurs.</span>
        </h1>

        <p data-hero="subtitle" class="text-lg text-gray-500 mb-8 leading-relaxed max-w-lg">
          Onboarding, objectifs, 1:1, congés, pointage — tout ce qu'un manager gère dans 4 outils différents, réuni en un seul endroit. Simple, rapide, pensé pour les équipes françaises.
        </p>

        <div data-hero="ctas" class="flex flex-col sm:flex-row gap-3 mb-10">
          <a href="#essai-manager-os" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-indigo-200 text-base whitespace-nowrap">
            Essai gratuit 30 jours
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="#tarifs" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gray-50 hover:bg-gray-100 text-gray-700 font-semibold rounded-xl transition-colors border border-gray-200 text-base whitespace-nowrap">
            Voir les tarifs
          </a>
        </div>

        <div data-hero="badges" class="flex flex-wrap gap-3">
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-500">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Sans carte bancaire
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-500">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Données en Europe · RGPD
          </span>
          <span class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-500">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Conforme Code du Travail
          </span>
        </div>
      </div>

      <%# Colonne illustration SVG %>
      <div data-hero="illustration" class="relative" style="display:block">
        <%# Blob de fond %>
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 500 500" fill="none" aria-hidden="true">
          <path d="M420,280 C440,340 390,420 320,440 C250,460 160,430 120,370 C80,310 100,210 160,160 C220,110 310,80 370,120 C430,160 400,220 420,280Z" fill="#eef2ff"/>
        </svg>

        <%# Dashboard card simulé %>
        <div class="relative z-10 p-6">

          <%# Card principale %>
          <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-5 mb-4">
            <div class="flex items-center justify-between mb-4">
              <div>
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Équipe · Semaine</div>
                <div class="text-lg font-bold text-gray-900 mt-0.5">Vue manager</div>
              </div>
              <div class="w-9 h-9 bg-indigo-100 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
            </div>
            <% [["Marie D.", "Onboarding J+3", "bg-orange-100 text-orange-700", "En cours"], ["Lucas B.", "1:1 cette semaine", "bg-violet-100 text-violet-700", "Planifié"], ["Sophie R.", "Objectif Q2 · 80%", "bg-green-100 text-green-700", "On track"]].each do |name, task, badge_class, status| %>
            <div class="flex items-center justify-between py-2.5 border-b border-gray-50 last:border-0">
              <div class="flex items-center gap-3">
                <div class="w-7 h-7 rounded-full bg-indigo-100 flex items-center justify-center text-xs font-bold text-indigo-600"><%= name.split.map(&:first).join %></div>
                <div>
                  <div class="text-sm font-semibold text-gray-800"><%= name %></div>
                  <div class="text-xs text-gray-400"><%= task %></div>
                </div>
              </div>
              <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= badge_class %>"><%= status %></span>
            </div>
            <% end %>
          </div>

          <%# Mini stats %>
          <div class="grid grid-cols-3 gap-3 mb-3">
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-3 text-center">
              <div class="text-xl font-extrabold text-indigo-600">12</div>
              <div class="text-xs text-gray-400 mt-0.5">Membres</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-3 text-center">
              <div class="text-xl font-extrabold text-violet-600">3</div>
              <div class="text-xs text-gray-400 mt-0.5">1:1 cette sem.</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-3 text-center">
              <div class="text-xl font-extrabold text-green-600">94%</div>
              <div class="text-xs text-gray-400 mt-0.5">OKR atteints</div>
            </div>
          </div>

          <%# Notifications en bas %>
          <div class="flex gap-2">
            <div class="flex-1 bg-white rounded-xl shadow-md border border-gray-100 px-3 py-2 flex items-center gap-2">
              <div class="w-7 h-7 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="text-xs font-bold text-gray-800 whitespace-nowrap">Congés approuvés</div>
                <div class="text-xs text-gray-400">Marie · 15–22 août</div>
              </div>
            </div>
            <div class="flex-1 bg-white rounded-xl shadow-md border border-gray-100 px-3 py-2 flex items-center gap-2">
              <div class="w-7 h-7 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <div class="text-xs font-bold text-gray-800 whitespace-nowrap">Onboarding · 7/10</div>
                <div class="text-xs text-gray-400">Lucas · J+3</div>
              </div>
            </div>
          </div>

        </div>

      </div>

    </div>
  </div>

</section>

<%# ─── WAVE white → slate-50 ─────────────────────────────────────────────── %>
<div style="background-color:white; margin-bottom:-2px; line-height:0" aria-hidden="true">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full block" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,20 C360,80 1080,20 1440,80 L1440,80 L0,80 Z" fill="#f8fafc"/>
  </svg>
</div>

<%# ─── STATS + TÉMOIGNAGES ──────────────────────────────────────────────── %>
<section class="bg-slate-50 py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <%# Stats %>
    <div data-animate="stats" class="grid grid-cols-3 gap-8 text-center mb-16">
      <div data-stat>
        <div class="text-4xl font-extrabold text-indigo-600 mb-1">4</div>
        <div class="text-sm text-gray-500">outils remplacés<br><span class="text-xs text-gray-400">(Excel · Notion · Word · PDF)</span></div>
      </div>
      <div data-stat>
        <div class="text-4xl font-extrabold text-indigo-600 mb-1">2 min</div>
        <div class="text-sm text-gray-500">pour importer votre équipe</div>
      </div>
      <div data-stat>
        <div class="text-4xl font-extrabold text-indigo-600 mb-1">30j</div>
        <div class="text-sm text-gray-500">d'essai gratuit sans CB</div>
      </div>
    </div>

    <%# Témoignages %>
    <div id="testimonials-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <figure class="bg-white rounded-2xl p-6 border-l-4 border-indigo-500 shadow-sm">
        <div class="flex gap-0.5 mb-3">
          <% 5.times do %><svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% end %>
        </div>
        <blockquote class="text-sm text-gray-600 leading-relaxed mb-4">"Enfin un outil RH pensé pour les managers, pas seulement pour les RH. Les 1:1 et objectifs intégrés changent vraiment notre façon de piloter les équipes."</blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-violet-100 flex items-center justify-center text-sm font-bold text-violet-600">TM</div>
          <div>
            <div class="text-sm font-semibold text-gray-800">Thomas M.</div>
            <div class="text-xs text-gray-400">CTO · Agence digitale, 28 personnes</div>
          </div>
        </figcaption>
      </figure>

      <figure class="bg-white rounded-2xl p-6 border-l-4 border-indigo-500 shadow-sm">
        <div class="flex gap-0.5 mb-3">
          <% 5.times do %><svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% end %>
        </div>
        <blockquote class="text-sm text-gray-600 leading-relaxed mb-4">"J'avais un tableau de suivi onboarding, un autre pour les objectifs, un autre pour les 1:1. Izi-RH remplace tout ça. Mon équipe adore."</blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center text-sm font-bold text-indigo-600">SC</div>
          <div>
            <div class="text-sm font-semibold text-gray-800">Sophie C.</div>
            <div class="text-xs text-gray-400">Head of Engineering · Scale-up B2B, 35 personnes</div>
          </div>
        </figcaption>
      </figure>

      <figure class="bg-white rounded-2xl p-6 border-l-4 border-indigo-500 shadow-sm">
        <div class="flex gap-0.5 mb-3">
          <% 5.times do %><svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg><% end %>
        </div>
        <blockquote class="text-sm text-gray-600 leading-relaxed mb-4">"La conformité au Code du Travail était notre critère n°1. Izi-RH gère correctement les 35h, les RTT et les congés conventionnels — sans paramétrage complexe."</blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-emerald-100 flex items-center justify-center text-sm font-bold text-emerald-600">AL</div>
          <div>
            <div class="text-sm font-semibold text-gray-800">Aurélie L.</div>
            <div class="text-xs text-gray-400">DRH · PME industrielle, 80 personnes</div>
          </div>
        </figcaption>
      </figure>

    </div>
  </div>
</section>

<%# ─── MANAGER OS ─────────────────────────────────────────────────────────── %>
<div class="bg-slate-50 overflow-hidden" style="margin-bottom:-2px">
  <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" aria-hidden="true">
    <path d="M0,0 C360,60 1080,0 1440,60 L1440,60 L0,60 Z" fill="white"/>
  </svg>
</div>
<section id="manager-os" class="py-20 bg-white relative overflow-hidden">


  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 text-indigo-700 text-xs font-semibold rounded-full mb-4 border border-indigo-100">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
        Manager OS — le produit d'entrée
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">Le cycle complet du management d'équipe</h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">Quatre modules essentiels. Un seul outil. Zéro tableur.</p>
    </div>

    <%# Pills + card interactive %>
    <div x-data="{ tab: 'onboarding' }" class="mb-14">

      <%# Pills %>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <% [
          { key: 'onboarding', label: 'Onboarding',     icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
          { key: 'oneonone',   label: 'Entretiens 1:1', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
          { key: 'objectifs',  label: 'Objectifs & OKR', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
          { key: 'formation',  label: 'Formation',       icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
        ].each do |pill| %>
          <button @click="tab = '<%= pill[:key] %>'"
                  :class="tab === '<%= pill[:key] %>' ? 'bg-indigo-600 text-white shadow-md shadow-indigo-200 border-indigo-600' : 'bg-white text-gray-600 border-gray-200 hover:border-indigo-300 hover:text-indigo-600'"
                  class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border text-sm font-medium transition-all duration-200">
