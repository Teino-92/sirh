        <div class="text-3xl font-extrabold text-indigo-600 mb-1">2 min</div>
        <div class="mb-4 text-sm text-gray-500 dark:text-gray-400">pour migrer vos équipes</div>
      </div>
      <div data-stat>
        <div class="text-3xl font-extrabold text-indigo-600 mb-1">100%</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">conforme Code du Travail</div>
      </div>
      <div data-stat>
        <div class="text-3xl font-extrabold text-indigo-600 mb-1">30j</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">d'essai gratuit sans CB</div>
