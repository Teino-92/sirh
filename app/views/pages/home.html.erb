<%# ─── MANAGER OS — PRODUIT PRINCIPAL ─────────────────────────────────────── %>
<section id="manager-os" class="py-24 bg-gradient-to-br from-indigo-50 via-white to-violet-50/30 dark:from-indigo-950/30 dark:via-gray-950 dark:to-gray-950 border-t border-gray-100 dark:border-gray-800 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 text-xs font-semibold rounded-full mb-4">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Manager OS — Offre d'entrée
      </div>
      <h2 data-features-title class="mt-2 text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-4">
        Le cycle manager complet,<br class="hidden sm:block"> en un seul outil
      </h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        Fini les 4 fichiers bricolés. Onboarding, 1:1, objectifs, formation — tout est connecté, tout est dans Izi-RH.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">

      <div data-feature class="group p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-indigo-200 dark:hover:border-indigo-800 hover:shadow-lg transition-all">
        <div class="w-12 h-12 bg-orange-100 dark:bg-orange-900/30 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">Onboarding</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Templates réutilisables par rôle, tâches assignées (employé / manager / RH), suivi de progression et score d'intégration.</p>
      </div>

      <div data-feature class="group p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-indigo-200 dark:hover:border-indigo-800 hover:shadow-lg transition-all">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background-color:#ede9fe;">
          <svg class="w-6 h-6" style="color:#7c3aed;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
          </svg>
        </div>
        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-2">1:1 structurés</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">Entretiens planifiés avec agenda préparé, notes partagées, action items et historique complet de chaque conversation.</p>
      </div>

      <div data-feature class="group p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-indigo-200 dark:hover:border-indigo-800 hover:shadow-lg transition-all">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background-color:#d1fae5;">
          <svg class="w-6 h-6" style="color:#059669;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
