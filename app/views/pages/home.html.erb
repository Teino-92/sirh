<%# Landing page Izi-RH — layout: marketing %>

<%# ─── NAVBAR ─────────────────────────────────────────────────────────────── %>
<nav class="sticky top-0 z-50 bg-white/95 dark:bg-gray-950/95 backdrop-blur border-b border-gray-100 dark:border-gray-800"
     x-data="{ mobileOpen: false }">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-7 w-auto">

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#manager-os"    class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">Manager OS</a>
        <a href="#fonctionnalites" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">Fonctionnalités</a>
        <a href="#tarifs"        class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">Tarifs</a>
        <a href="#faq"           class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">FAQ</a>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to new_employee_session_path, class: "hidden sm:block text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors" do %>
          Connexion
        <% end %>
        <a href="#essai" class="inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Essai gratuit
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <!-- Hamburger -->
        <button @click="mobileOpen = !mobileOpen"
                :aria-expanded="mobileOpen.toString()"
                aria-controls="mobile-menu"
                aria-label="Menu de navigation"
                class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
          <svg x-show="!mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg x-show="mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu"
       x-show="mobileOpen"
       @click.outside="mobileOpen = false"
       x-transition:enter="transition ease-out duration-150"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-100"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-2"
       class="md:hidden border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-950"
       style="display:none">
    <div class="px-4 py-3 space-y-1">
      <a href="#manager-os"    @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">Manager OS</a>
      <a href="#fonctionnalites" @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">Fonctionnalités</a>
      <a href="#tarifs"        @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">Tarifs</a>
      <a href="#faq"           @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">FAQ</a>
      <div class="pt-2 border-t border-gray-100 dark:border-gray-800">
        <%= link_to new_employee_session_path, class: "block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800" do %>
          Connexion
        <% end %>
      </div>
    </div>
  </div>
</nav>

<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<main id="main-content">
<section class="relative overflow-visible bg-gradient-to-br from-indigo-50 via-white to-violet-50 dark:from-gray-900 dark:via-gray-950 dark:to-indigo-950 pt-20 pb-0">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">

      <!-- Badge -->
      <div data-hero="badge" class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 text-xs font-semibold rounded-full mb-6">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        Conçu pour les managers, pas pour les DRH
      </div>

      <h1 data-hero="title" class="font-extrabold text-gray-900 dark:text-white leading-tight tracking-tight mb-6"
          style="font-size: clamp(1.875rem, 5vw, 3.75rem)">Remplacez vos fichiers Excel<br>par un <span class="text-indigo-600">vrai outil manager</span></h1>

      <p data-hero="subtitle" class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto leading-relaxed">
        Onboarding, objectifs, 1:1, formation — tout ce qu'un manager fait dans 3 à 4 fichiers bricolés,
        réuni en un seul endroit. Simple, rapide, pensé pour les équipes françaises.
      </p>

      <!-- Trust badges -->
      <div data-hero="badges" class="flex flex-wrap justify-center gap-3 mb-10">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Essai 30 jours sans CB
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Données en Europe · RGPD
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Conforme Code du Travail
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Prêt en 2 minutes
        </span>
      </div>

      <!-- CTAs -->
      <div data-hero="ctas" class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#essai-manager-os" class="mt-4 mb-4 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-indigo-200 dark:shadow-indigo-900/40 text-lg">
          Démarrer avec Manager OS — gratuit
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="#tarifs" class="mt-4 mb-4 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-semibold rounded-xl transition-colors hover:bg-gray-50 dark:hover:bg-gray-700 text-lg">
          Voir tous les plans
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
      </div>

      <!-- Hero screenshots — éventail 3D -->
      <div data-hero="screenshot" class="mt-16 mb-12" style="overflow:visible; position:relative;">
        <div style="display:flex; align-items:flex-end; justify-content:center; gap:24px; perspective:1000px; perspective-origin:50% 0%;">

          <!-- Gauche -->
          <div style="flex:0 0 36%; transform:rotateY(30deg); transform-origin:right center; border-radius:12px; overflow:hidden; box-shadow:-8px 24px 56px rgba(0,0,0,0.45); z-index:2;">
            <img src="/screenshots/dashboard-baptiste.png" alt="Dashboard employé Izi-RH" style="width:100%; max-height:260px; object-fit:cover; object-position:top left; display:block;">
          </div>

          <!-- Centre -->
          <div style="flex:0 0 40%; border-radius:12px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,0.45); z-index:3; position:relative;">
            <img src="/screenshots/dashboard-thomas.png" alt="Dashboard manager Izi-RH" style="width:100%; max-height:260px; object-fit:cover; object-position:top left; display:block;">
          </div>

          <!-- Droite -->
          <div style="flex:0 0 36%; transform:rotateY(-30deg); transform-origin:left center; border-radius:12px; overflow:hidden; box-shadow:8px 24px 56px rgba(0,0,0,0.45); z-index:2;">
            <img src="/screenshots/dashboard-nathalie.png" alt="Dashboard RH Izi-RH" style="width:100%; max-height:260px; object-fit:cover; object-position:top left; display:block;">
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── PROBLEM SECTION ─────────────────────────────────────────────────────── %>
<section class="py-16 bg-white dark:bg-gray-950 border-b border-gray-100 dark:border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Stats -->
    <div data-animate="stats" class="grid grid-cols-3 gap-8 text-center mb-14">
      <div data-stat>
        <div class="text-3xl font-extrabold text-indigo-600 mb-1">3–4</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">fichiers Excel par manager en moyenne</div>
      </div>
      <div data-stat>
        <div class="text-3xl font-extrabold text-indigo-600 mb-1">2 min</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">pour importer votre équipe</div>
      </div>
      <div data-stat>
        <div class="text-3xl font-extrabold text-indigo-600 mb-1">30j</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">d'essai gratuit sans CB</div>
      </div>
    </div>

    <!-- Témoignages -->
    <div id="testimonials-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <figure class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-100 dark:border-gray-800">
        <div class="flex gap-0.5 mb-3">
          <% 5.times do %>
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <% end %>
        </div>
        <blockquote class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
          "Enfin un outil RH pensé pour les managers, pas seulement pour les RH. Les 1:1 et objectifs intégrés changent vraiment notre façon de piloter les équipes."
        </blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-violet-100 dark:bg-violet-900/40 flex items-center justify-center text-sm font-bold text-violet-600 dark:text-violet-400">TM</div>
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-gray-200">Thomas M.</div>
            <div class="text-xs text-gray-400">CTO · Agence digitale, 28 personnes</div>
          </div>
        </figcaption>
      </figure>

      <figure class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-100 dark:border-gray-800">
        <div class="flex gap-0.5 mb-3">
          <% 5.times do %>
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <% end %>
        </div>
        <blockquote class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
          "J'avais un tableau de suivi onboarding, un autre pour les objectifs, un autre pour les 1:1. Izi-RH remplace tout ça. Mon équipe adore."
        </blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center text-sm font-bold text-indigo-600 dark:text-indigo-400">SC</div>
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-gray-200">Sophie C.</div>
            <div class="text-xs text-gray-400">Head of Engineering · Scale-up B2B, 35 personnes</div>
          </div>
        </figcaption>
      </figure>

      <figure class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-100 dark:border-gray-800">
        <div class="flex gap-0.5 mb-3">
          <% 5.times do %>
            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <% end %>
        </div>
        <blockquote class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
          "La conformité au Code du Travail était notre critère n°1. Izi-RH gère correctement les 35h, les RTT et les congés conventionnels — sans paramétrage complexe."
        </blockquote>
        <figcaption class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-full bg-emerald-100 dark:bg-emerald-900/40 flex items-center justify-center text-sm font-bold text-emerald-600 dark:text-emerald-400">AL</div>
          <div>
            <div class="text-sm font-semibold text-gray-800 dark:text-gray-200">Aurélie L.</div>
            <div class="text-xs text-gray-400">DRH · PME industrielle, 80 personnes</div>
          </div>
        </figcaption>
      </figure>

    </div>
  </div>
</section>

<%# ─── MANAGER OS SECTION ─────────────────────────────────────────────────── %>
<section id="manager-os" class="py-24 bg-gradient-to-br from-indigo-50 to-violet-50/40 dark:from-indigo-950/30 dark:to-gray-950 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 text-xs font-semibold rounded-full mb-4">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/>
        </svg>
        Manager OS — le produit d'entrée
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 dark:text-white mb-4">
        Le cycle complet du management d'équipe
      </h2>
      <p class="text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        Quatre modules essentiels. Un seul outil. Zéro tableur.
      </p>
    </div>

    <!-- 4 modules Manager OS -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">

      <!-- Onboarding -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl p-8 border border-indigo-100 dark:border-indigo-900/40 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 bg-orange-100 dark:bg-orange-900/30 rounded-2xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <h3 class="text-xl font-bold text-gray-900 dark:text-white">Onboarding</h3>
              <span class="text-xs px-2 py-0.5 bg-orange-100 dark:bg-orange-900/40 text-orange-600 dark:text-orange-300 rounded-full font-medium">Manager OS</span>
            </div>
            <p class="text-gray-500 dark:text-gray-400 leading-relaxed mb-4">Templates d'intégration réutilisables par rôle. Tâches assignées automatiquement au nouvel arrivant, au manager et aux RH. Suivi de progression en temps réel, score d'intégration, revues à J+30 / J+60 / J+90.</p>
            <ul class="space-y-1.5">
              <% ["Templates par rôle (dev, commercial, ops…)", "Check-lists avec responsables assignés", "Rappels automatiques si tâche en retard", "Tableau de bord d'avancement équipe"].each do |item| %>
                <li class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300">
                  <svg class="w-4 h-4 text-indigo-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  <%= item %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>

      <!-- 1:1 -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl p-8 border border-indigo-100 dark:border-indigo-900/40 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-start gap-5">
          <div class="w-14 h-14 bg-violet-100 dark:bg-violet-900/30 rounded-2xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-violet-600 dark:text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
