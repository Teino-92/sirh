<%# ─── FORMULAIRE TRIAL ────────────────────────────────────────────────────── %>
<section id="essai" class="py-24 bg-gradient-to-br from-indigo-600 to-violet-600 dark:from-indigo-800 dark:to-violet-800 border-t-4 border-indigo-700/30">
  <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-3">Démarrer votre essai gratuit</h2>
    <p class="text-indigo-400 mb-8">Aucune carte bancaire requise. Votre espace est prêt en 30 secondes.</p>

    <% if @errors.present? %>
      <div class="mb-6 p-4 bg-red-100 border border-red-300 rounded-xl text-left">
        <p class="text-sm font-semibold text-red-700 mb-1">Impossible de créer votre compte :</p>
        <ul class="list-disc list-inside text-sm text-red-600">
          <% @errors.each do |error| %><li><%= error %></li><% end %>
        </ul>
      </div>
    <% end %>

    <%# P1 Accessibilité: labels liés aux inputs via for/id %>
    <form action="<%= trial_registration_path %>" method="POST" class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl p-8 text-left space-y-4">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <div>
        <label for="trial_organization_name" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Nom de votre entreprise</label>
        <input type="text"
               id="trial_organization_name"
               name="trial[organization_name]"
               value="<%= @form_values&.dig(:organization_name) || @form_values&.dig('organization_name') %>"
               placeholder="TechCorp France"
               required
               autocomplete="organization"
               class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="trial_first_name" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Prénom</label>
          <input type="text"
                 id="trial_first_name"
                 name="trial[first_name]"
                 value="<%= @form_values&.dig(:first_name) || @form_values&.dig('first_name') %>"
                 placeholder="Marie"
                 required
                 autocomplete="given-name"
                 class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
        </div>
        <div>
          <label for="trial_last_name" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Nom</label>
          <input type="text"
                 id="trial_last_name"
                 name="trial[last_name]"
                 value="<%= @form_values&.dig(:last_name) || @form_values&.dig('last_name') %>"
                 placeholder="Dupont"
                 required
                 autocomplete="family-name"
                 class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
        </div>
      </div>

      <div>
        <label for="trial_email" class="block text-xs font-semibold text-gray-500 dark:text-gray-400 mb-1 uppercase tracking-wide">Email professionnel</label>
        <input type="email"
               id="trial_email"
               name="trial[email]"
               value="<%= @form_values&.dig(:email) || @form_values&.dig('email') %>"
               placeholder="marie.dupont@techcorp.fr"
               required
               autocomplete="email"
               class="w-full px-4 py-3 border border-gray-200 dark:border-gray-700 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
      </div>

      <div class="flex justify-center">
      <button type="submit"
              class="inline-flex items-center justify-center gap-2 px-10 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-colors shadow text-base">
        Créer mon espace Izi-RH
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
      </div>

      <%# P0 Légal: liens vers pages à créer %>
      <p class="text-xs text-gray-400 text-center pt-1">
        En créant un compte, vous acceptez nos
        <a href="/cgu" class="underline hover:text-gray-600">CGU</a>
        et notre
        <a href="/politique-de-confidentialite" class="underline hover:text-gray-600">politique de confidentialité</a>.
      </p>
    </form>
  </div>
</section>

<%# ─── FAQ ────────────────────────────────────────────────────────────────── %>
<%# P1 Accessibilité: aria-expanded sur les boutons accordion %>
<section id="faq" class="py-24 bg-white dark:bg-gray-950 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="mt-4 text-3xl font-extrabold text-gray-900 dark:text-white">Questions fréquentes</h2>
    </div>

    <div class="mt-4 space-y-3" x-data>
      <% [
        { q: "Izi-RH est-il conforme au droit du travail français ?",
          a: "Oui. Izi-RH applique automatiquement les règles légales françaises : acquisition CP à 2,5 jours par mois, plafond de 10h de travail par jour, 48h par semaine, calcul RTT pour les contrats 39h+. Les règles sont configurables selon votre convention collective." },
        { q: "Où sont hébergées nos données ?",
          a: "Toutes vos données sont hébergées en Europe, sur des serveurs conformes RGPD. Les données sont chiffrées au repos et en transit. Les informations sensibles (NIR, IBAN) sont chiffrées avec ActiveRecord Encryption. Vos données n'appartiennent qu'à vous." },
        { q: "L'application fonctionne-t-elle sur mobile ?",
          a: "Izi-RH est une PWA (Progressive Web App) installable sur iOS et Android, optimisée mobile-first. Le plan Pro inclut également une API mobile complète (JWT) pour les intégrations natives : pointage GPS, consultation des congés, approbations manager." },
        { q: "Comment fonctionne l'essai gratuit ?",
          a: "Votre espace est créé instantanément sans carte bancaire. Vous avez accès à toutes les fonctionnalités pendant 30 jours. À la fin de l'essai, vous choisissez un plan ou vos données sont conservées 30 jours supplémentaires avant suppression." },
        { q: "Puis-je importer mes collaborateurs depuis mon ancien SIRH ?",
          a: "Oui, c'est l'une de nos forces. Izi-RH accepte n'importe quel fichier CSV — qu'il vienne d'Excel, Sage, Lucca, Factorial, PayFit, BambooHR ou d'un export maison. Détection automatique du format, rapport d'erreurs ligne par ligne. La migration prend généralement moins de 5 minutes." }
      ].each_with_index do |item, i| %>
        <div x-data="{ open: <%= i == 0 %> }"
             class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
          <button @click="open = !open"
                  :aria-expanded="open.toString()"
                  aria-controls="faq-answer-<%= i %>"
                  class="w-full flex items-center justify-between px-6 py-4 text-left bg-white dark:bg-gray-900 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
            <span class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= item[:q] %></span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="faq-answer-<%= i %>"
               x-show="open"
               x-collapse
               class="px-6 pb-4 bg-white dark:bg-gray-900">
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed"><%= item[:a] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<script>
function initGsap() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  // Hero
  var heroTl = gsap.timeline({ defaults: { ease: 'power2.out' } });
  heroTl
    .from('[data-hero="badge"]',      { opacity: 0, y: -16, duration: 0.5 })
    .from('[data-hero="title"]',      { opacity: 0, y: 24,  duration: 0.6 }, '-=0.2')
    .from('[data-hero="subtitle"]',   { opacity: 0, y: 20,  duration: 0.5 }, '-=0.3')
    .from('[data-hero="badges"] span',{ opacity: 0, y: 12,  duration: 0.4, stagger: 0.08 }, '-=0.2')
    .from('[data-hero="ctas"] a',     { opacity: 0, y: 16,  duration: 0.4, stagger: 0.1  }, '-=0.2')
    .from('[data-hero="screenshot"]', { opacity: 0, y: 40,  scale: 0.97, duration: 0.9, ease: 'power2.out' }, '-=0.2');

  // Stats — cacher puis fade in
  var statEls = document.querySelectorAll('[data-animate="stats"] [data-stat]');
  gsap.set(statEls, { opacity: 0 });
  ScrollTrigger.create({
    trigger: '[data-animate="stats"]',
    start: 'top 85%',
    once: true,
    onEnter: function() {
      gsap.to(statEls, { opacity: 1, duration: 0.6, stagger: 0.15, ease: 'power2.out' });
    }
  });

  // Témoignages — cacher puis fade in
  var figureEls = document.querySelectorAll('#testimonials-grid figure');
  gsap.set(figureEls, { opacity: 0 });
  ScrollTrigger.create({
    trigger: '#testimonials-grid',
    start: 'top 85%',
    once: true,
    onEnter: function() {
      gsap.to(figureEls, { opacity: 1, duration: 0.5, stagger: 0.15, ease: 'power2.out' });
    }
  });

  // Features — glissades depuis l'extérieur de l'écran
  // Grille 3x2 : [0]gauche [1]haut [2]droite / [3]gauche [4]bas [5]droite
  var allCards = document.querySelectorAll('[data-feature]');
  if (allCards.length === 6) {
    // Directions de départ (depuis hors-écran)
    var startPos = [
      { x: '-120vw', y: 0 },   // 0 : haut-gauche → vient de gauche
      { x: 0, y: '-120vh' },   // 1 : haut-milieu → vient du haut
      { x: '120vw',  y: 0 },   // 2 : haut-droite → vient de droite
      { x: '-120vw', y: 0 },   // 3 : bas-gauche  → vient de gauche
      { x: 0, y: '120vh' },    // 4 : bas-milieu  → vient du bas
      { x: '120vw',  y: 0 },   // 5 : bas-droite  → vient de droite
    ];
    allCards.forEach(function(c, i) {
      gsap.set(c, { x: startPos[i].x, y: startPos[i].y, opacity: 1 });
    });

    // Ordre d'arrivée : 0, 2, 3, 5, puis 1+4 simultanés
    var order = [0, 2, 3, 5, 1, 4];
    var featureTl = gsap.timeline({ paused: true });
    order.forEach(function(cardIdx, step) {
      var t = step < 4 ? step * 0.35 : 4 * 0.35;
      featureTl.to(allCards[cardIdx], {
        x: 0, y: 0, duration: 0.5, ease: 'power3.out'
      }, t);
    });

    ScrollTrigger.create({
      trigger: '[data-features-title]',
      start: 'top 8px',
      once: true,
      onEnter: function() {
        document.documentElement.style.overflow = 'hidden';
        featureTl.eventCallback('onComplete', function() {
          document.documentElement.style.overflow = '';
        });
        featureTl.play();
      }
    });
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initGsap);
} else {
  initGsap();
}
</script>

</main>

