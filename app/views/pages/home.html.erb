<%# ─── FAQ ────────────────────────────────────────────────────────────────── %>
<section id="faq" class="py-24 bg-white dark:bg-gray-950 border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="mt-4 text-3xl font-extrabold text-gray-900 dark:text-white">Questions fréquentes</h2>
    </div>

    <div class="mt-4 space-y-3" x-data>
      <% [
        { q: "Quelle est la différence entre Manager OS et SIRH ?",
          a: "Manager OS couvre le cycle manager : onboarding, entretiens 1:1, objectifs OKR, suivi formations. C'est conçu pour les managers qui pilotent leurs équipes avec des fichiers bricolés aujourd'hui. Le SIRH ajoute la gestion administrative RH : pointage, congés, planning, paie, analytics. Les deux plans vivent dans la même application — vous passez de l'un à l'autre en un clic." },
        { q: "Puis-je commencer avec Manager OS et passer au SIRH plus tard ?",
          a: "Oui, c'est exactement la trajectoire prévue. Vous créez votre espace Manager OS, embarquez votre équipe, et activez le SIRH complet quand vous en avez besoin. Aucune migration de données, aucun changement d'outil — c'est juste un upgrade dans votre tableau de bord." },
        { q: "Izi-RH est-il conforme au droit du travail français ?",
          a: "Oui. Izi-RH applique automatiquement les règles légales françaises : acquisition CP à 2,5 jours par mois, plafond de 10h de travail par jour, 48h par semaine, calcul RTT pour les contrats 39h+. Les règles sont configurables selon votre convention collective." },
        { q: "Comment fonctionne l'essai gratuit ?",
          a: "Votre espace est créé instantanément sans carte bancaire. Vous avez accès à toutes les fonctionnalités de votre plan pendant 30 jours. À la fin de l'essai, vous choisissez un plan ou vos données sont conservées 30 jours supplémentaires avant suppression." },
        { q: "Puis-je importer mes collaborateurs depuis mon ancien outil ?",
          a: "Oui. Izi-RH accepte n'importe quel fichier CSV — qu'il vienne d'Excel, Sage, Lucca, Factorial, PayFit, BambooHR ou d'un export maison. Détection automatique du format, rapport d'erreurs ligne par ligne. La migration prend généralement moins de 5 minutes." },
        { q: "Où sont hébergées nos données ?",
          a: "Toutes vos données sont hébergées en Europe, sur des serveurs conformes RGPD. Les données sont chiffrées au repos et en transit. Les informations sensibles sont chiffrées avec ActiveRecord Encryption. Vos données n'appartiennent qu'à vous." }
      ].each_with_index do |item, i| %>
        <div x-data="{ open: <%= i == 0 %> }"
             class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
          <button @click="open = !open"
                  :aria-expanded="open.toString()"
                  aria-controls="faq-answer-<%= i %>"
                  class="w-full flex items-center justify-between px-6 py-4 text-left bg-white dark:bg-gray-900 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
            <span class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= item[:q] %></span>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="faq-answer-<%= i %>"
               x-show="open"
               x-collapse
               class="px-6 pb-4 bg-white dark:bg-gray-900">
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed"><%= item[:a] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<script>
function initGsap() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  // Hero
  var heroTl = gsap.timeline({ defaults: { ease: 'power2.out' } });
  heroTl
    .from('[data-hero="badge"]',      { opacity: 0, y: -16, duration: 0.5 })
    .from('[data-hero="title"]',      { opacity: 0, y: 24,  duration: 0.6 }, '-=0.2')
    .from('[data-hero="subtitle"]',   { opacity: 0, y: 20,  duration: 0.5 }, '-=0.3')
    .from('[data-hero="badges"] span',{ opacity: 0, y: 12,  duration: 0.4, stagger: 0.08 }, '-=0.2')
    .from('[data-hero="ctas"] a',     { opacity: 0, y: 16,  duration: 0.4, stagger: 0.1  }, '-=0.2')
    .from('[data-hero="screenshot"]', { opacity: 0, y: 40,  scale: 0.97, duration: 0.9, ease: 'power2.out' }, '-=0.2');

  // Stats — cacher puis fade in
  var statEls = document.querySelectorAll('[data-animate="stats"] [data-stat]');
  gsap.set(statEls, { opacity: 0 });
  ScrollTrigger.create({
    trigger: '[data-animate="stats"]',
    start: 'top 85%',
    once: true,
    onEnter: function() {
      gsap.to(statEls, { opacity: 1, duration: 0.6, stagger: 0.15, ease: 'power2.out' });
    }
  });

  // Témoignages — cacher puis fade in
  var figureEls = document.querySelectorAll('#testimonials-grid figure');
  gsap.set(figureEls, { opacity: 0 });
  ScrollTrigger.create({
    trigger: '#testimonials-grid',
    start: 'top 85%',
    once: true,
    onEnter: function() {
      gsap.to(figureEls, { opacity: 1, duration: 0.5, stagger: 0.15, ease: 'power2.out' });
    }
  });

  // Features Manager OS — fade in en stagger
  var featureEls = document.querySelectorAll('[data-feature]');
  gsap.set(featureEls, { opacity: 0, y: 30 });
  ScrollTrigger.create({
    trigger: '[data-features-title]',
    start: 'top 80%',
    once: true,
    onEnter: function() {
      gsap.to(featureEls, { opacity: 1, y: 0, duration: 0.5, stagger: 0.12, ease: 'power2.out' });
    }
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initGsap);
} else {
  initGsap();
}
</script>

