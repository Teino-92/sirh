<%# Landing page Izi-RH — layout: marketing %>

<%# ─── NAVBAR ─────────────────────────────────────────────────────────────── %>
<%# P0 UX: menu hamburger responsive avec Alpine.js %>
<nav class="sticky top-0 z-50 bg-white/95 dark:bg-gray-950/95 backdrop-blur border-b border-gray-100 dark:border-gray-800"
     x-data="{ mobileOpen: false }">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <span class="text-xl font-extrabold text-indigo-600 tracking-tight">Izi-RH</span>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#fonctionnalites" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">Fonctionnalités</a>
        <a href="#migration"       class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">Migration</a>
        <a href="#tarifs"          class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">Tarifs</a>
        <a href="#faq"             class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors">FAQ</a>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to new_employee_session_path, class: "hidden sm:block text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 transition-colors" do %>
          Connexion
        <% end %>
        <a href="#essai" class="inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm">
          Essai gratuit
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <!-- Hamburger button (mobile only) -->
        <button @click="mobileOpen = !mobileOpen"
                :aria-expanded="mobileOpen.toString()"
                aria-controls="mobile-menu"
                aria-label="Menu de navigation"
                class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
          <svg x-show="!mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg x-show="mobileOpen" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu"
       x-show="mobileOpen"
       @click.outside="mobileOpen = false"
       x-transition:enter="transition ease-out duration-150"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-100"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-2"
       class="md:hidden border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-950"
       style="display:none">
    <div class="px-4 py-3 space-y-1">
      <a href="#fonctionnalites" @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">Fonctionnalités</a>
      <a href="#migration"       @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">Migration</a>
      <a href="#tarifs"          @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">Tarifs</a>
      <a href="#faq"             @click="mobileOpen = false" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">FAQ</a>
      <div class="pt-2 border-t border-gray-100 dark:border-gray-800">
        <%= link_to new_employee_session_path, class: "block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800" do %>
          Connexion
        <% end %>
      </div>
    </div>
  </div>
</nav>

<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<main id="main-content">
<section class="relative overflow-visible bg-gradient-to-br from-indigo-50 via-white to-violet-50 dark:from-gray-900 dark:via-gray-950 dark:to-indigo-950 pt-20 pb-0">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-4xl mx-auto">

      <!-- Badge -->
      <div data-hero="badge" class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300 text-xs font-semibold rounded-full mb-6">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        Conforme droit du travail français
      </div>

      <!-- P3 HTML: H1 sans whitespace parasite, P2 UX: taille responsive avec clamp -->
      <h1 data-hero="title" class="font-extrabold text-gray-900 dark:text-white leading-tight tracking-tight mb-6"
          style="font-size: clamp(1.875rem, 5vw, 3.75rem)">Le SIRH moderne pour <span class="text-indigo-600">les managers français.es</span></h1>

      <p data-hero="subtitle" class="text-lg sm:text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto leading-relaxed">
        Gestion du temps, congés, performance et onboarding — tout-en-un,
        pensé pour les managers et conforme au Code du Travail.
      </p>

      <!-- Trust badges -->
      <div data-hero="badges" class="flex flex-wrap justify-center gap-3 mb-10">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Calcul RTT & CP automatique
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          RGPD · Données en Europe
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Application mobile (PWA)
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-xs font-medium text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          IA RH en langage naturel
        </span>
      </div>

      <!-- CTAs -->
      <div data-hero="ctas" class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="#essai" class="mt-4 mb-4 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-indigo-200 dark:shadow-indigo-900/40 text-lg">
          Démarrer l'essai gratuit
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="#fonctionnalites" class="mt-4 mb-4 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-semibold rounded-xl transition-colors hover:bg-gray-50 dark:hover:bg-gray-700 text-lg">
          Voir les fonctionnalités
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>
      </div>

      <!-- Hero screenshots — éventail 3D -->
      <div data-hero="screenshot" class="mt-16 mb-12" style="overflow:visible; position:relative;">
        <div style="display:flex; align-items:flex-end; justify-content:center; gap:24px; perspective:1000px; perspective-origin:50% 0%;">

          <!-- Gauche — Baptiste -->
          <div style="flex:0 0 36%; transform:rotateY(30deg); transform-origin:right center; border-radius:12px; overflow:hidden; box-shadow:-8px 24px 56px rgba(0,0,0,0.45); z-index:2;">
            <img src="/screenshots/dashboard-baptiste.png" alt="Dashboard employé Izi-RH" style="width:100%; max-height:260px; object-fit:cover; object-position:top left; display:block;">
          </div>

          <!-- Centre — Thomas -->
          <div style="flex:0 0 40%; border-radius:12px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,0.45); z-index:3; position:relative;">
            <img src="/screenshots/dashboard-thomas.png" alt="Dashboard manager Izi-RH" style="width:100%; max-height:260px; object-fit:cover; object-position:top left; display:block;">
          </div>

          <!-- Droite — Nathalie -->
          <div style="flex:0 0 36%; transform:rotateY(-30deg); transform-origin:left center; border-radius:12px; overflow:hidden; box-shadow:8px 24px 56px rgba(0,0,0,0.45); z-index:2;">
            <img src="/screenshots/dashboard-nathalie.png" alt="Dashboard RH Izi-RH" style="width:100%; max-height:260px; object-fit:cover; object-position:top left; display:block;">
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── SOCIAL PROOF ────────────────────────────────────────────────────────── %>
<%# P1 UX: section témoignages %>
<section class="py-16 bg-white dark:bg-gray-950 border-b border-gray-100 dark:border-gray-800">
