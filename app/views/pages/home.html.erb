<script>
function initGsap() {
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var heroTl = gsap.timeline({ defaults: { ease: 'power2.out' } });
  heroTl
    .from('[data-hero="badge"]',        { opacity: 0, y: -16, duration: 0.5 })
    .from('[data-hero="title"]',        { opacity: 0, y: 24,  duration: 0.6 }, '-=0.2')
    .from('[data-hero="subtitle"]',     { opacity: 0, y: 20,  duration: 0.5 }, '-=0.3')
    .from('[data-hero="ctas"] a',       { opacity: 0, y: 16,  duration: 0.4, stagger: 0.1 }, '-=0.2')
    .from('[data-hero="badges"] span',  { opacity: 0, y: 12,  duration: 0.4, stagger: 0.08 }, '-=0.2')
    .from('[data-hero="illustration"]', { opacity: 0, x: 40,  duration: 0.8, ease: 'power2.out' }, '-=0.4');

  var statEls = document.querySelectorAll('[data-animate="stats"] [data-stat]');
  gsap.set(statEls, { opacity: 0 });
  ScrollTrigger.create({ trigger: '[data-animate="stats"]', start: 'top 85%', once: true, onEnter: function() { gsap.to(statEls, { opacity: 1, duration: 0.6, stagger: 0.15, ease: 'power2.out' }); } });

  var figureEls = document.querySelectorAll('#testimonials-grid figure');
  gsap.set(figureEls, { opacity: 0 });
  ScrollTrigger.create({ trigger: '#testimonials-grid', start: 'top 85%', once: true, onEnter: function() { gsap.to(figureEls, { opacity: 1, duration: 0.5, stagger: 0.15, ease: 'power2.out' }); } });
}

if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initGsap); } else { initGsap(); }
</script>
