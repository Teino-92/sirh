<%# Page produit SIRH — layout: marketing %>
<% content_for :body_style do %>background-color:#0f0a2e<% end %>
<style>
  .mock-logo-z    { fill: #B0B91A; }
  .mock-logo-rest { fill: white; }
</style>

<% content_for :bg_decoration do %>
  <div style="position:absolute; left:-15vw; top:5vh; width:60vw; height:60vw; max-width:800px; max-height:800px; border-radius:50%; background:radial-gradient(circle, rgba(99,102,241,0.13) 0%, transparent 65%)"></div>
  <div style="position:absolute; right:-10vw; top:20vh; width:50vw; height:50vw; max-width:700px; max-height:700px; border-radius:50%; background:radial-gradient(circle, rgba(139,92,246,0.10) 0%, transparent 65%)"></div>
  <div style="position:absolute; left:10vw; bottom:15vh; width:45vw; height:45vw; max-width:600px; max-height:600px; border-radius:50%; background:radial-gradient(circle, rgba(99,102,241,0.09) 0%, transparent 65%)"></div>
  <div style="position:absolute; right:-5vw; bottom:5vh; width:40vw; height:40vw; max-width:550px; max-height:550px; border-radius:50%; background:radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 65%)"></div>
<% end %>


<%# ─── NAVBAR ─────────────────────────────────────────────────────────────── %>
<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm"
     x-data="{ mobileOpen: false }">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <%= link_to root_path do %>
        <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-7 w-auto">
      <% end %>

      <div class="hidden md:flex items-center gap-8">
        <%= link_to "Manager OS", manager_os_path, class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
        <%= link_to "SIRH", sirh_path, class: "text-sm font-semibold text-indigo-600" %>
        <%= link_to "Tarifs", root_path + "#tarifs", class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
        <%= link_to "FAQ", root_path + "#faq", class: "text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" %>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to new_employee_session_path, class: "hidden sm:block text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>Connexion<% end %>
        <%= link_to root_path + "#essai-manager-os", class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition-colors shadow-sm" do %>
          Essai gratuit
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
      </div>
    </div>
  </div>
</nav>

<main id="main-content">

<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<section class="relative pt-20 pb-24">

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl" data-hero="text">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 text-indigo-300 text-xs font-semibold rounded-full mb-6 border border-white/10">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        SIRH complet — Quand votre équipe grandit
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Le SIRH qui ne vous<br>ralentit <span class="text-indigo-400">pas</span>
      </h1>
      <p class="text-xl text-indigo-200 mb-10 leading-relaxed max-w-2xl">
        Pointage, congés, paie, planning, import CSV, IA RH — tout dans la même interface que Manager OS. Un seul outil, zéro migration.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <%= link_to root_path + "#essai-manager-os", class: "inline-flex items-center justify-center gap-2 px-5 py-3 sm:px-8 sm:py-4 bg-white hover:bg-indigo-50 text-indigo-600 font-bold rounded-xl transition-colors shadow-lg text-sm sm:text-base" do %>
          Démarrer l'essai SIRH
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        <% end %>
        <%= link_to manager_os_path, class: "inline-flex items-center justify-center gap-2 px-5 py-3 sm:px-8 sm:py-4 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold rounded-xl transition-colors text-sm sm:text-base" do %>
          Voir Manager OS
        <% end %>
      </div>
      <div class="flex flex-wrap gap-5 mt-8">
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-300">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Conforme Code du Travail
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-300">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Données hébergées en Europe
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-medium text-indigo-300">
          <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Migration depuis votre SIRH actuel en 5 min
        </span>
      </div>
    </div>
  </div>
</section>

<%# ─── MOCK UI POINTAGE ───────────────────────────────────────────────────── %>
<section class="py-14">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <p class="text-sm font-semibold text-indigo-400 uppercase tracking-wide mb-2">L'interface</p>
      <h2 class="text-3xl font-extrabold text-white">Tout votre SIRH en un tableau de bord</h2>
    </div>

    <div data-mock-ui class="rounded-2xl overflow-hidden border border-white/10" style="opacity:0; background-color:#1e2035">
      <%# Navbar — fidèle à la vraie app %>
      <div class="flex items-center justify-between px-6 py-3 border-b border-white/10" style="background-color:#15172a">
        <div class="flex items-center gap-3">
          <svg class="h-4 w-auto flex-shrink-0" viewBox="0 0 606 144" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Izi-RH"><path d="M11.4 144C7.93333 144 5.13333 143.067 3 141.2C1 139.333 0 136.733 0 133.4V10.6C0 7.26667 1 4.66667 3 2.8C5.13333 0.933337 7.93333 0 11.4 0C14.7333 0 17.4667 1 19.6 3C21.7333 4.86667 22.8 7.4 22.8 10.6V133.4C22.8 136.6 21.7333 139.2 19.6 141.2C17.4667 143.067 14.7333 144 11.4 144Z" class="mock-logo-rest"/><path d="M72.9516 142C65.0849 142 58.8182 140.133 54.1516 136.4C49.6182 132.533 47.3516 127.333 47.3516 120.8C47.3516 115.867 48.2849 111.6 50.1516 108C52.1516 104.267 55.8182 100.333 61.1516 96.2L141.152 34.2C143.152 32.6 144.552 31.2 145.352 30C146.285 28.6667 146.752 27.0667 146.752 25.2C146.752 21.6 144.218 19.8 139.152 19.8H63.1516C59.6849 19.8 56.8182 19.0667 54.5516 17.6C52.2849 16 51.1516 13.8 51.1516 11C51.1516 8.06666 52.2849 5.86667 54.5516 4.4C56.8182 2.8 59.6849 2 63.1516 2H143.952C151.952 2 158.218 3.86667 162.752 7.6C167.285 11.2 169.552 16.4 169.552 23.2C169.552 28.5333 168.618 32.9333 166.752 36.4C164.885 39.7333 161.218 43.4667 155.752 47.6L75.7516 109.8C73.7516 111.267 72.2849 112.733 71.3516 114.2C70.5516 115.533 70.1516 117.133 70.1516 119C70.1516 122.467 73.2849 124.2 79.5516 124.2H159.152C162.618 124.2 165.485 125 167.752 126.6C170.018 128.067 171.152 130.2 171.152 133C171.152 135.933 170.018 138.2 167.752 139.8C165.485 141.267 162.618 142 159.152 142H72.9516Z" class="mock-logo-z"/><path d="M207.111 144C203.644 144 200.844 143.067 198.711 141.2C196.711 139.333 195.711 136.733 195.711 133.4V10.6C195.711 7.26667 196.711 4.66667 198.711 2.8C200.844 0.933337 203.644 0 207.111 0C210.444 0 213.178 1 215.311 3C217.444 4.86667 218.511 7.4 218.511 10.6V133.4C218.511 136.6 217.444 139.2 215.311 141.2C213.178 143.067 210.444 144 207.111 144Z" class="mock-logo-rest"/><path d="M249.841 81.0749C246.241 81.0749 243.441 80.2749 241.441 78.6749C239.574 77.0749 238.641 74.9416 238.641 72.2749C238.641 66.2749 242.374 63.2749 249.841 63.2749H309.241C316.707 63.2749 320.441 66.2749 320.441 72.2749C320.441 74.9416 319.441 77.0749 317.441 78.6749C315.574 80.2749 312.841 81.0749 309.241 81.0749H249.841Z" class="mock-logo-rest"/><path d="M391.477 93.4028L386.675 93.3984L386.578 93.4001H363.978V133.2C363.978 136.533 362.845 139.2 360.578 141.2C358.445 143.067 355.645 144 352.178 144C348.578 144 345.711 143.067 343.578 141.2C341.578 139.2 340.578 136.533 340.578 133.2V30C340.578 21.3335 343.111 14.5334 348.178 9.6001C353.245 4.53345 360.378 2 369.578 2L391.479 2.00342H399.272C418.606 2.00342 433.174 5.99564 442.907 13.729C452.774 21.4623 457.707 32.8623 457.707 47.929C457.707 62.1957 453.374 73.2624 444.707 81.129C437.92 86.8332 430.333 90.2794 420.353 91.9404L454.782 126.475C456.915 128.608 457.982 130.941 457.982 133.475C457.982 136.275 456.648 138.808 453.982 141.075C451.448 142.941 448.982 143.875 446.582 143.875C443.248 143.875 440.048 142.275 436.982 139.075L392.908 93.4028H391.477ZM391.479 20.4034L372.978 20.4001C370.178 20.4001 367.978 21.3335 366.378 23.2002C364.778 24.9333 363.978 27.4001 363.978 30.6001V75L391.514 75.129H399.107C411.907 75.129 420.907 73.129 426.107 69.129C431.441 64.9957 434.107 57.929 434.107 47.929C434.107 38.1957 431.241 31.1957 425.507 26.929C419.774 22.6624 410.939 20.4034 399.072 20.4034H391.479Z" class="mock-logo-rest"/><path d="M493.747 144C490.28 144 487.547 143.067 485.547 141.2C483.547 139.333 482.547 136.733 482.547 133.4V10.6C482.547 7.26667 483.547 4.66667 485.547 2.8C487.547 0.933337 490.28 0 493.747 0C497.214 0 499.947 1 501.947 3C504.08 4.86667 505.147 7.4 505.147 10.6V61.2H582.347V10.6C582.347 7.4 583.347 4.86667 585.347 3C587.48 1 590.28 0 593.747 0C597.214 0 599.947 0.933337 601.947 2.8C604.08 4.66667 605.147 7.26667 605.147 10.6V133.4C605.147 136.733 604.08 139.333 601.947 141.2C599.947 143.067 597.214 144 593.747 144C590.28 144 587.48 143.067 585.347 141.2C583.347 139.2 582.347 136.6 582.347 133.4V79H505.147V133.4C505.147 136.6 504.08 139.2 501.947 141.2C499.947 143.067 497.214 144 493.747 144Z" class="mock-logo-rest"/></svg>
          <span class="hidden sm:inline text-xs text-gray-400">TechCorp France</span>
          <span class="text-xs font-semibold text-indigo-400 border-b border-indigo-400 pb-0.5">Dashboard</span>
          <span class="hidden sm:inline text-xs text-gray-500">Congés</span>
          <span class="hidden sm:inline text-xs text-gray-500">Équipe</span>
          <span class="hidden sm:inline text-xs text-gray-500">RH</span>
        </div>
        <div class="flex items-center gap-3">
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          <div class="w-7 h-7 rounded-full bg-indigo-500/30 flex items-center justify-center text-xs font-bold text-indigo-300">NL</div>
        </div>
      </div>

      <div class="p-6">
        <%# Header %>
        <div class="mb-5">
          <h3 class="text-xl font-bold text-white">Bonjour, Nathalie 👋</h3>
          <p class="text-sm text-gray-400">25 mars 2026 · TechCorp France</p>
        </div>

        <%# 4 stat cards %>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <% [
            ["3", "Onboardings actifs", "#22c55e", "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"],
            ["5", "Congés ce mois", "#8b5cf6", "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"],
            ["12", "Employés actifs", "#6366f1", "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"],
            ["312k€", "Masse salariale", "#f59e0b", "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"],
          ].each do |val, label, color, icon| %>
            <div class="rounded-xl p-4 border border-white/5" style="background-color:#15172a">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center mb-3" style="background-color:<%= color %>22">
                <svg class="w-4 h-4" style="color:<%= color %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= icon %>"/></svg>
              </div>
              <div class="text-xl font-extrabold text-white"><%= val %></div>
              <div class="text-xs text-gray-400 mt-0.5"><%= label %></div>
            </div>
          <% end %>
        </div>

        <%# Deux mini-cartes %>
        <div class="grid grid-cols-2 gap-4">
          <%# Onboardings %>
          <div class="rounded-xl border border-white/5 overflow-hidden" style="background-color:#15172a">
            <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">Onboardings actifs</span>
              <span class="text-xs text-indigo-400">3</span>
            </div>
            <div class="divide-y divide-white/5">
              <% [["Sarah Cohen", "J60 · mgr : Pierre", 89, "1 en retard", false], ["Yanis Benali", "J55 · mgr : Sophie", 75, "1 en retard", true]].each do |name, sub, pct, badge, alert| %>
                <div class="px-4 py-3">
                  <div class="flex items-center justify-between mb-1.5">
                    <div>
                      <span class="text-sm font-semibold text-white"><%= name %></span>
                      <span class="text-xs text-gray-400 ml-2"><%= sub %></span>
                    </div>
                    <% if alert %><span class="text-xs px-2 py-0.5 rounded-full bg-red-900/50 text-red-400"><%= badge %></span><% end %>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="flex-1 h-1.5 rounded-full" style="background-color:#1e2035">
                      <div class="h-1.5 rounded-full bg-green-500" style="width:<%= pct %>%"></div>
                    </div>
                    <span class="text-xs text-gray-400"><%= pct %>%</span>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
          <%# Soldes congés %>
          <div class="rounded-xl border border-white/5 overflow-hidden" style="background-color:#15172a">
            <div class="px-4 py-3 border-b border-white/5 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">Soldes de congés</span>
              <span class="text-xs text-indigo-400">Demander</span>
            </div>
            <div class="p-4 grid grid-cols-2 gap-3">
              <div class="rounded-xl p-3 text-center" style="background-color:#7c3aed">
                <div class="text-xs font-semibold text-purple-200 mb-1">
                  <span class="sm:hidden">CP</span>
                  <span class="hidden sm:inline">Congés payés</span>
                </div>
                <div class="text-2xl font-extrabold text-white">30.0</div>
                <div class="text-xs text-purple-200">jours</div>
              </div>
              <div class="rounded-xl p-3 text-center" style="background-color:#7c3aed">
                <div class="text-xs font-semibold text-purple-200 mb-1">
                  <span class="sm:hidden">AM</span>
                  <span class="hidden sm:inline">Arrêt maladie</span>
                </div>
                <div class="text-2xl font-extrabold text-white">0.0</div>
                <div class="text-xs text-purple-200">jours</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Transition dark → blanc %>
<div style="margin-bottom:-1px; line-height:0">
  <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full block" aria-hidden="true" preserveAspectRatio="none">
    <path d="M0,80 C360,20 1080,80 1440,20 L1440,80 Z" fill="white"/>
  </svg>
</div>

<%# ─── POINTAGE & TEMPS ───────────────────────────────────────────────────── %>
<section class="py-16 bg-white" id="pointage">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div data-module="left">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 text-indigo-700 text-xs font-semibold rounded-full mb-6 border border-indigo-100">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Pointage & Temps
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-4">Pointage web et mobile, conforme aux 35h</h2>
        <p class="text-lg text-gray-500 mb-8 leading-relaxed">Vos employés pointent depuis leur téléphone, leur ordinateur ou une tablette fixe. Géolocalisation optionnelle, validation manager, alertes automatiques.</p>
        <ul class="space-y-4">
          <% [
            ["Web, mobile et tablette", "Application PWA installable sur iOS et Android. Aucune app store nécessaire."],
            ["Géolocalisation optionnelle", "Vérifiez que vos employés pointent bien depuis le bon endroit, sans les surveiller."],
            ["Calcul RTT automatique", "Les heures supplémentaires au-delà de 35h sont automatiquement converties en RTT."],
            ["Conforme aux limites légales", "Alertes automatiques si un employé dépasse 10h/jour ou 48h/semaine."],
            ["Validation manager", "Toute correction de pointage doit être validée par le manager. Traçabilité complète."],
          ].each do |title, desc| %>
            <li class="flex gap-4">
              <div class="w-6 h-6 bg-indigo-100 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
              <div>
                <div class="text-sm font-semibold text-gray-800 mb-0.5"><%= title %></div>
                <div class="text-sm text-gray-500"><%= desc %></div>
              </div>
            </li>
          <% end %>
        </ul>
      </div>

      <%# Mock pointage mobile — fidèle à la vraie app %>
      <div data-module="right" class="flex justify-center">
        <div class="shadow-2xl w-72 overflow-hidden border border-white/10" style="background-color:#15172a; border-radius:2.5rem">
