<section class="py-20 sm:py-28">
  <div class="max-w-5xl mx-auto px-6 text-center">
    <div data-controller="reveal">
      <p class="inline-block text-sm font-medium text-primary bg-primary/10 px-4 py-1.5 rounded-full mb-6 tracking-wide">Manager OS</p>
      <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl text-text-deep leading-tight">
        Le système d'exploitation<br class="hidden sm:block"> des
        <span style="display:inline-grid; vertical-align:bottom; overflow:hidden;"
              data-controller="kinetic-text"
              data-kinetic-text-words-value='["équipes","leaders","PME","managers"]'>
          <span aria-hidden="true" style="grid-area:1/1; visibility:hidden; pointer-events:none;">managers</span>
          <span data-kinetic-text-target="word"
                style="grid-area:1/1; display:block;">managers</span>
        </span>
      </h1>
    </div>
    <div data-controller="reveal">
      <p class="mt-6 text-lg sm:text-xl text-muted-soft max-w-2xl mx-auto">
        1:1 structurés, objectifs trimestriels, onboarding en 90 jours.<br class="hidden sm:block"> Tout au même endroit, simple comme un message.
      </p>
    </div>
    <div data-controller="reveal" class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#pricing" data-controller="confetti" data-action="click->confetti#fire"
         class="inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-primary text-white font-medium hover:opacity-90 transition shadow-lg shadow-primary/25">
        Essayer gratuitement
      </a>
      <a href="#solution"
         class="inline-flex items-center justify-center px-8 py-4 rounded-2xl border border-border-soft bg-white/60 backdrop-blur-sm text-text-deep font-medium hover:bg-white transition">
        Voir comment ça marche
      </a>
    </div>
    <p data-controller="reveal" class="mt-5 text-sm text-muted-soft">Pas de carte bancaire · 30 jours d'essai gratuit</p>
  </div>

  <%# Dashboard miniature %>
  <div class="mt-16 max-w-4xl mx-auto px-4 sm:px-6" data-controller="hero-dashboard">
    <%# Barre de titre façon macOS %>
    <div class="bg-white/80 backdrop-blur-md rounded-t-2xl border border-border-soft border-b-0 px-4 py-3 flex items-center gap-2">
      <div class="w-3 h-3 rounded-full bg-red-400"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
      <div class="w-3 h-3 rounded-full bg-green-400"></div>
      <span class="ml-3 text-xs text-muted-soft font-medium">Manager OS — Tableau de bord</span>
    </div>

    <%# Corps du dashboard %>
    <div class="bg-white/75 backdrop-blur-md rounded-b-2xl border border-border-soft shadow-xl shadow-black/5 p-6 grid sm:grid-cols-3 gap-4">

      <%# Widget 1:1 %>
      <div class="bg-bg-soft rounded-xl p-4 border border-border-soft">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-semibold text-muted-soft uppercase tracking-wide">1:1 cette semaine</p>
          <span class="text-xs bg-primary/10 text-primary px-2 py-0.5 rounded-full font-medium">
            <span data-hero-dashboard-target="oneOnOneCount">0</span>/5
          </span>
        </div>
        <div class="flex -space-x-2 mb-3">
          <% [["bg-primary/20 text-primary","CR"],["bg-success/20 text-success","KB"],["bg-warning/20 text-warning","EM"],["bg-pink-200 text-pink-600","AL"],["bg-blue-200 text-blue-600","SB"]].each do |cls, init| %>
            <div class="w-8 h-8 rounded-full <%= cls %> flex items-center justify-center text-xs font-semibold border-2 border-white"><%= init %></div>
          <% end %>
        </div>
        <div class="h-1.5 bg-border-soft rounded-full overflow-hidden">
          <div class="h-full bg-primary rounded-full transition-all duration-1000 ease-out" style="width:0%" data-hero-dashboard-target="oneOnOneBar"></div>
        </div>
        <p class="mt-2 text-xs text-muted-soft"><span data-hero-dashboard-target="oneOnOneLabel">0 fait</span> · 2 à planifier</p>
      </div>

      <%# Widget OKR %>
      <div class="bg-bg-soft rounded-xl p-4 border border-border-soft">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-semibold text-muted-soft uppercase tracking-wide">OKR Q2</p>
          <span class="text-xs bg-success/10 text-success px-2 py-0.5 rounded-full font-medium">En cours</span>
        </div>
        <p class="text-sm font-medium text-text-deep mb-1 truncate">Réduire le churn équipe</p>
        <div class="flex items-end gap-2 mb-2">
          <span class="font-serif text-3xl text-text-deep leading-none" data-hero-dashboard-target="okrPercent">0</span>
          <span class="text-muted-soft text-sm mb-0.5">%</span>
        </div>
        <div class="h-1.5 bg-border-soft rounded-full overflow-hidden">
          <div class="h-full bg-success rounded-full transition-all duration-1200 ease-out" style="width:0%" data-hero-dashboard-target="okrBar"></div>
        </div>
        <p class="mt-2 text-xs text-muted-soft">Objectif : 72% · J-18</p>
      </div>

      <%# Widget Onboarding %>
      <div class="bg-bg-soft rounded-xl p-4 border border-border-soft">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-semibold text-muted-soft uppercase tracking-wide">Onboarding</p>
          <span class="text-xs bg-warning/10 text-warning px-2 py-0.5 rounded-full font-medium">J+30</span>
        </div>
        <p class="text-sm font-medium text-text-deep mb-3">Sophie M. — Dev Frontend</p>
        <ul class="space-y-1.5">
          <% [
            ["Accès GitHub configuré",    true,  0],
            ["1:1 semaine 1 effectué",    true,  0],
            ["Présentation équipe",       true,  0],
            ["Premier PR mergé",          false, 1],
            ["Bilan J+30 planifié",       false, 2],
          ].each do |label, done, delay| %>
            <li class="flex items-center gap-2 text-xs"
                data-hero-dashboard-target="<%= done ? 'checkedItem' : 'uncheckedItem' %>"
                data-delay="<%= delay %>">
              <span class="w-4 h-4 rounded-full flex items-center justify-center flex-shrink-0 transition-all duration-300
                           <%= done ? 'bg-success/20 text-success' : 'bg-border-soft text-transparent' %>">✓</span>
              <span class="<%= done ? 'text-text-deep' : 'text-muted-soft' %>"><%= label %></span>
            </li>
          <% end %>
        </ul>
      </div>

    </div>
  </div>
</section>
