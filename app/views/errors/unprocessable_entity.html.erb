<div class="w-full max-w-md mx-auto px-6 py-16 text-center">
  <!-- Logo -->
  <div class="flex justify-center mb-10">
    <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-8 w-auto dark:invert opacity-80">
  </div>

  <!-- Code -->
  <p class="text-8xl font-black text-amber-100 dark:text-amber-900/50 select-none leading-none mb-2">422</p>

  <!-- Illustration -->
  <div class="flex justify-center mb-8">
    <div class="w-16 h-16 rounded-full bg-amber-50 dark:bg-amber-900/30 flex items-center justify-center">
      <svg class="w-8 h-8 text-amber-400 dark:text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
    </div>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">Requête invalide</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-8 text-sm leading-relaxed">
    La requête n'a pas pu être traitée. Cela peut être dû à un jeton de sécurité expiré.<br>
    Essayez de recharger la page.
  </p>

  <%= link_to employee_signed_in? ? dashboard_path : root_path,
      class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    <%= employee_signed_in? ? "Retour au dashboard" : "Retour à l'accueil" %>
  <% end %>
</div>
