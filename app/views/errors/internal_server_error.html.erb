<div class="w-full max-w-md mx-auto px-6 py-16 text-center">
  <!-- Logo -->
  <div class="flex justify-center mb-10">
    <img src="/izi_rh_logo.svg" alt="Izi-RH" class="h-8 w-auto dark:invert opacity-80">
  </div>

  <!-- Code -->
  <p class="text-8xl font-black text-red-100 dark:text-red-900/40 select-none leading-none mb-2">500</p>

  <!-- Illustration -->
  <div class="flex justify-center mb-8">
    <div class="w-16 h-16 rounded-full bg-red-50 dark:bg-red-900/30 flex items-center justify-center">
      <svg class="w-8 h-8 text-red-400 dark:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-2">Erreur serveur</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-8 text-sm leading-relaxed">
    Une erreur inattendue s'est produite de notre côté.<br>
    Notre équipe a été notifiée. Réessayez dans quelques instants.
  </p>

  <%= link_to employee_signed_in? ? dashboard_path : root_path,
      class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    <%= employee_signed_in? ? "Retour au dashboard" : "Retour à l'accueil" %>
  <% end %>
</div>
